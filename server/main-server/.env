# ============================================================
# Main Server — Environment Variables
# ============================================================

# Server
MAIN_PORT=8001
MAIN_HOST=0.0.0.0

# Database — same as login-server
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=admin
DB_DATABASE=super_warrior_z
DB_CONNECTION_LIMIT=10

# Time offset (ms) — HAR verified: +25200000 = UTC+7 (Jakarta)
SERVER_UTC_OFFSET_MS=25200000

SERVER_PUBLIC_HOST=127.0.0.1
CHAT_SERVER_PORT=8002
DUNGEON_SERVER_PORT=8003
DEFAULT_SERVER_ID=1

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=info
