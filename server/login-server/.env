# Login Server Configuration

# Server
LOGIN_PORT=8000
LOGIN_HOST=0.0.0.0

# MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=admin
DB_DATABASE=super_warrior_z
DB_CONNECTION_LIMIT=5

# Client-facing URLs (sent in GetServerList)
# The IP/hostname the BROWSER uses to connect
SERVER_PUBLIC_HOST=127.0.0.1
MAIN_SERVER_PORT=8001
CHAT_SERVER_PORT=8002
DUNGEON_SERVER_PORT=8003

# Timezone
TZ=Asia/Jakarta

# server0Time = -(server UTC offset ms) — sent to client every response
# UTC+7 (Jakarta) = -25200000
# UTC+8 (Singapore) = -28800000
SERVER_UTC_OFFSET_MS=-25200000
