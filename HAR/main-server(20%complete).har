,"cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:11:06 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2659"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3281,"mimeType":"text/plain","text":"1202:43339[{\"ret\":0,\"compress\":true,\"serverTime\":1775056266612,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЗёГ¬в Јб Ўе Ўа°ўг  г ўжӨ„Йҗд•ғв ўж’№еҹҚвҘ¬бҲҘг”ЎвұҗвҲ бҘҚжҳӢдө«гҠ«е”ёвўӘгЁӮа¬„жғўж¶Ңж©’бЎҹг»Қеү®вӣҖеҖўгүЁвұӨаҰ‘в”ұбІӘеҷңвҷҖв… дғғеўҖJжЎҳг°ҫдӮіаЎӢж…ҮбүӮгҗ з“–зқ”ЙҲ?вәҰб‘ЎзЁҳКўвҶҒжЈқв’”в№Ғбӣ„дЎұв—„гӢ’еІҚгҖёMдЁҪд’Ёе¬”вҸ®бҷ¶ж®«YбҲІз“„а Ўа ңVдҙ бү®дҖ г»Җбҳјж ©а ңИҠгҙЎз·¶дҒЁеіҖЙұвҪҡвүҷбё·бқ¶гҖ В Шіб„¶еёёаҪ“г—һжҺҘЫ•б…Ҳгӣҗж®ҒдЈәбҘҶд“ҮдұӨбЎҸЕӨж  д© вҖ®бҮӮДўа° Ю’вҖӨб…Җб…©жҖ аӯ гҖӢеӨЈФЎбҙӨдҸ‘В бҘ¬ЙЈвў з№¬ж„„бҶ„еҲҙдҖЈвёҠжҷЈбҗЁгҸ°дЁјеҒ„ЙҖжү—а№ҠдӘҢгұҖбҳЈд¬ЎФӯаЈ‘вҜ©в©ӯбҜҘвҜөдҒҶВҪдңҮвўҖ0дҖЎзҒҲИ бә Р…д”©8еўўеӣҢд Ёа«Үвҷ“Гҫа Ӣе’’еҙҗзҫёбң«е””аұІдҸӢв‘җбһЈе’«ж°ЁаЎ°вӯІбҠҙа ҝвӣ»ДӣгӢұеҗЁбӢ©гҖ°е•ӢКҡдЁҪдңғаўҳг„јдӣӮгү…а§ҖвӮ”в§әдҗҰз’ҳе јИҰзҳ д•ҰдҖЎеҘҪзҗЎг§¬жәҰг®¬вӮЁж‘Әб’©в”№гҶҡдЁ дҗЎз°ўвӨӨвҖўз јдө…дӢҒбҝӨв•Ңвҹ…д’„ж°ңжәўв°ҘбҸҖзғЎаҝ§вЁҢзҪңвҫ·е—Ҙб’ӮвЁҠ%гҠЎб‘ҺзҹјЯҢвҚңзҲІдққбҹ•зҶ°гүҢвӢҘжЎҸР¬бҖ°дҹјгҖ ДҗвҒӘЯ•зҖ¬еў еҲ аҘҰжҒҖгҖ вҺҗб §еӨ®дҳўМҙе ЎП–б»·бҢӘЩ”еҺҙбҖӯеғ жҫЎвҖҙзү’дқұв№ғМјзҷҒКҲб»·з  е–һ@ж“„жҘ УҠбҸёе„–аұЈаЎҲВўв‘Һвҝ зӯ•бҮ„г„ғвҰЎгӨӨа®ғз„һвҒҒдҒҶРәдІҫжүғгЎӘжҶЎдўӢб„ЎбўҫжұЈе ұНҶР ЫҺд…”з°ҰгӢҳдһөзҺ„дҪҲб…ҠВ И…гҒүЖ“гҡҗвҙ“е№ дңӘЙ„вҰӘгұ«д ЎвҢӣд…Ӣг‘ҒгҘҠд–Ібү§гҒ©дҳ§д–Ўгі®еҠҖбғҖг»…бҚ§аӨӮаҪ§а ®ХўФҚвҹ‘з…ӮбӣҚдҢҗЗүг–әбӣЎе№ӘТүа¶ҡгөӘдғҖе®ЈвҡҷгҪӘдӮҘpеғ»а»Ҳдү§Oз–ҡа·Қд“»гӣӨгўјв·Җв«ёеўҰгҷҖбә…б•«ЬҘбҶҶдҜҮг‘ҳбҰҶгӣ %з©қб»өжҜҖб Ів…Қб»ӯеҮқаҝӢз–‘гҜүгҒқбҖівӢ”в№•гҷ№жүҠе®©д»ҹгҘЈвҘҰа¶‘еҚәдЈҪв№”дҗҡдҹҪд…Ҫб’ҢаІ”б¶№е  жө»е—Ігҗ№аҰӮв”ҺУ“д”–е®ҖејӮг№Ҷг¬Әг•ҜжҒёд»¶бә аҜӮзӘұд“ӮбҮ‘дөҖдҖ©зӯ“вҚЁР§жқұжҫҶвҲһеӯЎб•Ҙж•ғд Җвғңз«ҷеҲҝЗәС–ИҒж“ҖдҶӮвұӣжҹҒдӯ“ж¶ұзҪҡеӣұдҷ•ж“Ҙж№ҳЬ©зө—ж«©еҚҗдғәеҒ§вҳЎдҘҳжӣұж•һбҚҢбҸҷжңӯдҪ‘гҳөеғ•жҠ…зҝӣг¬ӣб“ңај…зҮҳеһҫд„ЈбҶ‘з«ҷеҳ°аІ«еңіз°¬дәұж’һбҹұдӮ©дҷЈдҒҹдҳҘд·ҡвҹ©зҜңжң„бӯ—дӮ«еҜқСқж·қзӣҷеӯ©вҙҒжҡҗбңЈз“’бң“д“ҹжёҶТқгӯ»еӢҗв„”гІ‘гү•з»ҹе«ҡжӘҹеӘӯеҡ–гӣ‘д®’гң‘з·ёв№ҪдҚ’вәӢзҚ•зҡҪж–’еҫҚеёәвҝӨжғ»вҡқзқңжјӣдӮңбһ…еЁҡаҪ…еӣЎдҖқз’•жқҢг„қвӯіе¬‘вҖ•е¬қбҫ‘зҡӣеҖҮж·°вёөд«ҷеҹүЛ·гү…еҺҚз„ҲеһҮејӢжөӯз—·жөҜе№әЦҪзЁҹSЭ»зҲ®ајҸбёҜжҒ зҲ№зөҒеҪ№жҗӘг°Ӣвғҙб¬ҙаәӨеЁүж№¶жіқбҒ•гёҚдөҳв®өгӯ д ®гҚ§г„ҶЬ„ж»ңж–ўж··её…е¬ӣгҜ’Цҝгҳ©В‘ПЎеҲҖдҡқв…„еұҪз·Өг–әдЎөзӘ»аә—бӯ’а«ҒдҖіе»ҘжқЈві«гҙёвә§д®ұзҜҗеҝ’зӮЎаёҒеҗіг»Үв’ӮеҮідІғдҗ е‘ҲдӣҮвұӨдӨҺбҺҰбҖ„аӘӯжҷўгҝ©вҗ„гҶҷЗ•Ъ”вҙҜжҪһе“ҫжһғвҮӣжқЈдўӯдҗҖгҺҰТ—ЪҖжһҜвҒ”аӯ‘а°№гәЁбҰӮеііа ·д…ҳгҫЈдқЁеӣ“з•ҖдҺұжҢҫвҶӘбққг…ҖК©дөҘж·ҹдҳҝг ®жӨҹаҰ°г ІгәұбІіжҷңвҙӮг“Өз®¬вқ„д„‘НҶдқ©бҲҠдәЈв–Ід№ҶвҢ’вҚҡгІӣдңҙд…©вЈ’дё©з”ҝзҮҢб„Јг№„бҗңгҚ§дүЈвҹҝг‘Әв”ғгҗҒз„ҒжӨ¶б—ібЁҙа¶ҡвҳӣз—ӢбЁ¬е»—аЈӯзҹ©в¶°еҮҹжүІдҜөвҠҶвӢ„жӮңМҲеҒ¬віІгҠҒе¬Ҳг»ӢбЈјЩҠбҺәгӢ»жҠӣвҡҢеқ гјҰз’Һжё вЎҢаіёвҒ–жӨҢд”©еғҚВЁгҶөбҒўжҒ гҳӮбҖЁеӣҗбҖ«б“җеҶӮзҠҝвҰ“гң зЎјг—ӮбҮҰбҠ…Рұж§ӯеҮөдҹӢж«ғвӯ•вӯұеҢ·а¬Ҡг©ҫбҠӯвҰҒНёг•ҰеЁҘдҰ„КҢа Ўз’ҹРЁжӮӘаӨҒаұҗе„ҰбҲӮб…ғбүҢвӢ„г©Өж’ҢдҢӮг§ҖеӘӘвәўЭ©ЕҠб ІдӘӘД„д”¶вҘҺб“ҖжҲЎеҡ№ж°¬е№Ғз“ҡгүЈзөҒг„…гқіе”ӨеҠҺбІҪбҰ«бІ д ©З”д•ўв‘‘дғЁвҹҲеЎқЪҠжҢӘдҒЁа¬°жЁҘвҖҙбӣўз°ўдүёбҠ вЎқpдҝҺзҲјдӘөб…іг…ӣХўв’јвҷӘвҮҘз”°ЧҖдЁ§жӮҘаұ аІ©ИҶа№ұбҖЁд„ЁвҗҶеҖӘЩҙжҲҘжәҚТҒгҳЁгІӣбҪ”г ЁдҺҶд§ЎзҲЁВӨж–ўФҗдЁ¬г¶¬е©ӨаӯӢаӘ¬Г”в•Із…Ғж  вҶӮЗўа§¶ж ҘаҘұб°ҘзҸүг¬ К®еўҝв“ҒзҘҺвӢӮз‘·бӮҸб—°вҖ¬дІҖбҚЎбҖ°вҢёаӘӨг•ӯЯ°гҸІбҒҶа№ҖгҖ°б¬„Сўжү“дҶҫбҲӨзҠІжұӯзҗ¬д¶ўаӘ»вЁЈб®•вҸ”в  ЖҷдҲ·гӮЁж„Ӣб Әж«ҚбҺ«вё•е§Ғві©зұ»г®Ўе®җа№ҖаҪғгҖЁВҙеұҘР…еүӣбҲ¬гӯҒбә—вһҢзӣӯа°ўв»қжЁҢг—°зңҗб—ҡгҜ”е…ҢЩ аҪҘЙЁбҢ№аЎҗжІҗг”ўд„һКЎзЁ©в„„б©ҒбҒҳдҸ„бӘЎе№§жЎ°аҜ®бӮЈвүҖд«ҹб’івүүзҪ·вҮҶжҖәжҡҝдғҖ!бү гҒҡв·°гҘәдҫҰе¬Өа»–еӘүVзғ а»ЈвөЈдҪҺдҚҖЧәг·үг„ӣвү°віЎжӯЎд„әбҮңе•ғг§ІзҶ«еҢЎдҜӢвҮҲзҝ©еіҶзһҺз¬ҘжјҳМ–аәҖв„ңа»ЎбҲӨбӣўжЎӢвҢ„дӢҮвө’  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2659,"_status":"completed","_startTimestamp":1775056265716378,"_endTimestamp":1775056265720839},"cache":{},"timings":{"send":-1,