sText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:05:28 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"4910"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":6209,"mimeType":"text/plain","text":"2202:43240[{\"ret\":0,\"compress\":true,\"serverTime\":1775055928685,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁКҗбғ г¬Јвұ аҙЁвЎ‘д°ЎбҳЈжі°вҲ зҢёжҖӨеқ«вёўе°ҰгЈӨдҒ©FаЁ§гҖҰгҹ аі Ы ТҖа§ З аӯўбҖұд—ҘЩ аӯҹгІөбӨІгҒұд“ЁЦҒдҢҖГҜеү…в‘ЎгҲңбіЁа° е—ҒжҸ§д· аҝҠдҰЎVеҗ»е„ҫвҲ°еғҫвҠ¬гҷ”жҘӘзҰҷзӢҠгғҺбӣҸШівҠўбҢҖЕ’ві…вҲҡеғ»б®©аӨЁдҖ¬еһҖЗӣе§ҳаЎўжҰ—бЁұбјЈ'б… Л»бұ ~бЎ©гҮҸбҪҖЖғеҢҖзӢ”еҮҲб‘ЈвҗІгҝһаІӯжҪҺдө—жҷұбўЁVвё¶зӯҘбЈ…СЎЭЎгҲҜШЎвҢңзёёв„ўбЈҪж‘’дҢҖДЁд  б№—зһ•д°Ҙг¶ҒЪҺзҚҠбғҖРҙдј„зЎҗ:д”®еҘ‘дёӯа©ӨеҘЁбҲ бҹ»РҗИҙаЁібҖҖеҒІгјівҲІзҶҡаӘҘвҳҖеҢҳаЁҪбҶұв’ӮбҪ¬вҢізҗІбўҘвҢізӨҷв…ӨеқҠвӘЎаөӨаӨЎеҙ•вҚ»г„ҲВўе–«аҫҒбҖҰбҗ©ж„•а·ҰаәҙжҚҗгҳҶаҙӨвӢ“вө–вҶҺж„Ўгғ бЎӢвҖ бҖЎдҢӢгЁҫвҶөгӨҮв—әзһўжәңз·©з–ӣеәңжҹ»зҒ д‘ўгҝ°аЎЈеӢҖдҢІаәҰжҲүвўҝвҳЁеҶҲжҒӨМҒгЎҠгұ—дҢ©г‘ӮвјЁв•ізӨүвјҰвғ…УҰвҡӢдҢұг ІгҶҝдҢҒвӢЎеӯҲе•үбҖөвң»д·үзӨўзҚӯе„үб©җ=жӮҲЕҙжұ„б©ӣаұәзҠ©е„Ёеӣ¬в¬қбөҺгҹҷв¬ӯд®„жҫӢг¬қгЈәг—ҖбҗӣвҙҒгҘјжӮҮв· зқңжҪ»вҗ…зЈ гҫҳЕҘз”ЈзҖөаҝ№дҖҰгӮӨбҶүдҜ„бҠқбұ—жҹғаўһб‘’в¶©жҳ№бјўб…ҪвЁӨд„°вүҶгҳҖвүҢдҳӯдӨёдҳҖбҲ¬вҷ‘еҮҷг„„е–·бӣҲз—ҹбӮүа¶®ж‘ $д”Ұз”қдІ„а№Җбў–вӘҲЖҒвЈҰЦ“гЎіеҚөдәЁбЈҒжӘҡеғұбӘҶдӢІеЁ»д®‘ж№®еҫ‘гӘ§еӨ•бәңдҖ·бә·дҫіЙ—е§ўд’ҘдүўаЎҸеҝӨдңүбҚҖз«ҰбөҒдҒ’бҫ дӨҠб•§жӮҹеҗӘгү’а®ЎдӮҙгөҮжғҰвҖ—дўӮбө„вҶөе«’е”җЮіеҗёвӯҙвҖ а«¬дҮҖа  дҹӘдҰҪд…ҠгҰ¬дҹЁгҮӘд“ұб§«Т Щһгӯ‘в—Әд‘ҡзҷҶж§әж·ёгҢҺв·өжӨҫеҫӨвҶҫв·¬в•ўеҜҫМҗз’ӘвҶ®б„¶в—һбҖҪбҗҗзҒқбҒёзҙ®вҺёаіўдһҶдіҝвғҖзұӨвҠ№её©дӯёеЈӘв…№д№Ұе«Ғе№ҪШӘг©„Г–зӣ«еҜҗгӢңЪҷвү„дҳҷЦ©гҗҲз•әгҘҷгғ‘д‘Һбҷҷг§‘з—®б—јд“ӣдҹҘб“ҳз°ҲзЈҲвқҙвҜўа®…жңјСЁд«һвҢөдЈ»а °б„ўвҢҲбӨҫв…ҶеўҘвҶҗзҙҜвҶЁб ҫвӢЁвӨҘвҗҖв®ҰГ еү е¬ёб»ҷШ•гӯҚС–б—ҖПҲгӮЁПўзӣ№вЎӨб”ҝбүӣзІөЗҒбӣәбЁ·дӢҶбЈҡеӨ”гҰӢгӣӯжҸӨбҠ§д’·в§Је°җвҗ¬еҢғдј‘б°‘в‘¶еҝғбҪҙв¬ҡвҚ…У·дқңвң”дІҙжһ¬ЗҚаӨҡе“Ја¶°а¬қаҜЈаұҒПівҶ»бӯёЪӨгұ”В‘в“ҺдҮҶеҷқбў‘зӨ°еҳ©дЎұжЈ–з—…в Ӯең·е°®еј»зЎӨе®ӘгҜүеҷёаіІдө¬дёҺд”«Йҙа°©г өеІЎгў“бҹұбҒ„аІҰбҮ¬дүЈВЎдўҜдҲҳгұҺдӨ¬аӘ¬еҷ°еұ–еңјзғәбӯӣгһ…зңҖгҘҗбҙ•жҫІеҗ¶зҮ’е®©з«ҙеөҢзҘӣа©ҚзҘ—вҡҚеҜҸЖ’гҚҹа®Ҫд№»д§іб№ұзң°бңҜаұ°вІ”еғ”бҠ©в–ғгё дҰ‘гӘібӮӨгҒӨжӯ©аЁЎб…ўб”ҫж—ҢзҠҹгҗӢбӘҡаӘЁбҘҰж§¶б„ҰдҒ°бҲЈЖ®вәҷдҹңз»ҡвҗҶзӢ©бұ•а§—бұ©дӣҪа«·г§ҷжҢ–з—җгёӢеқ”жҪ№ж—°дҒҙв°јз©ҙвһ’ВӮаҫ зҸҜзЁҗН“г’«бӢҲгҰҘдЎҖбӣӨбӨ®дұја°ҘеҲҙвғҳбҷҷбҸҢбЈҸвғҙжҶҶжҺҢдҙҺжҒ бққг«Өз°«еҝ©аҜ…зӯҚгғөбқЁеқ а¬Ҡе°ҜХјдҝ¶дё–еҳҡеҠҘз…“вӮ¶з©Үг ”гҖҒгіұЗҒжӨ ПҖеһ діҢзӘҲв’§жўңХ°б”®дўҡЭқа¬ұбҶ¬Э д‘…жҺӣв—§вғ»б“Ўз–ҠаЁ№ж№”д ЁвҠҢаӨҷгІ°зҺғбЁ”в°«зҗ„жғӮвәӢвөўж ¶дҠүдҠәбҝ•бҘ»гүөе¬Ұз–җаёҫгіӯж·ўв»ўзЁ”Гүвҗ¬дӨ“бІ°еӮ•П„зӨЈзҳ№д‘ҖеҪӨЦ©б„ІдғҶбӢҲбҫ®зңӯбһ®аӯӮб„Ҡб«Ңа№Ёг•ўе»ЎШ¶еҰҗгЎӮб„ғаөһг§Ҹж…Ўв–ңеҷӮб•©еҺҠвҜ…б©җжҸҒгҪҫбҹҺа¬¬жңҺбҲҒе№Үб–©а®»дҲ ЬҲгӘІдўҺзӣҠд„ҘжғӮжҳ°гҰҘз‘Һб “б»’дЈҲТӘе°ёзғ©з»…д§ёб… $вүЎР°еӮҖбҖЎаӨЁд•ҳд‘¬г“…дЎҘд‘ҙзғіб¬®бҠ‘ж ӮзҮӯб°Ҳб№“б‘ҡг§ еҗ°дүөК ВёзүҗеҰ№вӢҹд”°д’ёбҰһд© Вҝж¬җЩЎе’Ҹгҹ°вҝҲеҘүжі’вӯ§вҸӣаё…еҶҪТ¬гҲ–б’ІаЎёжі®вӨҙб‘ӯеҷҡеҠӨаҙ„зҡўбӣ·а¬®бё¶д·ҷвёҪгұңбһӯг° еҗӨвЎ„дӘ°бң№а°·жҒёдҡ°бҝӯб…ӯв—ҒгҚғбўӮа өдҮҒвӯ§г“ҮгЎҘзҳҠаҙҝЪӢжҮұвҙӨдғЁЭҳб…ҫг¬°дҮ“бӨ”дҪҒдҠҒжЎҙбөізҹҫдҢҠвҢ…бўғв—ҳНҗе№Ҝв……вј¶в•һб…Ҙе„ЈеІүгү“С–в…Ҳаҝҗдјіб Җе“ҘбӮІбҮҙвҮјУ„б…Өа әгҠӮМҗеҷҒві©еҳҚдҘӮдҖ©з ЁдӮЁаҫҶжӣҒг®ёз”ұбі¬в«үг°Ӣд—өжҫ«дұүеҚёгҲ„гҝҲдҜјз •бҰҳзҸҡзҚұвӮіжӯ“гҮўв…„вү§з ҪвӨёвӘІгҲҰв“¬зӮўдӮ’жҗқбҮҰз‘ҒгҚҰд•ҘГўз¬§жӣҘе‘‘б§ҖгӨұе§»дқға®өв¬өжҺҚвҷҳж—”еҙҡг–‘жүҰдёҚб’Ӣбөҷв•үгЈ hдҸ„вәӨвӯ…дӮҫж¬ӯв©„д…ҖаӨ»в…’аӯЎРёдҢ—дҖҮжҖІв…җвӣІб”Ўе«»гЎ—вҺ·гқЎдҚҜгҡ°ж’ҢеЈӘаЁҪвЈҸаё•бҒ«д§Ҳд°•вҮәгўҒе‘ҪаҫЁбҠҢд‘Ң8з—ўб®©еӨ ж„ӨбҘЎг»ғе•ІвҠӯвҰ‘Ц№вёҜдҖӘвҖІвЁҝд¬ҷбҒҙжҮҗеӣҮбҳҢвҒөд©ҖгҖ Г’б ўвҚҲДЎдҪ№зҗҝв“„е”°дҸЁа№Ңв¬ӢзҹӮгҹҫдҒ¬гӮӘаұ“вЁәв¬„еҺҡв әж ’ИҲдҠ©біұа°ҙаІ„вҲҝвҮһд––е‘‘дҚ©вӘЎдҖҝеӢ„Й¬еҒ‘а·„б© дҰғбЈЁвҫһаіҢжҲ IаӨЈLбҝ‘бҘјд–’е’’еҮҖгӘҸдіҳжЎ§зһ‘е үж«©жҘҡзҝёбҚҷв©ҒЦҙжҗ в№Өб№„дӢЁа°§а№ӮвҲҰТ§в’Әбӣ„в–әдўҠбҖҲжҒҢаӨүе‘Ҹвң»ж«®зӨ§дЎҪеҫјбҡҷзҜғгӮ–жҺҷгҜ№еӨҠж«ҫбЁқж§Іж»®ФІдҰҰеҖ г…ўб–¬вҺҲФ‘еүөбҡ„дҷ•еҖәаҘӮеҲЁаҙӘд°»е«ҒдҮҘзҝӢжҰ°ТҳзҗҘб—Ҷг’«зӯҺд ңдҶҜг«“а№ҙжё‘ж–ұжҪҷгі“жҢіеіізЁЁеҷ“в»ЁгҰңдүҺжәҢвӮғеӮЁаҝ®бұ’аӘ…зҫӘвҚҺбҚҗв°«в®ЈаөӨвҰ«бӣ°ж»•д…ӢвҖ а©”а»Ўбј°з·…гўҸдҚізҳ–е–әвӘ»б§‘а№ҹг…јгҪ—аә—в®Ҷв–Һжқ©вұұв•ҙУ‘бұ дһіжўҰа¬ҘбҰ дЁҚвӢ еҒҠдӯЁгҠ„жҷҹе”¬Д§дҳ¬гЎ–гў…вІ¶вҹҢд®ҙеӮҖаҰёг©“бӨ»б‘¶г…ҝгҢҡгҮҡгңҢзҡҚзҶқдңЈж®ӘаЎҫМ§дҒһзҸӮРқеіҰа№ б№‘бҚ”гҖ¬зҖҶзө©ај–бӢЁдІ¶аіҮгў§вҲһд ЁМҚж¶Ҳдқ дҖҪ8е©“вһ¶гҪҜд«ҹг„®аҙўе» бІҠеҒҡвӣҮбәүбқҷзҶҺгү·зҘіб…Өзһёв ёЩ’еҒҸзіҷО¶б„үдҸҫж—Җеіәеҳ…еҷҗжӢ вөӨв’Ңбҗ…з“қе»–жөЁаӨҺж«‘аӘ¬гӘҝеӢҪбә…жҝҫжӢје§ҺеҺ’а –жӨҢВҚдҙҢе…©зұ Фқг© бҘҫО…в’Ҝе· жЁ№вҮўж–Ӯб‘“зҢ¬ДЁв©Өб»№зҷ·бӣёд„ҒзҫҝзғҲгҡғжҗҸдҝңгҪ№ж¬ҫж—’г”ғжҺ’дҝәеҜҠг”«д»“жҶӯбҪүбҖ жҰЈзё«О©в„¬бҖ©аөғвӨҙб·ғдҪ дӯ—г®Ёв”—а№ҫзҠҸЙ’ГӢбұүжӮЈд…¶гҚҪж–”дҹӮдҝ»зҹҰг§үдҲҡб·ЈзҒ·еҝҪдҢҹгҙ‘еӘ‘вҪҙгІҰдҰ‘жң“вҝӨФҘд°ҳзёЈЭҠдҖ©Кёд‘ ж¶Ўд…ӨвҢ°ж© УҒРҘвҗҠеұ“зӘҪж¶ҰдҖ вҙәsеўҖе”…жҪҰбҜЁбҝҒбҺҠз¶һз«ёеҘқа§ӮбҪ©ж¬һдҚңеңүзҫ—еӢҰаҰ”е…үЙҗе®ӨдӣҢб‘§дұ¬жҚЁаұӨГЈб…Үд¬§ТұзҫҢај¬аӘ§д–үгЎӘжЎҶЖ¬бІЎвҰӢб•іа©ҜеЈҷвқҢжңӨж«“е•қжҙҖбЁӘЯҶе°јеҗІв’һгҜ»е„ ж»Ӯе¶ҠвҠ№а№ гў©еҒҺеҲЈУ©б’«ЙівҜЁбҫЎЯҺгҲ©е®Ғд„ўд”үФІг¬ӯа° в°ӨжҒҪзҖ№бҙқвҷҚеңӨзЈҝеӣ¬дҗ»бғҜжЎҲг¬…жҗғжҶҢж„·еҪҲдҜ„дұҫзӮ„б»ҙжҒҲгөүа®ЁбҚҗжӨүеҖҘДЎаҪҗжҲЁеҡӮвҮёдҫўзўҸа®Қа©…е¶ЎдҒҜа°ҜШјдҚҚгёҠе©ўХ§еҖҪбҖҲеӯ¶аӘЁбЎӮг№Ҳз°ёбҺ„аҪңЦӘдЎҰТ в©ҖеүҒжҷ°зҶҗбұ№дҪҰвӘңеҚ„бҜёд—ҸеҪҫе§җЦ МӨвӮүдҖәбһҷбҗӘа¶‘Ю№еҸЈв”ҪгҪҗеҲӢдӨҒдҗҝбғІЯ·бЎҒз”ідӘңеҶўе°ЁгҗүгӮёНҒд°Јд©үз©…дҚҲбәұд©ҖдҚҸжӮ¬д№№дҶҘз®Ңд•Җв•јбҗҰдғ”В°бЈғг·ҚбӮҰг¬ҳв»Өг…ӨбјІХҹдё№г¬јзӮңеӮ’еһ DдЎӘв №аҘӯгӨҰаӯ§дҜ©дӮ…ж„ӯвҙҘгҚҰЕ©дҰЁгөұд“ҚбЎ°дҙӘеӨ Күг№“зҷҹа··ЗЈеҷҹж„®гҗЁжөҰг§ вҷҠајҮбЎ…дӮ е‘ҘвӢ»а Ўб№ўб„Җвҷ«вҗӨаІөбўҘдҒЈбҖӨа° аі§вҲ д– зҒӣаӨ©гҢәгһҒеҘ‘б°«а¶ҜбӢӨзҜҘг…ҠеғәгҝӨбҫ®гӣөаҜҺвө§зЈөзә—б•°з°ЈеҢ¬ж„җдғӢвҲӢС§г¬ҳдүёгҢҷзЁјгүҳд’ұгӘұзҠҜжҢүаІғб№Ғд•”б’ ВідӨәбҪ¬ЪЁВҸдөҖГһг‘ӨдјҸаҘҶбҸёг¬—з•ҙеҒ„ж©Ҳд¬үз–“бө…гҸібҖІИһг‘ҡг‘„ДҒа Ҳж– дҺ©дЈҚв–ібҶўдҺҙвҒҖвҮӨаҰғзјөе‘‘дҘ бёҰжұүФ–аәҚИӣдҸұбӨІШ”жөӣзөҮжҶҹгғёзҺӘдҚҡеӮәд№°дҙӢжҘҮжўІгҖҰб’ в«Ҫз“ёдҮҪв’ЁеқҜв’ҠЕ вұ ЙұеҳЎбҹ„вҢӣеӘӯбЈұК”дёЁв•қдғ©гҷұг–Ҷвҝ¶е§Ӣаӯ„дҮҳбӯңг¬Ҡд№ңбҸӘе©ІдҮҡдӨ”КібҘҖв»ӨдҸҸгҷғг©”ж‘ жҺЁбҘұвӨҫвІІб‘ұПҶвқҗгіҢдһ дҰ„дҸ·вӣ°еҹЁеҲЎдҪғДёж”ҸвҗүзөҹЗҹаҝҢд•„д·«гҮ•аҪҖд’…еӯҠбӨ¬д…„дҖҗеҘ’бұұР°гҶ жҒЎвӮҝв…ҢвҰ§дүҫжӘІгҲ°гјЎаІјвҠ®д®ңеҢ“зЎ“зЁӮдҜЎгј’е«ЁеӨҪзңҚвЈ№ГҹеЁӘд®ғбЁЈз» аӨҜз„¬дјҮвЁ№гӣ”дҰўдј«жҺҫв°ЎбүҪбҠўз„ҜбЎҖв–ўвүҡб№°еҰ№дқ°в•ҖбҗөХ вҶЁг…ға¬®г§·еҒјеҲЎеҲ§аЈөд¬җеҘҰб•үгЎҢвҘҙдӯҡбӯғд––вҠўж—ҡвҚ—д•јж…ЁдҙҡбҳҜХғб„®гҒ аҜ®бӮҺе”®г•ҒгқЁеӨҠ+аӨ‘аҜӘе§Өвё•г…ӣбҒ”б“ўд”ҳаҜЎзЁ«зҡҙзһӣвҖҙжӯҳХ№г—ҹбә·е•ӯд–»аёӨж”“зқҢж”ӯаҙ¬вІӮв……д§©д•қбҷ¶е’¬С‘Х°б‘ дӮҫа №дұҢжҠЁбҗІдЁ·дј•г°ҶдЈ—бҲ“дЈӮеҷ·в•Қзҳ вҜӮж‘ҙбЈ…дҷҖЛјз№№бӯҺж‘”д«ҙжҘӢеӯ—вҘ„дү’вҜ©бҘҹЦ¶а®ҡвЁ¶жғёбғғд¶№г—…гҝ®гІЁдҚ§бЎ а§®ж„ҝд·ҠдӘҙвЈҹlдіІзӢ§е«“е”«гү’ејҮгЈғзәЈв¶¬жӣёЧҝЦҜб‘°вҲЁжҗәаҘ‘б•Ўб Ұбҳҫж©ідҪҠб©ўе«»зЎ–аЎҲв«ҙж«‘жҮҒвҹіЫўг№Ҷв§ёа«ІдӢ…еҷ“гҰҖвӯҙж…Ҡгҝ№б•ңвўҲжҳҡеӘ·еӢӮЭІг°өе’ӯа№»е…ҪгҡҮМЎбғӘвҶ¬гҠұб№јз„ҰбҷҢдӨҙзү—з–•в·ұаЁЎбҮҮгҳ’дҫҠдәөб§ЁбӨҰв»је‘”вјјб§Ҷв¶Ұе»Өдөёзҗ б„Үг№ұзғҶеӣәГ’вү©жүҘз’ғд‘ЁеұҒг“ӨдЈ…еҷІд®ӣгҪӣд¶ҝв¬ӘзҚөг—·г•ігҗҳз»өе§»г…Ҷв»ҙдғ·МҰз’ҜдҖЎбӘҒа°»бўһбҹІгІ’жҗҜаҙ‘жҖҫгёЈвӘ¶ејҸв’ҫkвҙӘе—ӨжҰҳзҺҳдҖЈдӮҲМҖвЁЎвҲӘд¶ӢдҜёЬҶа·өд—ЎдЎӘзқөвүҙаҘһд„Үг’ С ГҡзңЈ1діҒ бҘӮВҖУҚб‘®зҒ–ПҢбҫ еЁҚзҪҗб…Ӯа   \"}]"},"redirectURL":"","headersSize":253,"bodySize":4910,"_status":"completed","_startTimestamp":1775055927795370,"_endTimestamp":1775055927804560},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":982,"_uid":"07f66efa-ffc9-4387-9640-91d73186b451","_cid":92,"_ctime":1775055887626,"_sid":18,"_stime":1775055927499,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:05:27.040Z","time":302,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9a_Rj&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name