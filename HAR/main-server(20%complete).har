x"},{"name":"Date","value":"Wed, 01 Apr 2026 15:04:37 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3045"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3763,"mimeType":"text/plain","text":"1345:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“ғжҘ•жұ“б •ж§ҶзӨҶж»—Ь•Уҷгһ–д»җгңұзіҳеҡҚеөӢб”©б·җг—ҷбҮҳФҪеӣҠг–ҪжЈҪгһ©зЈҳзһҚж§ӮзҹҫЧҲеҳ•гӣҖгқҳе§’зҳҪзҮүгһқеҹ’Ь№з“җаҪөбҸқдһҶг«—з—ҒПӢв‘ЈвҝҚд“ҒеўҮе§қг«Јзһұд•ҶеӣғбқҪаҝөХ–бҷҚдўӣг“ЈзІҡе¬қаІ‘е”•в’ӢгңЈдЈҷж§ғж« б—ӯЛ”жҡҘзӘ–з’Јз·Қд¶©дӢҒжққЪңдјқб…ҒајідҝӢдјҷбҶһжғҘзӮ„дҪғжҰҸајқжЈҢа¶ӯЦҠвұҘж§•еҖқд’ғвҙ«б’үді„дҠғжҹ«дҰҖж№®гІҚж„ӯгҰқвҫ»бҜүвҙ»ж®ҷжӯіеҮ‘з“•бҪӮбһіжһ”аҫ«гҺҗвұӣвҫҠжёӯзўҸдёӢз®“зҖүж¶Ҹз”ізҫ“дұ»в„үжјӣг„Ӯв°§дӨ“зҰҪе„—в»ҮзӨҗбө…вҺҡе¬ӯеӨҺж·Үд§‘жІ•з’–жҝӣа§„еҷҮа¬…дө·Ж—бҝҮзӣҺе““бҺҚб’·жңҢе··гңҳж»ӣзҡ„б•қгҙғбҫіж««бј·ж¬Ҳа»ҪгҲҠз©—аәҳгі—ЗҡеӯҫзЁҲгІӣбјҹбҝ·аЎӢе—ӢвЁ”дј«гІ…гҫҪгҳҡз•Ҹж§ібұЎИҹдұҸаё–еө§а°үжӯҡеҗҺдұҮзҙҷжӯҮжҙҺб№Ҹдё—гӮҹжһ…зё•д’ӣбІ№дҗҹаІ•бӯҺзҲһз°Ҡб»“дҲңбҸўР—е…№г–ізӨ·ИӘгқҲа·ҰеҖ»еәһжӨўзҹіН вӣ№зҹҡШҖе‘’зёўаҰ–дҖұа»ҹжӘ”еҶ дҸҸеұҡдҜ”Т д„©жӯ©зҷҒб¬ғвЁ·жӯЈеҹ«а·ӣдҰӨзң№дҢқвЁ©еҢӯе–һжҖҪЫҗб•¬аҪҪдҸҮеҮәТҮз§җжёҗзғІаӘһгўүвҶ¬б§Јаі¬ж…ёгҢәжҰ°ХҸв°ЁГұбҳҒа°ІеҮ”б¶ҢгұҸвӢҲгҫҘдў•еӨҲдў¬вғӯгҹІзҢ¶е«Ұб–Ӯб©ҢжҢ¬вәҷеІҲд Ҳз”ЁдЈ°а»–гҶҮжҷҶбүўж“«жҠ¬д„ҠдҠ’д“қбҗ—дӮ§аҰұРҲгӣІб“ғгүӣгЎ Вўб°§дҸҗЦ CвҮ zгҡЁе ЁIај®з ¶rа¬·зҗ¶ГҶж°ӨВҙдһ бҖЁЧ©а §Г¶а«Ңе…қжҢҳгҚӨбё¬бҠҳв¶ гЎҲЙүзҳЎжӘ…бҶҖРӯжҖӘг„ӮзҠӣвқ¬дҺҘж“»К ж¬ҘВ•в«“зҷһг—ҡг“§дүўжҲЁд¶Ҙж’ҜЧ©гӘҙвҠ…бң бёЎжғҠг„Җбҳұж—ҲРҘеЎјдӘ гҢ®жҖ®Оід…ҹз—ӮвөҮбұЁВҳвҮӘдҒЈдҶҗзҳ вӨ®а¶ҖзҖ®ГӘг§Је№”ж— в¶ҘеЎҠдёҷзҳ©гғ®`бёЎг…¬аҜҶзІ•дҡҖзӘ©з“ҜаҝҒбҙҚеҰ§жҮ“П¬зёңвҡ“жү»е©„еҲӘзіҫгҢһе°іаҰ§жң“а©қгёүвҡҳдҒ„в“Үг “УЈз”Ўжұ°в—Ңе·ғгіӢд°ҷгІ·аҘёдһҝбҸҒеӢҶвҘ…б¬ҙз’¬еҡЈвҘүбҢҪе¶¶жҰғд—ҹЪ‘д№«аЈҘајҝж©Җа°•еҳ®зҠҰгӣ„аЎӣМ„зҺЈб“—@гҢҘв§®аӘӘд•ҒгҠәвҸЎвҖӨЕӮд§үв”Ҷвҙҷе¶Ёб•Ңе“ҢзЈ“дҜқвЎҷаҘӯзҜҡжӢҠЬұвЁӯжҘ»жҘҖаҘӢзӢҳб«үгӨ©ж–Үг«Ҡзў©дә…вӘөг…әв–ұв»Ўжј дҖ¶аөўаӘ•в‘ҳб§Ңг«…дӣ•гҢӨг—«б¬ұдӣҺГ¬бқ„еҷ»е‘Ұж№ҺгіЎа»җдӯ°в§ғбЎӮж•ҡеҺҰгҳ№д¶һв‘ ЧүеӘўЧ©ИЎШ•еәәгӢӮвҒ¶бҷҖвҒҺвӯ¬з—”Л§вҰҳК»д§ҷбҢҖХҲг«јаёЈв¶«в•ҳаҙӢа»ҹаўҪвЈҫжғӢбҘ“а»ҲеҢ®аё бһҷвҳўж¬Ңбұ“в»җзҳӯГҷвҰӢгҳЎа®Ңбҫ–гҶҮд•ңеҰүж”»жҜҠвҺІд–Ҷаҫәв·ҲзҲ®гӯұжҒ’жҚјеұЈЪҜдӨӯа ҒбҒҗг—’дӢ’ж°ҝгқ„бҳјвҚңб•ӘЗәд¬җе–ҪбЁҡеҳ«вң№жӮҢбЁҒвҖҙЙҢжӘҚжЈҚв§ҘзӮҙзғҷб„Ғж„ҰаЁӘв· зқ№вӣёД еіівЁҪКөcеӘҠа¬Ә<ај”в°ҙВһзӣҲгҢ№ж”үбӮҙдҗһе’өг—ҒгҠҪгҺ”аӘӣдӮ–еұ дҲ…ж»үеЎ·.ЪҒбҘҹв©ҢВ•еҶ”дҪұеҪҚб•Қаәӯд“№в•®б қвҜЁдҲөв№—бЎҪдҢҡеөҲзӘәа¶ЎУұвҳ–г¶Үб–ұбҒӣеҸ®жҺ—дә в№¶аӨҹбўҚзӮ»д«®г’»жӢӮвҶ’еҒ”бЎӯаёҝв№іЬҳеө“в„ӢдЁ¶гЁ·жҸ’б®’дҸ®д•Ўзһ…жі“еҰ еӯөжқӢд©ІгӢҠеҡ„еҷ„гқӢдӘұв¶Ҙд’әгҫ„д’«д«һб…ҖЮҡвҶҸбқҹгұҺе°·еӣҷз•ҝгЎҫе®Јж‘Үг·©гҫ«дўҚбқ§в»ҚгҢҮд—ҫж№ҝЬүејӢд©ҷгҚҫг•·бҠҷжҮӘжө—зӢ¬жіәжғёгЁҠе»–е·ҳа®ІгңҖб¶һгӣ–зҷҶжў’вҮҘеЈҪдҰөСҳгўЁгҜӢгё‘зһҷеҷ¶зҘ—б»ӯжүқзҜ№д–ҝд¬ӣжЈ–ж°…б –б§ҮзңҶж•Ҹдӣ·жҹҪеӢјжҳ“еұ«ајЎеӯ‘еҪ·віһзһҠжңҘвҢҗб·•е¶ўПЈжұҳТҘдҹ№г¶ҒвҫҳеҹһжҢҝв»ҝеҳ•еңҜг§·аө§бӣҗгҶ§ПҶзӨҶгң«вҶҝдӢ«жҚ“жүёгЎұеӯҮвҮҡвҜ еӣ®дӨүб„ҷжҘ№ж§ҙбә•зўҝзҗҳг№»вҠҹз®”зҠ®бі…жҹҷз«ҚвіҖе·…д–Ҙб·җг·ӣеӢ’зғӘз„®ЪӣвҫҰжӢўгЁңеёҚжҗ’гјұгӯӣв»җжҜҝВЎдҙёб…°Р <дў бҒқ0гҚЎВ„вһҖжһҗеӮ–зҸЁгҖ©зҖҖаӨ гҗ·ИҖбјҘеүҖ  \"},null]1:3"},"redirectURL":"","headersSize":253,"bodySize":3045,"_status":"completed","_startTimestamp":1775055876921060,"_endTimestamp":1775055876928792},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"79","comment":"","_id":911,"_uid":"4b724f4b-73e7-4a49-ac8c-8fbc18db18a9","_cid":79,"_ctime":1775055693743,"_sid":56,"_stime":1775055876643,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41062,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:04:36.445Z","time":285,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9ap5H&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"3"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9ap5H"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"1:2"},"headersSize":306,"bodySize":3,"_status":"completed","_startTimestamp":1775055876445752,"_endTimestamp":1775055876457054},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date