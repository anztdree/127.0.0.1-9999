nnection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":5168,"mimeType":"text/plain","text":"1835:4310[{\"ret\":0,\"compress\":true,\"serverTime\":1775056299709,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЗёГ¬в Јб Ўе Ўа°ўг  г ўжӨ„Йҗд•ғв ўж’№еҹҚвҘ¬бҲҘг”ЎвұҗвҲ бҘҚжҳӢдө«гҠ«е”ёвўӘlзӯ‘гң„вүӘг–үЛ—еҪҰвўӮгң•б§Ҡг”ҙЪҡб„ёгҹҲв®ҘДўдһҒдҖ е—Җз„җжјўвҷҖеһӨд№Ёд“°ЗІж·јж ЁеҖ г»ҡаұұа°ҚгҖӘТӨеғўб…ұв”ёд°јв…’в’ІдӯЁбү•дӮҖГ–вў–бү”жҜұЧҘб¶ҝд№ҢжҖ зүЁбҰўдЎҖИҝз  жө”iбҙ ДҡдҒёг§ҖбҲҝз Ҝб»”КҫдҙЎз“һдҒұвӢҠз’·гҝ”жҺҮгҒ )вЎҲжё¬ж· в·Ҷб„ҜжҳҰбғҖг•—ФҘвҙәгһҫж… вөЁд©ғв°…е§Өдҡјд№ҒвҘ¶ж“ҸЕ Е•д’Һа Ӯд…ҒвҗҝеӘҰЕІгҒІбҒўвңҗгјЎШ ПҷбҖўаў©дҪўв‘ҹРӨдә…дұҲ\\\"ж “бҢӨгҖ»аҘӯжІҶбҠүНҜв…үбҙ§а°—зҙЎжӮҶжҳЁдӢҒбЎҜжүҶзҖӨд–…аё®аӘҖгҫЈО дҖ дүҳгјҙд‘івӨ”гҢҪд•үв®”ФҰвҒ°ВҡЮ«У•гө§Ч°Ь…еЁ б•Әвҫҗе·ҰбҒӨгү…аҪӯгҠ„д¬өв”ЎвҲ зёЎб’ўбҖЎгІ®ГҰв“ІвұӘв¶Ёж—‘з’ҡгһӯжҰ№бғҙгҹ—жІҖвҖЎзӮҢбўӯвҚ‘еІҶбӢҲvвЎ…Ъёжқ“зіҫдҰҮжң«жҢҖз№јдұӨз‘ҸЗҗдӮӨаі¬ зЎҖзү©еһ¬бңұвІ аҘҰжҒЎдҖўгңҰТәж®¶е№¶aб¶іЩ«б—«зҢҮж“®дҪ“гӢӣзјҗзӨЎвңҲб»ҙзЎҠг’ібІҖХ·зҖў*б«Ҝд„”дұіе¶ҰбӮ°д„ӨдЎЁб¶§зӮібҲ¬дҠ“еӘҖаўёаёЁвғ–б–”дЁўа°Өз°°бҢЁдёҰеҶҮб”ҳв„§аўібў§гҒӮ,а  аөҪЛўз «Чһв©ҶдҳЎ9вЎҖдЁЎ#ж–ҖвӨҰвҺёж”ҪвҺҲдӮҘжӢ°жӮҜжҢүгё°ЕӨб§Ға¶ғвҠҖаёғбү„дһҒаӘ¬ИІвІғвҳҖгЎёЗЁбҝ—зңұжҲҫдң°аёӘд—җеҷөдҝңб§ҒдұҘзҒҶд…“бҷңдҳјд©ӣд©ұаЎҙаӘ Pд№іВӘгҮӮв…°ЭӮеҳҙб–ҖжӮӣаҪӯжұ¬в§ӯбҰ¶гҜӨвҳ–бҜЎвәҸеЎұг‘җбў бүӢб„Ёз№ҳб®—гҠјдҮғг№ҳбҡҶж— %зЎөа§©`зӢ„КҲжӢҷеҚ¬бҰҫеҷ•з ©еҮәдҗ§бҢ°дҘҪдҺўдЎәаҘ бҫ ВІжұҠдјҶжҙёа¶ҙдӮ„вӨүві¬вҰӮжұ·вҘҗз„ҠвҰӨвӣҜбңҳеҘўе«ұб©Іаұ СӘж» аӘ®вҹ”дӘ¶е¶ҙВҚбҚўж§ҜаӘӨб¶ҹвҒҖд…Ңг•»гӯәвҡЁдӘҫді д…”Х°Ж•е––жЈ„вүүж©ӢзҖөзҖҡдҹүВ ж„ҷжәҲбәҘв„Ўв¬Ҙб–ҰжІ№жЎЎбғөвЁ§ж–§в®ңеөЁИҠзө ж§өдҚЁжіҗеҚ¬ж®әжўўжІҲдӯӘж®ңжӯӯЖӣбҢ®жЈҰзӨңб‘ӣдқјбӘӢв–Ӣві§жҫҸжҰ°д”»з•ҒдҫңЙәеҷ»жҘҠбҪҫгңҡвҫ•д·‘еҢ“в„ӣгҳЁеҫҘжҢҶд‘¶д¬Җб¶ҶвғҜбўҰеғ»з•ҰЬҚжұ§жҶ”бӯ§г®Ҷб°Ұе•ЎЖ°дөЎб©ҶзҒ©бЁ»вҺһг“ҮзҡӘбҮҶбўҪб№әб…§бқ»аә…д–ҮжӨҳбҝәеіјаө–бқ№в ¶гҢҸжјҗгүңеұүд«ҪжІ’еҫҲеј·вҪҫР·а№әе№ҜжЈ•д Ұд„ғвҖұз«ёг¶үб„…еә®аӨҮеҮ«дӣ¬бЎ–еЈҪеӨ з©ғеәәб‘“жҖӢеӘ»еӨәгүҚв’№аҙЎб»ҶдәҝеўҶеҚҖгәҮзҒҹгҙҜеӣ§бЎҡдқҙгЈҸгҙ…ж®®в¬қжІӣб§Ҝжў¶д«®гҫҜж§Іг«ҝжҹ‘гҜ¶бҰіг©—аҙ©е№ҫбҙӣеҸҸдӨ•г»ҹд·°бЈҶбііеёҠв»Ҝг·ҙвҚјдҖҫжҫ°зӨҸа Өг¶үеәёО д„§бҖ•дҫ–гӮ®дҳӮг«·ж®•вҜўа¶“еҜ еҗ¶дҚҮбӣ•вқ¶дҷЎдёҒеӣ»жәЈг«ёаіҜеҲҳвҫөз§Ҝб§“ејҙг’ҺвҲҪдҳӨЭҒж·Ұг“ӣе—№гҫ¶е¬ҹвҚ§зҪҠгӮ”бҫҲе¬һж«•бҸ б”“дқ©е§ҳгӘ«в’•дғІаҰ®зәҲдҲӣжІЈвЎҲзҙӘбһҷбҒЈжӨһвІӯз ізҒҒеӮ„в„Ҝжҷғг—©аұҲв«»еҰізЈ—в№—дғёзҸҰзӣүжЁ бЎӯжҝ»еҙҰд°ӣдӣ„жЁҜг„җзғұз„Ўбё¶ЕіжһӮеӯҙеҙҖгЎӨжҒӯгЁ“г—°вӨҢа¬¶жёҚд»ҷжЁ•ж«ёбҺһе•ҰдҜҷг§Ҝб–җгққаЁұжҙұгҳ©бәқе‘„В¬гјёвұЈЪҹбҘҗеҢ§аЈ‘вҖ»зҷҺбЈӯгұ…д·–еҜҰг§Ҹдҷҙзҫ«вҪ”з“°жҶҢдәІжҪғзҜЎеҠҙвңӨб–ұгЁҸг¬“жңЁді¶ж¶ҚаҰ…жЎўз…ҳдҚҲвӯҰжҫ®дҡҲзәӯеӯҖгӮ–е ҚдҘ¶бЈўж“Јж°Әг¶§г·“дһҗжҘ«гЈһаҝ¬д ҙдӨ«ж·¬г•ҒКҺе—ҶбҺЎгўҖдҠ“з’°дЈҷеә°вёЈбҫўг…ҳгҸҶвӘ…бүӨж“„жҳ“аҙүдҪ©гңҸбЁ”бЈ“гҘ”гҳӣеҸәsдң жӣЁдҫҚдЎ бЁҒвҘәбӮ’дҜјгҺ®гҒҮеӘ„в”Ҹа·¬зөЈз„үб”ҖзҘЈб»ӮвҚ…зҗҒдёҮж®§жҷ„ж–‘дІўЖһзҢ·з§ӨжҖ«еҝҘдӢёвҜ»жӣ‘вһўеҚ“зӮЁаҰҘв ізҶ§бӮӘвҷ„зҠҡг©§бҶҹв“јеҳЁа«ја§¶бҢғдҳҮжҫ«гіјжІ©в’Ҙг№«г«°жҝ¬зһҹд§‘ж–өгӢ еӯ•вғүдҜ§д–¶зәӯдҜ’з»©аЈҹаұҘвӨІд…ӮеәҳвөҸд¬ҙвјҶЪҢвқңж©©е’№вҝһЭІб§ёжӢјзҚҳжү„гҗЎдұ¶в•Ід •в«ұе„‘аөҙвҘјбҸҠж•ҷд•–дҫҮжҶјбҡЁдқҺг”ҫв©Ҙвҡ¶д”№жҰӘзҪ»а¬Қг°»жҠ‘бҳҳеҸҚжЈ”дұ‘гЁје—ҙеҖ»ж“ёб«•г‘–дҒ°гў§ЗҺдӣғв©ҷУәжҰӯбӯғдөҚа¬…е§–б–әб ҮвІ®гғӮзқӯвһ№д·ғбү«еӢңдӢ…гғ»еү§еңҡеҶҸз«Ігһ–зІ·зә®б»’жғҢбӯҒгЎҷвҚівЈҰзҮҲгҡҫдҪҘзҺҪжЁ•бҠәвЈ”бҚәвҜ–гҶҒгҘ«бҫҚжҢӣв»ӯдқІбөҺеҪҠдғ§зҚүвӘ—вұ¬зҳ—бөҲв»ҰвЈҚеңҙа»°еҳғгғҺеҜҷвүҰзҘәг¬ӘеҚ¬е¬қжЈҘб‘Ҫзғ–еҝ»в“”г«ЁгҠ…жҪ зҹ„д•ҢдјҺе…өеҹізә…еЈӣе«’е«Үд¶өзҪјг’Һз¶ҠЖҘаҰұе“ҫОёб¶Ӣе·ҢвӯҜеҢ”ЮңаІөвәҚа»ҮзҮҒдӢҫдҸҘе¬ӣдұӣЭҹвІҷзғ®ж Ҡж„јб¬Ҡд°ЈВәгҳ„г”§б’ғг·ӯв№Өж„қа·ЎеҲёбҢҶбұіб®Ҷз”ҜеӢңвҷӣжҜёзӢҰгӨҸгӨҰж«ЁгӢ®а°ғжҝҫзҶұеҚ»жҜҖЬғгӣҶв‘өе”Өеҡ–вӣӢдӘ©аҜ№б•ҠгҺқдӘҡзӯҪвғ•б•§аҪ®жҫ“д»¶аӨқвҚ’вӨ°е•әжҜһгөҢзҳ„д¶–з•–жҷүгӣқж¶¶бҘңжҘІг®’г’ғе®јжҚҰеіўаҝңеіҺвҲ—в»ібІІвөӢбҪӣХңе®¬ж®…ПҺжһ№зЎ№а§ӢбӘ«аЎӣе¶ҒбӮӣзҡһбң•гҮӯж‘әвҫӘдҡҲвҰҜб«“зқ“дҜ„её“зҰғЮӣд ҙаіЁб”Ғе Ҹб—үзҳқд„»вө•гӨ¶еҜ„ЯҲзҷҸбӢ®зқҲеІ№гҰҫе¶ҷг»ҷз§ҷгҙңдҺ—вӣҹд¬ӯдңҶе‘ӯеҘ№Шңб ұдӘјвҸӮгқІе’ӮвңҘв—Һа©’жіӮеё¬з—ёб§–дҷңд§’еҜ–ОҒвЁ®зҹӯбўҡе’ҪдўҸб·ҪгҖҒгғқЕјеӯ·а®һзҡ„ж•ҘбјҲаҪҲжҙ»вЈӯжҖӢжҮёдҚ»г –вўғвӣқвҮҲЗ«зҳүжӣұзҮҖеә…зғұзҶ°з§«зғҶаҪЁз“өжҙ•ж•қзЎ«вӮӯеЈ«вІ‘дҹ№г°—вӘӢжҡҝвҹ®а§·з°ҷзөҸа·ҫбё«зӮқвөўгқ—е„Ғгһүз©Қе«јв¶Өе®үв·Һд¬©бҸәз°—бј—зҠ“зқ’жҰ®жҪ»б¶®е№ҫзҰҪб°§ж–°бһЎгҮ“дҜӮеӣҘзҡҢвҙңж°Іеөёзө“дҪ»дҡ”ж¬¬зіҺж¶Ңз©ұзҲ„гҳҒеҰқж…Һг«Ҫг¶ғеңҖвқ«б «жҝ„еӣ®ж‘ҝдҚ¬жҪҪд‘ҪеҜёгәігҒңд¶°г№ҚеӮқбң‘вӯҝг»ҝеҝғе»ҹж¶ЈгЎӢдұҡаҫӢбұҺж”…гЁЁж«ҝв¬„е»§з“ҡв¶§еҙөв…Із®ўеӘҫеҹӢб»’ж ҚЮ–г·‘жәһа·ҖгЎҸдҚ–г ңгҹҠеһҹзӘҚзңҪд“өе“·д—Ӣе ҡгўҝдңҗжҗүз°Һз§ҠдӢҪвҸһгө»вӨ§дөҸжЁӮеұҸеҠһгҹҶгј…б”ҠеүӢж’қжјңгҪ–дҺҫгҺ№зјӢжңқеһёз–ҫИ“бҢҘзғҪз§ҫв’іеҫҷб§һаі—жӨңбҪ—жһҺдӢ¶вәөзҮ–бӢЈеӘ¬з…·гҪЁг«®дҡҲз”Үб®ёз—¶зә„е„ ФҲбҝҜб»қжүӢyдҸЁе№ӣзҮ№а ҷЯ°з»ҝзҺҜИҗб«ҙзӢ’з”ҚбҜҷе—јЗҢзӢҹЪҳбҹіжңҠг”ҸвҮ№дҰҙгҡ»зҳҸбҢӢзҜәгІЈзүғаІҷаҝҰжҷ«гҠҝв©үб·©б»»ж…Ҝг«ҳвҒҚе№Қз“ҜвҗӨПөШЁа¬ҸбҘ“а»Ўд…ўзӣҝгҢҰдҜіз»ёаҘҝгҲӣб»јгәҷж’ҝаІ№е»ҙдҶүз—·аўҰвЎһз««зҚЈвҗӣПӨг“јг„§вҘёвҸҘг«¬бҹҝа·ёж§ҙг»өзһ§гү№бҮҙзЁҫзӮөбӨҰвҒҹв…ҢгҶ№а®“дҗЈд…әгҮҖеҮҡНёдё¶ајҜгҶҷОўд№өгҠ§г•ҷв—Ўж…ҙгңҖеҲӢгқ№ж№®гҗ°дһ§СҡзёјзҺҸбёҷеҹӨе©Ҷз• зІҘеҝјеҢӮзӣ—гҠ§д‘®бҮҹзҢЈб“’б§Ўвә§еҲ жҜҷеҒӨдҮҲзҚЁдәӢвҒҢвҮҗаҫ е°’жЎ–г©ҸзҠҖж…ҰеқӘб…ҙз–ӯвұҰе‘ҚгӣҮеҚҹвЁӣXдҶҖаӘҲжә§дЎһг»ҫа°»вҒҘбҝӨб№қа·ЈбҪҘвҸ«Е‘аіҸгҘ§б»ЎбҮӢгӮ—бЈӨвҝівәҡаЈЁж®ӣзҚ§б№ңз…җдөҲж‘…Е»з–ҹб“әеҘөдҮўг•ҲзІүвҜ®аёӯаі°дҹҘа№ӣжә“зҮ»бҷҰжҒ‘вӘ·аұ зһҡеҷ’гҳ·гҖібҸӨв—«г„јаёЈгҜ§бҮізҲҗдјҳеҡүжҷҸзҲҮаҪ©в¬«зң»бҒҢЫӘбЈ“е ҪдҖідҠјаҙӮж Өв„Ҳв•ҖаЁ аЁ§в’ідҡјЛ вҖ¶вҗ«дҡёКібўЁаіјДҗбҚіајІдғ•ЩғгӮЈд Ұвү’вҝ°дІ¬жҗ¶вӣ¶в¶°дҗҫж“Ұвқ’в®°а¬Јж’ҫбһ„жҙӮеЁЈбҠһФҲгҒўдҲјбӮҡТЁвҡЈвҲ¶б„‘pвүЈбҲөбҒқХёгҒІдҠІд„ҸбҳҙбҲ дЁ§жҗәв… #вө д¬ҳдҡӨеҒҸвӨҒдҪҙеһҜб”«гў§дӯҙеҳҗзҢ бҖӨа „жё§д©Җв§ӯбү°'аӯҡвёҘеҙҶзұҝв ҡгҒ“дүҰдЁ«в“ аұ’жҖӘгҡқгҘ”б©“з№ӨаІӨж•Ҷв•“еҗ¶дІЈвғҰвҫӨг©¬аіӨжһҰг’Өв·Ўб„”жҗҰгғ“бҢ¬вҙҢж‘Ұв №Вөаҙңж’Ҷв№“аҙ«віІж• еҹўдө©віёж”¶вӯ’б¶ҫа№…зў бүЎЭ®в”ҷбҶӘгҫІдІҙ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":4106,"_status":"completed","_startTimestamp":1775056298819418,"_endTimestamp":1775056298824330},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1476,"_uid":"88503aec-5c60-4b40-a7aa-988a10feb380","_cid":148,"_ctime":1775056284934,"_sid":13,"_stime":1775056297023,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Leg