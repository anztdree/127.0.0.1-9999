er0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖҪдҖ¬жҫ бҰ а¶ аЈ бҺ О бҡӘвҒғВҺбҠ бҷұе•әд¬„жҢҒд©°а«Ј@Жҙж©¶е’ўд°ҷбұ°гҲЁеқөбҖ©д«ҶгӢӨеӢұУҺа©»вЁӢд •жҠҡгө¬жҷ’е…ібІ¶дҷҙжӮұбҠ‘ж…’еҮҳв”„д‘ө=бӢідұ Ч‘дҺҗб…өбҡ¶б° гәӯа°·аі РіЖўеҖұвғ•вүҗа°©вӢһаЁӨв°№О•ШҖг—ғеүӘаҘўЙ«в«ҖеҖҘзӨӮе•ӣвҚӨзҮөб¶”зҡһЕҮб”‘вІўг·¶жҢЁдјҪдіҘзәҳвІ‘бҚңж·ӯвј—еҠ¶жҸҚвҗҳжӯҘзӮ®з§ҘбЈһСүд°җд¶®вӨ°бјўдҘЎзҫЁаұ„дҺӨбў‘жғ„дҲҙв‘®Э„дҢ„з‘ЁХҙдӢҠбІҠдӣ‘а·®з ұбЎӯбұ©вһ№бҰ’д·ҺгӮҠж„’еӢ–аҘҒбЁ–гҚҠбҫҪбҹ•дҚҙдҒ§бҷ©Пҷгҝ‘ж«ҖдҲҘгҶҲбӘ…зҗҒаҰӮбұҲгҺ‘б‘ӨеҡЁв®ҷдұӨе¶«в®®дҪҗж—¶еҺ•бІ—дӨ®зҘЎвҠҚд…Ғжӯүз¶ҳж”өРҶд–®е“©еӘҺвҺӣбҢҸд…ңвәҚвҜ‘аӘҗжў©е‘үз°үеўҮд№Ҳз«ЈвҺҢе„ҝд®Јб№®еіҲдқөгЈҝеҠҗж©ғвөӘгЈҲдӨ•а·ҳжҺ№дҗ’вөқжұЁз©„ж·–еҺ д§ҚгіјжӯӘжһҒаҘ“еӯҝжө№д«ЁаҪ”дҗҶбұӨдҝ«бҡЈеҫ–гё№гҹ„бј”гүқдң§дңӮгүһвӣҮзҜҡгүңж Үб°¶д®ҪбӢ·бұўжӨЁвіӯжӘІжӮӣе’„еұҸа«·г”ҫе»ҹв»—вҝүдҰ¶гғ…бЈ”еҚҲеҫӯМҙеғ©еЁ¬зҰҺз®·гҫҠдҰҒгҜӮж·қа¬ӮДӣа®ҖбұЈгЎүЧҒг®Һбө©в”…КҗаҙҠв”ҮбҲІД·вҘҢе·°е№Ғб”Ҹв ҙвҳ‘ЦҖжөҘа¶Ҡв•ҙг¶ҖвҺ»гӨ¶жұЁж«ӨПЁд ідҸ зӨ№РғгҝҚвҲӯвҙәЛқа§„жҸёд§ўжҲӯб¬әдіЈа§ӢМҲд§ҜИӯвҲ°бҚңаЁ°г“°еІ№дҲӯгҳ°бҠ“бһҸдүЈбҶӮвіӣг„әПӢбһүвҸ°еҺ…ж·ҳдҰ°жҸүгһҺж¶ӣбһӮбҠ§бһҒбҲ¬з’ҝд¶„жӘҒбҖҙзә„еҸјдӘҝдіҙжӘҶеІ—бҡ°бҸ—ГӢе°өб•®зӨҜвЈ жўә,бқЎе°ёНҳ[ең Г¶б ҪдҒҫгә гҢ жЈ–е„ёеҗөД°еҲ ОёзӢӢжЎҗа¬ҶаЈ еўҢе•ӘвҪңе®Әвұ’бө©вӘғбҹ‘г’ҸГӮвөҰв©ёеӯөа№№ејҘаұӮвҙўеЈЈеӮҶУўв¬ҶеҮ·з…¶еҳӣв©ҫвў„в–ҠжҳӣСҲеІ’жӘҺаәөаўҶаіўжӣ®дҒҙgб„Ұв«ЁХёж®’зҮҪе©јгЁ ВҘв ұдқӘдһ•вЎӢз ІЧЎж•¬РҒв‘Ҳд“ЎеқөвҙЎзҚҫаҙҠзҢҝдҠ°ВҲеқҚзЈҗжЎҙжҜүдҗ„ЮҪжӯ зҗҪвұӣзҒҶз”№дұүвҪӘ$дҙҝбҗ ХҪЙ”бҡӯеӮ”ж«ҺеҢғеҲ дҙіжёЎз’ҫвҲҝЖҫвӘҹб•ҢвҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1263,"_status":"completed","_startTimestamp":1775056083376563,"_endTimestamp":1775056083384366},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1166,"_uid":"4d8979c9-4237-4e35-99fa-d3e643d0e654","_cid":92,"_ctime":1775055887626,"_sid":91,"_stime":1775056082924,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the 