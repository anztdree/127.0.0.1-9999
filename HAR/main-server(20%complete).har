EIO=3&transport=polling&t=Pr9bwok&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bwok"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056170169982,"_endTimestamp":1775056170178630},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:09:31 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3026"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3759,"mimeType":"text/plain","text":"1337:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—г№ңг‘ӘдЁҹгӢҙаөҠжҰ¬жҮ¶бӯҡбәҚвҪ—аәҡдҡҝві·зҗҰеҡ°зө—гҡҶбҮҮвқ’зҹ·дӢҰж…”ві—дЁ–жӢ•жө·дҒҸеү’НӣеҳЎжҸөзҳ·вң“в“’дҫ¶бӢ°зҜҡП®з—ёзӮңеҪ–жҜ–жіқг–Ҹб·җжӯ·гҚҡгӘ¬бҪ”біҸд—із•‘г№·жҲүжҡқд·№вјӣжҮ”г№ҶеҮҪг®®гҹІгўһе§ҜгЈҰгҝ°зҘ–дҒ„зӘ¶еҹҘв©ҫб·ўЫёг¬·б ҫв—¶Т®зЎғг®ҫв‘қзҰҶг§ӯЧҒд— е¬ҫеӣЎЪҺЙҢФұг·ЎжҶұдҹўд–®гҸЈеЁұб»»зҜёдҷҖФҒд©ҸЧ‘е©Үе«ҒЩ“ЮұгЎҸд’Ўб©Ҡзӯ¶е¬№бҮҫаҘЎзӨ‘е—ўвӣ‘а§әвҡһжі№бҢһХҹз®Ғж•…дҷҒж·ӘгЈ®е»ўжү‘д‘ҷзҘұзұҲж’һжүӮжҗҺжЎғжЎ№вҒ…зӯұбӯҺдҹёз»ҙв•‘з…Җж—ҷж‘ҳжҡ№б’»дҳүдӯҹд—үб‘Ӣз¬ұдҺӨбң®зөҳЫүеҒқвқҘЭҮв“ЎгЈҢбҷ©зқғд“…жөҸвҜ…вҹҘж•№Еқв’№жіЎгҺ№ж©“бҷ…вҘҮг¬ұЦөб …вқҠе”өзғүб—өжқЎеӣҫд«ҹЭөдҚҖбӣ№д»ӣв¬ӯзҘүе–©е№Ҹжқ№Зғж–•жҮҸбҷүеғ•е–…ж§Үб”ӯеҜ§бӨ•жҷҒб •зҷғвҹөбҮ”дһҷжқ—ЭҚе·Ңе Қжқҫг‘–жҸ…в”Қд…Ҹг—ҚжғҲз“•бҸҶеһ…дҝөС•вҜҗгЈҪд§„е’•е¬«з–ҷдқ’вҳ•зҪҢзң–вӮҠЧ…вұғб•Қгҹ…г‘қдӮ…жўҚжҪүв–Јв§—г ҚжңҜе®қжӣ—еҹЈв•қзһғеІ‘е‘Қгў•з—ҪеӢ’аіғе«§аёғеӮһаөідЈ“зӣівҹ„аҙҷа§ӣгһЈзҜңз”ӯбІҒг§ғд—’дҙ“жӘңе“ғб…ғдҝғвҡ”в№ҘзҶҮа¶№вҶӮд»ҪеҰҗбҹ«е¬Ұб•ӢдӢ„вәғеәҠб”ӯжўҢгҡ“зЈ•жңӢж“Җж¶іеөҷвёқаЈҠг°ҚгңӨгӣҘж¶…в¶»гҰһж·ӯвһӢгҡ»зҝҚвҝӣжЈіжјҷжә•жјӣа®Ҷе §вәӣж»»зҒҹвҪғЮҒдј»аІҮжҪ§зҶҒжё»зҠҷжі»зӣҗбӣ“аұҠвј«бһүб¶ҠЫ–еӘӯз”ӢжјөвӨҶгңғз„„жұ·вҙҷвҖҚе«ӯбө»аҙҲбё·бҘҳеі„д®Җеһ·гӣ–е’§ж’үејЈбўңгӣ·гјқзҳ“дҲ•аёҮж®Қе№·е—Ҡгё«бЁ•е№§з¬Ҳеё–бҜҰе№ҮзЁ—г©ҸдһӢвј—еҸҸвҫ«е«Ұз¬ҜвҺҡвҙӢзңғз“іеҗңз¶·д„•дҖ—жӨ„ж‘Ўжқ«гі«ж„җгқҡзҡ„гұҮеҖҡзҙҮа ҳб·үгЈ—вҲҗвҢЁгҠ¬жҖҝгәҖбӨңз—№зҙҪаёҡжұ”зЁҹвҳҗбңҪзҗҶгҢӘЕқжңЈжҸұаІ гҜҲаҝҺФҝг§’ж„қзҷҫзҖјжҷҒжҷЈбқЈзіҸдҢ§з–№Я§бЁ¬жңӨаөәгҲјж№ҳб„ҪзҒӮгҙёгҰ§зҸӢЬібҳ©жҺҢа¶ҰбҳғжҶЁжңқз“®дҸ°в¶ӣеЎ®бӘҗеў¬еғөгӮҺж„Ід„·жҒӮзҸ®вҠҸдЁҰб’Ҳз®ҸгҡӘВ°аҰұд„№б…®дҡҖзҮӨжӢ”в¶ӨбәҘдңҹЪӯдҪҮзҳҒеҙҫе„Ҝж·ўзЎ’К¬г„Ҳвў‘С зҲ’зЈ©г•ЎдҙҙзҶҶбҢға«§жҸјв’Өе§ҷдңҮвҖ•з¶ӢаЁұд·Ӣз…ҙб®„РұжҒңб¶ в° Дәаё Л°вұҘдҒ в№Ёзў—дғҗеІ°еЎҳжғ‘гҘ–жҒҖбғ„г°Ў`бҷЁдҒҳЫҗд¶Ғжң‘бҲіб№ҚжӮҒбҸўж’ҙР„з¬ӨОӮдЈҗИҰзғҷбўҗеҘ…еҸҰвҮЎгҠҚд… г–ўдҖҰе‘№гҙівЁҰбҺғгҺЎгғ¬б§ ж°¶в’ҳбҷ®е“ӣЫҗжҠ·>ДҒж•җзҖ¶бҫ…еҗӨЛёбҷӘдҒ“ЮҖЬ©дҰЎб’ҢбөӮвҚңвҸЎзҷҙИја®§гҒјдўҗж¬§ВҗаұідёҪзҮҰвёЈбӮҷв–ңз¬ӨеўҮ@ај еЈҶа»ІвҪ¶вҠҢвә‘вІҮв ҳзј¬гӨ—еҖ‘б–Іж„©бЁІвҖ¶бҲјгұӨгІҹд•ҸбҒ©жҢ’в¬¶бҖўзҰҺбҷңе…—ж·ўвӘөдҘібӣҲжўҜжў аўҒвЈҜд—Ўб®«г“–бҒ‘вҒөе·ңвҢӘдөҚа¬ҡв¶Ўдў·зҶўеӢ«в“ҷвӢҹе„ҘвӢңг§ңд“Ӣе¬ЎгҮҷЬЁе§ҷбҒЎж°«бҺјбЈ…е°ЎЖёгҘ®гЎӨвҝ©бҰҝвӨҫФ бҖ®а°•вҘ„ж•ӘвңҢгЈҸгӢӮбӣҘгҷ»б–Һжҹ«е“ҚжӘ’д’ҙбҘәжқҳд ӨеҠҘв№©б”ҙвүІе—ЈаіӢж®№г—¶жҚ«з®ңг¬§г°ўxг”§дӨөб„ҒЫҶжӘ¶аіөд°өвҗ°гіӯд‘қв® гҢҘдӨ«бӨҠгҮҷжӘ’е§ўб№¶жқёа§Қж“Ўд«№жҠұвЁқбҳ•ЫҮбүҖбЈ·дөЎЖ„д„ҘЛӘжЁӯвүІеЈ‘ДЎЬ¶жҮҰвҮ№з№ӯе“ңв№Әж“ҢдҰҗеөөд§Ҫб„ҚаөүжҮ§вў—гҰ–дӣ®г–§гҒҘдҙ№бӯҝдҰ§Ь гҸ„еҢһгҶ–а№ҒеҳҺзҗ дәів·җбЎ»гҒ»еҪўгҜүжўҒгҺ„г–Ҙз‘•г»ЁвӢ“ГӯЫҝе§ӣб·ҲзҖ№г…Һв№ҖО•жЈӮжҰЁдҚ№жӮЈбҝ…ОӨе–¬зҜӢбҲ¶а№ғб№ҷвҳһе•Әз Ҫвұҳж¬¬ж§ҷбӘ‘еӯ‘гҮ•вЁўжҡңе‘һб«Ӣз«қеҠҗвІ°з„ҒаӨӘжёҪг®Әгӣ а №жҗәеҫҚж“ҲРҚН°еЎ°ДҖеҹӮжғҖбЁ–еҶҸЫ®бӯ«д’ӨбіҘж“Һвө“б®Ӣеө—бҸјЧ•жҲЁаҝ®д•¬д»ҳВҗгҢҰдҰҳгҶҖг·үа©„жӮёеҫҡжӣҹбҗӯЫ ж»Ҫг‘өдҶ»ж‘ўд»ӮбҜёв “жҺ•г”ҲеҖӘдӣ…ајӯв•ҪвІ©а·јжә–жҷңзҗ вһҮб ҹбҶҫЪ©жӨ•д•ҪгәӮгҫғжҡҳбҡ©вҠ•жғҜдө¶е¶»жҙ©жӯ“жҘёд®һгӨ·вәӢдӘӮзҸӨвһҷа·…з„Қж–ӯг’“в“ҷа¬өвҺҮжҰӮбңёвӯЁд«ҝдІ бҳҢЦўвӘігһ…г¶ҒгјҶе–ӮвғҸвҹ¶гөід¶©зҺ§дҳҢеӨіеЈҳбҙөгЎ·з№Ҡз«’жЎҚЬҺвҫҢжөёзҳҡеәҗз…–а·һгҪ–еҹңеҷӮгӢҢзҰқвұӣбіәжёғд’Ӣз№ҫе–©е”ЈдӨ»еҹўжһӣж«јвҢҚж°Ңз–ҜОӢб——еӯ—а¶—дҡ–зҳҰжӘҸв„ҳжІҙзҸ№ЧідјӣеЈ•зӮҹг®¶бё©гҹӮзӘҺгјҡж»’з§№еёҡеҜҗдӮһб¬©ЬҜг“—а ҺзҺҸвҲҺа¶Ҫзӯёгғ—зҷЁгҹ”жӯӮеһҚЬівңұж—ҚгҺ‘бјӣв…ҳжҺ§еӯ§Ь«дһ§г•ҰжҠҖа«©жҮҡаЁ„жёғеҮәб…ўгҝ«жЈ¶бӯЁзҝҰдҙғдёјИҝбңҠбіқзөҝеҰһг§Әбҫ°гҜһеӮәбҙ…жҒ…зҘҺз“ўе¶©д–ҘеҺ№гёӢбҚ”ЕјзӮ¶гҙҡбҸһДЈб©җвӢҖа  Yб„ вӮҡ@жҡўГЁд» бңҒвҶӯжһ°жҒҷеҝ бҲ жЎҺП гё«в‘   \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3026,"_status":"completed","_startTimestamp":1775056170721867,"_endTimestamp":1775056170727446},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"100","comment":"","_id":1310,"_uid":"1578bc70-c980-4b5b-9e75-f79f7a6f0547","_cid":100,"_ctime":1775055939645,"_sid":74,"_stime":1775056170169,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":59648,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:09:29.608Z","time":291,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bwfv&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name