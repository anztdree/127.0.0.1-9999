\\":false},\\\"805\\\":{\\\"_id\\\":805,\\\"_curCount\\\":2,\\\"_haveGotReward\\\":false},\\\"806\\\":{\\\"_id\\\":806,\\\"_curCount\\\":2,\\\"_haveGotReward\\\":false},\\\"807\\\":{\\\"_id\\\":807,\\\"_curCount\\\":2,\\\"_haveGotReward\\\":false},\\\"808\\\":{\\\"_id\\\":808,\\\"_curCount\\\":2,\\\"_haveGotReward\\\":false},\\\"809\\\":{\\\"_id\\\":809,\\\"_curCount\\\":2,\\\"_haveGotReward\\\":false}},\\\"type\\\":\\\"Notify\\\",\\\"action\\\":\\\"battleMedalTaskChange\\\"}\"},null]1339:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“ғжҘ•жұ“б •ж§ҶзӨҶж»—Ь•Уҷгһ–д»җгңұзіҳеҡҚеөӢб”©б·җг—ҷбҮҳФҪеӣҠг–ҪжЈҪгһ©зЈҳзһҚж§ӮзҹҫЧҲеҳ•гӣҖгқҳе§’зҳҪзҮүгһқеҹ’Ь№з“җаҪөбҸқдһҶг«—з—ҒПӢв‘ЈвҝҚд“ҒеўҮе§қг«Јзһұд•ҶеӣғбқҪаҝөХ–бҷҚдўӣг“ЈзІҡе¬қаІ‘е”•в’ӢгңЈдЈҷж§ғж« б—ӯЛ”жҡҘзӘ–з’Јз·Қд¶©дӢҒжққЪңдјқб…ҒајідҝӢдјҷбҶһжғҘзӮ„дҪғжҰҸајқжЈҢа¶ӯЦҠвұҘж§•еҖқд’ғвҙ«б’үді„дҠғжҹ«дҰҖж№®гІҚж„ӯгҰқвҫ»бҜүвҙ»ж®ҷжӯіеҮ‘з“•бҪӮбһіжһ”аҫ«гҺҗвұӣвҫҠжёӯзўҸдёӢз®“зҖүж¶Ҹз”ізҫ“дұ»в„үжјӣг„Ӯв°§дӨ“зҰҪе„—в»ҮзӨҗбө…вҺҡе¬ӯеӨҺж·Үд§‘жІ•з’–жҝӣа§„еҷҮа¬…дө·Ж—бҝҮзӣҺе““бҺҚб’·жңҢе··гңҳж»ӣзҡ„б•қгҙғбҫіж««бј·ж¬Ҳа»ҪгҲҠз©—аәҳгі—ЗҡеӯҫзЁҲгІӣбјҹбҝ·аЎӢе—ӢвЁ”дј«гІ…гҫҪгҳҡз•Ҹж§ібұЎИҹдұҸаё–еө§а°үжӯҡеҗҺдұҮзҙҷжӯҮжҙҺб№Ҹдё—гӮҹжһ…зё•д’ӣбІ№дҗҹаІ•бӯҺзҲһз°Ҡб»“дҲңбҸўР—е…№г–ізӨ·ИӘгқҲа·ҰеҖ»еәһжӨўзҹіН вӣ№зҹҡШҖе‘’зёўаҰ–дҖұа»ҹжӘ”еҶ дҸҸеұҡдҜ”Т д„©жӯ©зҷҒб¬ғвЁ·жӯЈеҹ«а·ӣдҰӨзң№дҢқвЁ©еҢӯе–һжҖҪЫҗб•¬аҪҪдҸҮеҮәТҮз§җжёҗзғІаӘһгўүвҶ¬б§Јаі¬ж…ёгҢәжҰ°ХҸв°ЁГӮа©ұеӨёд»әбёЈб·ұН•еҪӘжў•еӨҲдўӘеЈ—зӣӘзҢҝД®бҚӮЯҰгҙ¬вәҡд“ҸТҖдӘӯеЈ»М¶гәӢз…„бҷ¬е№Ҳжҗ®д‘Үб‘«жҘҹв®Ҝдөқа«Ғзё»біІбҠӮб№’ж°ЁбҮ гұӣx\\\"бЁј%еҺҲд– дӮңдӨҗзһЎг„ҷбғ‘гҪЎгҲ’гӣ вҒ‘в’ҳД дҖјдў г ӯгғҠжӨІаҘғвҗңвҗЎе°¬бҠҳвҒӘдҒўдҫҖа»ҠвӨ¶`жёҝбҢ®Э…е©ҙж‘ҳа№ӯеЎҲЫҗв §в©Ӣбҫғз…”вҗ”гӘӨв‘ўжҲЁд¶Ўж’ҜЗ©еӘҙвӢ…бң бёЎж…Ҡг„Җбҳұж—ҲРҘе јдӘ гҢ®жҖ®а¶Ід…ҹз“Ӯг“ӨжұЁВҳвҮӘдҒЈдҶҗзҳҜдӨ®а¶ҖзҖ®ЕӘг§Јеёҙж— в¶ҘеЎӘдёҷзҳ©гғ®`бёЎг…¬бҸҶгҡӮвҡҖзӘ«зғӯаҪҳжұ·зҶҒб»“П¬з·–вҡ‘жҠ‘б–ЁзЁ–зұҫгҢһе°ҪаҰ§жң“а©қгёүгҸӨвүӘг®ҹвЎ¬бҪ°аҝҘд№№зҮәбҸӘві‘ж·©вңӣбҰҮжһ…аөҠгҠІгҖҒвҝЁж–ҲбӘІдЎӢзҚҢuд–үжЈ®ајӘз’јвӘҰбҖ«з«¶Ю’аёҘгҗ’вӮЈе ®вқҳвҘ«г ўНҗдӘјзғҲеЎізҚ‘еүңаЁ вҖІбңәд©ӯа«”д»јж’јгҶҺеғӢдЎҫдҠ“дӮ¶аҫұб’Әе“ҚжҢҸд№өзқөзӨІеқӢе»ҡжҺ°еҷ¶вІӣд”ҡзҺігӢәвІ‘з„өжҮҠајҗРЎгғҙГ…в©ЈдҠәдҸҠвұӢвӯҗбӘ°вҒ«б¬°дӣҺГ¬ЭҮбҡӢе’ҰдҪ®гўҮд°ұж¬Ўгҳҷбү“Й”еӢҠвўҶжҮүеҳ„дҗ§б¬ӢвЎҖбІ°вҖ°еҪ»б“”дҜһЦӮжҲӨМ…б“®еӯ вў•бһҜдҘҷбҺІвё°жӘ’вҝҮв·“в•ҳвҙҸа»Қдәөж©ҫжҒӢб…’а»җеҢ®аёўбқ№вҳўе¬Ңбұів»җзҳӯГҷвҶӢгҳЎа®Ңбҫ–г…Ҝв•ңжҰүж”»жҜҠвҺІд–ҶЮ»в·ҲзҲ®гӯұжҒ’жҚјеұҰаӘҜдўӯб іМәеҖәвЈЎзӘ’вҶҒжү“жүҙеҖ№е“ҸUдҺ«е–ҖеӘ‘дёҰжҶҫаЁЎвҖўж“ҶзҜҙвҮҫв©¶вңЈдӨ®аё°гғҹбӢјЮ–дӘҚдҖ°Ч©б¬Ғжҝ©в ¬бөҶеғҗеҖЎж„ҸвӢЎвҖ§зһ”дұЁд ®дё©в©ҳб”ҫеӯ»зҚ‘ж¬ҡгҪҮеұҮг—ӨР№в»Ҡд¶Ҙг  зӮҶЖіг«Ӯж„§вҙөв“Ұб–©дҚҗжӣ°аӘӯУҝб—‘еҘ№з„ЈеіҪе…—віӨдһ№д–Ҝе§ӢбӘ‘бЁ»И‘е¬ҶгҮқжҳӨгҷ«дҚІгҡ в№¶аӨҸбўҚгӮ»дӘһеҮӘгҠӢзҺ’дЎ”бўҶеһҘе«Із«җеұһеіҒгҸҒг…ӣЯӮвңўвҒҺбі¬зҢ…Фҫдҡҙеҙ‘еіүбҸүе„ҮгәҹбҷҡеқҺв«¶дқ„в‘»еҠөвЁ«жңўа¬ҙеӮӣвҮҺзЁәжө•вҘӨдҝҳаөҝвңҸдҸқж…ҝаӯЁг“Ңзҹқбӣәзҗ—дҢ“дҶҷж“№бҰІе©ғз»“жӯҖЮҡж–’вӯ’жҸҸвөІж№®д’ҫе®Қе««б—–зғҚг°әб®…вӢЁгҘҒжҢҹеқұдҹҢбұҳдҹ»а»‘зҒҪг…¶ОӮвҡҺбјҢзӘҚжјӯе—ҫдҳ„б—ӣа§’г°ҚгҲ—жққзҹўжҜ дҲҠвІҳб«әб—іеҙ§зӢҢдӯҗзӘ¶зҳја№Әж…ғбҮёжҪёбҸ»гҰ·еҘ»зһҰдҹЁбӯЈдӨ«зӣӮж§Ңең–дёғдұёбң’гёӣбһҘвҹ®вўҗаёЁдјәжёӯжЁҗбӣід’ҜеҸ№е §в§ҡдӯ®ЫҜзҰҗвңҷзӮҢб°јбҙҖзқ№ж¶өе«’дҶ‘бҢ¶аІ–вҺҡзҡӮж—Ўв—Өе№Ҫз…һгҗ–гЈҗдҡ–бһ§еҡҶд«һајЎжҷҮгёўН”гҒҘвҖ° гҘӮ`зЁ вғӯИЎдўҪдғҚж…ўд·Ҝбғ в—ҹдҒ„Г°вё§дӮңаӯЁдҖ  \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3392,"_status":"completed","_startTimestamp":1775055930717501,"_endTimestamp":1775055930723991},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":993,"_uid":"37fc7959-f63a-4b8f-8fa7-5314fe3b2b00","_cid":92,"_ctime":1775055887626,"_sid":23,"_stime":1775055930425,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:05:30.424Z","time":303,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9b0Gn&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"124"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9b0Gn"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"120:42244[\"handler.process\",{\"type\":\"rank\",\"action\":\"getRank\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"rankType\":3}]"},"headersSize":308,"bodySize":124,"_status":"completed","_startTimestamp":1775055930424975,"_endTimestamp":1775