845},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:53:57 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1253"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1496,"mimeType":"text/plain","text":"577:4356[{\"ret\":0,\"compress\":true,\"serverTime\":1775055237456,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖҪдҖ¬жҫ бҰ а¶ аЈ бҺ О бҡӘвҒғВҺбҠ бҷұе•әд¬„жҢҒд©°а«Ј@Жҙж©¶е’ўд°ҷбұ°гҲ©аөіМ аҰ вұЎдҠЎв§–дҷЎв§ҖеҢ”дҘӢд“•вӘӮеұјУҗе…“д“ӘдңҒбҺІб…ҙВ”дӯ®г„ бӣҰа· д•ҙе©ёзҖЎз©”гҒјгҢ бҒ¬ШӘдҒҘЙөаЈ гҖҘбҢҳв ҫгҹ„а»ҙбһ еҳ®дҘҲФЁж…ҷв·–г•ӘвҖ«зҮҘв«–Ъ©дҸҠв¬‘ж”ңаӯІж—Үб©№ЖҡеҡҰаЎҫв¶©дҲјеӢ§бӘ„гўөбҝҢбҒ…бқӣд’ҘбҮ¶дЁҳг—ҶзЎӨеў®еҢҜжӮҘбЁһбҶұж•ҒРҖвҘҳб ©жҶӨжўҗдңӘб°ҙжЎўдҠ©ж„„жЎјдҰ©ГӘжЎ№вһӯвЎ¶Ж№жјЎбҺ©бҺ№бҙҗеүҺгҶөж„®вҙҫб©Ұж¬җгҠ–зўһбё•гҚӘгҫ§бҖӘбөҙжӮҸб…«ИҘвҡһб”ӯа°ҶзӮүд—ӯд”©ж‘ӨеғӢвҠ…аұӘе‘ҺжҠ…еІҶеҺўзЁҡгӣҚбӮӢжӢңеүұеұ“бҜЎзҰ·дөӮбіңж©Ҙеә—еҚҠж¶ҙжҚҗбёҶзӯ«б”ҸдҶҚеҚҜб°ҠзЁҷеһғб—ӘзЎҘв„ҳеЁјзҗҚжҘ°г¬Ёд¬”аҘҳгўӯа«ңж•¬гЎҸж«өвғҰе–јд«ңжө°гҜҲбӣҷб””бҠ»дҸ’вҙЈжәӢв¶ҰаҘҶжҹүDдқЈгҢ‘г«ҪдҘӨдҗҲз Җе»ҫб…„а ӣжҮ°зӨҪаҝғжјҷгјҪајігӢЈжҡҪз¬ІвҲҺг©ҹжҹҮЯ‘г©қбқ—б°ҫжҙ«жҙ‘бЈҒзіёбӣӘдҒўж’”е’„еұҸаЈ¶г’ҫд»—в«”б°ӣеҶЎгұ…еҘ¬б«°еЎҜОӣбҖҒаёҚг‘…жҙ№а·§г ҫв–ҖОӨвҹҜеҙҜб№Ғб·©б”ҶаөҒг‘Ҹбҙ—а ӨеёӣвҡүдӢ·гҘҒеө°еҷғд–©б°Һв’©а®Ӯв”©бЁүдҚҙг®ҺвӢ жІҢж”©гӯҖе¶¶аӨҺвүЈвҙҙдҺүгғҠг”ӣгҘҸз‘»гӮҠЛҳе„јгўҳж—ӮдҠёзҮ«бҙӨдҳҫбү“в »дҢҙзёјг”ЁдІҙвө жјҺбүӢвЈ…вұөгҖғдӮ»в–ғвҺ”зҙ»в“»б„ҖбҚҢж¬№дҺ§в–ҶбҠ„д’©бүҫг’Ҫдө»бІ№гҲҙзҺҪдҸ©а¬Ӯжұ„бӘёжұ”дһұбҮ—гҫіеҠ„дҲҠб’Ҝа®Ӯг¶ӮеҰіеЎҸбҳҚгІҠбө ЖҘжЎ—МЎвң Ю•жҖ б«ҰПҗвҹ«е„”жҖӘзҘҙвҢөЛҖвҲҙдҖ зҚ’еҢҡз©ҠеЎ“бЎҰЛўдӘәвҙҳв¬ңвҰҖвІӯдҒ—вө«Р¶бҡҶвҪ»дЈҶжё«НҚаЁ‘е«ӘдЈЈеӮҶУЈбӘӘеғ—гЎўе‘ЈбўҶЫ–еЁҘеҖўбІЁН¶вӮәдҪҫв°–зҳӮзҮ°$б• дҷҒвҜ»вөўжҝ дЎҺТҠгҖҝХҒвүҶЭҡв¶ҲНүОүвҳәбҠ¶д‘Ёаә°е…’гӢ”жҙ§бҷҳв•Әе••жҝҖдұҺж°”бҝ“ЯӢХ Вів„ҲбЈҖJзҗ¶еҒ”вҡҘеӢ•вӘЈаә°жІ—ајҙбҜҺзӨ°з°ЎзҰід«Ғг„   \"}]"},"redirectURL":"","headersSize":253,"bodySize":1253,"_status":"completed","_startTimestamp":1775055236561268,"_endTimestamp":1775055236565304},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"54","comment":"","_id":273,"_uid":"744cafc9-f49a-41a8-9a54-41830fcf8a57","_cid":54,"_ctime":1775055043431,"_sid":71,"_stime":1775055235175,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39938,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:53:54.749Z","time":301,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9YMQh&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"188"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9YMQh"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"184:4255[\"handler.process\",{\"type\":\"hero\",\"action\":\"autoLevelUp\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"heroId\":\"71ee2d7f-98d5-4b8a-82c3-fc417faa3737\",\"version\":\"1.0\",\"times\":1}]"},"headersSize":308,"bodySize":188,"_status":"completed","_startTimestamp":1775055234749957,"_endTimestamp":1775055234757715},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1",