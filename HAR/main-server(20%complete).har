Іб¶¬дӘ’вүҢз‘Іг№Әд·„зҸҚа°°б©ҘжӢІг№®дЁӘзӘҢд«јЮұд¶ӘжҷјаЈ“е·‘з•ңжҹҺвҹ©гҗ Ш·вҒҢа°ўд° б·· ж¬ё\\\"е“ҖаёӢвЁҠгҚӘгөҡгҡӘд…°б„ӘвҖ г§•вҜңз•№з—Ғеҗ¬ЧҒб•§в·ӢвҒҡбҹӮеұұд—“аіҳдҢ•еӮ“а©ӘеұҪгӮөдҡЁжқӘаөӯЯҖзҖӯб—ңдҚәбң»УҳжҪ”дҷҒжҝҘеҡ’еҶҚаӯ¶з…әеј«ЕҠд‘ҚЧҒОҷвҹҠеј Т’бғҚвІ§г–»вӣҢг¶Үд” жҖ аЎөОҲбӢҒз–•гҸҝЕҖе°ӯе“ зҳҙдҲҗд°«зҡ•жҮ—гқҠз·ӮвҰҺж„ҰзҮЁжҸ”г“¬гҸқбҘҢбёІз–„жЁ®дҒҗ&вҜ·жјӣв”ҡж ¶еүҙ)б¶Јx\\\"еҸЁФөзҚҲз–ҮвҸҮв‘ғбәҶвұҹж· дҘһМҶгҪ°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1285,"_status":"completed","_startTimestamp":1775056044284832,"_endTimestamp":1775056044291057},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1093,"_uid":"987fa2bf-4b33-4ee9-8384-a9e0edb200d6","_cid":92,"_ctime":1775055887626,"_sid":58,"_stime":1775056036500,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:07:15.958Z","time":293,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bQ1h&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"144"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bQ1h"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"140:42269[\"handler.process\",{\"type\":\"task\",\"action\":\"getReward\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed056