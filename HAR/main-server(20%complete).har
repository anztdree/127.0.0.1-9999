,"_endTimestamp":1775055769690836},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:51 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"257"},{"name":"Connection","value":"keep-alive"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":257,"mimeType":"text/plain","text":"253:43192[{\"ret\":0,\"compress\":false,\"serverTime\":1775055771504,\"server0Time\":14400000,\"data\":\"{\\\"type\\\":\\\"tower\\\",\\\"action\\\":\\\"getFeetInfo\\\",\\\"userId\\\":\\\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\\\",\\\"version\\\":\\\"1.0\\\",\\\"_feetTimes\\\":5,\\\"_feetStartRecover\\\":0}\"}]"},"redirectURL":"","headersSize":225,"bodySize":257,"_status":"completed","_startTimestamp":1775055770610081,"_endTimestamp":1775055770617600},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"72","comment":"","_id":795,"_uid":"3108ef68-b74d-4c84-86d8-9e4c1ec608be","_cid":72,"_ctime":1775055552939,"_sid":54,"_stime":1775055769684,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":54620,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:02:49.328Z","time":302,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9aOxg&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aOxg"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055769328478,"_endTimestamp":1775055769341775},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:50 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"5961"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":7571,"mimeType":"text/plain","text":"2662:43191[{\"ret\":0,\"compress\":true,\"serverTime\":1775055770518,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨГ®б ЎеЈ вң°ЛҷвҘ в’ бҺ’ПҗН“жҒ“;1дҒҮ'MбҒ вҚӣбү©Lб№“аӯҶд“ўвҳ№бҖөдҢҪдҖЈЮҖжӢЎв’ҳЬҗб ЈгЈЎвғӮвҷұЩ бҙЎдҢ зҙҙв”ҲЗҢа Ўе«ҖаҪўвқӮФёдұҢвҢҘж ёаөҘбү’бӨ бҚҲеҸёв’ зӢ—дҢ§е„ЁзЈһYбҲ бӣ®аў Р·вҸҗвҚў$б“ҙжһ Лів»Әж…ҠвҖЈд·ӘвғҚаў°е№үПҰв©Җг‘ұг—”ЕӨгұңг©җИЎеңЈж«ҙдһҖД«а  бә«ж—әв·•Д№б“’Д–еЁұвҶ—вқҪдҷўг•ӣбЈҢе№©зҷҒвҲ°Жҙзӣ–гҷҗдҶ бҹ№гң‘з°ЁаІёжҗұзҡ№б  Д°ж„ҶзҗҫМ uбЁІд„ӘПҳгҘіе‘ҺвҒ©ж°№ГҜжҖ№жұ©ајЈеҺ©Й…аҫҜжү©жҠһа®¬д©©дүЎЮҘжүҲзү„бұ г…Җгұ©дү…Ш°б‘ҲбӘӨдҒ б°°гӮәбҚҚз¶ӮбёҶЛҖеңөд»¬вҖ гүҗЗӨаҘҳгІҠз„әд—’еҳҠз°івЈӮбЈҗаЁҪзҳ‘ж»ҙг»ҶдҒөвғұШЁдүЎв¶Ҡд·ҮбҖҰд№ңв„«гҖ б•’ЬҫеҢҢбёҖВІжЁёЖ•дӯҜв®Һгҷ»еӣҖжҷ¬еҘҖжҒҗб»Ұд–ӮжҖёУҒвҮҶбӨҖе¬ёгқҚжЎҰб”ҝГЁеІ‘е·ібҮҶв…җд…ҡгӨ¶в—ұЭ®зқ…еҳңзҘҲвј¶а ібҒ®з җж·җеҫ©жІ¶з”‘б·ұбӘӮг–Өб…¬б№Ңжё№УӘбҚ„ж—ұа®Јбҗ‘жүҘа®¬гҶ‘жәҪВҗд„үгҸЈгә–вҝҘИЈЩ®бҶ‘з°ҪаЎӘдӯ—гЎЎДҹОЈз—Һж”—аӯ„гӘғбҘҮвқҸжүҳдқҪвҲўзһ”е°«зҢҒдһЎдҶҗгүӣең°вҝҳдҠЈжәәв’Ҫз§„еһңв—”а®ЁдҲ·зқ…Й–зҢҖгҹӮдӣқб—ҺгӢҘг—ҶеӮҢзҺ·зҲқИҝзҹ„еһ°бҖҖвӮҸг— дӨ«зүЁеҒ»дҒ„бһЎдҷЁзЎЎа©Ӯв‘»а¶ҚвўҚг„ҢбЎјз–ўжІҹгҢіжҠ·аәІвҒҠд„ӮгҸ„дҘқаӘҲб„ӮдһәдәўбӘ“зҺів–»з„җе’ңЗұзҪҺЩјвҝ’зҷқа©’в‘ұаЁ«г”ІзҰёвҷЁбҠ‘дӨңжһЈдЈ“гҠ“д©ҳдҺ®дҰўв¶Өзҳ“зҖҪдЎІв·һзҒ“еҝҳвЈ“з©Ёв№Ёдҷ©дҪ’вҒҹа«“аЎ®дҰҢвўңвҪЈжәҶа°Ңе–ЎеҖҖз—Һвұёз¶јвҪӮа °дүЈг ҪбҶңз“•вӨ жІ«зҺ…дҹһб ҳзҪӣе„җбҗҘеқ жҠЎг•ҳ[еҚЈе¬Ҳ дҘҡжҲҜеҡҠвҮүВӯзҮҡдғҠдғЎвӨ”ві¬К°б ҪзӢјгҖӘгҷ¶бҹӨЖ’вүҝдҸұдӨ«дҺЁгұ©вҚ‘вӨҙвҸҗбҢұд§°д”ҝдҶҺМ®д“ жҹӘвҘҠз№°в¬Әе…¶е°ӮдЎ”зҚӘеҘҫв°•д•ўбҮҰаө№гҺҠеөҰОЈбӮҳжӘәбЈәдҚҡНів§әаіҪЙҡж’•ж¬ д»Ҡб¬ҡаЁҝжЈЈв—ҳбӘҰж° жҒҰаҪ«ж©ғвІһб©Ҷж“өб«Ғаі«бӨҶбҹІд’ҷвҸ‘зҘүа№•еҷҲдәүж‘өеғҳзӨ–г»®еңҫв„¬г¬ҖжғҖв»үбӢ“зЎҺд”©гЈҺг—ЈгҰҺб·ҜгЈһжө–в¶Ғв’јеӘЁаҜӘзЈҫгҜ®д•–зқје•®еҹ«дһһеӨ®бҲЁаҜ¬гҒӢвҸ‘вһЎНҹз–Ӣдғ—ПЎНқб–Ӣж‘…зӨ…в“ӣд”Ғг№Җв”Ҳдү‘зң©в•Ңдһ»зұ«д“ұеҝҝз©‘жҒ”Ч‘Л„бҡ‘ГӣЬ‘з№–жё©з„—гў©а№Қжҗ§аөҮжҗ«з—Ұб•үвҰҡбі«жҢ’е©Ҙг”“в»·гҷҢзҖҶЧёзҰ№бӣөб°«жӯҚвңұе„‘ж•№вҢқдҫһбӣҙеҫ»гҝўе·№вӯҶеІһеөӮб•№дң–гҝӣб“…еіҷд“–гі–дҫһбһӣв““б•№зҫғгіөвјңжҙөЫҲвҮөзҳҸб“өжһ„бҹөаі’вјҝзіҘе—үгӣғеҡ•ж»җдҢ•еҫ№гғӯг§Ӯг•ӯвҖҢб«„аҪ•аӯҘа¶¶ЦҲв әжҜҖЫІжҙҪеғ’г·ғжҒҹдІҗдқ§дҒ®дғЈдҗ®д…ҲбЈҰбҠ’вҷӮдҷҘжҒҗМЎаЁ®д„ҳа№ғзқӣжЁ’ГӮаЁұвҗҠб’ӨгҖҙбҚҲзҠҘ5б©ІжҶ¬гӘјб‘җЩҗаөҳзўҮгғҙж¬ӯвЈҫжЎ‘еӮЎбөҢбӨғв’ӮзӘңг‘ҶеўӮаІ„жҷ¬б“Јжғғбҫ§а§‘вҘҶаӘҶжҷҰг“¬аҙҫд“ҢжІҷвҲ«гҰ–дғ«аӘ©дҰ¶бһұв•ӢбҲ¶еҢўбҡҘвҷҢе°өд”әе§ҠжҺ®е®ҫвҳҶе№»жҹңе—®еҳҰвЈңеҹӨЕ·еҜҗбӘӯз «вҜ’гң°ЛҫЖғеә§жҲ еҘ в°ҜеҢ«гЈ—зҸ§МҙЕ„зҹ‘зұЎжҠҢж°ғжұЁжҺ¬вҰҳбңёжӢҲгЁӯзҢЈЭҢеӯҠзҠөдҝӯеҮЁгёӮв“ҳгЈҹд§ӣЪІеқ¶зҶҫбӘ·в№әв…ја®Јд•Ҹе„“бӢ…дҘҘв№©бҳҪП¶еә№вЁҚдөІа ҝвҗ“д•үдҹӣгҸҙжЎӘдҪҲеҶүвҘҸб№ұвҗғдӯ–б“ҢеҜҶаөҶз§…НІг‘ҲеҺ©еӢ„гә•вҒ’дқ„ЗҜеғүгҡ’в«өв…ұУҲдӘҠНҢз»’ж¬ңбө№гҒҹд°ҳб•Ҹз¬ иҖ–зҪЎеҲЎгҮҒбЁўбёўе©ҠКҖгӮЈгӣҸжҚёдЎұpз–°зӨ¬бғҲб¶ҷаЁ»вҶҢдј§д°№дҘҲг¬ўжӢҫбҶ°з‘¶д ¬бЁ•е‘Үз‘ЎбӨӮе·ҖбҘҗд¬Әв©–аіҙдёҙвӣјб—ҙвҡҜдүҚаӨ№ЖүжҮғПҒаўәгҚӨеІүбҶһдЎ еұ•жҰ„гұҗв’”гҚ’еқҚбҷҡгқұгӣӨжӣәбҝ•г©Қв•ҶгғҘеҸӢв«’а®ҖеЈ•бҳ¶б«ҠбҡҠгҖҷжҺұжү“е§§ЩЎеҜҳзҮ’дҙҡзҖ¶г–ҪеҘҜдҢҳеқҢСҖдӢӣдҠҷе©Өжҫ©д”“г‘ҷдҝ§жӢ”вҪӨiд‘ёе’ЁгүЈв®„еӘ•бҙ•бҗ°КёеҒҘбҡ…в••ж–ІЛҶа®§в“¬ж¶ғдіңдіҢвҡ»вұ«б»„жөҲжҚҚвәӣб®·вҹ—вҪ¬гј·б„ӯвҶұг°Јж”өжҚһДөгҜ©ві’гӣ”д–івӣғдғӯеіІд¬Ҷе№ңг§ҷг°ІеҺ…зҡғеҹ–гҸӢбҙқд»Әгҗ„в¶өвҲ»еқҹжҗҖа«Ӣжҝҷж”ӨдЁ“еіҝаўҷбғ„зҘҶбң°жҝӯзҠҡдҖҘзәҢж®ңдӢҙжәҜМҷpе«ҢеҲҖбҒ”аӯ–е°өжҒЈдҗ№г‘ӘвӮ“ШҖвҗЎв”ңЦӘгҲ©вҖөеҢҰгңұвӯЁа©ўвҗ§еҢҖг¶ҮгҮңдұЎУӣз–ҲгӨҒаіҷбңЈвӣ…гӮөа§…ж¬Јеҗўеҗёдҡұд«ӯаұ·аҫӣбңЁжў®бҺ‘аіҶбҪ§ж”Ёг ұв“јдұҘгҘӨаөҠдҹівіүР№вҰҶНүдҘҖд»ҳжҘӣдұҝеӮ©е•ҙв©ёз¶¬вӣӘеҢ¶гӢ№бңҡеңҢзҮ®дҗід•ҮбЈ’гЈўдӣҗг”©ж·•е°«бёҷдҪӣжӯҢбҲ°дҮҠеөәа«§вҹҠв’ҝвө©зҪҙгҮ”г–Ҡд©Өгӯ«аІ”бү·еҳ©жҝҚЙ”дҙ№з…Җд¶•бҮіа·”еҰ»гҰҡг“–г’”д”Ӣгқ•б„ҺаӯҮеҚқжӯҢгЁӘзЁҳбі—жӢ…г•„бӮҘаҪәжІҫбӯ–аЁЎвЈ…еҫЎгөҮдҠ”бҠҜгңҢз”ҢајҺзһ•ж®·еҸҮжөҡбқ–зө„жҡ•ж«ҢдҙүжҢҺд¬°жҰҷз Ғе·ҹбҝӣзҪ„М—в„”дӮ‘зҡҫз«·бәЁвөҠд»Ңб’°бҢ©ж ®а ұбҺҲбҶёеҳӨбўҖКҲвўЁвўЈаўҶвіҷаӨӘзЁ‘г”ҖгҲ¶вҚ¶б№ б‘§дҳҲвӘЈвЈӨаҪ°вӨјвҒҶз…ұеҳ§вҺ”вҪҰд©ЎдҳёеҶ®бўіЫҗгҢ®гҲҲРәеҳҰжҺҢЛҮжұ·вҷҳж–®гў·И¬гң®зҖҫб“ӮзЁ«жҮңвҹЎвӮҸд“қвјЈз„һаҝҶж®ӮаҘәзҳ°гҖўбҚӮвҘҰеҲҲв№јб ҰбЎЁПҖз ӨдӨҢв®Ўбҗ¶дҒ„бҺ…зҚ…Р°з„¬дўҳа ҘжҲівҮӨа¬ аҘөТЎеҠҸдҗҰаЁҰжҳҫгӯҙеҢ§бғ®ЯҒеӨ–зЎӘа»Ұг…”аӨ”г“Ұг„іж—ҳгҒӯзіҺд¬ҘгӮ¬б‘ІдӣҒдӘ¬дӘҰгҸ¬в©ҷд‘ұжҫ№еӘ“ж’өвіҷз‘ҝбҜҠжі”ж¬“д»өеҰҠбІҡеӨ’д№‘гҰ·бҖ—б—ҶзҺҺгёІзў°е„ҚдҜҰгұҰеңӮдӣЎзҘӯдӣҙе”Ӯвҗ©зү©бЁӣаәігӮ§дӯҚеҜәж„ҝеӘ”жҘӯдҲӘвё§бҡ‘ЭҗзҷӮвҰҫдҘәгҫҺдҡүж№”ж•ҳгўЎдәҮвёұжқ°зҲІе„һгҚ„еҰҶдҷҺе¬„зҘ©аұҪдІүб®Қгң®жҜІзіәзҺҘе–„вҮ•а«¬г—ӘЮӘе‘¶а¶Ҡд•¬зіӯЫҪбәіжҫҫв№°е№»бҷҸгҢҠвҘҘгҹқз“ҝг©ҳб“ҹд©ҮбҡңбҸҠгӘқе¬ҡзӢЈв өз§–вәҜб•ҪеһіжҮ…гЁ’б–ҮзҺ·з®–аҫҲЫҡвӣғеҳҲаўӢдҜ·еҺһб»ЎдҲЎа°”ШўвҗұжЁҖг…ҮеҘҙдҮ„бҒҖдўҹеҰһг°©ЖЁдӨңб»ҖајЎдҙӘвҡҙд“Үа©івһҖжқ®бұҖжһңб§ЈбӨ¬в’…еҫ…дҸҒеҺјеўҚжқүаЁ“дҷҘМҢвҢұгӘұдұјб’ҺХҚаҘЈдҒ№еӘҚвөҺг„ёд•өбҳҢеңібӢӢдҺӯбҸҶбҷ бҶӢдҰ”д№Ғгһқг…»дҸӨжӣҶбҺүжЎ©еҒ…зӣҒаӯҳбҒүеӘ•зё…вҙЁз§үе…ҷдҠҶдҰүгЎұбҒ”зӘҺдёҰдҰҰеҢҗбҮүеұҲж®¬Щ”зҮ„г…ӘжЈ–е¶җеҡӮжғ–бғ№е• бөҠжј°вҸ—дҪ”дҷ…еҘ—бЈ…ПӯжҳҮеҡӣаҘ·дӢ”з©Җг…ҡзҜҘЗңв·ҖеҰҳеҢҮд–…з…©еӮөзҺ–е…Қбј„гЎҫзЁҸД…дҸҢбј¬еӘҜеӯҢгқӢгә—г®®аҪӯгҗӮвІӮеҜҺеҗҳе–ӮеҪҪжҰөе«ҚГҶжһҖв«Қб»ҚгҒүЦҳаӯҫе¶җаЈҖгӮҒМғеү д ¬дў–ЕЁСңж ҶгӘ–ЗҲаҪ д ЈдҲўа©Ҳб№ЎзҒўвқҸеҠҹд’өз‘ҖЩ…в…іеҠөиҖҠвҚёбҜЎеҫҪаўҶзҘ°ХҖг°ўжі„б…ҲРәб¬ӯа©Ӣж•ҫг¬ вЎөзүҲдғ¶гӯҖг”Җж©Һбһ”жҸҖв©ҪзӢӢбҡҢФЁвјўвІҸа©–бҘўдҒёаёҮв’ӣаЈ№д»ӯжңӢеҡҠШ»бҡўвңҒг–‘б§»еӘ•вјҖдӮ—гӯҸЧЈзҖҰзғјВҗгҝҪзІҚз”ҫШҡд¶©з°ұЪүжӨҰдіҳЪҸдҘ‘ЩҰд“„еҲҫвӨўзӢЁгөңж§©г„ӣбЈҲгӣўжұ®еғІжҒҳгҸ…еЁ°вө®зҶ·е·ҷдҚҮзҺҺзү¶е¬ўзҫўаӯ…У…аұҢзӮәж¶Ҳе ІвҜ”е…Ҙжј§д ‘аҫ„б°әдЎҜШөаІ”ж•Ўг№“зғјгҠ”Д°зәҶе„өеәңв–ҺаӨҲдҷӨгҠҲзІҫејәе§Өг¬ҖвғҲдў«жӯ„вөҪеҹӮбҒҗжҰ¶Х бқӘеҒ·жҰҪЪұдӨ«бЎӨдҶӮеңҗз ҰжҗёДҗбј©зҖҠвқҡдҡ¶б’ҙдҖүМҰаӯІеәјбҙҙжңҫдқ¬вҝӮбё©Г®вҰ“д‘өгҖҫбўӨФҒд°Јг“«бӨ’бӯӘеҶӮг©ғвҚіЪ§еҶӯдҪҠе”ҙдҡҢвҚҙеҷ…е”»аӨҠеәұжҗҪбҷӘЬјг—Ҙвңәг–“дһ»Э•гңҖгҠҢе«’вјға© зЈҮдқӨдҝёе°ёзһ•б¬җгҚ¬ж§ӯеҺ„еҲңг©ҳВәбғўдЎЁвҗІж•Ӣа¶җв—Үа№ЈзҡҢв„’зҖІгӯңж§¬в’§бЎ—а§ӯдҳ…зҚІз°”дҢіеІӮд©ҙзӘҘЬІжҳҪбҰңв‘”дЎүдёҶв’ӨвқҘаІібёҸа¬ҫзЈІгҫҷз’»г№Ұв“өЯўвІ№бҫүжӯҜдЁҳеІҫжЁҫв’ңдҗёг„өаЈ•зЁҹаӨ”вҠІгө‘вңҸдҘӮжқғгҺқеғ а¶‘ШЎбҒ©И„вҺұвҝҲеҖҘКЁај аҘЁжҗҙдӘЁбқід”°в’—ГҙвўөвӮҢзЁівқідЁӯг”Ҷжў«вҷ“е¬“дҙҺз“»вҖ¬вҮіеҖҙз“ңбӘ”вӮ¬зү„вҚ—вң”вҸІбё§бЈҙЩ«еҹІв…«бһҡбҜ«е©ҳв«…бҘұжҷ¶дўЈж¬ӮгҲјбғҰвҡңЦҫзЈҒбӘңг‘ӯе№үгӨ”ж•җв—ёа»Ҷж„‘зЁҶвғ©вјәеҚўж’ңв‘¬жҲҠвіЎЫ§д¶«дҡ„дәғГЁв§“бӮ¶вәҲвҷ”д•ЁжЁҫжҰ–жқҷдқўОҝаЁІжӨҷд¬іжҸ аӯӘбһёгҜҳж©ібіҘдЈ—е’іеҺұеӨӘвқҺг®ҷв®ұзӮ¬е§…еҺ“жқҚеІ¬е«’вјҳдүҝеіҗдҢӨвҚ°дһ¶аўіжқӯбҫІб„ҙб“ёдҹІдһңжғҲж®Қдӯ•еҲ°ж¶Ғж¬ёа®•еӢұг¶Ҹж¬ЎгӮ бӮҚе„«а »зӘўбҙҘжӨ©дўңдғӯеҪҖд”Ұз®’ЙҚеӣҒж° ж «жҚҙгҮғб®үж ҫдҺ°бһҚзӨҜе®ӣг„Ҫе¶ вһҸбЎӘв§ҢбҺҖг¬ўШ»еӨҰајҚвң з®…еӢјбјҒзҺҢзў…дӢңРҖеј§гҒҝеӨў=гҘҪзҳ¶еӯўбҗҪзӮӨдҗҙвӮҖгіёж…ӮвҘ§еҠЁаӨ вӨҒдЎ¬гӯҲаЁқжЁӘгҖҝжқҺЮ еЈҺгҖ«ж„ҝеҪіг”јв•ІжҒӘбЁӘвҙ№еҫҳжҸ”г„«з“ҢдҠўбӣҒвҺҪжЎҙбўёЦҒгёЈгЎҙбқҠгҺқвүөбәөб•ӯаӯ“аҰӮзәҙжҚәзӨҖгҘҙа«„еқ¶бҰҰг¶ӯаұұзұӯгӨ‘еӯјЫӢеқ…гҸҺбғјж««дҖӨв–»еғҙвңІг”»гӯәеһӘб§ҰбҢ–бқӣд»өзұ°в’јжҷүеҪ“е“ҙаәҢзҗҒаҘңз§ўві’зҶ¶гғӯе°ұжӢ©б”Ёв№ңгұ дј®гң§дүҳвӨҜа¶–жӣ–вӢ«дЁұеҢ–ж‘Ӯгҗұг¶Ід’Із§ӮгӮ“г·§гүӘз§ұвҒҚв•Ңа®ҡзӘҘеҡ“гҷІв“өдЈҘд§ўдүҪжҪ§бҷ…еҡіРҢгӨҰв’ҜеҰіб№»еІҝб”Өг„’жҜҲеҪҫв‘ҫвһ”К№зҡӯз«өең“е…ҝеҪқеӢҺб’Җг°§жҲӘвҚ’бҖЁдЁ¬е°ЈПҲб’Җб’®в°№ЙҝдҙҪеҖӢгұӣе‘ЎгІјж“„жЈҝз«Ўг—ғвә®ж…Қв„ г¬ӘвҖјдӘ¶вӯҫг»ібўҸз«¬б–¬вЈҡбҢ·дҠұдҡӘдӣіСјвҢҸвқЈвІ«б ҝз“Ҡбӣ—б¶ӮвҶҪж№Қд‘ҰгңҷгҷҢдЁЈд—Ұв—ҘдӣҚгқҜаӨігәўдүёж„ӢдқҗвЈәдіҫжӮ¶гҳ‘дҡ»зүјвіҸдҗҰе ӮдӢ°еҠҠжһЁгЈ…еҮҶУ…бҠ®г°қеӢёеғғг’–віҳе¶ёеӣ„в”үг”іжәҺд“·бӘӮвӢ©е«ұж»“бһҜбҷ»ТёгңҷдҜ®вҮЈж’ҝа©Әв‘…еі»еӣҫеІҪд—ҷгҚҢг¬»зғҸбҹ’гҮҲв»әжӘҺв”ҘвұӢбһҪзӣіж ’вҝәаӨ·гІ©вҗ®дҫүдӨ¬бҒөЕ–аӨ гҮігӘҳдҒҪВӨг’ӘбІ—жңһв¶ҖдҒјжҗјдһ°еҮғб‘Ҹг«ЁбҡӢИ¬гҒ¶г’ Р·гӢІдЎҪг“ІзҹІеіӣжӢҢбЈңгҲЈгў№г—ІЪҰзһҗжҪҡв Іж»№в®ңвҗёвҷӘеЈ ж’ёеЎ“жҷӮдҡөг®Ұв©ІПөаҙқдң‘дҒҳдңәбәәХҶгҠӣеұ°жғӢд”©гҚ’ЙөзҡҶг’©в№ӘеҲҶе»ЁзӮҸвЎӘб–әж№ҠжһҰе ізҜ°жіЈз•«вҙҡгӢҪгҺҷг–ҝв¬ӣд«¶д№Ҫб—ӢгҪӘдҺІбҰҠзЎҠдҠ’зўҝеӣ’в”Іг«Әвӣёеі“гңҸЛЁе’»ді„е®ҜЫ»жқҠзҢӣгҷјдһ“гқ…бјёаіҹаё§ж»ја« а®Ҙгҙ“дЎҡв§·еқҚбҝәз°үб”ӮЭӨд Әз ¬бҒҒдЎҲа®ұдҲҰгҪӘд—Қеө б®ЁдқұЬЁа»ҘдҲҜгүҢв§ б°Әж”ҸвӨҗбҰҮг“Із‘ҷв§ІжҸқг ўдўӮвј‘вҜ“дҺҙб—Ҫдҳ гқ·в »дӢҸдӢҰз’ўЙҰеғөбҲ…д’ёе“ӘаЈ°еқҶб«ұвӮўбҫ жӢЁж’Ӣеў“дҸҪвҡ§г«іг©ңеұәгңҫб’ҘН’зҸәаӨҘз”©вҳӮеҷ”ві®б•©вһәгүідӨҝдұ©г…«а¶¶вәҶжӣҙдҚқе№“дҪӯбҷҷеӯӘз¶ІгүҪШ”еЎҮвәҲгӢҮз–ӨзЁ„дқҷаҰ«Р»в«ӘзҺігҢҷдҘҺг§ўXдҰҙе„ ж—ӘеёҙбӢҗаІҝИҰд»әв—ҝбқ®б—әа°…ж©…з®ҙз„ҰаЎ•зӣҙа№ еұІг…ҙб»қеҲҖбҫӢз°ЈВҒИғд¬Ҙб ҒгЁ§жЈІЮ дөҷбҖ¬дӣЈеј©бқіеҒңв…ёТҮЪ·в…¬з‘Өб§ӮиҖҚбЁңзӣІд«Іаӯ–дҚ”б“ҢжЎ‘зұҡбӨүаӨЁз—із—ІдҢҗг”ұвҜІзӯҷеӘ№гЈҹгӨҮе‘ҙжҺңЭҲзӮЈв©ңвғҪдқҰв¬әбҗ°г•ҠСҶгІәбҸҙзҰ«д”ёжӘәвҷһзҰҙжўӣбҒ«в“қз§ӣд№§е ҮбүҪбҲңзҡІжҮ§гҪӯејҮа»¶г—Ұд©ҫЦөбқ§бёӣжҹҪв№ёвҙ–гё¶в«ҝжіҖдҫ—У•аҝІбІ¬в»ЁжүҮдҗұбәҲдәҹв©—дӣҝгғігҹ№гў¶в®өгӣ•ж‘Іж»»её°зӣҠв№ жҪҮбІ»З е”ҙжҺ¶б°ҒбёҒвҷҘг«Үзһ»а¬ҖгЈҚг·Ңж„„д«ҶвЈ…гЎҗз¶ҮжӯҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":5961,"_status":"completed","_startTimestamp":1775055769624549,"_endTimestamp":1775055769630039},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"79","comment":"","_id":794,"_uid":"e078cffe-4cf6-439c-88e7-a4563634ba83","_cid":79,"_ctime":1775055693743,"_sid":23,"_stime":1775055769328,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41062,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:02:49.328Z","time":291,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9aOxa&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"127"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aOxa"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text