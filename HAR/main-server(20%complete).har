la/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Z6Hf"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055430776663,"_endTimestamp":1775055430782292},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:57:12 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1261"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1492,"mimeType":"text/plain","text":"580:43110[{\"ret\":0,\"compress\":true,\"serverTime\":1775055432040,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖҪдҖ¬жҫ бҰ а¶ аЈ бҺ О бҡӘвҒғВҺбҠ бҷұе•әд¬„жҢҒд©°а«Ј@Жҙж©¶е’ўд°ҷбұ°гҲЁе•ҡбҒҳвҡҡжӣҚЗҠгҰҚгўӨдҘЎв®ӘбҖўг…ҠвӢ„а«ҶзІҒвҺ¬бөЁвҺӨж•ҰзӮідӨұвЁ г©«вқ‘6жҢӯжҒҘв©әвІҗДҡб©җв№“0вҳҰХ вҠ жӘЁжҒҗжҢ’зұҲбғҖгҲҘжЁ·дҚҙдқ©б“Ҙа«Қв’җдҪ”жӨ°Ш‘жӢҲг©Ұд’ғе•әе“¬зё°бҫ№гӢөвІўвү—вҢЁдЈҪз“Ҙгү’жӢ“дӮ°е¶ҢбҒ„г ӣаҰҒЛүжӯҘзҷ•еӮңаЎ«б”ҠгҗңаЎіа ҫбӘјеҠҗгёҘб…ўвӮјбЎ§Ь©аЈід…§Сүжўја№§ЧЁгў°бӢҮЩөУөб¶Ңб©јЬҪеҠӢгӯўж®“еҠәз Ҫеқәгҫ„д”ідҪҶг®Һз§“дғідҪўвҳўзҙҡвў¶Ю’б•Ёв‘ұжӣүгӮ©в„Җд’«вҳ№в”ҝбӣҲжӨүвҒ№д—ӢеЈӯв¶Үд—ҠУқвҙ„бӘ•дҙӣеӮ№аЎІжӣ‘д«өЪёдӨҝдң©а©’гӣӢе–івЁҚгҺҷеҶҲзҰјеі—гё©а¬“б»ҡвҺ№аЁқзҠЁзӢҫбҳ§б…үг‘һжҡҪг…ҳгҷүгӣҠзҶӯг…ҹжқӣе«ҳзқҪдә«б„Јв№”гҳ¶бІ©б“№еҰӯб—ӨвҪҒбҲҡбҠӢг«–зЈіж—ідҮ—С—Т©RжҝЎг¶ҫзүҳаұ©дҢ–жЁӢбҖ–бҲӨжҜәбқЁе·ҘгІ’Жңе·Ңзҡ‘вёҶеҺўз¶‘жІ¶еҸ’жһ“дҶҲе—ҠгӨҳв–үд·іж·ӣб№ҙв„…е”ғвЈ©гЎҫЧҶжЈңгөһдҺӮгҪ’бҚўжӯ§гӢҲЕӨдҜәгӨёвҚҶе“Әа«Ҳз®ұеҰ–вЎ«з…ҡбҖёг°–гҮ°зў д§ӘдЈ®гғҰа§ўд—өТҶз»ӯгҰҒб°ігҘІж·Ёд’ г·Әд ҫзүҳд§ҠеҝөЮІбүәзЈұеқҝеҘЎгүҜеҘІе”ӨбЎ‘в‘Ӣд“Ғб©қЭ’е”іХҶжқідһәб№ңд‘Ұе“ в–©гҺЁвӣәе…ҮбҰјгҘ®б¬ҒжҘҹХІзҰІжўұзҚ¬дҹ©жӢөбӯұзҘ’еҰ–з©ҢбҜ¶дӣІзӯ’вӣ§е«‘в©»е¬әе»«еҘ©еҚҸдӣ№гҘ…вқ®в»№в—®г•ҠгўүеҚӢвӣ№дү”жҳүб« жһҷд©–ж’№б•ҳз§ўгҸёжЎҫд“ҷд ҢеҜҫзЎһзӘұеҖ жҶ”а·ЎдҖ«дҖЈе¶җ-гҶЎжұӣзҳүзөҗЯқг”ұд•Ўв ұХҖYд«ҢзёЈа»үаі¬бҶЎгӮөвҰ°з№•вў°гұ„дҲӮдҠ’бЎ“з«јвӣ©зҠүв¬Үв©ІбҚҸе”¬бҙҰгҒ¬б·үе•ҪвӣҶзғ…вўҰгғ¬ОҲз‘»вҖӨгӨ°бӣҢдҮ•Зҡе”ҪЯҘжҸҖ(вӘЎаұІеў–г«ҚеҫЎбҒја«ҙжҒһа©ўд‘¬Ц”г«°аҘ°бҙҒбҷ”д•ҲбҢүгҗӨбө”дҘӣб„®вІҳдһҡж»”ЭўзӘЈеҗәзҫҶаі¶дӘ ЕҠдӣӘ\\\"еқ аө“в–үжөҮв·үеӨүПҰФ—ЯӣдҫұЯЎвҫҘб·Ӣд¬°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1261,"_status":"completed","_startTimestamp":1775055431146145,"_endTimestamp":1775055431150167},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"66","comment":"","_id":439,"_uid":"5a024f9f-a64f-4802-9c08-9fc9410d7aee","_cid":66,"_ctime":1775055331875,"_sid":44,"_stime":1775055430776,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39906,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:57:10.286Z","time":293,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9Z69x&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"189"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Z69x"},{"name":"sid","value":"ZIFlnwc_Kqme9