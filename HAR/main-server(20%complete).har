·дЁҷв•ҫеҠЈз«”С•г ·вңҲбӯІеҫөаҙёдҡҲвөӢвҺҠеҷӣвәҳз¶Үд¬ҲаӯҜвӘөбөҹвЈўдң”жЁ»дҚЁжҙәжҚӘвЈ—дӯҙж•№гҢ®в¶•в–ҡжҲүеіӢе©әеқ»еЎҷеңәжәӣжәҮеқ–е»¶еәёеӯҗЫ»з®ҺжҜёдӮқвҗөг«”еҡҳжұҘа Ӯж’ӣМҶеҙ…жғӨжӮ°бҜҡжўЈб’…бӘ«ж–ҳв«ӣбіӮж‘Ӯж ҙаӘӨаЁ·жҮ жёҡб’җб¬ҡе’әгҝҶг“Җејҙд¬қбӘӨв””б®ҙаў„еҘҜжҒҙеҮӯаӯ¬еҗҙзҢҶгёҡз‘јгҪӨб“ҳгұҸбўҰбұ¶бӢҹа¶ҙг©•г»Ңгҳ“бұёбЈ»бҜӯд’ҰбҗҮж–ёж…¬з»Ҝвөӯаё…бғ…бҰ«г«¬Цӯа»ҜзғқбӮҡбҡЎжІ„з“‘а ҡзҮ«б’Ҷз–әгјәбҲ„гӘӯеҮҘжӮҳгІЎгё„жҠіг¬Ҹд·ӨеӮҡвҢҗз¶ҺжҺ«б®Һд¶№жҢ·з§ҙз‘ҚбҺЈб©Ҹдҗ‘г’ҚаӘӘе“ҸеҠўа№ҙжӘ§гүҪд«Һгҗ¶ж«қгҪҙв“ҰеҸҮз¶¶е“№дә®е«‘жҲ‘еҘ—вҡұеё•гҜЎеұ–зңҷеІҘбӯҫвҝЁжӮ„вҰҶж’”в‘ўдІғОӮж‘һдү°г©ҒдҰұа°ҙа«ІдҰүаҜғбүӣдӯұ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1512,"_status":"completed","_startTimestamp":1775055461761854,"_endTimestamp":1775055461767105},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"66","comment":"","_id":459,"_uid":"0a12672f-4288-40bd-9865-1c896d91f1ec","_cid":66,"_ctime":1775055331875,"_sid":53,"_stime":1775055459936,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39906,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:57:39.593Z","time":306,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9ZDJy&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"3"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9ZDJy"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAA