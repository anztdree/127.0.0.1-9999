rriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:10:21.493Z","time":293,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9c7Kk&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9c7Kk"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056221493997,"_endTimestamp":1775056221501970},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:10:22 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"5910"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":7509,"mimeType":"text/plain","text":"2643:43330[{\"ret\":0,\"compress\":true,\"serverTime\":1775056222354,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨГ®б ЎеЈ вң°ЛҷвҘ в’ бҺ’ПҗН“жҒ“;1дҒҮ'MбҒ вҚӣбү©Lб№“аӯҶд“ўвҳ№бҖөдҢҪдҖЈЮҖжӢЎв’ҳЬҗб ЈгЈЎвғӮвҷұЩ бҙЎдҢ зҙҙв”ҲЗҢа Ўе«ҖаҪўвқӮФёдұҢвҢҘж ёж“ҷеү’з№ҜгӮІЗӘжј¬аҪӨбҲӮз° зүЁ{бұӮ0вә®жӮӯР аЈҳдҰҫ+вӣӣб–°е’ Э‘б’Ўб©ӮвҶҳеҲҜаіҲдғұвЈјж ҘаӨҗзӨҲжҖЁНјЮівӨҪдҖӨбҷҖВҷжҳ·г“–жЁӨ3бә„ИҚг‘ӮдҶҸаҝ»аІӨжӘ–Ж‘гІіжұўд‘ҖНүж¶ҢжІҒМ вҫўзҜҜжҒЈд’Әвў»гҚ©дҖ аўҰаө—в„җб  ЛүеҲҙаЎ°б·©д¬ҪвҶ’б…Ҙжҗ‘вҰҒб№Ӣе„‘ЙұаҘЈбҖёаӘ‘б‘ҜжҒ…вҡ…бұ¬б…ӯзІһЩЈеҶ¬б„ЁгӮЎв…Ўе‘„ИЎжҒҖдӨЈбҗјгӨ•д‘·д°ӘдҒҪаӯӣбў ГЁжғӣГҲз„җб—Өг”¶жһ¶бҳҗгӢӮд’ӮжҒҲвҜ·жҮӣвўәдҙӘвӘЈвҲёб„©Е”б–ҶжҷҜзҷҳзўӨг« sвҗјаөҪеҹ—дҖўз§ҹеҖҘжЎҚдј•еғјгҡәгә№Ж„дҶ жӮӣФұд– гҒўдҠ д·ғд…¬гӯ°еҜҒаІ„гёҜаўӯаә№Е’аҰӨеҲғдқ—дәЁг©§гҫӮвәҮз®ҢзқҗдӮ№Й§гҘҺдҡ¶аўһа§—дҪіжү§г’үжәҮа©ҫжәҶзғЁвҷұбҫҸаӘЁз–һб өжҢёеұ§г–јб¶Өг©‘зӯұб°·вүЎа№Һб„Ӯг©ҒбҫҚв№ӣКҡжұҲбҶҺЩ—ГҜеӨүдҡқеӘібҫ©жү„е‘©б№ҡеұ«ж„Ҙжғҫвё¬д’•жүҸзһЎжҲӯз’•вүҲаёҙб№…гңјШЎдҲ°аўһжңұЙҖдүје°®б‘ұЮұгқ¬бў№гҷҙзӮ–зҷЈаҝҖдҡңеұӢзһқзұҮзҺҚг ¬дҷҚж® еқҚгӮ“гҷғаўһзҹқвўҡа§ұбўҹЫўв®ҪаҜҚаІһг’Ңб—Ӣа·ңдҒҪаӨҢбҰ№гҲҢжүҫгӮІд–°зҶІЛҲзһіжҸ„дӨ віҲаҰ„ВҶдІјгӘ•зқізҖ®дҳҷг ¬з”ўгҺ¶з‘ұзӯӮд‘ұг–°дҘізҒһж”ІвұҫгҒҚзҡҷдәізЎЎжҺІж№Ұд·Қд©Ҝдә’жӘҹд»Ҫб©Јз““бҜ‘дұіжҷҘзҳіз¬ұд¬ӘжҷЁЕЈбҡҳаҰ«г–ҙаЎӘгҒұаҘ«діҲаә„бӮҺИұХІвҜ«ж¶Ҝзҳіе“‘вӨЎаЁЈаӘ“з•¶зҚ…гјҜж’”бёҘЙ•жЎҹбӢӯдң Ю”ж ¶еҙ 2бӯёд„•ж• г•ҖвҮ”гқ°гҘ»жҘӘдәҘбҰ еҲҰЛңж®¬mвӢҙТ г°өбғ ЯҫеҷЁзҳҰв…Җд„©вҲҖзӨІвҢЁбҙҪдҸҗдӨ жҶҗж„ҰДӘбҢҪд…қеҶЎгҠӘа№«дӨ’г№¬еЁјжЈҡвЎӨз…Ів¬•жӮһг–ҠгүЎгӢҠз•ҰfвҘ·в°ҠгғәдӢәвө№вЎәв“ҪНәг’һж¬ зӣ„бҜҡаЁіжҜЈЧ—ж°ҡж° ж„ҰвқҘжЈғеІ’бӯҰеЈҫб¬®в“Ҙб§ҶеҒҗдӣ‘е„»а®Қж…ҷд”ұзўіжӣ…дӯӢг«–зӣ°е–Һж©¶д—өеҒ”бҳ…б·«дӢқПЁзўҫг§өгӘЎвӮӮеңҖзЈүжһөз…ӣзӘЎзҝҰбҳЎжҒ”Т…ж“’ЭЎDд•һбҹҰвҮһаҝ«з§ұгұӢе°ҶдәҒв”¶Ыҳбҹұгөҳд§Өд” жҢўеҚ‘ві№бқҲе©ҷжҫ•жҹ«зөӣжӣӣв’Ҝв•үбөҺвҫ©бҺҺд—Һвқ—вң»зөҮвҫӣг¶ҸбӘ№е««ж»ӣвӯҳж”Ҳг·Ҙб“ҷдӯҠб¶“бәӢжҷ№гҪҡбёҘдӯҷбұүе”•бҹҮжғҒзЎҮгЈ’жҳҮгҰ¶еўЎУңж¶Ӣе“ӣб•ҷеҸ¶еҗөж«ҹеҖӢбӢҮб»ӣв„ІгөөвқҶеҡ…е°ҫеӣ«бЁқж‘Ғгӣқеҡ•дҲ»еһңЦӘг“ӯгҮӮгңҝдҮ”дӢӯдўһжӯҠв—ӮдғҚзҗӯг’Қв·ңж”Қж„ұв„Ҳж„ҫвҲҖз¶·в„ҲвүӨе„ҡаҝЎеқЁвЎ©аЈ еіҚжЈ№в–ЈаЎ–вҷҖбҝҚж“ңдҸҙгҲ°зӮІе‘ІдҶӘЕӘвЈҖвҚ—гҶҰж¬Ұе‘ҫдә¬а¬©аҙҢаәёзҒҰб©әгҷ”бҖ»вҮЎзІҢаұҺд‘¬в“§МқбҠәв§•бўҳаўғбғ’гҡӮбЈ§аіүдӢӯдҰҝдҚұО»бӘІвҚ«бҶ”жҷҚзҖҙдұӢвұӮжІ„жӢӨе‘…еЈ©бғҖзӢ«г——е№ІбқӮд©ҲзӣІжҮҪв»ів¶ҮдҗЈжҹҶгҲ—гӣҖб®Ғбү–ж“ҶжәЈж”…дҸ°жӢ§еЎҠзҠӘгЈ»бӨіе¬§гӣӮвһ…еүҺжҘғж»ҝеҙҲдүҘд¬ҙд—‘Р…е¬Әбҹ–в©үзіҰаёјг©әеө»дҷҳз’ЈгЈҮгәІХҳзҶҺГҶд№ҡвӮӮз…ҲеҰ¬ві’дұЎг®№hбұҖд§°з®ҸжҖ®в•ҪвүҲвҶӢбҷҳбӯӮвһ„зҰұв’ҰжҚ©зғӢвІҡбғёеҘқбҚІеқ„а№үд‘·а¶¬зқӣаӨ–зҚҖзҮҘж”ғдҚ„ГҮд–ҷКһвӨ”з°ӨвҪ•з’№жҳҢа«ӢжҶҚжҜЁеҗҖа§ӢаІ«в¬Ҹг„Әз–“з Ҡд°ӮбӘҮж’қЭҡг“ҸдІӢдЎўжҸҝвҗ–гҪўУәжҫ®бӣўвІЎвҲўж…ӨЙЎзҒ„дҺЁгҗғзҫҢб„ёдӨӨдӮӣдҸЎдқ§дҶҙШЎз іжҜҗајідӮӨа°ҡжҗёгў¶бәўбҠіПЎе¬§гў’еӢЈв„ӯеҫӮаҜҙеҲҙг“Ҳж–“дңіаіҚбӘ§жҰӘбҖіМЁз©ўЛҘбҪўжҶЎдҪЈвҶҝа«©гҪ’бҰҝЯ¶вӯ’аў°Ь‘еҺ¶а«јжҒ„е©§в–әд®ЎЦӨг¬·вЈ•бЎҮдҘҫдҰҒвӢҠбұ„вө–зӨӮбһ“зққеЈӢбӨівӯјЮүа·«вӘ“бҹіжҷүж•ҢгҮҡзҖ жӣӣбғ«зў°Ф№ді®бЁҗвҮғв…ӣвүңгұ§гҘІеӢөгҙұжӨ№д°ўгҫҠеӮЎжЁқаҪӨгҒјеҫғвүҝб«ӨеқҜе‘һгҹүжғҙжҰ…дҪҠж·»в”ҷеҸҶе©Ҫа§¬ж”ӮжёўдөӘа¶ІвәҒвҷҪз®ўеҲІдЎ—жҖҝб“ҙз¶–зқҙеӮӯОҘаҙұв§ҠЬ®б®ӮеҜҶзҜҚв§…б„“еҡ«в¬ЁаЁҲеҘібӢ’гҚқеӨҶвҶ…еҷІжҳөЗҢбўӯзҺөвӮіеҰҚвҹ’Я зүңФҳв№јжЎ®е”Һбіҷе‘…ајЈг§Ӣв»•зқ•зІ…еЁ…а°ҫГ•вҳҙдЎҺЪјб ӨеҖҰаЎҒбҪ’дў°а© зҗ¶дҸІај§зҒӨе Җвҗ®зҒҝвҚүгғүИЎдҘ”д”¬еӮҖеҳ©дЁјаәҰжҺ©д—„ж‘ЈдңӨдҲӯаҰ¶бһ‘б•°дҙ«бҚҡа§ҶгқҘв•”е °б“Әд°№в®ҘвҮӢбқ“ЪҖзҢ–гҳІејҝдІӮбҜ¬б§Ёв°ҷг‘ҙбӯҳеқ«вө«Сҗжҫ№гүӢб–ӯв»Ӯв…•жӢўг·ӨжЈҡе¬©б–Ҹб№°б—өе°¬е§Һжҝәаө„ЖӯгҚ’дө№дңҖбҺҲвҒӢвё©дҙ¶з„ұбЁӮж’§в–җж•Ҳеөҝб§ҡд®ӘжӨҗдІ–вўёбү‘б‘әвҮғбіҲз«–еҗІгӨүд–ҸжҷҠжәӯд“ҝдӨөжҡәв•ҢеҸ“гІҡзҺқаӯҙе¶җв–қб®ҺеӯҢж№ҘеӨҙаҘ¬жҷӮдәҶбҠҪгҳ©зҺҺаҰӘзҢіжқҒбҗҷвҮ’д•өе«ӣв®®з®•вЁ‘е§Ңа»ҰеҳҪбёҠб· гҝ’гіҺгҜҸеҡ•аә•з©ҺзҢҠгҪөжўҷзјҺж©ңд„ңеӮҪВҒаёіеӣ’бҘ’жҒ ЩҹдҠ’бҖЎаЎұМұвҷ®бғһвҫҗеҲәв„„аҰҶж‘јдҹҳвә®вўөаұ г”ҪзүҸаЁ—бҷӢвӮ”бқҘа©һдҖёвҶўбўғаі‘бҢәгҲҲб”·бЁәжҠҢгЎ‘жІӣв‘ҳЦӘгӨҮаё¬еңҰз„ҺаЈҒгЁіжғңгҜЎвҒҜдқҪвјЈз„һШӨз®¬а§ӘзЁ°гҖјбүӮб…ҰжҮҶеұ¶вё®жҖәаўҳзҜҹгғҶаҘЈдҗЎж ўдҲ¶ж ёС°зҳ®б„ҢПЎг„ӢСҶжҗ—еҘҮбүҖзҝ°а© гҠқбӮҢд—ҝе„ұгҝға°җвёәбқЁа»ҒзҷҠбӢӘа§ҰеЁұв–җгұӯе“җа ҚаәөеЎӘа¶ЎзңҜвҮ®вӨЁвұһд’®её¬д‘ҝб¬ҲеҒ·гҡҗеӣЁдүібҮ©вҘ№жҘҪбҷ…е§“еӣҫд”өеіҳе–ҹМҫб«ҸзҠібҫғж¶үжҸ•вҸ§бҰЎб ғвҒӯд·ҚвӘҘзЎ»еёҰбӯіжҷӣбҚңз ҡг·үвҷ“д·¶вқҗжҠҡеӮ‘з«°з •вөҳаөҡг…ҰКөжһІвЈӯгҺұгӮ№жҡ’еӨҢз‘’ж“өгҺ¶вүіж—®жқӣеқ—зЁҠвӘӣзҺ¶зҜҶзҒӘгӢ¶жҘұвЁҶзә–б ӢгІӣЛ¶в©№гЎҝгҷЁеӨҚгЁҶв©«жҹ»г•©бһўд®…дҠЁзҳҸЩәд©ҢеҘҷз¬ӣд®·бҷ¬зҹ°вҺҺвЈҸеқҰжһәдҗӘж °гЁҖжҹўв“Әа©ҖаЁізҰӨЕҖж‘җдғҪвҠЎдҒұКҝжҸЈжҒҗеҡ®зғ–в’Ҙб¬Ҫд•ҺбІҚз№ҹвӢңаЎҒЪ“з‘ҡд®«вӮңбҘ»жҶҖвғөбҪЎдөңг„ҡгәҒв‘һжҶјб«®жўҳзҶҳвҢ®бҚҖдһқзҒөжҶҜбҒғжҫ…еІҮдңқвҢҸб„©в©Ҳе«үеӢҖбІ•зҮҲеЈёз„Ҙб°№жҗҺеә‘а®¬еұ¶бҘҷаіӯа«Ҹбһ…вЁҫаҘҪв«Јв°ӯг¬©аҝ„вң…бҚҶбЈ©е©№е¬ҶаЎҪгӯ¶еҒҢдӮЁгқӢг… г¶©дЎҘжҲ¬бҶҒЬ©д»ҜбҺҡб °в»ҙвІҸз…·вҜҲдӨ©бұҰдҲҰШ‘аҰўе©ўвҢ гӮӣд…„гӘҚбқөМ№еҚ„гӘҒгҚ°зЁ·бұқеҷ«гҲұв¬Ёв„ҖаәӮаёўжЈҷеҸӯеҢӢгүҜбў№дҜҳзјғжёӨеҠҮдҠЈд№ЈдјұдЁҮеҠҷШүбёёеӘ·е№ҚжҳҒеҘҠз «б•ҚгҳҺбө¬еӯ—дҡ”жёҫгҰҷжЈҝДқеқҺжјөжЈҹбҲ„4жӯңРҺдҫЁг°¬бЎ©ГЁЬ”г’ӨдҖҫДҲ5еі дў·бҶЁб јгҖ ж‘¬жҘҸе үвҝүдһғжҜҸд°”е°ғзғҮв°һдўјаўҺЩІг©ҹеІјбё®гҪІвӯідҶөе ҶвЈҶгӯҒеҳ¬ж”ҖжҡҮзҘ“ОҪзқҺзҫҺгўЁе®…зўҖбқһг„ұд‘ҪжҸҰбң°ХӘеҘӨе§ҒГҷв«җгӣөжӘҸг•„ЬҘбөјдҷүеқҘдў°гҖҗд—Ӯгғ“ЮәеӘўеҷҠеҺүбӨҲеңЁв°ёеӨ»г®ӣХ¬гӣҲжҺ–У’бұӨвЁІбүұЪҰеұЈгј„аҫҹгӯЁвғўе©«бғІзҶ§д…ҲгҡҺбӮ’д®№ЬӮв№ҘвҰүгҚһбғ•вјҫзҺ„з¬ҲвөқвӮұдј еҜ…бҮ”бҳәжөӢЭҘд“қв·ҶеӨҷдҰ°гӮҗаёІдӯ¶еғҳг„ҳдё…з„ҢеӘҳг”ҳаҜҠгҪ«дҗҳгғҚД¶г–ҳзў аҪ ШЎаЈҲв®Ҫб”ЁзқӨеҒ‘В еұ д Ёзұ…ДЁбІңбҪЈбҒңОЁбҲ”вӨҸЖ…зӨ„в‘©аҪҜдЈӯзӯҠаҙҙеғЁвққзўідӨқвҙҫг‘Әг«ҙгҢқз”ҝОқз©Ғе–Ҙдҙұж…әгүҙв·ӮбёўзҪ®д–“еЎӨгўҮзҪәзҖӘеӮӮдҢӮб•ҷаҰҘЕҘбҚ„е…җеғһбҡӯбҳӢбқ…вӯӢбҢўв¬ҖеӨқа®Ҡд–Ӯг·Ҡд“’ЭёдғҪаӯ„гң№д‘јвәӮб°өз…ғдқ»дҺ„г»ҘдёҜв §а§јвҮ§з” жўҮбқ”ЪҸаҫҳзӢңгғ¬зіўдј¬д«ҰдҷўвҲҒзӨҷЦңгҘ•бҲҮзЈӘд¬№бҷқдӮ№еғ°вһҲвқ“ж·©УҮдҳёгІҷдҳ»УҘдӘҫбёІг·ҶжҙҘз„·еҠ„гҳІд“’з©ҢдӢқв»Ёзғ¶бғ·дІ•гўҫШҰзўҳвјІд’ҙвӨғеҰІвј…д–ӮбҢӯжҘ•е•ЎзЁҰдҠ–В д°ҳжқӨеҒ„З№бөЎгҷ¬ХңГҜд”Ҙд„ҺжҖёЖҹrбғўзҙ¬г§ӣб„©жҠ¶Щ©в”һдһңв”»б’Ів’•б№ігӘёе“ҢгҒҝдӯ°гӮҚе“әгҘҗдІёдҙҝгјҪв’ҝдЁқзӘұжӨ–в®”гЈІд№«дҚёзӯҰвЎҙеҡёВ»вң в»івҖұбЈ·гЈҺг§ІеҖ·бқ…гүӢеҘҪвһӘеңӯгҺҡгңўе¬ҲгҳӯдҳҰвҹ•дҶівғіг°Ңгәғд°·жҳҘбӘӣа®ЈгҶ°зһҳжһҡе…’жҮҰзңҙж—јвҪ¬ајҪдіүШҶгҚ“жјұдөҜдһҜЙқбҢәдӘҹд“§діІе–ҫб№Өз©”дҸӯвӮ·еӮҝб«¶бЁІж¶ІгӮҙбҮўвқүбҳёвЁҫжҡөб«үгҶҚвҗЎж”–дў’вҺҘд“ҪдҜ…е—ўгҺҪб¶‘еҲІв»«зҰҖеі®з©ңе“ҚжӮЎвӯҠеӯҹбӣҚдҡҜвӯҰе¬Ҙб§Қб„ӯаЎёд…’а©ғвһҪж®”дҲ•дқҒзӨ®г®’Мӯд«Ғж°ӯвЎіж—¶бҠҢвҙҰжЎ®дҺ°аәҢгӨ е®ҒдҠқР”в®…б №дҺһеҰҖе®…б‘ҪеӨҡбҫҚдңЁгӯҘеҚјбңҒОҲз ҘдҚңаёҖбј§гҒӣе ўбҲҚз‘ ФғдҶөеҲ°жҫӢРӨв…ӮРқв»®г•ЈЗҒајЎИўЖҳгўёбҗјгҹҺеӮҲгҜҪбҫ зІҫжҒЎЗ’г‘ғб’¬д«Ўв“ҫгӨҘз°ҰеҪЎвҗҙвЁ“е°Қб“Ҫз¬іеё’б”ҫЛҠд“ҙвЁ¬зҫөгҪ•вӣҝеҚівҒёж•“еҳҠвғіеҒ¶жҳҫд’әвЎҪЦ бЈўбЎ¶г¬ЈдӢўдӢӮбӢәг№ңе’ҸжұҮвң®гҷјгҖ»бІҳЮӮб„ўб«ӮвӢјбӣҡвӮӘе ұжҚ’бӣұв¶ўжҶ№з…ҹвҷұгЎЁе¬івӢҪдӣ°гһЈеұ«жҠһбҲјвҰӘвҶ¶гқӮУ‘гҘӯе°ұжҲҙбҲҗвһ©а°ҝж”ҙа®үеҚ“жҰёеӢҚбҒЁв»’гҮҒд№•б‘Ҷдғ’жүҙвІ©бҷҲв»ЁеҲҢв№•Ъқв№ңвӮёжҙӮжӯүв©әеәҺбёҫг“¶дЈўгӮ°жө–жҡҘд—•б¶ёд“®жҳ–гҸ“вўәеӨұзҺ№вұҖвҺҪеәҢвһ®вқҚзўёжҪ©жҹҳвә’жёҢеЁ д—ҺдЎғжҡәеІёЗЈе ұеҺ©бҖҫОІб …аЁЈеІұзӨёб© гқ§Ю–бҲЁВқд–®еҪӯеӣ©ФӨаҫІд–қе—®в«јВҮб”ҸбҗІеё’бқјж–ҹжҳіЬӢдҒ·гј¶г©қвҒұжҙӮз«®вӨ“еёӘжҡёдӢ«вң¬гҸҷвҢҫдҢ‘д‘ҡвё‘вғІб°·в—Җв·іСҫе–Ҡв—Јвҹ”г«ҺвҠ«аҰғгӣӨеҗјбҠғгЁҢгӮўЬёжҠ¬зҚ‘гҺўе“¶жҢҹгҶҡеЎҷг»ҚжӢҒЭ“в©»гӘҚзҷ–г–ҶвҚҷбі°ајҘгҗ№аҫ№бҡҖбӣ®з„Өдҗ°жЎўбҡҰжӢ©гўӯзҲҢзұҚУ«гғөз–ҪзҺ”з«¶еҚ«в¶іж¶–жңүв„із©Ҫг„„в”Ӣг“«з«№д”ҶеҚҳг“әа№Ҫзғ“гӣ®в§«гӣҫв”ӣг–әдңӮвҖӨе¬һВҪбј”вҒӢв”қЕҲбҫҖзІөзӨ»еҖёб¬үжҲ«зё№=аі