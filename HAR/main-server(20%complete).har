537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bSJe"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056045301772,"_endTimestamp":1775056045309400},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:07:26 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1307"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1548,"mimeType":"text/plain","text":"599:43272[{\"ret\":0,\"compress\":true,\"serverTime\":1775056046974,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖҪдҖ¬жҫ бҰ а¶ аЈ бҺ О бҡӘвҒғВҺбҠ бҷұе•әд¬„жҢҒд©°а«Ј@Жҙж©¶е’ўд°ҷбұ°гҲЁеӢіб®ІжҷҪжңңеҳҠжөұГҗдҘ·МЎа©ұд°Ғж—ЈдҲӘе–ңвҸүеҺ©дӘӯж…ҮбүӮеҗ з’¶дәӮMдҳ»дӮӘе“”еӨҖИ”г’ҖеІҶ@д°¬аӘ д”ўе”ұдӮҒЧ…зЎ°г№ҝвҗЈе‘ҸУҠаәІвӨӘаЈўдӯҷТ®г“ У Ш‘жӢүеӘҰд‘ғе–Ҡд“ҙзёёв—үгҒәд«Ңд„¶бҜЈСҘжј„жі–жЈ“дЎідЈһе»ҫвҫҮаҘ«еӣўЙ¶зҝ‘бҢЁв¬јаӯӯзў¬еӘҹд„©гҶјвҘЎд¬ҸК№бғұдҙ…бҶўаЎүаӨҪФҒдү”в„үд–ја©јв…Ҝд”Җзүјв№ўв’Ўж•јгіүвҗӨг’ҪеІҮгӯӮж¬«дёізҜЎвЁ»дҰҝеҰӮе“Ҹе¶ҪеЁңгіҲвҙҮеғІбӮұв–өвӣЈжҙ®г•Ёд•Әзіөб”ёбҹјдЈібҘід—ӢбҙҒаәёв”ӢвӘӮвҘ¶б–іЪӘв“ідүҢНҷв’Қгҷіа®•дқёз•ғаӯіа№ӘгҠёжқҘд¶»гқҪеіҠдҫҚб«ӯзҚ…еҜ°бҳӣзҒҘеЎёаҪ’зіҘеҗјзҷ«гҮҫгҜ»бҡҢзӣҘв•ҡб•»в«ЁзҶҒд•ӘзЁ©б№қе Ҷз««гҙҖг ҮдңҢз©ёеҰ»зҰ«в»—ж’·гўІзҢідЎ©дӮ°ЙӨзҷҰз·ӘгҜһж°ҰдҲүвүЎаІҮгјёжІҡж№ҶР„зҡҷзҜҮзӮ©аӯ”еҙҒеҠ–зғ’жәңж—үзёЁФҜе–Јжү«вІҸг·Ұз”ңжұҫдқјвӨүв–үз¶ЈжЁ”дһөе„…дҙ…вӘҷгұҶд—ҚзҰ”бәЈгғәП¬гҮ¶вӨЎвҚЁг…Ұд§һвҙҰгҒҢжҪ·аӘ®жҷҘвҰҲдһ№зҸңдұ“зҸ–в‘°аӨ–з§Ҙз©Іб—ЈдҜҺгЈҘа¬Ӯб·ўз°ҺзЎўе¬Һб°ӨзҜўзҸ¬дҡІзү®дўЎзЎ¶д©¶з©°ж©’г©Ҡд¬ҡП«д§Ід§Јд“®жҷҠд ұа№‘г®©ХҰдӘұе“Әжў©а№әбЎҡдҘҷвқ©ХңзҢұдіЎжЁҶП еЎҡж©ҷвӣұаҜұгҒ‘ж•үдҡүЫ©Уҫз…ҚеӨҠа»©вҰ–б»ҜеҜ–е№Ӯз¬®ЭҷЪүа§ҪеҰ©бҪҚв’¬аӨЈв”Ҷе»»вңңзҘ”б–ҺЭ’д—№вҚҲб’№гӯңж”ҘдӯҠб•ҫе—¶жҡүгҜ§вЎһд«©зҜҫзқ…Сҙдҝ«з«ҙзӘ М«еӮҺШўвё ајӢдҖ г–¬ЮҖВ—вҳүдҒҮзӣҲдҷҠХ д‘ү!жӣҚв «з’ҪвўҶгӮ¬ЦЎгҳҢеҖҜг•ҙеӢ аӨјгәҚжҶ§а№ҘбІӢб—¬бӘЈд©°вЈўбЎҘбіғв«„г„ҲбҰўгҒЈгҡҸбҗ«г№ІвөІе«¶бҳӢгҢҠа«ҫг¬Ӯбұ…г«ҶзҖӯвўҰгғ¬аҙӢгҗ§вҖӨгӨ°з»ҢдҲӯж§ҚеңқвҝҘжҸҖ(вӘЎа°Ұеҗ”дҡЈеҫЎбҒјTжҒһа©ўд‘¬аЁҜЫ°Ж”жҰӢеқәДӨдҰғС‘вҮ–вҚөЧ•ж¬»аЈҖб‘·е‘’вҲҡУЈгјҳа®өвӘҶЯҙбӘ ЕҶдҮ°аҘ uж Ҫв’үдөӢв„»е•ҮбөҖгіҝбҘҲе„ҺГ©з ҝзң¶б¶’жҲ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1307,"_status":"completed","_startTimestamp":1775056046080691,"_endTimestamp":1775056046087312},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1100,"_uid":"8b79d17c-b59c-4a5a-bf60-92c6191e41ab","_cid":92,"_ctime":1775055887626,"_sid":60,"_stime":1775056045301,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:07:24.903Z","time":292,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bSDZ&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"189"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bSDZ"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"185:42271[\"handler.proc