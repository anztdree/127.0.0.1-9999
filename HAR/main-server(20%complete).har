r","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:17 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3418"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":4271,"mimeType":"text/plain","text":"1531:43186[{\"ret\":0,\"compress\":true,\"serverTime\":1775055737820,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨГ®бЈ ЛғаӨЎгҷҳдҖөж•ӘЕ„В»д ҪдҖ№дј гҢ б¬ бҶ вң Ь вҙЁдҒҰбқ„бӨ вҙқзүҙж‘ҜеҢібҖөдҢ«дҖЈаҪЁдӘұв’ҳдң“б ЈгЈЎвғӮвҷұб№ бҙұзҚҗз©ӯзҖЈг• 6ЮӮгңҝб№ҰМ КӮзҖ©г“„еІҡе•‘б“’д©ӘбұғбҗұвҜЁТ°дЎўе№ўд  бҹ»РІа¬¬вҲғж—ҙдҲІаҘ„д’ұдЎҝд«ҚгҳҒдҰ©бӮҙгүұе«„бәҙвӨІвү…аӘөбһҙдҶўвЈҒб№Өа«—вЈ¬вәҢеҮҢв«ӢзҰӮгүЁдўёбқҫЙ·гҜҘбһІеЁҒз•Ҷб—“вӘ°ЧҙдӨҹдәөж©үа«үз””бүәв№ҺбҜҫеҜҠвӮҳе’ҳгҪўвһұв»ів•ҫг„ЈаұӮбҶұе‘ёж”’Т©з•ұТҳвә№еһұбӢұа°ЁжҶЎТҡгІөбҲәдЁ в»ҺЕЎгҶҖбҗўа ҮдЁ„вў©дғҖеү ^е”ЎдҶҒзҒ°а¶ёвҚўКҒбұӯбҮ©аӘ…аөЎеҶҲгӘқбғ¬жӣҚжһҶа¶№Л аўҷбңҰжӣ¬жҠӮа°ҘвӨ№ж¬Һд§Јг„“жҙ”бӮ§дҖЎеҳ біғЬӨв…Қб  ајҖ0ГҠзҷҖе‘„в®ўбә§ГўвҖ зҚ»гҲ»бЁ’зЎІа¶ёж’ёејҡа® К«зӨңа° дҒЎзҳҢзҹӢдҖЎЦЁ'д•һеҗ гҷҗг¶ҝбөөв”Ҡж¶°дҠЎзҗҢзҝ…д‘ғзҚјг—ҒдҲ®б—ӨаЁ°дҖЈбҗјзӯҮаҪ—е“„гӢӣбҠўвҮ°зҚўФІд””б•ҡеҳҰбғҖ2д’–бҝ бҸүзөёаҘҒзҳ бұ»в§Ғж “жҸ•Ю»ВЈеӯҹб© вўҖ$вҶӨвҹ°г°¬ЭӨгҖ°еҒҮдІӢзҲҘаЈ”в¬іг—„д“’вӘ°ж’”дҰігүјдҝЈзүўдұіең°д–ҡа ӘФЈдјЁХіж‘Ғај«вғ№дҮ№дҒҙаө№еӨ№дұ 9бҶғkа¬Ҡді№бҶҢвҲ“г¶ЁвҺ«аёөв’үЮҺгҳӢгәғвҺЁдёөЗ•ШӨвӮ°а¬ҙвүЁдЁҺеҳҳв„ӯд° КҘзҠ‘е‘ҝаҜ…вІ»бҲіе§ғаәғвұ©аӯӮд ёМЎаё«зһ…С—дӮҖб‘Ҷд®қгіҹбҮЈж «Ш‘г°ӨдҚҗж№ңд„ұПҳбһңдҡңНҙвӣүдЎ вЁұд…°еҡҖзҠ©б©§зңҪжӘ©дёҗеў»дҸұПҮеҹ’з·ҹдҰ“зҒҒвҖҪг ӘдҲ’аә”зҡ“гёұдҗҪбқҳвЎ з©„вҘ«ОЁдҒ«зҢЁдӣӘв§ҖзҳҒзҘўШҖд–ңХ«г Өжғ«зҖ№гҷ«д–ҺВ°ж–ңВұб–•вӨЎзҲЎд«ізҚ—вӨӢгҷҪдұ’зөід®„Еів¬Ӣе№ҪвІ„ОҺЕЈвөӘа¶әе¶ңвәәдҘёжӘ«б¶–бҒәеҰғв«Ӣгҷҫвә»ЦҺжҜұб®үвәәб–Һжі»г–җжөҢд®’бҒ»ж¶…ж¬’г¶ҸдөӮд®ҹв–Ӣзө…в»’е…ҲдҢ’еҚӯжҘје……вҪ“бҡ•д¬’жҶҖбёӣжҪӘжӘҰж®ҳжҜ»гЎ„з”ҡг®ҡж§ӘдЈЎжӘҰдқәбөҙв©Ҡа¬’жқҙбЈҡгӨӮбӨЎжҚҮжўҠв”ҮвӘЁвөҪв§Ҷд®Ҡа¶ӢвЎ§в®җв©ҲвЁ»гөўИұвҚўбҙҠдҲ бҙҮеҶҗбӘӣг °д’§ЛёеўҮгғӨеҫҰб®ҲвҪ«ДҒбӮҮбЈӨе»§гҙҲвұҶбҢ‘бҪ·вҢ•жў·б“®еӨЎз”ібІҡе”ҖзҺ“вө»д©әгҘ…еЁҶеҶ—ві»ж№ўжҫ“еҪ°д„“зүҚдӘӯеҚ©д“ӢвЎҫдҠ°еҷӯд®әдҳӘе¶ӣеөәеӘӘд…ЁвҘүвһҘКғжЎҺеқҙа»қДғж  ВұзҶ“Ь®вқЁб•ҳж ҷдӮӘдҘөгөҙЫҡгҡ—вҒҗП“еҷҡеә„ж·Қвј…е‘ҲвҮӮг‘Қа·ғгҰҳбҸҶз“қбҝҮЕЈТҖеЁ„зҙ®бғҗгё¬вҮЁвҰөвҺҳгҢ®жҶ®вўҡвЁғдІЁе…ҙвҳ§дҝҘз¶·е„®ЕҜжӣңгҡ«вҫҢдҺ®зӨҲб®©жҫҢвһөбә’вұЁеҖІв–ҡбһһЩ«дҘ»ж”һвЁҠе•ҜвҰҡг»©жЁҸзҳ•г–„в„№а ӘЙ г°ҙвҮ“бі°вөӘе„°ЪҰзҒІИўж“із•ҠеЁ§е°¬Ю«вҜІаЎҝгҳҖв„ӮГІж¬•гӢҪаұ ЕәЧҠбЁ»вўҗгӨЁз—Ўд¶Ҡз«әжқҢг•өеҗӯдӘӨдҒҚбЁЈв§”б®Һеҡ–гҜҒжҡҒжһҚгЎ‘д ¶еЎ№д¶јжӯҖдҺҙвҙұгҷәЧғд„ів—•еҚ°дҢҲг«ЁбӣүЪ…в§°вөӘа¬Ғг¶Ҷа»”б—ўаұҗв¶ұбёҲеәЈдҘ’гҜ·гғҪаҙҒзҮЁвЎҮгҖ•бҪ·дҢҹдҖҘlЬқвҹөв„ҒаёЎдҝҶбҮ„жІ¬з“ӘвҺҗв©ғаўңжҠҳзҹіжҺҠгқҒеҙҙе„ів№¬з“ӯвҺўвҚҰе»қб¬ЁжҚ“е–Ҷг“ҡеҡ…бҒҰТідҘ…бүІвӨӨаұҝг„ёжҘ—зҚҶгғ‘гЁ¶бҷ¬жҫӮзұҲжіҗвҮ©е¶Јб°ҖдЁҜгў©е”°вҡҮбҮ№бҖІз¶ЁбҸ’в•Ҙд©ёвһ„д‘«б“ҶаҜҒа®Үв©¶жұӮгӣҜеӢ’вҮәг·үвҳ•аҜ•жҙөЗҶв ¶зӢүбӘІдҲіжөҠгҒӨз·Һж¬„аЁ¶еЈҷд№©аҫҢа№ҫб«ҲвҮҫК’б–ёжҸҢгҜ§вҠ—гҲјзҸ®дҙҶгҰҢдҶ“вҗҝбҙ«еһҷдЈүг©ҫвӨӨеһҠз—ҙвҪҸвә«ТЎд¬өгӮ„б¶ҒгЎҶжҺҢв»ӨдҗЈдүҳб ўгўҮа¶ҒбңЁгұ§д„©бҖІаЁ•бҚҶбҚүзӢўе©§еәҳв«ңз©қдў·еүӘбәҡеӮҸаЁӨгҪөзҚӮР…жҠӨПҘвҜ в—№Мӣд“ҒИӮжЁ“еҪЎбҳІжүҙв№Ҡвӣ„б©ЈзІҖбқ«з’Ҝз® з®°ЭғЬҰеҖҪбӘөвҲҗвҲёб‘җвҒәвүЎжҷҖжЎІгҚ”аӘЁзҺүгҷ«в““зҢәеҚ©еһҮжҒқвҡ•вҚҜб•…е–үзҰ®жҰҪв§ізҢ»еӢҳвқ§дҷ»СҚбҷ¬ж¶үв°ұгІөж„ўбҹҙд•ҷдӢҰгң№жәәеӣҠЫҢжөҚв»’г…°еҲҮвһ•Ы–з–ӨгјӢвӣҷеңӨж—ҲвҫқаҙҡвІҙж“¶вғ’дЈҫжҜңгҮҙбҖјбғҲвғҺа«’гҡ•жҢіЩ®бј”е»…гўқвҜ©г•ҜдӣҢеҫЁбҚҜеҡүжӘӮаөӢдІҠе№ҙжҜ§бү—гҠ”гқҘгҖҗжө—а Ҷзҡ„жӣ–еЁҙв§ӢдіігӯҶзҺ”в«ҡз№Ҝг¬Ҳеҡ‘гә„вөӘжҙІе«”вҖ№дҪ·вҠӯгҡҘб¶Ҡа Ұжҙ¶вӣҪа©Қе§өгөҗаёҡгЈҶЪһзң¬еүӯаҙҮгҡ‘зҶЎб—ҶаЈ“д»ЈвЁ№аӘ„гұ–гһ§гҸ—е’Өа©ҷбӨҖв—Үбӯјд§ҘбҙҺв¬ҮгҫҷжңһзӘ”жңІвҘҺж№ІзӨөж•Ҫе©ЈзҚҘе»ӣж№ғжҚңбўҘгІ—д”ҳжҫ«зӨҡ(дӮӨаҰұб°Іж…јаҜўжүҚв©ҶвӣҰе‘ібә„вҰӘд—»аҜЁеӣўвўЈбқҹг¬–еүӯзҠӮжёҠРҢдҷӘдҹўдӘҝдҳ“дҝҗд©ҝгҳ•вҪҶв§…бҷјжҚјгҹқвҝід¬¬еҗҡзҘҪвў–жҫЎаЎ‘гҲ°жғ„е•Ӯе ¬еҘңжҮјЧҖбЁ¶дҫүдҚўд«ҳаө№вҷ¬еҚҰжғӢгӯҙвҶ—в•·Сұг’¶жёўжӘҪвҘҠеӣӮе·ҙбқҙбҜһдҚәдһ–г·ӢЦҰдҷӯв©һж®әЗёзүЈе§”вҸҲвҺӘвҚўд’ҮеһҚб·із¬ҡдө‘г§„е·ҷа°әаӯҘжҹЈг•ҜеіІб§–е”јб¬ҜеҸҶжҶҝзӣңа·’ж“ҝжҷҮб°Өб“ІдұЈб¶ҜжӣҡгҠҪвҪ„в¶ідј”ж—һеү”бј№бҶІз•ӨвҺ»бҚҡжјёзҹ…еөұбұІг…‘в¶„ж•‘гӯұдҫ“вҫҲгҺҹвҖҶЪӮб¶ІжҙІбҸңеҸӮвҡ—віұеҜ®е¶Ҫаӯ…жұҲЪҶеөҺгІҚг…Қбқҗв·”аҫҒеӨҫжғ‘ж’Ҹе•қж„Ғб·ҪвҙӮгўғжӮҖгҜүа®қжјҳеӯ»б–ҪдҰқжҝҲгҸ§бЁӣРЎб° жң…Дқжқјж·®Жўз–ғгҷ¬зЁ…жң“еӮ–е¶өв»Ҳж„ЁгҜўб”…жў„в•ӨгІҒд‘әСҠгўӘб„‘ВұаӨ©бҺҷбёҪајӨв№ўж»Ӯд•ҒаөқжЈңдҷўа¬¶бһӯаҪҸвЎңбӢ¶вҝҘгҷҷжҲјгҘӘд—әд®„еһӯжҘҪаҪ©гҚҸдӨұбҙ§з…•з№әв•Үдҡӯе¬ҰзҮЁд‘үжҮҳг’Өв“ӯдҰҲеӯҶЗӢб’ІеҷјгҲ…жҘ„а«ұв№өб’—д«ёдё–вҰ“а ӣе«Ӣвө©гһҢжҰүбһӣв·¶д®әж»қеҰҒжҫҚг—ів°ҮбҚ§дҢҺеЎҚдқ·ЩҪз•»дҙ§е©»бӨёгЁЎе®…зҶқеһ©аҘҚжә¶з–ҲдҺЁж–©г»ҶжҪ’еұ№бҝ№г°¬жҢүдў—ві”е»«з«ҡвҡјжЈӢЬұб· бЎәвЈҫеқһе–Қд§Ӣвҝ•дЎӘдҢ·б§ҶдҝҮе°қг…ҚеҲҚжҮҰЯ–жүіеҙ„жұ¬Ч°еҡ»зһ“вҰ“гҳҺдӣұгһөд»ҶбқібҜ•з¬ҠгҺҚе«ҪзӘӯгҳ§гҙҝжӣ¶бҪ®зҘҫб·…жұ¬дҘҗгӯөг®·зҰҗв°—г®ӣеҪӘвҝјбөҹжҳҶгҪһзҹ—е’ҪгӨқзҳ…з·№зҖ—зҝ’зҫ“еҖ”дҮ»б–ЎеҰ•гіҲб§ҺжӢҠгҙҮдҰҳгһҪДҸИ‘в®Јаў©еөӮе“ІбЈҶФәвҶӮзһЎдЎ…ЖІбң жҖ§зәҜдҲҗбјҒгӮҝбЈһдҠ г®Ғаҫјд№ҳв‘ҖМ еҒӣзҡҖЭҮаҜҒвҖ©вғҫЗҖвҳҰжҙ·бғңЕҡЯЎаЁ©дЎӢбҺ„гҗҰжҒүз ¬`дј°ж §д‘јв•ҙбҗ«е—ҫгү“д–ҖеҲ“зҒҗдҶҜд…Җж«Ӯз јд…ҶП°б…Јб„Ўе„Ҡдү°г¶ҖвҖ з ®дүңа¬§зҙјдғ…ЕҲбҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":3418,"_status":"completed","_startTimestamp":1775055736925028,"_endTimestamp":1775055736929047},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"72","comment":"","_id":759,"_uid":"220789c0-6e3b-443d-9009-2b159d2fc5cf","_cid":72,"_ctime":1775055552939,"_sid":45,"_stime":1775055732830,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":54620,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:02:12.506Z","time":287,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9aFyH&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value