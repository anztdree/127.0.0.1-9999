‘№гҚҙеҳҸб’ҸвҫҮг·ҸбҺәж–ҝв°Ҷз°әбҚ ЖҘжЎ—М вј Ю•жҖ б«ҰПҗбҝҜеҖ¬жҖөз§ҙвҢөЛҖвҲҙдҖ зҺҡе ҡЪҶе©“бЎҰЛЎжӘҰв°ҡб¬ӮвҰӮгөұж•ігЈҜдұҒг‘ҷТ“еҘ¶бҘігӯҲвғғТҷдһҙеӘҰаәЈбЎҶП·дҡ№е©ӘвӣҮвөізӨ·б‘…еҙӮжӨёеҪ—ж·Ўв«ӮаіЈбЎЈе§із«әдҖўбІЁвқ¶вҮҡжЈ°ж«ҫе°ӮзҮ°$б• дҳөв¶ҡз¶ӣжҝ дЎҺМҠгҖҝХҒвүҶа ӣг¶ҲЩҡдІҢжӘҢајўдҮӯвӢ—г•„жӯІе“җбҲўвӣ»вҚҗбҝҖд°«жҫЎжҰҚвҡҖбөөв  бҠҲбҙ§бҗ ХҪЙ”бҡӯеӮ”г»Һеү“еҲҘд·“зҠӨајҖжІҝЖһзәүеқҢвҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1299,"_status":"completed","_startTimestamp":1775056050717346,"_endTimestamp":1775056050786344},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1108,"_uid":"95e7e689-cbbc-41eb-9316-df239b926f12","_cid":92,"_ctime":1775055887626,"_sid":64,"_stime":1775056050219,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:07:29.816Z","time":294,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bTQH&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"189"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bTQH"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"185:42274[\"handler.process\",{\"type\":\"hero\",\"action\":\"autoLevelUp\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"heroId\":\"c589af82-b7