00/socket.io/?EIO=3&transport=polling&t=Pr9a4rX&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9a4rX"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055687025110,"_endTimestamp":1775055687031629},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:01:34 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2453"},{"name":"Connection","value":"close"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3022,"mimeType":"text/plain","text":"1103:43171[{\"ret\":0,\"compress\":true,\"serverTime\":1775055694060,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁЕҗб— г¬ЈдІҖг¶әвҖӯРЎШЈаі аҰӢд„°НҷдүҖбҺёВӨд–Ұ;бІӨеҮҶМЎбү©еҗЈе ЎдұЁНҗЗҗДёКҗВҗЛівҗӨг…Ӯбҷ°ЛҰбӣӣгҰңдұӮе§ӘЕёгӮ°QдҪ®жәәв–„дғ’г©Ңе° в«°зҲҒеҳөв“ЎжҮҖВ„гҖ гңёЬўаҝӨД°жҮ„еҲӮбғҙВ”в¬·бЎ‘дҖ¶жӮ Ыө вёҷеЎўе…•а°¬)д’®б‘”вҘҒдІ•гҠӘвөҘв•ҙеҘўв·ҶеңІб„Ів‘ӨНҖг№ҒгЈ”еўўвҚіж©«жҳ…аё’вӯ©бў®д§ӨвіӢбү„жӯҠвӘҶд’ҶдӘігі”еӢ‘вү–бӨўб‘җд®ҘаЈәв·ӢвіқдӯәгҮғеҢұеқүаЎҠгӮ»бҠҷа ӮбүҲжЁІа§ҰгҒҪжҢ»еҠҢд…№еүӢЖҖзӯҲжӘҷаұўеҺүбҲІб“Өе§үаөҠдҳҘгғЎбү“аөўжЁҪбғӢдҠҮгў в‘“б…ЁЧғб•ӯеӮҚб„Ҳжҷ“б№Ёг…ҖдЎ¶віҘе©үз”ҚТ§еҜЁжЁұдҖ«е‘ҖжЎҲв°ЎдҸӘв•ҖбӣҪдҢҖВӮзү„вһ‘дҗ зҙҰбІЎдҖҙжҖ бҘҰгҖғж–Өа»ҸвЎ”гі№ИҙЭ«жғҖбӣҡзӣ BзҲӯФ зӮЁаЎ„жҠ«дҸӯжһҲв„Ід–ңд” гұҙб°ҲгҰңЦҮбӘҲUеІЎжӮҗг‘»вҗ§зҹўжҠ§вҗҘеҷЎгӮҲеіҫвҠҠдӯ¬зіөжҢ§е…ұеө’вәӘж§јзҜ дӢҰг§Ӯз©ғвҫӢж—ЁеӢ•в¶Ҡжұҗб№ҮвҫұбҘҢе•қдҝ»аә¶жҷһг—Җв јеҹ дӣ„зҺҷдҰңеҝ¬е—ҢзІҷе•®гҗҲе©Ёеғ…еүҠзӢҖб·Ҫб•Қзҡ–е…ёвүӘд«ҷбҢҫаЎ©аҙқа©ҲеҷҠзӯ§гҝЎе©§жҷ–дҘёж©“діўбҲ”дҖҲП”б§Ўд“ӢСҚді•ФҶгғҹа°ҲвҮ„г°Қб„Җе–ӮбҮҝаўўдҢЁг§ҘЙҮбўғд·ҮвҙҸЙ гІ®зё„б°ізө„б»ӘМҙ4КҲжҖ¶гғ·бӨҢжө•бҺ…еҗЁжҺҶе··а¬Ҫа§•ЬҪзіҢб–ӯеғәбҙ»вҸҲдҖІбғ·бҲғдҚ•вЁҸдҸ—аІҶе¶ҸаІҪа ҝгІёвӢ·б°ӮеҺңв ҺеҚҳж„«д—ҝв№үдҸівҲҪеӢҙгҲ·еҗҖбҰӨвҢ–г°ҮеЈҹг¶ҰгӨҜг’ұе°°в•§бҸёдҠұгөҘа©Ёеұ·а¬Ҳг¶ҙе®ҝЕҠбӘөзү”ж„©вЈ”дЎҪа©¬ж•©ОӮж°өгҺҢеҰ»аӯҢд‘ҝеү б§ҜгҢҗжҷёеӢӮдӨҪеҚҠбӨІдӘҸгңҪМҺв’§жҲҙе„ібҮҝаІўгҠҰгҡ°бЎ¬зқ®з·ҡб Ғгұҝгғӯж°ігӨҰд…Ҷб¬°ЗҪдҳҙЧ $дў зғ—бҮ—б«ғвў§а¶ҲаӘүдөЎеҸҗбҳүд»–гӘҺдҸІз©һеЈ—з©ҷеҒ—ФӢг’·Щ—бү”гӮ“вқ—з—©д’•9е “еҡҷдҹҰжЁіеҲҸгҷҮв‘“вўӢд·–гҙӯеҠ‘зҮһа·“бҷҝвҜ—б«қеҝ‘ж…ЈејүГ¬гӢҺеёҷвҹЁвёЎвҒӢв№ҰвҜҚжјӣе„—еҘҪгҢ–еәӨбЎҠРҒгҫӯбүӨвҷҠПҡгҪҠеЎҹеҖ—еҮӮвҗ«ЖІИҜг»©гӘәеҡүв ёжҳңвў«вҮәвҢ«б•ёгё“ж•ңж«’б•Ғг“ҺеҢҙвӘ®Д¬зңІг…Ұв¶ӯа¬ҰвӢҸгө•гӮ©з»ўвҷҝеҗӮв‘ӨдӨҰг—ӘОҹд“«вЎӨж„ҪзЎ„зӣҢжҘҰвӘҫв°үе…Ҡб®Ңж»ёеҘҰг®ёвҘ–г„•вӯҮеөёвҒ®г…ЎгЁ–гҸӯбҗ“дҝӯвҺЎв©Ӣб¬ідұҸд”ҙзі»д–ўзӯҲг®‘ж§әеӯұгҺ»дһҺзүҺж—ёгҷүаҜүзӯҸаӯ ж“Ҡг•ҫзј‘з¬»г»үг–№жӯҺг•Ғг—Ҳв Қгӯ¬з•¶гҜҚз–қг…”а¶—ТӢа¶ігӘҚд¶ жӯ°вө«в–ҺжӮӢв‘•еҘ»гЈҒж¶ҫеҜөз©…еҙҚаҫҖз‘җвҫ·г©“гҮ—в•“вҳҝдҖҸжӣһбғҗб·…дқҗзӣҝг ӢдӢ•дЁ©г¶ЁзёүН§жҰҷз·ҪеҲҪдҸ°вҳ»вңҗжҠ’вҜҫв‘ҹзҰҒз№§вҗҶгҢ»жёЈжҠӘеІӮжјҳжҺҳаө«е–ҝбҳҗг«ҷаЁ©бө“аҘ№гӣӮзҒҲвҒ©жҢӨвҷҪбұҮб«ҳгҡҝбўҘГ—гҚҒгӣІгҙ…дәҘжәҚбӢ§д·…д№әз—ңе №б°•г„іг•Һеј®в№”жЎ„е«ІдҺ еҪ»еҚҒе®»гҮҗвқігү’д®…дјҡОҢвӣөН•ХҡСҰЪҠбҳЁзӯҲеӮҒЭ…гҠһжҖҪд•Ёбөҹеҹ«гҫёгӨҘг¶°аЈҢеҡӘзӯӢгңҷжӮөзҷјвҠ”гү§еІ¶Ы№аә’бқӮа§ұбҲөаә„бҫҪе•Ўе’ёвң’дІңЙ•К•еһӮгҸЎг®Ҳж№ҒвіјдЈ°в“»д№җг®°жҜӯаҫ–вөһз”©біӨб»қж«”дҜ®е•Үдңғвһҫж§ҜвҮІгӘӮдҢҫвҹўе№ұдў¬бҜ¶а·—дҢҳЖ»ж ҝгҖ…МӘжҳҗеҗҚб„ҮжӨүбҹ г·Ҹдҙҡг»ҷвҹҝС—гҒҲгңјб ҠбҙҸдҲқжһӨвҲҢХғвҠҝзўҘгҰ•бү“ЕЁз¬ЈдӣҘвһ¬еһјЙәеҲ§дҰ¬У…вө”в„…дұ°жҗІГӮбӮЎдҷғг•јгіҰеғҡаў№в–Ҝб®ӢаЈәе¬·гӨ–бҮҚЙІд“ёгәәбўӯЩӢгҙӘбҘҶаі¶б……вҮҡжҮўзҫЁж‘ҙгҒҰвҸҶеҺҲдӣІаӨ“бҹұд„ұе§һЧ’д‘Ҙж·¬е©ҰжІјдһ·бҰҰж ҘдүұеЈ…з§ұаҜіеҲҝеҸ”бҚ§аӘҝжӣ№вІ’дқҖв§ұбҒ°д¬‘в¬ғб”·гӢӮе„…вҸ‘жӣ№в§ҜгҰ“д§ҺШҪв©ӯв¬ғж№ҹЙ бҸ§д·қг«’жҫ¬еҺҒд°©е»ҢаӨЈв”іПјбү§дЎҙжүӨв—ӨзҘҜдіҲбӣәзқЈбјӣв«ёжҘҳз’әвҪӢбөҠз¬„жҠғеөҚз…ҢвҹҲв§ӣжұіа«җзі•бӨҡв¬ЎдЁқб»үзЎ–бҹүвӘёж§ҮвҝӘгҰұз°§П…жҙ·вҳғбӘ©зҪ…жҗ№вҺҖЗёж°ЈбҚ”ПҶгӮёвҒ«гҘ ж„ҘжӢӣдҹҘЕӢзұӢбӮЈвӯҷдұ°г–»еҒІаў№аёӘОҸаҝ®а©·гЎҙеҷҚв‘¶О¶бӯәжҺҚа«јзӘ…е„ҲдңүвіҶеҖ¬бҘәз§•дҚҫг¶Ҙв“Үж’»аҝӯвӨігңӯжў©аёҖеҲ«дҷ·дҚјвӢ©гј¬дһ…аұҢгҘід –вЈ…ж…ұжІӘзҺҪж©қг ҳвҺ¶д“§бәҜд•ўв¬ҘдҸўв–„е¶ҪгҘҫб’үг‘үжҘҘгЎ’зҺ¬бҺҶвҪҪзҷұбІјеҗӮаұҹжҺЈдҹӢеҜҖе–—бЎ¬вөёеҖҺжјҖзҙІеЈңеӢһж«•аҘІг ¬ГўаӨӨз°§д…Җбҡ«еў¬дҸҒеҲ г…–бӢӮв°®дҗ”аӨўвҒ№М°гӨӯжЎӨЙҗдҖ  \"}]"},"redirectURL":"","headersSize":248,"bodySize":2453,"_status":"completed","_startTimestamp":1775055693165525,"_endTimestamp":1775055693170865},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"67","comment":"","_id":698,"_uid":"57a0d9ca-92d3-4fa6-8cb2-266dd7afddbc","_cid":67,"_ctime":1775055373090,"_sid":100,"_stime":1775055687024,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":35432,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:01:26.682Z","time":296,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9a4mJ&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"156"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9a4mJ"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"152:42170[\"handler.process\",{\"type\":\"guide\",\"action\":\"saveGuide\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"guideType\":5,\"step\":5105,\"ver