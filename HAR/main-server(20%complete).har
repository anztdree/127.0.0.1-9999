Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bxxm"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056174840862,"_endTimestamp":1775056174847787},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:09:36 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2715"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3321,"mimeType":"text/plain","text":"1235:43317[{\"ret\":0,\"compress\":true,\"serverTime\":1775056176490,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘДҢа№ҲЖёГёВ¬ЕҳXЖүгҲўбЎҘбӢҲЖҖзғ»е«‘вҳІгіөГҢбЎӮ8бһҶзӣӯвҮ’д·ібҒҝаҰ’дҗәДҲгҹҳДҡе‘җбјўбҗ У§гҶЎе«Ёд”өв©ІзӨЁе»”дғёж„Іг•°жЎӢз–”вүҗаЈ„зЎЁбҙ¬вўҘа«•дҹҰбүұд§үз“Ҙвҷ¬бӯ—бҮҜдұҺбҗұдӮҖГ–в  а¶ІЯҖЭ„дҳӢдүӮAзҫ ЫівҖӨд§°/еҗҘдҺәЕҒзҫ зЁӢвҒүз“°аҪ«зҗҘа©ӢгҘ©жҺібҖ аўІбҙ г„ EвғҖзҰҡгұЈбәұв—ёбўӘа«ғжҠҰзҸҖеғЁбҗ зЁ°д¬ЈдҒЎзј№дҰҲО’жҙ а«…гҝ Г‘зҶЁб„№аҘҘбӮҖ[е©ЎгҢҳеҒІбҠ РҗеЈ„аў ШҖгўәжӨҰдҶ„вўҢдҢӯдҜ…жЎӮжёЁдәЈз„ҰвҗӨСӮбҠҖ'д„«бҖ°зұёгўҰдҗ д«¶И¬ЖҖзЎҗДӨбҖЈСҖбҗ жҘҗд–…гҗ ЛҚГҠгҳ»бұ Мҳа јгўЎж…Јд”’бӘЈвҡід‘ҚвәўжӢ”гү–ЙҰжҶЈвёҡа°ҫв•җвіӘаҘ¬еғҒаөҶе§Ӯж«”ж¶–зўЎжӘ”еөҗбҜғж©Ўг·јаҪҝе’ҳжӮғУўдҖ вЁҶж– аҘЁКүвҙ гҖҪвҖ¬гҡёНҚзҙ з …г»°зғҖД’бҳІа®©д…Һ$еҒ¬вүҪг‘һkжҜЁбһҸе ҚзӮЎВҰР¶Щўг„ҳг„јдӣӮжЈҪЫӯдңӮУӮгўұеҺ©Щӯбҷ§вҷҳгҘҪвҰІж—’біҺгһҝЙҲЛҒг‘ҫбҹЎбҢүвө¶Jд«©дҚҘгәӢгҖӨа©ғгҒӨЪ°Ф§г’‘аЁҙаӨҰе…•гҲӘвҹ©аЁёгҠҲбЁўв„ҖвҲҘд‘җеҲІГұзҲҘдқүвҒҸе‘ЎбҫәвҲңзҫҰвҗўз©ңв”ўб…ҳаұЁеҒ¬аёқзӮӮаҫ¬зҙ»б”ёб—”ж“ӯвӯҖШҠбЁ дҺ…вҖЁlvбЈ П©зқҚв§Ӯ!дӘ—бҹғбҖ ГҢвҰ бё°д ©б»ҜзүҖЗЈЙҗеҒ°О‘ж” ЩҰвҶ®дҠҗд„ІвӢҳеҠҗд“ІбқҘдјҳеӮұбӢ’бҘҘжӘәаӘІв№–б©Өв әНҰж»ҢдўғжёҘДҗжЎ–бӨ–аӘӮеіҖе№’еӮҰеәӘеҘ¶гёҜдӯ°вҖ¶Э°еӨҸе©ўвҒӮбӯ®е“№ФӨгӘҡбүҰдЈҠбҘ§дЈ‘е…ҲвЎ–аЁҜд”үг…ҰдЎһеіҒВҒвүҺдә‘б©Қд—ҡб№Ңв—©вӢҘвҳ’бөҢвҮҙе№Ғж—ҪКӘвҷүдӨӮді«ЦҮа »бҖҰз·ӘВҳвҶҫжҒҖЬ·аӨ жҮүжӢҷжӘ»ж„ҳеҒӢгҢЎбң Э·б°ЈЙ«зӣІг ҙдӮҖеҖ еӢҡВ–бҶӘд¬Ҫж©ӘбқӨеҡӨв—ізҺ©бғҗеәҘд—ұб“‘еқ’бЁӨв–ұаЁӯд·ҪбІЈдЎЎдЁҘдҶ“вҹӣдӘөбәңеҲ’зҹҹдӘқзҖідҪ“жҝ…дў©жҲҘдһұг©ҷдҸҗзҳҫдүЎа№‘дҷұа©ҷдҳңг…ңд„°бЁӘЦұвӣҢд—Әб‘ҳбІ§е„ҢбЁӘе–Һд‘§гү’бө§в©ҡб§‘бӨ–б·§дӣҷаұӯдҚ’гӣӮвҒҢж‘№вӯҖТҡШ бҮ”жҖ®в“ҙKзЈ аҘӨе”ӮдңігҶҖв¶ ЬұеҷӨеҢҖГІбҫ Н»бҠҙаіҸбҡ вҗӘж”ҒжҜ•е’©жў–б‘Ҫб”•жІ·еҸ©е»Ҝең„в”ҝе–ҳжҪҝб°®ИҚвҚ«еј«ЭІб‘ӢеЈҒв§«бҠӯжҠәдј–дұ«ЖҖвҮҠвң°дҗәе№Җа§Өа¬ҚбҗҜгҳҢгҗҝгҷөз·ӢПғдјҖзЁҢд‘җз—ҷб«¶г•§ЫҺгҮ¶1вІҖГ…дҳ дЈҷвҖЎб‘·а¬ҙ$вӨҗвҗ гӮўд®Ёвҗ”вҰқжҠӢвҘӣвҙ®дҖЁе’Ҳ-дӘ…зҖўзҺәе”‘жҮҮеҶӣеҚҳз…ӘКҸеҘ“гӮӣб‘«гҡҳгі»дҖ”бҒҪаӨҸбһҪвіғејӨбғҖа©җе«Ғг“ӣеҹҖг‘„Ш№б‘Ҳд«ҒбҒӯТүвІ‘Ъ°вү©дІҘзӢҚзҰ¬жҒҪзҝқГғзҠқбЁ»аәһвҝЁгҢҠжҝҳЫ®д©ҺжӣЈві‘8ЭҒеў аёҶзҗ г…”жҖӨдҺёгЈҖжў“%аҜҳвӨҘд¶Һбқ б‘Әе„Ҳа№ Р§з…„еҝҗгҜҡжЈ¬гӣіжӯҒзҒҡв§ӯбҒҮвҝ…д’©еҮӨбӢӘжҗЈж®үгҢҒеү©зҹ’зҺҲгІӘЧўзҸјеҒҳа»ҳСӮз«ҫЧ’зҘ§жҸңбөҜгұҖа¬Ёд ҪжӮ°г®ұд”әб…Җа¬Ҙз„һаҰ зҹЎаЎҳжһ”бҳҪбӮӮд„ҡзҗівӮЁгҶҘгёҙдқ”б ҒжӮ№ЗЎзҲ¬жүҢбүҳдҒҡдҡҲСўжўӯЧҶб©ӨМҡбўӮб„ёжҺҙб“§дІ…д‘ҳдӯ–Г¶еғҖзӣҠеў Х—бғёдҖ©зҠ”В—еіҢжғҢв–”вӮғдҶ„еҫЈжӮҲбҰҗбҚ»вҒҖа·ҡаўҖзҸҚвҖўзҗҠHPЗ„зҠ аҫӣа°ҫз·үеҠ–аөўа®ўжҮӨбӘ“вғ•в“ғгҠҰдў…ЗһгҳҪбёЁаөҖгұҡжөҸаҜ©ж¶ӘеӢҸг°ўХ°гҒҖз©©дӣӯб»ғжЁўжӮ°Э бӨҪеү…бҲЎжӘғЖҰб„ўдҒ«д‘°з©һзөӘаҪҲдҷЁдҶ¬дЁ діүдҜ°Ь°д«ӘаҪ“еҝҪжө‘д–Үдҗәж’ёгҫ©г”®гҳ©б–Ё(вҚ а •вһ•вҖӨб•үжүЁЛ«гғғxв“ҳб¬ғВңШЎбҘ•г’•д’ӨзӣҲзҗӢг„’дә‘Щ–И¬ж“–в•қз®ЎЗӨбҸҮдјӯеӨ”еҢҗг¬ұа ӘжӮғе’ҸдҒ вҒӘж–”ШЎаіӮвӯЁа®Ўж…№jзӨҜбҒ·бўұзҲ¬б‘үг·Іж‘•еҺҡг° гҪўгҷјдҢӘв—ҝжЈіб“ҹбҮүг•ўжҰқб‘ёеҚҺгӘҷЦ…еү»гҰҢж іеҢЈе—ЎбұҶ!жғ°ЕЎд©‘бЁ’вҢҪаҘҺб®ӘСӣдғҗв— в“һЙ©б’°*еҗЎеҡҳбҜёе«»бҚЎб°ұдЎ№вҹӮНғдҠ°eжҹҢдҳҗа«ҲвҖ°вҘјеәҳг…ҝжӨЁдҹҸз’·жҡ°зҹӘж–ІеҢ г„»з·„ЦөзҗӯдӮҗб•–вҗ«аө°б„ЎгҮ©аЈҖвҲ°ж‘ҒдӨӘгҷҘЖҰжІ дҡҘдәӯдҘ»аё‘еұҠд”јжҒігҡ¶гҲҰгқҲбҡүд«јзҺҠе©Ӯеў Яүзҗ зјӢгҰ”зҙ•вҡҠз«§б’„П°дғ„аӘЁгҗ°зҜҹгӘҙдҮ“вүЈЩҡзҲҠг«ӨдҫҒб’№вҮҺд§ҖбҘ–д©’гұүж№ігһ•вҸҘз•Үд–ҚжЈӣеҗқг»ёеһ®б”Јг”ӮаІ°Ц–зўЎжғәвӮғзҮөД”бӣұзҷҪбӣ¶ж–ЎвӮӢЙ’МўзҒ®вҺӮбҹ‘вғҸгҪғгҲ©жҳҢзө…г®Ғвј°жҹәзҡҸеңәд№ҘгҲўа Ҙж№ҫгў•в»§гҶ•вұЎжҮҮб’—Д‘дҢ«ИӢКӢе№Үжүјг“—вҖ®ШҘдӯ°вҮҖе‘ҷзҘҳеӢ§гЁөбіҢбһҜвӯҜг«ғжј•вҝ…ж§ҹвҡЎгөҸж–Ҝв§әз‘ӣзҺғг ІгҰ…Тқж©®гӮҡбјҪдҳ«вҸ¬бЁёжҘ‘зҰҗз‘”б »а°ғдӯғгӮўгұӢдҠҸвҮқеұӯбҚҙдІҹвІәеөҪЯҚбҖҙгўӘе“Ӣ2ЭҲВ°У #д§‘а«Ңзі©гҶҢ&еҸҺжҘ©гўҶе»ҚПҶж®•дҳігӨ®Тҗај дҖјаіҖжҪңд‘қај©ж °бғ…бҘ»а ҜЙҙдҘҮгҙјдӢҡеҷҝдүҷЖ…еҷӯг¬ұг¶ӨаҪ“д®ҺдҝҺз¶қжҫғвұ№з•Ға©ғЕјжҳ•аҪұз”°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2715,"_status":"completed","_startTimestamp":1775056175597174,"_endTimestamp":1775056175602355},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"100","comment":"","_id":1327,"_uid":"18fde9e8-0744-463a-93f2-e22c3f014906","_cid":100,"_ctime":1775055939645,"_sid":77,"_stime":1775056174840,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":59648,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:09:34.197Z","time":540,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bxnh&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bxnh"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056174197310,"_endTimestamp":1775056174203574},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:09:35 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3043"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3754,"mimeType":"text/plain","text":"1346:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—г№ңг‘ӘдЁҹгӢҙаөҠжҰ¬жҮ¶бӯҡбәҚвҪ—аәҡдҡҝві·зҗҰеҡ°зө—гҡҶбҮҮвқ’зҹ·дӢҰж…”ві—дЁ–жӢ•жө·дҒҸеү’НӣеҳЎжҸөзҳ·вң“в“’дҫ¶бӢ°зҜҡП®з—ёзӮңеҪ–жҜ–жіқг–Ҹб·җжӯ·гҚҡгӘ¬бҪ”біҸд—із•‘г№·жҲүжҡқд·№вјӣжҮ”г№ҶеҮҪг®®гҹІгўһе§ҜгЈҰгҝ°зҘ–дҒ„зӘ¶еҹҘв©ҫб·ўЫёг¬·б ҫв—¶Т®зЎғг®ҫв‘қзҰҶг§ӯЧҒд— е¬ҫеӣЎЪҺЙҢФұг·ЎжҶұдҹўд–®гҸЈеЁұб»»зҜёдҷҖФҒд©ҸЧ‘е©Үе«ҒЩ“ЮұгЎҸд’Ўб©Ҡзӯ¶е¬№бҮҫаҘЎзӨ‘е—ўвӣ‘а§әвҡһжі№бҢһХҹз®Ғж•…дҷҒж·ӘгЈ®е»ўжҺ‘гөҷзҘұзұҲж’һжүӮжҗҺжЎӢЬ®зөҳЫүеҒқвӣҒзӯӣвҳҠбЎҷжҷ№з№Қв“ҒеҚ…бҺ№гҪҲУһж©Ҷжҷҡе‘җзҠҘвҹјб•№ЕқвңұдҺЎж”үеҪһбңҒдҘҠб’‘б“ҹеӘ©вҷңвҗ№дЈҷЬ№вҝёд‘Ңдҷ‘а ҷжі”еӣ№жқЎгҮ…бҪғжӯөУҖбҹҷб·ўеһҠвӣҒз«•віҚж•©д»Ғеһ•еҜ®бқ‘еқҗж—өг©–жү•еҜҝбҷҷг…—дңөжӯҠгң…жҮҺг’ҒЧҖг“өЗҮб’үв»Һг‘ҺЛҸе“үд§қдҡһе‘–гҹӯз“…еқұб·Ңзҳ©з·қг’ҘжҸҺз—•е«ңз’№жіұеһҷе»Қз •Яҷбңӯжңәзқ•дҘһз’өдҝ—еӨқбҹӢг•үаў…г•Јжҝ…жӨҶгҮҲе‘ӯдў‘з–•бӮ–е¬қЫӨз“‘в•Ҹгһғг»Өаҝ©гӮҗе•ҚаІ‘а№қдҜ…ајғеӮҸз ҒТүб”ҘгӘҮа»ЈбҜ‘г“ҷаЈҶдІҷзӢҳаәұЛһаҝқе·•г•қб§…аІ©гўӮжҡ«дӮҲбқғбӮҢжң«еҰҖаәғзә‘в»ёеЈ…в¶Ҙг–Ҹд·“жў“дұібҶҸв»“в§«е—ҳб»—вңӢеҸқвҙӯдҰ’жәӯб¶“бӣ»з¶Ңеқғдһ‘дҪ»бһҷг–»зҒҗжәӣвЎӢд№ібә‘бҳҘзһӮжҫ•д·ҳбІ»еһҸжҪҘДӢжІ…зҮ—дҝ§г—Ғжҙ»д••в·§з„ҹж·іжӨҳжҫҮеҫ—б¶Ҡдӣ–е®івҙҶжј·а»ӮбјӯеІҚаөіе”„еҝҮгҢ“бҫӣб”Ңбі·з«’в»¶дһҒеә§зӣҗгӣ·бј…б…ҮвқҮжҪіг”Ӯзҳ»е« е№·аЁүе¶—ж§•еҙҪбҰҠе№Ҝжң—гўҜбҜҝеі“дёӢеӣ¶бҜӘжҪҮз’‘гҙҜзҫҷаёҝж»ҸаІҝдң“еҫҝФ’зІұб°ңгІ—дҲҸг’№вҝҺгӯҡеёҺв·»зҺҢжҶҪа·ҡжҫ зўқбҷ”Г»Фҫа¬Һж»Үжҫңбҝ©жў гӢёеҝ—бЁҸбҢ’аӨӨаІЎгЁғЖ—жјқжӢ«зҙ гЁӨдӮҠСҹг–Җдғўа¶һе »дҲҮвёңзҚјдү°гҖҷе¶ҘзЈ°зҳ•зҪіг“ҫз°ұЗЁбҲҪд‘һЛғИҘПҒгҜҸбЁ—дӮЁбҚҗвё»а»өжүЈг®¬вҺҜдҠӨзҒёТӢг ‘О‘а©ҺаёҶд…ҜвҚӮЙһгіҝд…Өб–ІдӣғгҸ‘жЈ‘гҠҰе„өеҮёбЁЈдҷңЛ¬аҝҡаІ…ЬҲж¶–еЈ‘зҹҒгҳҫеҮҶб°ўзүӮжҗ…дҮҰв¶¶Ф°дҢӘдҪ—аөҫбӨҠеҮўбһўаЎ’ж·…еЎ…СјЦӨеј¬е®…гҚҫШғаҘҶбӮЈг№–з–№еҝ§зһҪЮҚвҷҜвў°@дңЎз„ҢЖҖ(жўҗ6д¶ӮбҳўЗӘвҸЈеёҘдҺҙдӢЎМҘдқүе¬ЎГөбҲҖРўjвҲЎжҒ•дҺӢбӣ°бҚ•аӘұе§ҰзҒҗдЁҒгүӘЕҠг¶ жӣҚв‘ёДЈгў’дұҳбҠ·жҘ«б„Җв•–жғҖб«ЎвҒғвӨҢеҰ¬а№Ғдҙ©в’Ӯ+ЩӮгҳӨеүңУҶе©ҪдҚёвө«дҖҜВҗдҡёг «Ц’жЁўЖҢУ…вҖ№дҸҗОҰб“ЁдЈҶдҺјд§”жёҗбёІзӢҖб„ҖеұӣОҙдҺҰеЎҳО еӘјз„ҸУ’зҖІМәв°·еЎ…дҚҳД з Ҙд•җдҶҝз©ҷжһіеҘӮвҺҰгһӨдҖӘдқӨе”®К§д–ҒдүІбҘҖеӯ«бүҢдӘўгҒҘбүөбҷҲзҝ®жЈӣаі‘д”°дҘұбӣ«зҷүдҢ гҶ¶дҰҢв—®г»Ёзўҫа¬өеўўб•§бөӘзҺҘд«ҷг№ӨзҘҫдҷ„віҠЛҘаіҗз•ҫж”ҰжӯҳеұҗаӘ•гіёдҮ•дҸңдҺЎжҙ’дЎҖзҳўв§®аӯІжё дғ¬бҮҮбұҺбҷҙз«¬з’ҜК а Ҙд•¶е•ҙУүдҜҘдә“г–Җе”ұХҲаӘөвў®аҘјзҶ”еҷӘжҘ’б¬қгӨҶб–ҷд•ӘзҮ¬зӢӨж·©з©ұбӮңе«ӘдҷӢжҢ“е°ғеЎӣжҖ°ЛЈв ӘдӘүЬЈгҳҺе“‘а»ҢжҒәвӮЎгҡҢвүәе°Јб Ід»№бҪұдҘҺбә»ж“ҮзӢӨг«Јж¶ҷв“¬еўӯе“ҶдӘ№бҝғг–…б„ зӣүжЁЁУ„аЎӮбӣ–зҡҸзҪҶаҘёеўЎГүв““бӣӘаҜҪвҳғд©©в’ҙд® еӘІд¬№д®ҚжҘ®ЛҡзҸӣдӘ“вў«вұӣДҢдӢҜг«Әдұҳг Ўе¶•б”«гҜҗзӮҚв¬—вҒҠвҜәж¶ жӢ»Нқж•ұг¶ӢвҶ«вқӢвұҝгҮүв№®б–ёаҰүзӣӢдЈҷжө§Г«М’з„ҰбӘ’г·”д‘Јбӣқб®Ҡдңҹв«қбҠ°еў‘аҙ‘аөҠЩәвҜЈд¶ҒжӮәзұҚбІҮЗҗжһҘpЗ“б§үдёҮгҶҘаўідӮҙдҺ§Сҙв®җжҸ»в§–aаҪҡж«Үгі…вҖҙзқәдӢўдҖ§Оқа¬ҘДҹеЁӮаҜ‘зұ ВҮОЎе”ҰеЈҰгң•дӨ•гҶҫвЁҺZз„ЎЯ—в§Ҷжұҷв— ОЈб ўдҘ•а¬Ўб¶ҳеіҮг»”в©Іг‘ӨбҚҝд—ҒзҝҢВҪз—‘_бҺӢвј°д№ӣдӢігҙӯзЎӘг•ҷзҳҫеғ а®Ідғ¶а·–вӘөд“„бү•вҪҰеҠЁгқ‘дҒ®зұҙеӮӯеҪңзҸ§бӘҙвў„д¬…г…ҰеӢғд№Әеҫ»а«ҙеҗ«Лһд°’еӘөаІ•б«ӘзқҚг—ҳвёЎз»өв•Әеһ“гҘ’жҗҲбҖ¶гәӣбһӮзі№еҫ”в№ІжӘёг—·ПӢдҪҗбҜүг§·ЫүдӢҝвӯҢжҢҳжҙұб°Ҹж—ёжҜ“зӢңзҒ…гғ–гҰҺбҹҲжўҺе« жөүеҡҸбјҒе¶јгҹҙж®©бў·жұҷбқҚеҺҚбӢӨдҢјвҪҪЬҡеӨҒж’ӘбҜігҝ·аӘҺбҒҺз”Қв»§дҒ…е»әж¶Је§ҳгҹҡзҮ©гЁ«зҫғе¬®а»ҮЗ№бҡЈд«»вҳҖеҪӢвј®ЭҘгҲҖг®үв©әзҢҢе»ұзҖ’д§ёПӢеҜҗзў‘д¬©а®Ҝж–ҡжғһжҸ¬зј’вҝңЕҹзҚұа№Ёв§—ж¬ұгӢҒЬҙжҷүж№Қдӯібұ§Нңг·әгҜӣж“җзҒ”з®—з®ӣеҖҶзЁҪжҺҷвө„вӯҳд·ҮМ·е§ҷбҺІз®ҙаҙқаҫ–ж’ҫеҮӨбҳһзҚәвң’еЈҗбҜҷдқҖзҢҖгҢҒеқҢзқја»ҘдҢ“еӣҹвҮұаіӢвғңбһҙзӯҳа №еҶўб” дҖ З©а ўП°ДҰгҗ°ЩӨзҳўзңӘаҫҺгІҰЖҪзёЎбҖҰдҶҗбёЈзҒәвҲ   \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3043,"_status":"completed","_startTimestamp":1775056174727582,"_endTimestamp":1775056174737605},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"100","comment":"","_id":1326,"_uid":"47e7fd37-febb-452a-98e4-38bf31d1a209","_cid":100,"_ctime":1775055939645,"_sid":76,"_stime":1775056174197,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":59648,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:09:33.755Z","time":285,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bxge&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"152"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bxge"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"148:42316[\"handler.process\",{\"type\":\"backpack\",\"action\":\"openBox\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"itemId\":541,\"num\":1,\"version\":\"1.0\"}]"},"headersSize":308,"bodySize":152,"_status":"completed","_startTimestamp":177505617375514