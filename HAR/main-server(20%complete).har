tpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:08:13 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3009"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3757,"mimeType":"text/plain","text":"1352:43297[{\"ret\":0,\"compress\":true,\"serverTime\":1775056093163,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨГ®бЈ ЛғаӨЎгҷҳдҖөж•ӘЕ„В»д ҪдҖ№дј гҢ б¬ бҶ вң Ь вҙЁдҒҰбқ„бӨ вҙқзүҙж‘ҜеҢібҖөдҢ«дҖЈаҪЁдӘұв’ҳдң“б ЈгЈЎвғӮвҷұб№ бҙұзҚҗз©ӯзҖЈг• 6ЮӮгңҝб№ҰМ КӮзҖ©г“„еІҡе•‘б“’д©ӘбұғбҗұвҜЁТ°дЎўе№ўд  бҹ»РІа¬¬вҲғж—ҙдҲІаҘ„д’ұдЎҝд«ҚгҳҒдҰ©бӮҙгүұе«„бәҙвӨІвү…аӘөбһҙдҶўвЈҒб№Өа«—вЈ¬вәҢеҮҢв«ӢзҰӮгүЁдўёбқҫЙ·гҜҘбһІеЁҒз•Ҷб—“вӘ°ЧҙдӨҹдәөж©үа«үз””бүәв№ҺбҜҫеҜҠвӮҳе’ҳгҪўвһІвңҲа¬ З’дҲ еөјКўжӢ в ӨаҝҜбҸЁе„іЕҜТ ВқвЁЈЛЈжғҖв№җдһёдҖўгӮјвҡұж’ӘгҠӯвғұг‘ҡгә°жӢҰеңҮгҢ·аІўжҖЁгІ·ЧҰжҡӮг„¬Лүаҙңзқ©жҮ“аҰҳзЁ°дҸ Г¶<еҶ§ЙҒаӘё.зҖ а  е––бҠҙбҠ“д„ҫдҺ ж…ҖВ“в«ҡг„ӘдҰҳвӨ·аЈӨдұҰзҙ«дҖўдҳҳзё¬`вғҘгІ‘е— ВҘдҗ П§зҖ…в…җг¶ӘаЎЈз¬ңж¶°дҠЎдҺҳз§…д‘Ғв…јгӢҒдӢ–г§ӨаЁ°дҖЈбҗјзӯҮаҪ—е“„гҠҫбҠўвҮ°зҰҸбЁ‘аЁҷгҒ‘Ф Вөе—әзёҜбҸ·зі дӨҜгҖЎжӢўдҙ№еҰҺг—ҲгіёГҺз…°еҲўдҢ BаұҮеәЈжӮҖг©ғВҘЕңжҰүб№ӯзҒӮжЈҢвӣ¶дӨІж“ҠвҚҮв•’жіҺвҝ§ж”ӘжҠҜгҲ·дјЁаЁҙНҳдғҠзӨ°д’ҖдӨҝе§һгҳўеҒ„ж®ЁжҡӮ ж•ға°ӯаёҖаӘ«з–‘в’ҢвғҒг¶ЎЛғаІҮМұгүҸдё…бӘ…С°еҗјЛҖгғҒдӮЁбҲ«дҚҖзҗ№бёҷгјЁвҶЈ е–јд№’аҪғвў®б—Ҙе’җгӢўгЎҫаәўзҒІМ жҒғд“јзЈҒЬҗа°ҘИіе®©бҚ…дӮ„бҳ‘зҲұдҠЁз©ӣдҠЁб—ҳбҮҪеҠҮг …гүўЙІеҲ»дӮ°б–ҙвҲіг®¬гӢІв°јдёҖвҲұдҺ‘а©Ҙг‘•жӘүгҚ“г№ҒвқҚг Әдҷ’б©ӘдҠ’гәҘг“ҳа№®дј“зҖұдғҢвҲ§дҫёа¶¬еқ’гәҺШҖж…ўШҒЖҗв· бҚҹдҫ еүӮвЈҢбҲјвҫЎгҝ„вёҗдҘЁЮіеҰңдЈ«гЎҡбҷҠзІҫвә«ХұдөӘбЈүвұӢзҷҙдҫёеҫЈвЈұд•·д«ҠдҶҠд°“дөҪгҺӢв…Ҫвў«гЈ–дҫ зЁЎв·©д•ўв¬ҠбҚӘв°Ӣб·ҡвҰ»в©¶вҜӢгҘЁжӘ«е¶ҺУҘеҰҶбӮӢзҙ®жіӢж®Ҹд Ҳе„ҙв„ұЪҚвҫ»вһҖвҫіаӘ’дұ’д¶җдҫёе„°дҸ»жәҠвӘ©бөұж»Ӣа©®жҜ°з®Җж«ӣдҺҲжЈұеҝҒд¶Әбҫ”жјӣбӯЁЬёг®ӮжәҰХҙв…әеқәжҙәЦ—зӣ«еҝӮв®җвЁҪдӯізҚ°д‘ӣжЈҪдіҡдҪўИ°е„ЈвЁұаҪ©дҫ г”•бҫӣУ·жҘҮг °дҳӢж”қвҖҡдӯ»б°§бҙҲдӣҶб„ҒбӘ§віЁИ°зҺҹбЎ§вҢқвӢҰжЈҰжЎӢгӮ–в¶ўаө®вү·д“ҰжҫІбҚұдҠҮбҙңдҰҶб®ҮжҜІЩ№вӘ”з•©дҗӘзЁ°д…°зЁӯд©җзңқеў—зүҠд©җзіҪбҫідғҰеі“еҡҚдҘҲеҺҘЫЈжЎҲе „б«қСғж  ВөбҶ“б ©ЭЁаұңдқ°е°®г…ЎгҫҙеӘӮв§—вҒҗбҪ•вҷӮеәҖд·№вј…е‘ҝдҮӮг‘Қа·…дҶҳбҸҶз“қбҝ…е№ЈТҖдўғКғз»ӨбЁ•гјҸеҗ”жӢјжҗ©Р в ¬жҰһд‘Ҷз„ЁбҘ»жҲЁвӨ©дғЈзёҘж¶ҳдҢЁгўјвҳІдҫҗгӮ®зӨҲТ«бҮҲгўІдјҢгәЁеӮ¬гҠһвһһб–Ҝг„«жҺҹж…үжјіз„ўгұҜв§Ӯвңҡж»№вёӯа·Үа©ҘзҒ–в© г®ҝж§»б—ҘгҒҲдЈңЫ№вҗҫбҰҚа»ұеө“КЁгң з ӯаҙўгҒҒе„Ңд¬әЛҒвҺҪб®Ів¬Ұе„ҶгӘҚж»Ӯж¬Ңб©Јжё’дӢ‘ЧҮбў«гіҗеҳ©гҸҶвҰҢвҮҳКӯбі®вҙҗв“»аӘізЎ°ж…°бҚҪгқ¶еЁів«Ҙв•¬гіұе–Әеҳүгўӣв§өг»“гғҺжҷҠд°ёжҲ’а¶ўвө·К”дҠҲаЎ»еӨ°еӮӯбӮӯбһ°зҲҙб…ҙбңҢг‘Үз•„еҺёжҹӮбЁ№гҢ«еҚёжҢҠдӘҖеӢҰж¬¬ж“ жҚҳгЁёеҫ»з®¬в ”г¬§еҮәеё»е…»вҸҢЩҗвҠһеҙӨг“Ӯд Ја»ІдЈ®ж…°гӮ…е«’бҳғзүҮз”ҙгЁҲе‘Ҝж§ҲеһЁжўёг“Ұе“Қдҷ“в®¬бҝ®жҚІг Ҙд—һд’үб…–еҺ“а«©д¬Ҫбӣ”ж–Ід№ҡвөјвӯҮеұјвҡҳжҰ…аЈ–аҙ°вІҮз„ёж°ів–ҙбҢӮгұ„в§„в—Өз‘ӯбҷёдЎ¶вҙ·вӣғжҙӮвҖөвөІдқҖжәҪеӯӣвҘ©г–ҚгҗӘеёўгӮ°бәізүІеҺҷбі№аІҳжҚүв®ҙб”·гҹҒгјҫб…ҠДўеҒ–ОҖгҹ№з¶ гӨ§б№…дһҳзҠ®еҺ»д”Үб© а§©бө—дё©еҺјзҠ°бҡ‘жқұв‘’МҲеЎЁаі‘в¬ҰвҮ¶а®ўгҷ–жҢҢв‘ бұғдҶ бҺҰгЈ¶аҰҗв·ӯеіҝаӨ гј«вӘӮб‘•Еһз…Өа°ғж»“ХқзөңгІёеҺҳз‘јзЈҖвЁ’вҫһв…ҫжүҲвғ„в•қб‘Ҝаў—дҶӘаЎҺбһҝбҲ’е„әбү…ж”ӢжҢңвЎ…гҹҰГӨдүӘбҝ”ж”һбӮЈгЎҒд•ІжҖ…ж«ңа¬ҘЛҷОҒеҗҘгӘ®жҳҢдҮЁбҙҳаЎ©дҗ»жҒҠвҠЈдҚҚП’е«ҮвӘӨд‘ҖгөҜж„ҢеҡүЛҠжҰүвғөбөҒЗҡг§»жЎ»вӘ„дӯөг„ҠеғӨаё¶жӘҘбӢөд•ҢвүҶгһід©Өж©ҢжһӮжӘёгңұжӢҮзҲғв«…аө—дӨӯг•«а¶’д—•б§Ңзҳ«в«әеәөз„¬бӣЈзӯЈз”ҚгӘҡгё§жҒҪа»·ж’ӯеҶ№аӨ б•ўе—•д»ҶбҘҪвҘ—е¶”зӘҡжҶ¶з¬Ҹа¬ҒгҸӢз…—вҖІдЈӨбҜҮдұ•гӣ‘еһ¬б»¶дң„гӣҶзЈәвІ©еҗҲжёІдё‘д¬әеҚҰб¬„жҰҶжҡәд©ҚзӘӮв·өв–ҢеЈўе«№еҜ·е§•бӨҠзө“ж«–гҠҚдҠӯвӣҰе№Қе“әб°ҠХёзӯЁзЁ–дұ’аҙҷе„№бҘ¶бҘҶжҷәз«°б‘ҙЪ„в–“е®ҡдӢ¬Цһд–һд…әе”»б«ӣж»¬О–гҲ§ж–ҒжңӣгҪҮзӯўР®гҙҢа»Ғж®“бқңЫ®гҲ¬вҺҙг¬ІзҠӮзҢҮді®жҙӮбҢҸбӣ¬Чҫз„ҫбЁҒд‘ӢжҸңвҹҰзұҝдҹ°dСҖдҪҖжӮ№жҰҶбҳҙгҜӮб“ӣа®•вҢҖб”ўвұ·ЙҳеӮңзЈқТұбәӣгғӮз«’дҘҠб…•зқ…гҗҒвӢ»жҚҘгҜҝгіҮеҶ·вҰ“б”‘зӮҫЕӢз„…вҘҮг№ңеӘҙвҹ’ж—Ҙгә„д–”бЁҲб’ а«©в¬ҪеҚ…ж©Ҹвҫӣа«җдҙ°в«Ёв¬№г‘Һд Ұз«ҝвЎҠе—ҫеҙҙдӮҠаөёжҜәвғӢвҺҢг’Ңе—ӢзӮ»вё„бҮәеҲҰг§ёбҸһж«Үг—үзЎӯзқ№зӮ«е•ӣбөІжҝёаө’б•”жөўб«јзҰӢа«ҮдҫҚЯұб»„гҳ“жЁҠд¶ёд…ҖвЁҪгҚ®дӯ—вҷ№дҚ№г©©гө§а®ҡб·ҚгҸҹвҲ”зҡҚжҮҹеҳәеқ№жҜ¶жҒӯдҚҶжӘЁбӣ»ЪҚеҠ¶еӯіеӯңз№ҶаҰ¶в°®ж ҠбҺҒж§©вІҢа®‘б•ҡаі«дҢҮв…ҮвҙӣбҰғаұҪзҚҡд°¶вІҚж°Ӯж–¬з¶Ңвё—гҸ®б—җж–…ж–№ж–«жәҰд¶ҺбЁ”б№Ід“ҜвҡҝгәҰзө·вө»в№–г®ҸжҝғвҚ•гӣңТ“дӮ„зҠҖз¬…жғҪж•јд·ҜдҮӨз‘ЈеұӨзӨ№ж¬“жўҸбІ жј°жңјзүҺгЁҰв№өжӣ®дұӢбҸҲдҪ•жў«е°ҙбұ“бҸҡбӮҙв¬ІзҖёЙ§г—ЈзғЈд ӨеӮҙжЈҖаҪ‘еҹғаҝӮж„ гҒҠгҙЈгҖӘд•ҡд” дЁ»жӮҲбәҫе•ҺвҖ дҰЈжЎӮд…ҳдҢ»д’ӨзұҜж®Ўдғ©з’ЁжЎүа¬ұвҪҖз»ҙдҜ‘д¬ҫвҹӨв«ҜжҙҚгЈҷз‘–зЁүдҗ’еһӮдҚ…Н¬а Әб°әд№ҳеҢңж§Ёб“ҖдЁ°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":3009,"_status":"completed","_startTimestamp":1775056092269569,"_endTimestamp":1775056092274030},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1195,"_uid":"555d017e-4a98-44cf-bc5d-2a63180268c0","_cid":92,"_ctime":1775055887626,"_sid":97,"_stime":1775056090037,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:08:09.686Z","time":309,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bd94&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bd94"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056089686021,"_endTimestamp":1775056089692905},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:08:1