01,\\\"version\\\":\\\"1.0\\\"}\"}]"},"redirectURL":"","headersSize":225,"bodySize":244,"_status":"completed","_startTimestamp":1775055724981902,"_endTimestamp":1775055724990819},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"72","comment":"","_id":741,"_uid":"723c78d7-bc35-473c-b309-68bfb5712382","_cid":72,"_ctime":1775055552939,"_sid":40,"_stime":1775055724203,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":54620,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:02:03.845Z","time":300,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9aDqw&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aDqw"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055723845287,"_endTimestamp":1775055723867393},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:05 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"6449"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":8183,"mimeType":"text/plain","text":"2883:43180[{\"ret\":0,\"compress\":true,\"serverTime\":1775055725011,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨГ®б ЎеЈ вң°ЛҷвҘ в’ бҺ’ПҗН“жҒ“;1дҒҮ'MбҒ вҚӣбү©Lб№“аӯҶд“ўвҳ№бҖөдҢҪдҖЈЮҖжӢЎв’ҳЬҗб ЈгЈЎвғӮвҷұЩ бҙЎдҢ зҙҙв”ҲЗҢа Ўе«ҖаҪўвқӮФёдұҢвҢҘж ёж•Ҙбү’д„ бҚҖеҸёв’ зӢ—дҢ§е„ЁзЈһYбҲ бӣ®аў Р·вҸҗвҚў$бҘҺвӘҮдҖўж§Һж–Ғб•ҖЗӯж•ҖгҡЁдЎҫб’Јжј°г‘өгҹ”ЕӨгұңг©җИЎеңЈжӣҙдһҖД«а  бә«ж—әв·•Д№б“’Д–еЁұвҶ—вҹҪдҷўг•ӣбЈҢе№©зҷҒвҲ°Жҙзӣ–гҷҗдҶ бҹ№гң‘зұ§аІҰв Ғзҡ№б  Д°ж„ҶзҗҫМ uбЁІд„ӘПҳгҘіе‘ҺвҠ©дҰ‘ЭЈеҺ©дҠ„еүЈжҖёд №аҘЁеҢҪбү•еЎЈЙЁгҒҘШҜжғ©жүңЮ®жҗҗЩ”еҰҖб¬°еғўКҘН°д ЁО дҶўЩұаҫ·гҢұжҪҗб”ҘгЈҢзҠ ЩҰZв•ҮЮЈв№ғвЈ–г«“вҫЈг”ҙвҢ¶ЕЈе»һб·әд‘”жЈӘеҗәбғЎаЎЁа·ғвҜ”зҲ ж§§д‘Ғгҳ ЛҶв„Җб«ҪдҸң2в·ЈNеҰҚз–ҚбңӢгӣІаі©дӯ„а°ҰПёжЈҢв°ЈВҙбҗ¬жҢја®ғдң…еҙЁжӢғзҒҰеІүз“ЁбҰ°дұ„дәјв—’з‘ЈеҠӣдӨәзғңд¬·в–ӨУЁбҠӣзІ–жұҺС—еёҳбҫҘжҺ©бә©еҢ»вұҒа©ҺжіҗгҮҳдҘҘбңёжӘЁеұҗгұЁеҶ‘дҷҺбҸіеҲ®а ҪЖҳеӯҺб—ұбҒ§а®ЁеІһЭӨбҚ…д·Ҝвөғбё·ЙізЈ¶зҖ№дӨўв•ҺбҪ„жіҳдҢҘвҲІв””е°ұзһ е°§зүјгүҮең°бӮҳдҡЈб»ҲдӮўгҠЁз‘јеҫ°дҒ‘еҝҳдҗұЙҺзҢҒгҹӮдҮңе—һгӢӨз—–е’Ңжҹ–аЁқдҷ’в қВҗаҙЈгЎҲбӮЈвғ”аіўеһ®аҜўСұаҘӮвұ»г–ңз—ҮгқўжҹҢаҰӮО°дІөдҺ§дӢғбҝҳдӨЎвЁ»аҫҪвҠңд«ҚЮҙдҪҢвҹҠдҰўе–«зҒҢз—ӣз•Іг©ҹж— dа ўбҝ•б‘ұа©ӢгҗІЩұж„ігҠҲзғҚгҷ№дІІаәңЯӮбұўд№©еҸҮд°’гәӢгғІЖ–дә’бўҸдҝіж‘ұжү“жҶӮж–ҚзӮҶдҜӨдЎ№дҘўдҘәа®«дӣҹгӣҚбӘӢб…ӘвҖ°дӮўдүһвјјд•ҙа§ІеҺ®вҙ“а©қг“Әгү–а°ҷа¶’жғҖеӣҡВҙд—үжҖЎжәәЗ·вҖ ЙҘж¬°зӣӣв®•вҗ·еҗӯжЁёдҒҶж•·е„ҶгҖҙдғ зһ¶зҶ жҮҠеЎЎбҖёвҢЁд„§в…Җж·ҹдӢІбҙҙвҒ„бӯүДҲдӨҪд°ӮдӨҪдғ жүөдҘҖе·ҮвҢЁдҸ¶вЎӨд…ёвӘӘз…ёв”ёбҹһв©Ҡбҗ№в°’ж§ңе®ҠеөҝвЈ вӮ„жҰәг¬®бӯ°еқЁж®ҠЭ«бҜҖжқ®аҝҡжҖіжўҳбЈҝжЎ°дғјајҰдӮјб®ҖМӘбҰҡбҪҰа»ғд“№б«Ҷз“өзҰҶбіҜбЎЎд©”гӘЁб·ӯгҡүе«Һвҷ”гқ„П№жЈӢж’һе»ҝеӨөаҝјгЁ–е°ҝжҳ“б•“б•ҺгўўзҘҫгҷ¶зҜҫб’Јг ҫаЎҢб—©еҚ„ЕҘе§ҫЛҘа¶ҢСЎзӢҡвіҳХ‘бҡҷд‘ӮеңҖг““ж’…а¶Ӣз«ұгҝ©еү‘зёӨЦ«д•Ңд”Ӣз«ҹбӣ‘зҡғдә®бЎҗвҠЁгўұвҖёж·Өж–җзҶ№б…§в«·дәӣвқҺжұүгҒӯд“©ФҠеЎ«дҫҠв»Үбҷ„бҳ“бӨҪгҖӣбҺҸв—‘г¶”гў№еӣӘеҳ“дӯҳжҷҫд¶Ҡбұ№зӨҷд»“зқӮж“ҮМ—жҹҮа»іб·—жғӮж ҮаЈ•е®Ӣа»Өе№ҺУӮж‘»жҰ•еӯ»д¬–зҖӣжіҲеҳӣбҲ—ИөеіҳгҝҘвҳңЬ…вҺҹвҫ«а¬Үвіөаҝҫе ңвӣ”зғ•дҲӯеңңж–ҙгһӯдҮҳгҷҝб»”дҒӯв§ҹаІ•ај¶г‘°з§қЙҚж—•г–№з—һзһЁб”Ј\\\\дӯ©аЁ©И–еҘЈжЈ„дҢЁбҳөжў–Ш°жүҸв©ңЮЁШідӮһдёҲд”ёеҸ•б“…е–һвҒҙв•ўзә жҙңе»ҙз…ЎдЎ“жҮ“вҘЈЧӮе©ёгӮҰж–Ёдҷ®дЎ вәЁа·ұе©җзө–б¬ғбҒ“ЩӮгүҶбҠүдҡ„жөўб“ІвЈүдө’зҚҚб®ҶвўҜвүҰг„ңбҡҸеұҢвӣӨЯ«дҮҷеҷҳг¬ еӘёбғ•ж”ұгҠҲв§ЎЙҪжҶҘгӢўбІӢд…№жјЈзғӢвёЎжңҪгҗҺгҳ…еҳ°в«ңеҘ·WеҸ©гҹ—г¬Җб§“зҺ‘зӣҫбҖҘб№ҡжҚңз©ӣзҰҹбә©б·ҳд„ЎаҜ–гҶ—гҺӮвҡҲеәӘвҜқЦҪд’”д“әПҗгӘ§вҠ§ЭЁзҡ®ЕҶжҲӯжҝјбү№бІўд–Ёг®ҪгҢҲеў·вҘ–б“‘г•ӮжҠЈжў„бҫ¬еі¬е©…дҲөгӘ…вҮІе№ӣбҹҺжӨҙж№ңжҲ…б—өеі’вһ»зүұжҲҙеҘ©зҺ“аӨҢеҠ»еҠҶв…Іг…ҝб”‘аІҡвҷ·д’–аҫӘеЈ¶вһҫбӢҺбҰғд®ғб«ҙе•—еҪҲжӘ®д‘ҸбӣӮбј¬г•һзҗҢе‘·ж„ңгҹўзіҡејӣз«Җж«°з—§аўҜзҢһдҲўе«ҹа»ғб№№ИҠе”үв”ҙЮ¬ЖўвЎЎИ©зҸҢдЎҗЧЎаІ«дғ–дҪЈж»һаӘ ж“ҘгөҒвғЎдҝүб“§а¬өгЎҸзҗЎдөұаЎЁбӯёб»ғб„—в’ҰзҚ®вҷ—бҲҒз‘ҷаҙёгҒӨгөӢШҡВ„бӮҢвӨ¬вё№аҙ„еҫӘд‘ҳвҠүдғ‘жҰӨд’ Я”бҳЁдІҙгҒҰзӣ•б‘ғв©ұеҶ„вһёвіҠд—ӣЭ©жӯҺдЎ вұҚеҶәвҝІгӢҜжҢҲдҶ©Йіа§ӣбғ«Рұдәңб¬ҝдЁ®бҹ¬д№ӣеҚјвқ»еІҢзҘ»вЁ°з„әб ‘в•ја§Һж©Ҙж…ӣжҙҷгі’зҡҮзҺәжӢҢУӢвҜ®е№јеҮўв®іа©јвӘӮгүҙЩІдҜ“біҢбһҢз…үжҪҙдЈҘж•іг—ҫж°Ҡв№Ёзҗ»бҗҗгҚӘв•¬дј…в„Әжіһеқіз»”гҠҡвӢ«ОҸд§ҠеҮЎаІ°жЁҶб–әдўібӮҠб¶ЁжӯӮгҲҗвіңж—ёд…·е«ңе“–ЛӮе§Ҙвіәбӯ“ж—§а®Үж¶һз ӘдҚ¶бјҜСҷе°ҒгҰғвӘ“бҚёг©ңФ…вә„ж Іе°—еі…е’ҷвҖӮГқбҙҒвІҫбҒ„ЖіеЎ“гҒ’вҠЈжҖ°бқҡбёҜг©ӘаӯҗдғӢдҶ–д¶ғдұ”бҗӘвұҲзөҢа№ҳвҺҢдҳҳб·үСҲжҰЁвқІг…ёб Іж§ғжҠЎаЎ…вүІдӣ¬бҶ¬еЈІдҜүвӮ»гў‘бҜІзҖҢгӢід…¬б„ҫжіҢеғӯб©«д°ҖЩҘе§Үд©ҡеқ•гҳұвөІдҶ„е»ўж«…зҫҰвҜҠді¶д„Ўдҹ«аёҶбӨ…гҲөЛҝ:е® вӯҚгҲӯеҚ©з•ұв“ҳдҲ·ж•№д¬Ёг«ҝб”®жҖІyв©ўгһҙгҘҘа§әе¬ҙгӘ зҲ®е”ӨдҘүбөЁжҘ‘в•қв„·дҚҰгқ©гўүв»өЬӯб©—дјҒеӢ’дӨӘбҜ«дӢӘб¶ғвӣ·КәзӨҙжҘЈгҡҝвүҚжёҠз№·бҜҢжҡ¬зҪ•дә¶жҢ»бӨӘжҜүв«өг…•еәҙв•ұеҜӨзҝ’е®“д°өа»ҲдӘ¶бҝҚж¶»б”ёгҝәЭ•е‘ҮвӘ–бҫ¬в№јжҗ•д»ӣдЎәЧҙзЁ‘вҶӯвҠҪзІҒбҙЎж„ўб…ҚбҖҺе© дӮ¬jзӨұФ°г„Өж’үаҘғгҘҡвҠ„г№ЎеҷңдҒҲдһ§жЎөНұдҗҫе„әЫҺж”әжҠ”аҪЈз’һвҲёбҶҰб іа··ж°Ұг„Ҷбә аўӣвҠҢа»Ўгҫқдһ”жҺ¬еӨҮаҰҗвҝҰз„ҺИӮдЁҝвғңбҜӨз°ҙЬҳв—өзҒһбҖҒвҡҠбұҒаӯҺж„ҰBгү…б‘Өб¶ҷзёӨж“ҠМ гЁҪд…„бІІз өбҖёгҒҢжҙіб—°бҙ§дӮҹб’ҖгЁ§дғӨбЁҠд№ҹбҸҖжёӢеҡҺвӮқгҘ§дҲҹв•–б„Ёаіҝг’ҘзҮҷТҝв”ЁгӢ”гұ…дқ¬в•¬бҙңвұ”дұүвң№вҰҠбҝҡвөүзғЁбҫ¬жЎ‘зғҗгі«бҰјвҺҺжҫ»б„Ҡа·ЁзӯҗвЈ…а»ЈдіӢдҢҘвҫ§бҘјгҘ•д–—ОһдқӘгӨјв¬іа»ғг–ҸдЁ¬г·ӢЫ»жӯјж„Јеҙқгҡ‘дҲҰзҲӣгғ•еқІе•–е»ӯдў“вІқеҙҜд”ңвҷ©дў“ЭҜеө©ж’Јаё№б“ҶгҘҺбҢідөӯзҺ‘вҹ“бҶҢвңҪб·‘жӘіжҷ‘еўҶг—©бЁўді¬еЁӣв•№д·қгҳөж°Әд„–гҢ–г”ҺПўжҗўжӘ…бӢӮе»·гӢҡзҰҺб®ҫеіӢзҚ«зҖҶв•Ёбң«аҜ—бӯёвҪөСҝжҙҶеҡ«зҺ№бҙ©гҡ“дқ”еәҮгЁӣг”јз“…з –гі¶г¶ҷбҢЈВјдҠҖг°өзҹёб…Јг‘үдӮ§гӘ б ёЕ„еҷЁеӮҗб» еҜҺО–д¬”вҲҶХЈз“ҒзөҳгөҘд’һд—«К®еҝға»Җж¬ҝзҪ©бҳЎзҘҸгӮІгҙҒдҠҒОӨзҰҜжә¶е–үж¶ҙдҲўаәӮгӮҫв©®гӮ®жәҸг–®е”ҷгҝ©б•Ҙвҳ…з§ҹеһ®в”Үа¬ҪаҘғбҢҰеұјЗҳе®ЈеұқжӢӢбҚЁд—ҢбқЈаЎұдҘ№аҫўжІҡбҰҠд№…д»Ҳзҡһб§ҡд·№бЁҶа °е®Ҷе№ҪзҖ§аҫ„бҠәеёўШҘдҠҺбҗҒЭЎСҜжӮӮб„Әе»үгӣҮдғҫб©әеҚјвұҜгјЈг®ҒВўзўЈжҠӮШ‘бІўвҡғбҒ“б®ҶдҘҷжіҘд¶ӮжЁҰеҙӯзңҠаө§г®үеү•дҷӯаҙЈбҘ№аҝЁд©ӮгҚіе Әеңқж§ҖаҫғгҸ—бӣӯвҲҲбҘҫзүҷд©қж—ҚбҰҶжӘҷдҒҲдЁ„еёҝбӯҢдЈҲЖҒжө—зҜҖгӢҲгӯҖг№ЁеЁ·дҙҷзҶҠб¶үжӨӯбЈқгҶҚгҘҠзӯҢЫқбҝӘдӯ…жў№дҗ дғҲв‘ңИҖЩ з ӯбҒҺBаҘЎШҜеӘҡвғҖеҙүвғ…жҒ№ДҜе‘ зҢўдү”аЈҫдӘңаЈҚз©җг«Јд”ҙаӨ„з№·жўӮд¬өв”ӮаұјвӯЈа¶ңгЈҮв„јг ЎејјдӮҶж„°бЁҙв°¬з“ҲгҪІдҷіШӯе“ҰгҪ§дЎ“еҢңеүҠеүҹгҜҝе¶јеўҢзјјб§Ҳдј¬б©ҖвҚҳд”ұеүёв’ҮбҡӢжҶ«дӘ¬вҖ№зүҡбӯёеҚЁЖҠдӮӨПҖгЈ•б ҪдӮівӘүб•ја ·жҺҮгҚәд–Ёе ҢЩұб¬ӣЯЁаҘ…бҢіг«ҝд©ҷжңҺдҰ–гҶҗгҫЈдӘҺвұһЫ»еҘЁбӘҶаө•СҰе¶№вјҒбғ„еҠӣд§„жҷ«бғҝгЎ№еҲғе№ҰеӮ»бҘ…аЎЈжЁҙдЁЁзҰ¬дӯЈгЁ№д„„еҢҲв…қаҫӯзҚ…дҜ–еөқж·ӮеЈ‘жҒёвһҳеҳ·жҙўзўҝаЈқжҳҖзғҳеӯҳвӢқгӨ¶вЈ»д§ӯбӣқаҜҸвјҫгӘүГүаЁ®бұўвҚ„ШҢзўӨКҗдҳӮаЁҘж°ЈбҒ–зЎёбҰ°дІҜаөҖдҘқдҠқвӨҝЦ’жүӮеҡқеӨјзө”вЁ„вҰңбҝҠМ·зҺһд“Ӯе”ҺејӘдҡҸд«ғе°ӢвЈқз®ЎеһӨгҶӨгҫҶд“іе—ғзӮҒжЈ©аҘҒд„ҳгіҶдҚјзҒҲдЎөгҲІзҫҒдҡ–д‘№зјје¶ҸзҘ°гөјд »вӮ°ГұдҶғеҢҢжөҢв—Ңг“№жІҢжҙӨзӨҢв…өа ҝеЈ°дЎ°гӯјвңҝеқ“вҰҰвҫӮКӮКғ{дјӮеңӢжғөб«ңвҗғбӘғУҘбғӣдҪ¬г•үб„ғбҒҶеҜҪб—ҰгҚ°вҮҶе§ҳдҘ¬зЈҖз«ҲгҘўг·ӯУӯХ…б©ңаў№еўҫгҚӮвғўа·Ҷд’©зҮҮд“ўбЁҶвӘҺжЁӮв»Ҳгҳёв“ӣЦІв’ІжҳӮзё·Щ·д¬јбё°зҘ”еӘҘе¶Ҳг°¬еӮҗвӘ еү бІЈIМұб Өд ЎбұӘвҸҪеЎ бҺҜдҗӯжҠ§бҘғбӨіЦ—еҮ„вүібҫ…б“ҮжӨқаӨҪзӨ№зө—ЯғдғҢг‘„зҙҢгҘғбӢӮдҡ вқһаӨідҺҘдҝ®вңЈзӨһвғізі„г“ҳбҰЁеә№бҙҫг”Һд—”еҹғзҲұжңЎд–“дўғз’ёз“ұд“јв—ігӢүбЈ’бӯ¬гҠӯаҫЎбқ°Х«дёЈе¶ІВҹв—«дЎ’д‘Іаіҳжқ°вҚҪК…еһ”бӨӢд«‘зҗ¶гЈғгӯ©е“ҪгҠҶдӢ®Щ»дҗғај¶Р¬ж”ҰдёӮвҲұзЈңжһЁгҪӯгјөвҘҸг ўв—…еҒ»г’°вқ¶ві©дҲүТҝжӮҲв°ІдәҚеғёзЈ¬еӣ•вўІдҫғУҸаҝ“бӯғдјҫж°ҮеҮҲеҶҠбҙӮвқҝбІ”жҺ¶гҠӘв”ҙг·ЈдҰүзғҡзҜ…дҙҚеӮЎг®ҳвҶҹШ’г“Ңв®ҢЛңе‘ЎдІәбҒҮеҮ—еЎ з «еө…ЕҖаӨүг’ӨФҝдЁҗбҘЎбһ§зҰ„дҗқдёЎд¬ЎдЎҢдҒ•еҪҖд”©е®’МҳЯ бҖҜа«¬д”•дҜҒгҙ®вҖЎе°„аўҚдңӘЬөвҮҢбІҚзҢӘд••дғӯеҘұзҺҲдІ‘зҚҚдҡүгңҜгўҶеӯңбҰҒвјЎзЎҸдҮёб·Ҳв»©зҪід„ўбӨҢдӨӯдү§бһ…еқҢдўўд‘ҰгӨӢР з ®жҖўвҲҘв® аІ¬жҫһКҺг»үб’ӨгЁҪеҚЁЫүж’ӨаәғКҪбЎЎвҠұгҙ‘в•ӘНүаҝҸЬ№в‘ҸдЈұа®Ӯв„Ҙв—ҙвҘів°Ҡе“ӘвҹһвҶӨзӨ…зҙҠдңһгһқзҫ·е”һаЎқг«Әвҙ¶К¶вӘәг¶ҙеҙ№дӘҹзўёб№„еҡ№зҷӢбҺ¬бЈ”зҡҪжЈҳдғҳШЈдЎ¶зҪӯаЁ•гҒҪзҘӯз’ўб•ҢвҷҪдІҸдЁӯд’‘еңўд‘өаіҡб“ҰгқҷвЁҸбҚ®бҳіг®Әе§Ҷд№¬жҳігӯ“е»ӨбҠҰд¬Ӣд¬іаҙӯзҷ¬Ч’бҜёаЁҸаЎ©дӨјв¬Ҡд‘ҫгүұбҗӘеҖҗж»§вә„жўһбҗ»аЁ®ЫӘжҗҘбӘәзү»вІҜа©үвҮ“гЁІеҠЎвҘ’гӣҳеўјд јв”“Ч“ж©өзҺ–жӨјг®°бұӯжҷҘдҰүг·”вҡҸжҒҺа –бҲғз°«бӣҰв”өа№өз¶ЈвҚӣжҺүгҸ•вҳөд”ҢзӨұгҰҠд•ӘжІ·г„өП’вҮЈеҶҡбңӮгұҚеҳ»еһ‘дҺӨеҝ„жӮ©бӣӨз„ёбұ…в•Қж‘ўв…«г·ёгӘғж’үаҜЈв—җП„бҙ«б–®д§Јвҷід»„еӯІв»«г’өгҶӣвҰӢб–җд„іжҒңбӢқдўұИ«зӨўвҺҪД°аІЈж”«ИҲбҗ°еһӯдӘөвҺҫвёҙзҹҒдЈ®зңқбјӨгЎӢб’ҘеЎһг…ід”өв„ҝеҹәбөІвҪ¶дҷҘбҗ’еҒЁа©ЈзІҪз©ҠвҒҖеҪ»аұҶдқҠб”ңвҡұЛ“вҡҷбӨ¬г…№бӣўвҲңеұЎеЎўг»ҳдҒЈвҷ…жӢ¶Ы¶вӮ«гҺјзүӯеұ·М»гһјзүӘбҡ‘дҳҸбҙ»бҢҢжөҝв”ұв’«д·ҮдңҖжҗівҸӨд“»д№Җз•Өдұ¬г№ўгүізҷ з”ӣжұұжғ«гһ„еө“д·ҖбғјзҒӣгЎЈжўҖеЈҜдҹҒе°Ӯе–ўжҡ жҹ‘г¶»в¶ҝаЎ–бӢӢдҪҷв¶«жҡ°а°«вҒүа»ғзұөИ•г‘әгјҖбҡ‘ИҷД»гЎӨаҘҲајҷЩ«бҚҸбӢ©д®§еҠ„в«·в©•гӣ–Нәе«іај еӢ–вҪЈеҸўвЁЈг”Ӣд— е®өЗҷај»вЈўжӣҙв©ҳа°өб«»гӣәв„ӣг’өа§әа¬је№·гңүгҸ”е«өзӣје„ӣв…ңв»ҘеҘғд’§В’вҮҝд“ІбҮүеІҖеҲәбҖ·ОҺа№§вҹёдөЈдҡүеҹҡг ҶС—ИҷЧҰжҹёгўҙзӣёејҡгү”гӢ»ФјеҠ“ж’ҝгғ«бҗ·гёҳг’ҝбіәзҸҚбӮұдҹҪЕ„ВІбҷЎзһ«зҘҚжҜҲбҡҒеЁҰРёГ„KвҲ бҒ«жҖҪгҜҡе„ҮжӣіеҹҜд«Әдңўб»»е–Ҝг ӘвҝЎеҫүз’Ұбҗ гҘ ејҖб¬іеҰӣвҜ°жЁҚвҠҸг°Әжі„гЈқз’№бү»аұӣзҮ–аҫҝв»җЛ§дҗ·ЗҒгҳ»бҘ¬а§§з’¬вҫҪгЎӘз»ўжғҖжҜІбҝҙвӢҸз’ҳд ҡд‘·зј’бҗ зЈҙж…ҚаіӨа№‘гёЈаЈұжӢҙжҷҖжӘ»е»§гһҸгҸіг„§аі·а¶Ҷг—‘бңҰе–ҜдҮ®г”°жһәбҷ®вҶҜгўһа©ҷдҘҶзҶҫгҲўвҒ№дҚ”зҶ в·Ёз¶ҰдЁ°еӣҺајҲвһ§д«·Фһаҫ’бҒҰбҷ¬бҶҪг•ӮвҚ«з«ҙвӘүаұҲжҜ’б№Ғгң…аІөаөҰв•ўеөІЦҲжЈҲг©‘д“Ҝгҹӣгғ§б јеӘІеҠёзҝәбҷ’Зјз©«бғ«Ь·гҲһд§ҫбұ гҚ—зҶіз‘јзҷӣе¬ҠвҘөКӢв„»дң§зҲ–б”’бұ„д…“вЁ°дәҮвўІб…һбҙ“бҳҮгҮўг…ҹб¶ӣбҹ¶еҲғжіүжӮ«гһЁа ӨдЁӘбҒҚЕҲДұзӯҰеўңд№ЁбӮЁбӨ§а«ІФІа¬ вӨёгӘҫз“ЈдүҖзҗғдЈҖгҲ“гҰңжҫје”‘зӣһвөІбҫұе“ҸжӣҜгіҗжҪҙе»»е“ҸгҠјг»ҳз«һд°Јг®ҡдғөЛҺг§’Э жё¬вғјвҒ¬жҗӘзҮҢгҖӨг“ҝв„Әзҹ»б—ҘдіҒвҫје©…зј¬бқ–дҢ»бҝёвҠҪд»«е ҡж‘ұз„ӘбҷҖжӨӮжҝҲЗ“дј»аЈ вҰҫдҢөаҙҗгҙӯгӣҙдҶ¬зҸјзёғУҙз§Ізғңз¶ёжҪ’жҲҜд№Җж®әб¶јг ҝд№¬еҖҮв©¬г «гңҷР¶гўҖд·„зҖҹеҡҶбұӣеғёгҖ“гё·зі·жҮ®гҖЁжіЁдүҡеӢұајӢгҪЈбүқд–®бҒ»гҘқб·Ҷвҡўвј…ХҰгӣҙвӘ•аәІз¶ҶзһЎв–·г—ҹд·»з¶ҫжөҡвІёжҝ»жҷҳа»ӢаёҮе‘ӣгҷ‘ајҹдјҒбҚ—в‘ЎзҲҒвІӘзҰҗдҠҲаҰҜжҒҢз‘ҶвҺҫаҰұеүӨзӯӣв«–зі№ж–ҳвәІвҜҲеҲ®в„ҚаЎӮгҪғеҒҪж¬ӨгҘ„зҫ…Е¶вӣ·г®‘з°ӨдҖҙа°җаұ гІӯвІӣв¶ҙзөӮдЈ…дЈ»ж–ҫг«Ҷе№«вҰөз§ҷгҖ”еҸәв–Ҹж’”зҖ’дҡҰа·Ұд‘ҜвҳҳеҮҹвңёжё¬жҒёгӣҝжҒ‘в»Ҷзіҗеҷ«бҒ—ГӣаӨүбӘ•еҸ«жҗ”вҒҲЯ¬гЎ”бқ»в§ІМҠз“Ӯбҡ¶ж®Үж—”г§ҪдІҳеҫҶг—ҳг§ЁдӨ зҸёвҒ—еқІгһӣбҳ§е»Јг§Өа·јз„ҰаҪҹж·‘Х“г¬§вҪ–жӣ–бҖ°жҠ—еҪ”д©ҝдё¶в»үТ©е°Іж”Ӣа№ўеҙҖеҸ…бҪ«гҸ…бұҹбӣғд№Ӣг‘үгұҳдҳқжҪӮз„—вЈңг·ӘзҶЁз·“жҹӣдӘүаөҫзғўзЈ”г§ӣжә–дҲ—д“һжҙ·жҫІзқүб“ӣжі¬вһһзҸ»гҝҗжҳҹжҙҮеҰ¶дӮ–ж–°бІ’ж°®ЛӮЙ—ЗҝеҒ¶з‘јбҳҠвҶҗбҘҸд§ҪбҳқбҫһбӨҜПҖе—”бөҠзқӣа«қа§Ңб»№вә“вӯЎдӯЁвҠӯгҢҚв№Іе“ёгҲӨбҪјв•»бҒқдҚҹаҝ‘д–ҢвӯҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":6449,"_status":"completed","_startTimestamp":1775055724139469,"_endTimestamp":1775055724145981},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"79","comment":"","_id":739,"_uid":"3035d54d-f839-4b75-bbf6-64d8e1d9ecb2","_cid":79,"_ctime":1775055693743,"_sid":11,"_stime":1775055723845,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41062,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:02:03.827Z","time":281,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9aDqe&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"127"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aDqe"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"123:42180[\"handler.process\",{\"type\":\"arena\",\"action\":\"select\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"version\":\"1.0\"}]"},"headersSize":308,"bodySize":127,"_status":"completed","_startTimestamp":1775055