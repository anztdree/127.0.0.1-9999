":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41062,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:05:38.587Z","time":284,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9b2G9&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9b2G9"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055938587033,"_endTimestamp":1775055938593091},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:05:39 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3021"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3752,"mimeType":"text/plain","text":"1335:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“ғжҘ•жұ“б •ж§ҶзӨҶж»—Ь•Уҷгһ–д»җгңұзіҳеҡҚеөӢб”©б·җг—ҷбҮҳФҪеӣҠг–ҪжЈҪгһ©зЈҳзһҚж§ӮзҹҫЧҲеҳ•гӣҖгқҳе§’зҳҪзҮүгһқеҹ’Ь№з“җаҪөбҸқдһҶг«—з—ҒПӢв‘ЈвҝҚд“ҒеўҮе§қг«Јзһұд•ҶеӣғбқҪаҝөХ–бҷҚдўӣг“ЈзІҡе¬қаІ‘е”•в’ӢгңЈдЈҷж§ғж« б—ӯЛ”жҡҘзӘ–з’Јз·Қд¶©дӢҒжққЪңдјқб…ҒајідҝӢдјҷбҶһжғҘзӮ„дҪғжҰҸајқжЈҢа¶ӯЦҠвұҘж§•еҖқд’ғвҙ«б’үді„дҠғжҹ«дҰҖж№®гІҚж„ӯгҰқвҫ»бҜүвҙ»ж®ҷжӯіеҮ‘з“•бҪӮбһіжһ”аҫ«гҺҗвұӣвҫҠжёӯзўҸдёӢз®“зҖүж¶Ҹз”ізҫ“дұ»в„үжјӣг„Ӯв°§дӨ“зҰҪе„—в»ҮзӨҗбө…вҺҡе¬ӯеӨҺж·Үд§‘жІ•з’–жҝӣа§„еҷҮа¬…дө·Ж—бҝҮзӣҺе““бҺҚб’·жңҢе··гңҳж»ӣзҡ„б•қгҙғбҫіж««бј·ж¬Ҳа»ҪгҲҠз©—аәҳгі—ЗҡеӯҫзЁҲгІӣбјҹбҝ·аЎӢе—ӢвЁ”дј«гІ…гҫҪгҳҡз•Ҹж§ібұЎИҹдұҸаё–еө§а°үжӯҡеҗҺдұҮзҙҷжӯҮжҙҺб№Ҹдё—гӮҹжһ…зё•д’ӣбІ№дҗҹаІ•бӯҺзҲһз°Ҡб»“дҲңбҸўР—е…№г–ізӨ·ИӘгқҲа·ҰеҖ»еәһжӨўзҹіН вӣ№зҹҡШҖе‘’зёўаҰ–дҖұа»ҹжӘ”еҶ дҸҸеұҡдҜ”Т д„©жӯ©зҷҒб¬ғвЁ·жӯЈеҹ«а·ӣдҰӨзң№дҢқвЁ©еҢӯе–һжҖҪЫҗб•¬аҪҪдҸҮеҮәТҮз§җжёҗзғІаӘһгўүвҶ¬б§Јаі¬ж…ёгҢәжҰ°ХҸв°ЁГӮа©ұеӨёд»әбёЈб·ұН•еҪӘжў•еӨҲж–©дўЈзҶҫдҢ¶е«Ұб»қд©Ңдұјгһ№гҝҺТҳжҲ•ДӢгҢ¶гәӢж„ёбӢғгҷ–вөӨд‘„дЎ«жҘҹг°©аЈӢа®һе¶ӯб…Ҷб”ғбӣ д„јПЈе ҘдҖ бҮҒжҖ вө–д‘ёРЈж’ҜЮҳа¬§дӨ«а°”а¬ҜбҺҢИЎа©§дҖ°РҰж’ЁО ж¬Әеҳ§в”Із№ҷжӢјШІгұҚдҒҳбҗ б”–ДҠбҠұгҖӨЬҖзҘҗзҮ’г—ҶвҷЈдҺ„ж¶ўдӮӢК г«ҢеЁ–бҪ”з©ҠдҗҳвҡҗбҷҖд“ёгҷЁзўҢд§үвүӮвҰҗИҖаёўеҢ®ЖӮа№әдҒ в¶Ұж“ҲНҗзҳ зҒ№бҗізҪіеҚ¬вӣӨдҖ§дҖјеҗӨб°·ЮҖгІ°зғ¶Ь зҖӨеҺјбёӮвҷјЛёв¶ е’ҝдҫҖд¬¬зҖӨИҖа¬ҙжҒҡвҺ„г‘ҙб«®гӘ«зғӯаҪҳжұәаҰҫбӣ“П¬з·ҲвүҘжү»е©ҳеҲ¬зҙҸаұұзңұз§Ёв¬“г“„д«–г°ҒаІ®С„зў«б„ңвә©зјҙв•—жқ«вҘ‘б·©гўөд’ҷзҘҡаөӢвӮҙд«…жіҲж–ІеҒӢеӢ„Л№в•ӣгҫҜбһ“в‘ұз„”в§Ҙдұ»з«¶а®’НҡеҲЁб¶ЈгҠ“дӮҙе® бҒ“Гүжңўд”Ҙбқ’аөғжғҖИўб…ұеқ„зіҺеЈ„д®‘жҷ»д•ҖаҪўг§ д¬ҜдҫҙбЎ¶еҡҳзғҸзӢҜв¬©бҖЎб”®б•Ҡж»ҷж–…в©–е¶ӮвқҷбӢүзў®в¬өб§®ж„Ҹ`а¬ӯвҲ’гӢ„б°©еҹәеӢӨе«“Uд–»аўҰең жҳ»бҠ¶в—өдҺҮдқҳбҸ¬аӨӢЭ•гІјбҰўбүіб•җгҺҒд“¶зүӨЖәе—ҲбӮҢдЎҖзҒ»в·Ӯе©«еӯӮж… вҸ вҒҺв©¬з—җМӣвҰҳгІҪд§№бҢҖзҘҗгӘҡг«№б©ідғ®жӨҸжӨ‘жјҳж¬®жғ«б№“зӣҖеҢ®аё бһүвҗўж¬Ңб°ів©қж «д¬Ҷе®Ғзғ–ж„—гҺ…г¶ғж’¶д№ұе»ҡе‘ҷж‘¶гғҷеі»ЭҹгҸ•аёЈбҳөж—ӨаўҸгіЎвўһаӨӯОәе ҠвЈЁзҜ’вҶҒжү“жҒҙжҖҫе“ҸЩ№дҰ»е—ҖеӘ‘дёҰжҶҫаЁЎвҒңжқҶзҜҙвҮөв©¶вңӯдӨ®аёұеғҸбӢјб®”дӘҚдҖ°г§®б«ЎжҜ©в Ёб·ҰеғҗеҖЎж„ҸвӢЎвҒӣз’ӮдұЁдў–дё©в©•жҰ¶жөәзҚҒжӘҡвҪҮеұӣг—Өг ҫв»ӘдҰҘг  зӮҶаәіг«ӮжҲӣг”өв”Ҳд ҺдӯҠзғёаІӯа©Ҫа¶©еҒғвҜЈж«§в–¶жЎҪд„ҡд«үдЁ„а·ҒгЈ№гҢ©е№ғгҒ–в—ҷг—ӯбӢҺв¬Ёжһ»еӣЈз—ӘжқӣзҲ”еҙ…гҘ б®қгӘӯПҺвўҰжӮҠвҮ…г—Әаӯ’б•ҶгҳӢгҘЈжҹІжҗ—дҺҺвЎұеіүШҮа·ӘдҘ’д¶ҙеҢәбү—б—Әд»¬гӢӘд–°зү§Чҙжө…бҖ§гөЎгҺ¶жҠ”бқјаҝ®вҢ…вҝҳгқҪдҲ„бҸқд“ӣа°һгЎ–вҸҶеһ’зҸҘжҫ–вәҰз¶јж—ӮвҖӢХ»жҜ…г“ӘзҺҸбӣҚгҶҢв«¬зҢјб°Ҳд¶®е№ӢгңҰжҜ“гӯ·жҠҮжҳҙгғҚеңҹвЈ•еұӨжёӢб»»ајЁж°…гһ—еј°зӮҺбңҺгҘ«жҫңзҜ»аӘ©бөүжҝҗг·ҹгҚ–дҰҺбқһгҳҢа¬ңг”өд©ёз өеЈӣбҸҡаҜЁжҖ–аә…еңҢб„ҫгӢўвӢғе№ҫеЎ§е«“аҝ‘бҗҸЖҜвһ”ОІбўҢеіҜві•зҡёбҸ°еҝӯдӘңвӯҸН®вҰҒжҒ©жүҢЫҙвҙўзөҹд—„дһҮеӮ”зҒјзЎ—К—дҪ№з«ҸеҘіжјғдӯәеӨЎгіӢд§ұбҹ»гҢҒеҢ…з ”ж№јв“Ҙд…“еҚҪб§Қај§жғҷг¬¬жӨҙа №еҶўб” дҖ З©а ўП°ДҰгҗ°ЩӨзҳӘгңӘВҺгІҰmзёЎбҖҰдҶҗбёЈзҒәвҲ   \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3021,"_status":"completed","_startTimestamp":1775055938865070,"_endTimestamp":1775055938871450},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"79","comment":"","_id":1019,"_uid":"a8a6c5c8-a265-4902-8ed5-92ad2ebda33a","_cid":79,"_ctime":1775055693743,"_sid":99,"_stime":1775055938586,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41062,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{