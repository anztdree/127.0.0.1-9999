stamp":1775056287941801},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi1AAme"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:11:29 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3236"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":3987,"mimeType":"text/plain","text":"1336:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“”гһ©зЈ—в–…жқҷжӘ•дҮҚа …жӢ—е‘…з»ҡг“ҫвҜ»еңҒж·үгңҚдЈ•гҳӯгқ„гңЎжҸ•е•ӯж»ӯгҗҘг§ҡзһӯді”зқӯдҜһзҘ•жұ•з—•ЗҷжӢӯвҜӢг“қж«ҷгҹ‘жі®е қдҹҗа¶үжӮҸеңқзҹҮбЈҘз“–аҙҚеҝ…СЈб»Јз—¶вҝҲеҷүб«қаіҡдІһе‘үеЈӣз’ЈеҸңаёіж«ҝз–ғдӣҮе“ғбҸһа¶Ҫа»Ҡд№ЎжҚҷа¶ігўҺз‘ғжү“г“Јдә•а·ҪдӘҹз’©гә”дҙөвә—жң«з¬©а¶ӯЖ‘дҙ«КҹзқҘзҡҺвұ«дҶ”еҹҪгҡҢвІ“з–Ғв№®КҚжҢіаҪ—вұҷз¶ӣгЁ»вҮҖвЈҪбҪӮбҷівҺҷж«із§җе–»еҜҠв№»жЈ¶вұҚбӣ–зҖүз®қг–ӣбһ”б’ӢаЈҡг”»вһҖеҡ№ж„ңжёӣд®ҠаІіеҺҡб·ӣе„ӢвІҚвҹҢв”§д—ҷбө…зҸҡе¬ӯФҚв»ӣеҫӣб““жӘҗбө§вҙҳеіҚеҢӣвҝҮзәҸвҫҮвө®еқ¶ЮңеІҘд¬’гҹӣеҙ…бҖЈМӣжұӯбӢ…б№іж«ӯбҪЈзҶҲеә—г®ҖдҪ¶еәҺеҫҜв”Ҡе°ӯбЁҳж·…дҢҒг№ҜбҙҶеҪҫбҳҷжұ·бҫғгІ·жңӮЩӣгңҶж°ҝв…•бұЎаӨғбёҸИҶеқ®а үжӯҡеҗҒд№—д«№ж«·гҲ‘бІ—дҲҮбІҹең•вёӣд Ҡб–№дҗҹвҫ‘бӯ•зҲһз°ҶгЁҝж©ңз·ібё—е ҡгјіз°ҮРӘД’гҚҰеҖөжӘ бӮўзҹҙа¶ҮбҗҘв¶®ЫҝгҖӘзқўаҘһжҲҫжәЁбҙўеҫ°дҸҸе»ҳвһІУҚв„Ҝдқ”а·ЎеҲҙбёӨбҪЈзҸӘРҗгҗ§з»ҠЫҸгЁ¬дӯүз ҒзҖҙбҲҢбҶўвҒҢж…Ғдҳӣж–»зҰЈбң¬вҚӘаӯһвҳҫжӢ”б«ўбү„дӢ„вғәдҒ ФӢвҗ®еғ°гғұз„»е№ҙбһўб“ дҠӯеҚҘдІҠдқ е’ғбЎғгҺЎгҳҪе…Ӯб¬јз©Җз‘ҙгҳҡбһ©дҡ«бҙ–зҪғаі‘ајҙгҲҰбұӮвҮҝв–Ҳг§ҘжҰұж®ҳзЁ‘ж№ЈеҢ©бӨӮеҖӨаӨҖбёҪдҒҢ!аҙ®\\\"жӨјвӢ вҒ–в’ҳгҜ еўҢдЎёзҝҖеЈ№б®ҖбҖҝбүңВ вҖҰв‘ б°Ұе өг“әбІҲжҲ–бҲ жёҰаҘңбӣ б°ҙМ„з¬ з•ўдЈҗИҰзғ№бўҗбҘүеҸҰвҮ гҠҚд… г–ўдҒҡе‘№б¬јз¬’бҗғејЎгӮ„вӣ гү§дӮ„ж•Әб…ўд® ај зғ…бўҗа¬ҜгӢҙИўж°Ұв• бҰ§гҖ§Э©гјёЪҚб»ңж©ҶгЎңбһ…вҒҒжғҳг¬Ұж’§Ыҗг §ВҘбҙҒжјјгҢҖбӣўжұүвҡңз¬ӨеўҮ@ај еЈҶа«із“ӯгҢӮгҡ‘ж‘ЈгҜҢз§ жҢ–д№‘жҫўеҘ—жәӮбұ–біӮгӣҰжү»жһңвҙ’зҪЈаЈ‘вҡҒбҒҜбјЈв№ңбҺ°д‘ҮзұӯбңІзҷҙаЈ’вөҘа©өа°ӨеғЈвҪғеҺӮЬ¶Хҫб•Ұб•ҢгӢӮв§ұе„°ж•Һб•Ҡж№ӣб•№гӘ¶бүўдҷҹгҹҰеј·дёҒз»ӮДҹв¶ҖеқҸеүҠвӮЈе Ұвқҳв…«г ўНҗеҠјзӮЁе®ІгҚ–еүңаЁ вҖјбңәдү¬дўҘвіҢб…өе–”еҸӢб»җбҸқгҫҙзЎҝеҷӢвҘҢдһҷвә…жқҒб–’еһӮжӢ„Ж…вӯҘдҚІвқҷбӢҢд¬Ҳж®ҡжҫ®ж„Ҹ`а¬ӯвӮ’ві„бұүе‘ҡеӢўе«“С•зҰ»аЎҰең жҳЈбҲ¶г—өбҰӮгҷҲзҺ§еІ№а»җаӯҪдҰЈбҚғХҢеҗҡвҲәдө¶в‘ г§ҺеӘўГ©ИўЧ•еӮ»в«ғгүҢбҗӨг°ӨМ…гЈӘбӯҝдў•бһӯдӨ№бҶІвё»бҠ§вҜ…а·қв•ҳвҙӢа»ҙжј•ж¬®жӮ«б©’а»—бҢ®аёўбқұвңңе¬Ңбұів©қж «дЁ¶е®Җгғ–жҲ—гІөХ¬бҡҢж¶Өб°»жҜҠг¶°д–Ҷа®әв·ҸгҠ–гӯұжҒ’жҺјеұЎЫҖгҲ…бЁҪзЎҗг§ҠдҮҖжІҜвҚ„бҳјвҚңвҘӘЖӘд¬җд–ҫбҰҡеҗ«вң№жӮҢбЁҒвҖҙЛ¬зҠҺжҢҙвіҘгўібұ®ЖІаёјбҒҒгӯ…е°®зҳҙж¶ бҖідҘ•вҮҪдҘ°СҡвӣҒгғҖЗЎжҪҘд… вҝҚеҢҺгңҳбҡ¶ж•ҠеЈңвҖәеӘҶгҮөгӘ–вҹҳЮӢдҗЁбҘҪгҠ№ЦҗДҖжҳҘбҢ•вӢ ЭІб“©еҜҸЬ•аҰЎдЈҝаҙ§еӣӨСҡз§ӨжҺ·бЎҪдҺҗдҒЁд§ӯгӮ‘гЈҪж•”гӣӮС–вҳҢз©өбӢҺвҰ’жўҺеЁ—г—ӘжқһжҳһгІҘгҘ б©јжҮ®б’ҺвЈЎдғҠз«Ҙг—ӘдӯҷзҸҳеҰғгҘЈжһўжҗ”жҺҺв©ұе–Ҫж—¬еЁқгҪһзҳ‘гҮөв–Ңжҳҝе·®дұ®в·Ўзё«е»Җеұ…бғ•бә—её·гҠ–дӣ„з·ўв¬қг“®бёҢв— ж¶“еӣҡбөҫбҪ·бҰҷжҮ’з§Қа¬—е’©дҪёдә©ПқжҘңе—ҶгҜ¶е¶ңе•ҰжҜ¬гӘ‘жҮһдӣёж–№е®җвӣ”дҜЁг§ЈвҒҷбӮӮжүҚд«ЁИјбұЈд·Ңв«ӣај®жӯӢгҪ—зһңзҷҡзһ·ж» ж»Ҙж‘ҫгҰӢеӯ«г«ҷе®ҷгІ“гһ“еҳ¶жҜЈИӣжҪҪеӢ№вңүеҘ«СҫЭ»гһҒз„ҸбҳІаӨҫгҢ•дүқе¶Һг·Јдһҳе’”жӣ”бІұбҫӮзӣ¬ж¬Һз”Һбі…зәӢбҸ°еҰҳдӘҡж¬®аЎ®жҫӢг һвҡҫжҸҒж…„гҚҡд—ҮЮҮбҝңбҚјзј¶аёҪгқўвЁҚжј—ж”ҚжғңжҗҒгӘҪеә—жӯҺХҺеҠҗжһ…жҶҢвұқбҙ«жқҫе–ўаЎӢз“ҡб–үеёҗа №еҶўб” дҖ З©а ўП°ДҰгҗ°ЩӨзҳӘгңӘВҺгІҰmзёЎбҖҰдҶҗбёЈзҒәвҲ   \"},null]228:432[{\"ret\":0,\"compress\":false,\"serverTime\":1775056288949,\"server0Time\":14400000,\"data\":\"{\\\"type\\\":\\\"user\\\",\\\"action\\\":\\\"getBulletinBrief\\\",\\\"userId\\\":\\\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\\\",\\\"version\\\":\\\"1.0\\\",\\\"_brief\\\":{}}\"}]"},"redirectURL":"","headersSize":253,"bodySize":3236,"_status":"completed","_startTimestamp":1775056288205247,"_endTimestamp":1775056288219586},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"147","comment":"","_id":1438,"_uid":"537c6d5d-7c7b-4c0f-9e00-d6af34aa4bb0","_cid":147,"_ctime":1775056284918,"_sid":4,"_stime":1775056287935,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49918,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:11:27.773Z","time":285,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cNWQ&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"134"}],"queryString":[{"name":"EIO","value":"3"},{"n