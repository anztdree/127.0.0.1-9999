47,"bodySize":0,"_status":"completed","_startTimestamp":1775056354920524,"_endTimestamp":1775056354929809},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi1AAme"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:12:36 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1117"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":1344,"mimeType":"text/plain","text":"212:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":false,\"data\":\"{\\\"_curMainTask\\\":{\\\"6023\\\":{\\\"_id\\\":6023,\\\"_curCount\\\":10206,\\\"_targetCount\\\":10209,\\\"_state\\\":1}},\\\"type\\\":\\\"Notify\\\",\\\"action\\\":\\\"mainTaskChange\\\"}\"},null]435:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа «д„¬аҙҖж¬°бқҲКҖЖ дҳҰдӮқЕҢЕҗвӘәВҲвҶҖбЈ в® вңЎдҲЈжөҲЮҶбғІе ЎгӮ б® еҢЎжҢ”жҖЎб–ҳПҳвҚ°бһ ЪҒ&ж”·дҒҸе“Ҡбү¬гҢҷСұбҸ’еҸҲжӢӯдІ·бҪЎбҲғбҸ…жҷүвӯІдҖ№д§—бӘҠвҗқбЁӯдө»жҲҚбЁҖаӨӘд‘„еҲЁеӯ…вӘЁб” ЛўзӣізЈҖжҚқЩһбҚ®вҒҘд‘ҡжё°е’Ёг ўеЁӮж№ҲКҙзҹ‘дҝҪдҡ„аі•У№зҗҚе…ҲVг…®д—ңе’Ӣз җжһ»ЛҢжҮ’дӣҲжЁ б¶Ҫеў¶б¬Ӣв•ҙРҡз•ҷжҮӣвЈӘ#дҘҡдҚ№д№¶зӘҠеҰЈЪөжҘғеҙІгӘ’вҚҖбЎҙзҜӢбӨЈз«јзҮЁб”ғвўҘеҡөгҙҺзҖҮг—№вҶЁд§ҠгӯҷжҪ·Д¬ЮқжҰқдҲ„еЁўе…ід№ҠС„аЈЁвәҮжЁқЭҮеҪӮзӘөжқІе”·еҜҪа¬ в’Ӯг«”зЈ®д¬…зҺ”еғӮдҖ„г®ғвң©дӨ№зЈҒеҚҠг•Ӣе§ја®ҡв¬ҙЯҢзӨҚдҺіг«Ігі¬гҰҲж“Җnб№ҠвЎҮгӨёжҸўвЁҘеҒҲг§өвҫ¶зё§бӢҺаөҒдҡҮаӯҒЯ¶вёҙг•–г„‘г•җдҘҷзҹөе»ёЙ¶жөӨвёҲзӣ–аө„д„ҡдЎһжәІгө®дӢ•ж»—гҲҡжүӣж©•бҠһж—ҳдў…б¬ҡе…°жҫўжҢұдҜҠжәӯвҢҡеӯҫбҪӯбҸ°е’ҸдӯӯеҰіг»қдө–г§һгҸҮбёҮб•ұб« жҙҜжҒ•д§ҡзҮ„бҗһдӘҸбөҖж®–дҹЎФҺеҮҘд–ңв·ҙдҒ•еҹӣеҝҚбІқж®—б«Ңгӯ©в“Ұе№«ЧӯзҫҺд°ҝеө•еІҺеЈҫвһұж–Ҳг§ҢгҚ»жӯ§г№Ҝв ӣдҶһб§ҸаӯӯжіҘг¬ҙзҳӢдғ’зҪёдјЈдҗҷзҮҢж—Ҝеіүг·қвһӣзҜ…б–ӢбӨ„М»б§үвЎӯб°Ҷз–ҫбҖөжіЎг°«Нұвҗәе·ҝгҷ„Н§г°ҫдҠ°иҖҶеІҖеҙҸаІ жҢӮвұҘг°¬дҗҸгҗ¶дҺ‘Дҝд–ҹРідҚ°еҚӨМҜа јг¶ҲжҫҰвҢөФёжүҸб¶„ПҸг ҫжҗҲеңөаў дӣӯвҠҘг„јжұҳдӮҠдөЁбҖөз¶ҳз“ҚдҺ—вё¶дҚөв“Ҙб‘•б¬°дҮ„е®…віӮб  Ең#еһ вҒҖ#дӨЁб°ҰвҲ№бҖҙдҒ зҲ¬ДҖзЁ©дҺ№(ж„ЎдҒҗаҪӮз  аӯӢж„җК uеҖ¬ЧҖе°і!жҡҶгҘў  \"},null]"},"redirectURL":"","headersSize":253,"bodySize":1117,"_status":"completed","_startTimestamp":1775056355200452,"_endTimestamp":1775056355205356},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1571,"_uid":"0ff11e97-dcb3-478c-9c53-da528a2c80c2","_cid":148,"_ctime":1775056284934,"_sid":45,"_stime":1775056354920,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:12:34.531Z","time":298,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cdpK&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"141"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9cdpK"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"postData":{"mimeType":"text/plain","text":"137:4228[\"handler.process\",{\"type\":\"equip\",\"action\":\"autoMerge\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"equipType\":2,\"isRed\":false}]"},"headersSize":308,"bodySize":141,"_status":"completed","_startTimestamp":1775056354531993,"_endTimestamp":1775056354553229},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi