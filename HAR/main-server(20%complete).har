alue":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9b5DT"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055950697780,"_endTimestamp":1775055950703940},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:05:55 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1583"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1937,"mimeType":"text/plain","text":"724:43260[{\"ret\":0,\"compress\":true,\"serverTime\":1775055955213,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁЙҗбғ¬гҖҰжң жЎўдҶ¬жҖ©гҖҫжҖҪд„°ОёжҢ бҠӘгҲЎбў°бӣӨвёўе°ҰгЈ а§ бү©еҠ г¬ б§һВҶVбҲ дё аё еӘүВ¬вҷҲдЁ еЈҰе–Ҡв®іК©аҘ в¬¬бҢ ЩіжҘ»еҲӘгҖҖзҷҰдҰҰаў…г“ҷдӯҰд ҙжғҲдҗ дҙҳжөҶбҒјдҘЎвө„аіҙвҜ№г‘°аӘӮб“‘гғҺбјӨд§ҰвҢ вӢҠвөҚг  гһһгқүКұа«ҖП„еӯҳИ”зІ¬жҶҳVеӢӘе«ҠгҲӯбӘ»ві•бҲӘз»ҷвҰЁе©»а»іж®ҙдӘәгҜғд…ЎдҶ№зЈөгӮӢвҝІбӣ’Щ№ж•өе…әеҺ…еәўжӯЎв¶Ӯб•—ж»Ҡв•—дҜІбЁқеӣ…еҝ’вӣҷб•¶дҰҜеӘЈеҲӘгҘҖж“җвЈӮбҙ„гӯ’жү„дўўвҙҫдҲ©еҘҢзіҹжЁ’е‘ӮбҶҪдүҖвҘҙе”јдһ•аі”ж——вғҒдҘҢг‘¶жң®зӨҺгІҶбЈҖИ¶г”ўжё•вҰ¶К¬дҗөдіҺаўўеҖ‘б·„б…’ж ‘дұҺаҜҲжҘҶд¶–ЩӨжӘҶд‘Ўб„ЁбҝІСӨгө„діҗдү…еҫўж¶•бЎҒб…ңеЈҸг‘ҷжЈ•ж••ж°ӘдӯҡбӮ•жЁҰХҷжҶ—гұҒдӯ—ж®Ҝг”Ңд”јдЈҖеІўв¶·дҢ°г«Ҡа·ҸвҜ“д§…бІҖжҜ•зҺҢдІ•дЁүдұҫдЎёбө©зҙҙдўһжөҸз¶¶г¬ҪеҰ…еҘҚж®ЎвҮҲжӘөзҸ–жң—гҸұгҙҪе“ҢдҠ®вҙ«еҘҒжҙҒб¬ІеҖӘжҚ‘еҚҗж”җв§ұжҮғбҰҖаҙҺдЎ ж—Үг®ўа№·ві—гқҺг¬¬вҫіеҙҙбәӣв„Ҝг«ңгө…е…Ҡг·ҷа©Ҫб„Ёе©“еҸ—вёҲжҲөжӨӯгҚҫз–ҘДҢзҗҲб•®г•”жЎ—жӢҙе®јеҢҗбүӯвҲҖж–«МҜuжі©жІ„гө’жҸұеё вңЁгҚӯдҲ©ЙҰв«ғж• вҚҗгәҒвЈҳб‘“вҮізҠ“дёәЮҒдё©д•Ҡд—ЁеөҚвҰёаҘ«вҹӘдңұХ»д„ўв”ӘбәҒдҶ‘д…ҠжҰ«д№Ңжңҡаӯ»дӯ«г”ўдҝ“жһ—дҳ«ЩөЛӘд•—дҹ‘г’“жүӨг№ҷвӣҖжҲ®вғ’вөЈд»©е…ӣв®ҒбәҺжҸІб…§дҠүб“•аҝ’бӮЁдқӮзҘҷд”җжұӢд–‘еҳ¬вў‘зҘ”вөҒаҘҮдҫұаӨЎдҳ©зҗ¶жҪҲжҲ»К“г©ҢбҲ“дҢәж “дҶҗвғ“дјӯв”ӨЭҷв§°г”·б„ҰбөҘжҡЁОӢЬ’У•аәӣеёІб„©гІқд·‘жҙҫб“ҠвөӣвўёЩҲе®ҳвҘҺдҢ¶в”–жҗ‘жұ„бҜ“ХӨбҚёгҠҪдү»г¶ғв·җз„әжҮ“вҘ®дҜҰдҢ вӢ№б№ҺвўҡжІҚб…“вұҠбЎ§ж„ҫд§ҘжһүдҠҗа©Ңвә„з№№б’Ұд№Ҳжӣ§зЈҚвҘҶдң©бёЁж’”вӨӘзӯӨвһ‘з‘Ғжӣ‘ж№ҝдҪүбғ—дҶәв…«в«Ҙз•°е’©еҗ®в№—з№°бҰЁГҢвҚ»вөӨбҗөз№ӢеҖ№г»»еӣӮз©ҙбәҳЖҮжҪ“віӨбҗ‘бғҺдҗ’аҫҹдҫұд¬ҷвһЁаҘҫжөҠеҳҫдҲӢеӢұдң©гұөбЎҘаҘҫвҪҲНЈж«’зҷҠж”ӘбҰ–жҡ…еіӢбә’аҪҫе•ұвҡүдё’ж¬ІеҺҖдқҸд·“Ьүв•»еөҡгү§аӨ—в®№вҷҸбҺҒвјҖдӣ‘ж”ІжҮ«гҘӢдғӮзӨЎж ёзӘӢФ§ж–ҚдӘёгҘ¶жӢ»гҰ“бёҗдҪЈдё…ж°ЎжҲЁж„івёҠзӘҺжј’в…ӯдҮҗг“ұжІүвҶҸдҝ§вҳјг»ұб—ЎбҫҮМ е°ізҺҸд·ёдғҪжһӨдӣҠдҺҖгҘ¬вүөбёЁвЎҮдҫҹдёӮбӢқбӨ’зә•б”—ж–җз§іжүҢвҒӘбӨ¶жҫ«гқЁг•”еҘҙжҘҚаҘөв®ғдІ ж•…жқҝд©»зё¶жёҖвӨҹж»°гҢөб”©бӯҚв…ҢгӨ б°‘з»‘г–җв•ҸТҘеҡҒжҢ®д№Үд–үвәҜдүӨж„¶ж–ёзЈ„бҰ¬а¬қдҚ“еөҳв–ҘеҫҒеҳғгЈ—дҪӨДҶвҶҮгҰҶз°іж¬©дҝ»зҠ•дӣ“б§®д—ҘвғЁвҫҮЛҝд•җГ§бёҖеөЁгұ“НҰв«ёд”Өе¬©аҘҲбғёдөід°ҷг–ҲвҚ’в№„вәҲд©Ҙеҳ·еӮҶ\\\"зҗ бҹЁ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1583,"_status":"completed","_startTimestamp":1775055954323657,"_endTimestamp":1775055954335681},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1034,"_uid":"a3c4ee4b-e40a-4a8f-a3f1-05f2e23ebf6d","_cid":92,"_ctime":1775055887626,"_sid":40,"_stime":1775055950697,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:05:50.275Z","time":350,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9b56r&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UT