00/socket.io/?EIO=3&transport=polling&t=Pr9bOuk&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bOuk"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056031294122,"_endTimestamp":1775056031300556},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:07:12 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3034"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3767,"mimeType":"text/plain","text":"1340:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“”гһ©зЈ—в–…жқҷжӘ•дҮҚа …жӢ—е‘…з»ҡг“ҫвҜ»еңҒж·үгңҚдЈ•гҳӯгқ„гңЎжҸ•е•ӯж»ӯгҗҘг§ҡзһӯді”зқӯдҜһзҘ•жұ•з—•ЗҷжӢӯвҜӢг“қж«ҷгҹ‘жі®е қдҹҗа¶үжӮҸеңқзҹҮбЈҘз“–аҙҚеҝ…СЈб»Јз—¶вҝҲеҷүб«қаіҡдІһе‘үеЈӣз’ЈеҸңаёіж«ҝз–ғдӣҮе“ғбҸһа¶Ҫа»Ҡд№ЎжҚҷа¶ігўҺз‘ғжү“г“Јдә•а·ҪдӘҹз’©гә”дҙөвә—жң«з¬©а¶ӯЖ‘дҙ«КҹзқҘзҡҺвұ«дҶ”еҹҪгҡҢвІ“з–Ғв№®КҚжҢіаҪ—вұҷз¶ӣгЁ»вҮ–вұҚбӣҮж‘ҘдӘҲжҪҡеӘһгҳөгҺ–з•«д®ҡбӯ»еһ”б’Ӣз®“ж№ғе–ҶжұӯбӢӮбқӯвҺҷж°өеҚ—жҫ»зөҒжҫӢвҹҢв”ӣд—қж¶§в¶ғгҷҮзәҸв»Үв“ңзқ¶жҮ„дә»бӨҮбҫ…бҡҡдҫӣжӨ…б·»гӨҖдҪ¶вўҗе·Ӣгһҡе¶Ҡг«Һеј»г“‘еј·жң…г–·б’ аұ—ж„Үзһ“з”җбҙӢдјҠе№ӯаҫҸб°Ҫв„ҷб»»дЁӮжҪҜжҜўеІҘаЁ”бјҮејҡзҜ—бһ’еҝҜзҳ”е»—аЎүжіҸбҜӣеҝ‘ж§ҡе§ёдӨүбјҸб„Ҷеқ®а үжӯҡбҗҒдІ·д«№жЎҮжўңвө—Ш—бІҹдһ…зё…дёҷдҮҢзҗҹгҫ‘б®‘зҸҫз°ҶгЁҝжҶјеҝЁеі·еЁҘгј№дҖ·Р¬аҫ’гҚҰбҗөж«“ж®ңдҸ жіҗв«ёзӮҠзҘ жЎ–в„қеӣһвҙғзјӣж‘„дҝёзІЁг”ҡзҝ–вЈҖж җаҪҷзҸһеҲіЗ·жҺ¬е‘ҹаұ°дҖҠеҒҪбӨҪв°“бҫ„а§ҶдҸҺдҶІзҖҢзұ…дӢ°в¶ҘзҒҙд–ёгҝідғ¶а·Ўа°јб№ұдҡҒз—¶вҚҙгүҘзҫ Я°зӮ¬гӮөе“ұзҖұжёІб Ңг—ҘКӯдӯҘдұјд—Ҳе”‘бӨ…а»ұжҲҫж„ҙжЁўдӣ·дө“е°ҷг®ұд’ е–ӯеЎұгҢ‘РІвҶҺвҖӮдҷ¬г·¬гҷҡгјізҘҳжӮ¬д”Җа¶јз„·гҮҡбӢҖРұжҒңб¶ в° Дәаё ЛІг‘ҘдҒ в№Ёзў—дғҗеІ°еӨҹвғ‘гҘ–жҒҖбғ„г°Ў`бҷЁдҒҳЫҗб–үе«јбҗғе‘„ЛјШІг° в• г№ҜгҖ®еҷүа¬ вӮҺа®іЬ«бүәвҠ„б°¶вӣёбҗҰеЎҲПҠв–іг„ҫдҮіаЎғдү„ЖӮб‘ӯдҶ„дһўж”Ҡд©ӮжҠ·>ДҒж•җзҖ¶Д…еҗӨЛёбҷӘдҒ“ЮҖЬ©дҰЎб ӯжӯ„бҠ№дү гұһж• вҮЎгў–Ч©ЬӯгӮҗЬЎд•ҷжҮҫК…жҒҚдӢёгҘ®зҙ–Уҗжң вҖҫГ‘вҳҪеҗүд ҘдҝӮвҗёз©Қзў№жғҒжјұеҰҺб«’еҮҘжҗ„вӣҡжү®зўІз¶ҜзӯҜаҫЎд әз„ҝбҲ вҪ…вҚүв•Үбіҳв”ӨеөҚбӢҶа°ЎжҙӮб…®д‘ӘгҹҘд©ҢгӯӢдҰ‘б‘җеқӘзёәвә…з…ҪЕұд“«д№Ҷвӯ–гҡ“еҰҚбҹӨеҪҲгҫ“дү©бҙјб–ғбҖ•еҳҰзҲјаҰҶзүЎПҗбҷ®гўӮд®җИҰг„…бҙҒдЈҹбҺҶг»„г°ҙ`ЙҚб«ҚвЁөвў№вұңеҸўд«Ҹа®ўгә¶б– еҷ°жқӯдӘ°Фөд…ёе–Һб•Ҡа«җжү…г°ғж–ҚдһҠжҹүВөвәөеЈҙдҮҝа»Ўжј дҖ¶аөЎзүҘв‘ҳг§Ҡг«…дҮ•гҢҘвӨӨГ“г„Өж¬ҖаіЎгҠӮжҹҡж’ҲгҢҮТҷд”ҪгҒ¶е®ІдҚ‘вҺӘвӢ„ЩӨб®әд№ЁдҒ«в·•ИҘдӨӨШӘа·қбӘөв–ӮжҲӨМ…УӘб®ҹдӘ•бһ«дҘ№б–Івёёж«’вҹ…а·ғв•ҳвҙҲдјҢв®ӯаӨӯг„ҢУ’жҚүж°’г„ҒжҒӮз’ҙзҝ«в»Јдқ•жҸҪГҷв–Ӣгҳ®а®Ңбҫ–зҘ®б•ҡбұҺжі»СҳеҜ·вЁ§б’Әжҳҝб«»в„…зҡ–еҮ гӢӨеіҳдңӯгһ°а¶әжЁ’бҝҮж°ҡдҗЈаҪ¶в‘ҢбұҰгІ’дӨЈвӘөзҒҰеў‘з«„аӯ®б§ жұ“ж… бҗЈдіҙж»Ұг‘№з¶§еЈ«еҘҒжҮўаЁ¶зү»д„Һз…ӯе ўНҷгҚІб·ҷб” вҸҢжЁ¶аЁ бұқз‘ёбҗҰвҶ°жӨҒб§ҰжҰ©жјҰеіҢг„ӢгҡҮбөҜвң„з®ўзӣҳдҠЈб—ұв§°ең аё¬жғІгҪҙв°°з“ӮжІҪеҶҙбӘҶаөәЗұеўәб»Ғбү°гҰҷг…ҪаәҰз¶ҪбўӘвІҚз”әД©еңҮбҸ•Щ°гҷ«г¶„д»Ғж№°аӨҸбЎқеғ»дӘһе§Әе“Ҷе¶’дЎ—зҶӣжҷӢв№·ЬҖжЎ…Щ»д«¶гЁ¶дәүв®’дҜӯд•Ҝд·…ді”гЁ“бұ«гҝ°аҜүгү·ж•ЁеңўжӢӯбҝ’вүҘе«Қзў°Яқбғ—д®Ғг¶·вё¬еҳІжҸ»жҪјгҖҡзІ№Дӣж№«зЈҗдҗһжҫҡбҰ•еӣ’ж·§жҫҺвұҰз№јв—ІбҙӢбҮ“аҜ®НҮв«ҷбҠ•вӮҺж¶ӮзҖ•з’әб®Қеә«ж‘ҢгЎҚгӯ–ж¶Қз–ҠжҷӨжҙӣд°»вҮЈд’қе¶…З‘з„•г»—д§ҡвҡҺајҢгңӢжҙӯеҪёбёҮбҮӣзҮ’г®ігҡ·вққзҷҫз°Җжј•а№Ҫеіҫз–ҜХ»г“әгӯ зҘ¶б…ҷзһ г©ӯж°ЁбіғеЎҳв’”г°…аӨЁвҚҜг’әбӨ—аҝҫб¬Ҫгҫ’Э„бҹәдҳӣеӘӢгө’в ”гў‘Ч–дҝўжҳӮбЁ–вұҳХҳг—ҡг°Ҙбҡ•бӯ©а·®жҰүж„ҷз…Ңд”Җеҫ•дҺӨвҺ®вӨҮзғ•гүӮз©–бҳёзҷІжҜҺжҳһб»№д№ҡг—ғбҰ·бЈ‘г„ҢзІҜж«ҶЙҒзҚҸа¬Ҷе®ңИҰг’Җд• бҖ В’вҲ д„”aдҙӨЖұб¶ ж·ўдҺ»дҪҒдӮӢгҫ вҗЎеҒјЮ з°¶дў   \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3034,"_status":"completed","_startTimestamp":1775056031658208,"_endTimestamp":1775056031665364},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1086,"_uid":"12bc5292-c0a5-4402-a5ab-9e4441642228","_cid":92,"_ctime":1775055887626,"_sid":54,"_stime":1775056031293,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:07:10.953Z","time":288,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bOpP&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksil