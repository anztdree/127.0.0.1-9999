,"cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:03:25 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1600"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1953,"mimeType":"text/plain","text":"727:43204[{\"ret\":0,\"compress\":true,\"serverTime\":1775055805615,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁЙҗбғ¬гҖҰжң жЎўдҶ¬жҖ©гҖҫжҖҪд„°ОёжҢ бҠӘгҲЎбў°бӣӨвёўе°ҰгЈ а§ бү©еҠ г¬ б§һВҶVбҲ дё аё еӘүВ¬вҷҲдЁ еЈҰе–Ҡв®іК©аҘ в¬¬бҢ ЩіжҘ»еҲӘгҖҖзҷҰдҰҰаў…в—‘б ӘвӢ”жһҲб•ӯд©әгӯ‘ЖІаӨІж“үгҡІгҮЁеҶўвҲӘзұҶв““ејӨд§ҰвҢ вӢҠвөҚг  гһһгқүКұа«ҖП„еӯҳИ”зІ¬жҶҳVеӢӘеҖӨжӢөвў—в°өа©ӮдҘ«вғјдҸҒв¶®жЁ»д§©бҚөвӣҠХ‘з“„д–Ӯг•әеғҫдў«в’ізәІеҢұб»үд¶ғеӘҮбӢёзҳјг¬өеҲҪбәҘг’әзҘғеӣ„аё№аӯ„жұӨзүҮжҘҷгё—вҮҙе¶ңеҚ…дҚ’гҙңж“ҠдқҶж¶ҺејЈж„«б°®вӮўдҰӮж§–аҫ¶дӣ•бўЎдҸӮжҺғе¶Ұеә§вӣ—жө¬дҘӮжҢЁз·ҢгҶ°ж–Ҝгҗҙб»ҷбғҖгёҶж»Қдё’гІ„д¬°жөҶеЈ”зҸһв Ҷжүүд¬§вҝ•з‘№гӘ”д№”дө„ж’јдҒҺдЈҙзҘўеҖҮеӢҠб§’жҰғв®¶жҜҹвӘҗжӘҷв»ҹв ”жҢ”еҪҹжүӢб°¶вҮһжЁІз”өеүәе«®еҙөвӮ¶еүҒбіһж•әбһ„еҙҰЮ·е»·з§®д•ҳе—ғаӯҙдҘһвІ”дұ–бЈ®еҢ«зҙҺзҰҜж»ұдөғд–Ҡд Ғдӯ…дӨ©б»ұзҢҙз‘·вҮ–Сҫбҙҗг»‘г¶ҡМҹж®Җв°®е®әжі–дҚЎеҚҷбҚҲжёңеҰҮвҒ°бҡ…дӨ¬жө—д°–з”ҮвҚ’НӢдЈӯд¬өаі¶жҶҝжӢ”аҙ®г№¬еҸҢг·әеӯҲвҰӮеқЎбә’жқ„д§‘д–•жҪӢдұӨжҷ®жӣҗвҙҷг·Ҝб—ҒгёҚЖ•гҪҺдІҶгҶҒж …Уһг—Ҡбҡ‘ж’ӢС“гҷұд’ҡжҪҚдӘЁвҘіаӨёвҰҹдЁұеҡҺдұҗж…ӣЫӢгЁ№дӢ©гқҠдғҖвҘ°д©’б•ҹаЁ«дқӨб©җд…ідұҷе‘ідҺ№гғ“д®Җз„ҫдҢ“бҠӢаө’з№ҚаЈЁбё¶в—ұзҰ‘вҠӣе©ӣеҖҗеқҒдӢӘбӨҪдҹ»дӨ№аұӣбҚҷд№Ҡвәҹжө‘КӢдһ“з©„вӣӮеӯҹЛ’бҘ”жӯӘв№ҢбҖӨзӮӘв®ҲжұҘаҝ°дәҲж©ӣв„ёві©бҚҫб¶§вҷ–бҪҠвҚҰв¬ұб“ҷбһҗжҚһвүҒЕқвҺӘдҪҖжЁҮз°ҫд·“гЁ»бҸІб‘өа “аІ№вҲҗжҚһж‘«д®қдҸҗзҷЈд¬ұгӮөд«үаӨўд°ғеҶҒдҺ…еўјв°Ӯв’ҖеҳЁаЁ№вҚ§аҫ”вҶ«з•ўеЈЁвқҜбјҮаҪҘаЎ·дҠјб«Ӯбңёбіҗж•ҙвҲҮв°ёб¶ҒеҷҖбҢёзӯқжҠӨж‘ғвҡ‘гҗёбһғЙҖеҖҖжұһжҙёжғӘвҫіж“Ұв”ӣв¬Ҫв’»гЈ§жҙӘзұ‘д©ӘдёјбӮ‘б–Ғж”Өвң ж©“МҲв «еқғв¶өаҘөжӮ“дјҝбғ©вәӯеў“вҷ‘д¶“з«»дЎ“Эӣаё·зҡҗе©©зә–б§Ҙд„әеҚҒб№җвҝүе…»дЎ¶г…ўж¶§зө®жӣҘзқ»Щәз№»дӮ’жҠҒж®Өе№ҳж¶ҰгіҜеҜҷеӯ“ж…ҳжҢҢгүҒаӨ№Г‘бө©дұ“б®җеҰ‘г©—еў§г®“д§әдҷәв©“гҷҘжһҒвҷ–біүгҷ„бҸӢз«ұдҒёеә•в•Ёжӣ–г¶¶жө©гІҳвҘ•вҝҙа®ҹаӨӘжҺ…вҢҰеӘ¬жҒүдһҺд–ӣаҪ•nбІҫе®Ёзҳӯдғҙа§ҸдӢҷз¶“дҹ«г—®дқ’д…ҡж»ёХүеҒ®гі¬вҳ¶дҳўд–ӢеЁӨжЁӨвӣҖвҙәбҰүб¶ӘЛқж°івңүдЁ©г„“дҡӘд„ӯдұ–дүҝеўҘзұҗв»ҡб’ҒдӨ№а·ҲгІҳбҷқжҡӨзқҡг•ізұ”вҗӘб•‘в№«д•ҹдӘ…е…•вҘҲв№Үжіҗг”§дЁ°д„…вҡҘИҫдҠ“вұҹаӘ“ЙҘвј®еқҘжӣҲвЈӣдҗӘа«»аЈҺдҘ–б©ӨбәқдӘ«д№‘дө№вҰҚдқҗжҺҢе№Өвқ“дҸӘз°°гҲҠМўгҶ—е…Ҙе°ҡбҡҘж»ідҘ®ж¬©вҫҷд—“гәғз°«жҙ„д…”еҷқЕҡгһҚдӘ’гҳҗеұҺжҜӢзӣ„бөҘжі№ж§ёгҳӨзӮҝбҪӢжҶјж§ҒгЈҖ}%зӨ   \"}]"},"redirectURL":"","headersSize":253,"bodySize":1600,"_status":"completed","_startTimestamp":1775055804718929,"_endTimestamp":1775055804726285},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"72","comment":"","_id":841,"_uid":"975c811e-32ae-4f1a-b6ec-c7dca91958ac","_cid":72,"_ctime":1775055552939,"_sid":70,"_stime":1775055801642,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":54620,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:03:21.253Z","time":290,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9aWkN&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"428"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aWkN"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"424:42203[\"handler.pr