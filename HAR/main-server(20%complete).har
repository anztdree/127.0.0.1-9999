status":"completed","_startTimestamp":1775055865921802,"_endTimestamp":1775055865927308},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:04:27 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3021"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3749,"mimeType":"text/plain","text":"1340:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘ұе№ңд“‘а§»гЈҒж’¶зЎӘзҜҘд•‘зЎ—Х©Йӣеӯ„бҝҫвҳһдұңв”Ўг…•д–Ўж§»бҰ‘е…ҮдӣЎг№ҳЫүвөўжҲҺеҝ зӨүзҚӮв‘Ғвӯҡд“Ғбӯ“вҳҠзӯ‘з©ҷгө’вҡЎж·јУ№бЈ®ж’ҒжҪүв ‘д©җжһЎдҺ»д‘ҷзғ’ж ҷаҜҘШјеӯӢв–ҷдҷҗЭ‘жқ‘бқҒжқҘб’ҷзҜ¬жҹҘзө…жҹ‘зҒҒгҸұд•“бқүЕҹЦҠЦөбҡҷаҪӘеһҒУҗвҷҫЫҶз©өСҳеҳҷзӣ…Ъ•жөұеҳөгЈҡе‘ҘгҸ®еӣҷжқ°гқҡЛҺеЈ•аӯ„е”…в§–жғӯбі»еңҒе»ӣбҹ•зӢҲг—®а·Ңдңҷж·’г–өж»°г—ӯз»Ўг•ҷб•ҷгҹ‘жі°гңҘг“ҷе”•гҮҚе’Ҫж§¬зң–е…Ҡз”ҪбҜҹеқӯбқ«з’ҘжҒӢгҳқзҹ“зқҳдЎ”жҡӯеӣүг”ҚаўқгқЈгғ•з—ЈбҸҖгҳЈж«ўзққд·…а¶№еӢқа№ЈдІҳгһүж’–аё•зӮһз’ғдӮӢаІЈб’ңд·‘аҝ’дёівўҳаұ‘дҸӢб–ЈЪҲжҗівҜ¶бҡід—һдё№вҡ–жӮ©еҡҲе—іжҸӢдј«бҚҢвіЈЖ’вҙ«бәҶб•ғаіҢдұӢГӣд°Јдҹүеҡұвұһвә“д§Ҫа·ҳжҠқбҹ“б«’бқ©в¶Ҹгҳ“е–ҹв»өвҰҲжҙӯбӘҚдёӢжҜһж№Ӣв®ҡбЈ»гҺңгҗ№а¶’дј»в«»ж»ӣеҝқжІӢе·ҳжҪӣзҶҚв°»зҫ‘жҫӢбҮҹд·ӣа®ҚвңҚг‘–вөҮе„…бҝөб»®в”Ӣбһ—в’“г„ҚвҷідІҳбё·зҺӮг‘ӣВҡеЎҮбҠ–жҪҮв¬җжі·б’ӨжәҘЬӢбө—гӨ…е№§зҢҮж”·жҙҲвҡқж«Ҫбөқе¶ӮејӣеӢҚбј“б–Үж·қгҷқаҪ¶жҜҜеәЈжҢҮбөҸж®–гІ§ИӢеІ·дҳӮЫӯбҳӮв»§е”ҳгұЎвӨҺв№—гҫ”з№“е§№жӨҝбӨҚг№¶жқҘд¶ҜМҹе№·ж°—гғҹд„Ғз·»дҲҺз”Ҹеӣўе®ҘзӘҮај’зҪҒзҠ¬б ҠбјҷжҙҪзҝ·гөҹа§ұд°ҫг©ҮЮ—ДңгҷЎв»…еёіжҪқд·№Н—дҚҷеӮҮзҘҜбҲ©е№ҖгҺһг өг№„бҳҷзЎ”КЁгҠҡжәӯЦӣгҳЁзјҰаҫҰбЁјзҷҹвәЈгқ®зөҒд”§жҡ«ж©ҹ(з„’аҝ®вёјвҶ¬б’Јбғ®еөӯе®ҳв’ңбҘ ж…“зҪҠаІұбЁібҮёжққвЈЎг¶°г ӣг»Җдҹ дҗ¬ВҪаҙұХҸе…ҠбғӮзҹёж·ҙгҡ№СўХӯбҰҰб¬ёаө‘бІӢгҶҰбӣӮгҸөд·Өв¶Өв§…д’«ЗідӨҸа»ҺЬҝг„һбҺўе©Ҡб’°в§ӨС«дҗёдҳӯУ¶а·ЎжҘҖвӮ®ИҒж°ўжҖ аЈ°зҖ бҡЎжүҢИЎгү§дҸңЦўж’Ҙд’ҰЦҘд§–Д зҘғжҖЁИЈеүӨЗ г–ҰвӯҜаӯ‘дјҶзҮҝЬҖгӮіжҒҘдЁ зҠӣЛҚЕЁе ўОҗвІёгӨүбЈівҚҒжҮІгӣЎвҒ•д… Н·дҙӢаҝІеҳҢбҮҝГҗжҳ№жӮҢбө„гұҡв‘ҙе„°б“ҳДҗЬўвҰ§Г‘гӯҚвҒҖбӣЈеүҙЖёг¬ гЎ”дҙ¶г …зҶ©бҹңбё§гӢҖб„ҖеұӣЖ„дҺҰеЎҳО Кјз„Ҹа©’зҖёЙӘгёҮеЎ…дҚҳД з Ҙд•җбҡіаЁҶбҡӯзұ–вӢўгҒ№жҺҪЪҲз©ӢжҪ…діҒгҡІв„ІФівЈҒбҸўв№ӣаЈҒЦӮз«“жҪ§д¶Ўд°Ҹд–Іб…ҖгӢўдҢүг®ӨвІ’ЭҲзөӢгӢјвҰ…зӨізҮ‘З«віҸдҜ©гҰөдӮҸбқ·аөҚвғӘвҘһеі„ж—”е©ӢЕӮбҠҮбҺҰеӘҖе‘Ҹв‘–еЎ«дўҗзҰөдӨӨа»ЎжҘҷжҖӘв· а №дӮҙзҺЈдҠјдӘ№бӘұзҒ°ДЎеғҸв°Ӯв–…жұ®зҖӘеЈҢвӯ¬в ©бһјдӢјеҪӢб»•ж’©г·ҷв•ізЁ зғӢд¬ҡаё•дҖұбҳ•ж »вӯ‘д©Ҫв…·дҸ—жҸҗгҜ бҖҘдҚ°жІәвӨ®ВӢеӣүг…ӯвіЈд©ЎЛ¬жұҘж«ҳНҗз’·бӨ®еІңдҮүв¬ҺвҺҮвұ‘е–„зҪЁжІўдөүеә°ж«ҺЦібҘӮВӯвіҙаЎҡвҗ°бҒҲеӣ·аЎ…бҖўеЈ‘Д вҘҙгҺӯе°Үвө«жӮ–з©©г ҪвҪ©дәјгҡ•б”ҒжҸҗг®ӮвҶҙдҒ•дҸҗгі®аҙӢв§©дҺ§ГіеЎіеҪһг¬®Гҙзһ”Г…гҮҚеЎЁв·җа·ҙд—өжӨ«жӯ–ж„®аҙ”б«ҺжӣўеҰ§вӣҡж·№ж¶Ҫе’җаіҗжқҺбҲқвӣҰгһӣЮңб ҫвіӘж Ўж··е”«ЬұдјӨеҠҹгі…гұ–еҳјЫҲЛід“№д–Ҙе•°аө“гӢҷжҸғв§ҙжңідҸ„дҺ§Сҗв®җе—°в§–aдқҹв®ӣвӯ…вҒҸг ҠдӢўдҖ§Гқа¬ҘВҜе§«жғҰгҰәвЁ„е–Ӣеқ©бҰҠдІ»вҙүвІҫзҒӯең°дӮғеӯӘгӣЎгүјXбҰҰв’ӯвЈҗж»ҝЧўгў«зІӢд¶ҸеӨӨдҺ„е’ҡжҘҠв•Јб®ҺзҲӮв—ёе®өз„ӨжӢғв“Ҝвҙ„Чҝв’ҺбӢ§вұ‘жқ‘гҗҸжңҮзЈҘб‘ұвҒ”біөбқҒг№ідңҗж°іе Ҡаө„г»ІбҲҘб—Җжј¶е–ӮеЈ…бҶҝе§”в°«еқӮд©ҺдҖҶвҰҡв«Іж‘„еў—д¶Һд©ІаҰЁе «жіҳЕүв…ҙзҰ–ЭЁзҚәбҲҪд»ҷе•ҝгҰ«ж°“дӯҹд¬¶бҶӣж»ӢбӣӢг°Җвҫ—е–ҰжҰәШҮЦ«б№ҝа¶ӣжҶҡдҰһеҡ§вғҸб°Ұві•дҚҫајҺбӨ«з»–дҜ®С·дҡ“еҡғвҗ вҪҘвұІдҘәзҳҲе№–д—ҳзҺ…гңҒд¶ӢжңҶз•ҘбӮ’вҢ•ж‘№з§ҳд‘ӣе“–в¬ҫЗ¶еҡҒзңӨжңғжјүв·қеғ№з«…еІӣзҮҷдӯҸгЁ—е¶ҲзүһжҫҺгӣ·дҠЈдӣјб°ҜХ»ж“ҳЮҖзҙҜе®„в¬ҡжӨҺУҪдүЈз•ҫд–Өдғ§вЈҷеҜ¶аҙ—в¶ҮжҚҗз¬ҺзңҠж“°зүҰз¶ҙгўӣд·ҡеҚҳзҪ—б§ҺдёӘжҳӮб§»вұҳв•ҷе·ҶдҖӣе§ҷбҜҢзҚ–жһҮдә©ж§ еЁҖе»Јд“ёдҮЎг©§жӢһе®ёз§–гҷёвёҪеҗҶд»јвә©жЈ№гўҷгЎ«дөһеһ‘жЁ“жҙ”дҝҠжғ®в°¶еіҝТ вӮҶдҳЁеҗў Э„вҖЁаҪ Р№еҒ бӨіеЎҚеұҲЧҷзҲёЗ—з ӨдҖәЧ з ҜдҶүа   \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3021,"_status":"completed","_startTimestamp":1775055866664019,"_endTimestamp":1775055866670764},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"72","comment":"","_id":880,"_uid":"52771f6e-93d6-4f1a-b252-356fe38d31b1","_cid":72,"_ctime":1775055552939,"_sid":85,"_stime":1775055865921,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":54620,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:04:25.397Z","time":306,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9amOg&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"127"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9amOg"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"123:42214[\"handler.process\",{\"type\":\"gift\",\"action\":\"buyGol