eType":"text/plain","text":"822:43131[{\"ret\":0,\"compress\":true,\"serverTime\":1775055518951,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зқјНёжҖөв•–бҖҘг ¬зҚ в’ бҢӘПҗЖ»зҖҰгҖЈгҖўб ӨзҖ зҖҘеҠЁТҶз—«бҖҘдҒҒг–Ңж’ёеҙғгҲўеўғг  гҖҪаөәбҒӨзҪ“аЁ¬бёөз ҙгң¬дІ°г·„зЎ еӘ»г»’з…јгӢҢдҖ©дҢӢдҒ•ШҠв•ҘвҮІгӯ”гЁ»Д а·ӮPа®‘з§Өд©Ҡе–ҺЛ„дөЁвұӢбҡөжҖӘдӢЈвӢІОңбјӯдҳ©вҜЈдҺЁб Іе–ғгҠңвҢӮж«ҳе•®вҲҖбҹ¶аў»дҳҗЙҡе«ҪвӘЁ7вҺӯж•ҘжҖЈдіЁ*вҲёгё¬.вӢ Ч“в’№гҒ¬дӯҖаё а¶ е®—гӮңгӯӯЦјвәҗВҺг‘–аҘҷб„ЎвҖ§в…“б  г»қдҰ§д… еҒІвӨ„вҶјеқӣдЁ„д§ңеҪҠеҖ„Цўб•ҳвҒ„д—ӮвӨјвӮұжғҒа° Й„вҮҗеӮӢеңЎГўаЁ·дғЁв–ўAвёЈдҖўУ гҒҠВӨдҸҺбЎҮж¶җвҒҫдүҝбәҰеөһ,дҫі+зҖі+зӮ…бҲ гҠёа®ўзҗҖХҒбӣЎгҶҖеҗІеҚўбҮҺжҜ„еҝЁвғ®бҒҗб”§вғ бЎүаұҘжҶӯвҘ¬е° в©Қж¶ҺеҝҢбҜҺ2дҳЎжҶ ВҒгЁҘдҸ•д¶Өе—ҶжҜ•а ®жҝҹжЁ¬дҺҖбўӮж ўбІЁа·үЫ–зүҚвҲӯе’‘в‘ҒгҰӢе°ӯвҹіг– Л„гҘҗб„Ңзқҹдіҡд–ІжІ®в№·б®”бҠҰд…Үд—”ж§’еҹҢзҖӯгӮҫбӢҒгЁәбҺӘвҖ©жғЁвў’бІ»еҠӨбҚұгң“вӣ№гӮ»дӮ“ж«Ёвқ“ИҮеіўзӮ№з«ҒеҪ’КўД¶жӮӢвҮҙа·‘аЁҠз ҪвҮұаұҢз өеҙҸе–Ҙбё”зҙұг°ӯгёҳвҡ°дҫҳаЁұзЎ·вӮҖд°ҘаЁӣгҪ°бғӣЖҹжҠ“жӮҒаЎ№аӯҪаӘўеҒӮЖәгҪәжҜҷаӯ…жөҠбҪ»жҢҷж¬°ГҖдұ°д„§жңІб ҳДӮбғӮб©·вғғТҗбҫ§гҫҡбҙҰжғЎвңӮе‘ӨбұӢе№ұвЁҗг„Қжқ№зқ—вӮүа¶һб¬ӣжӯўвЈ»е„ңбҰӨаӯӮж“«ЭәЩҶУҒб°ЁжҖ ИӢЗҳаәғз  віҺЭігҺ¬еқ•дӮәжҖіжҹүЖ дӘ«З¬гӮ©д»ҳжЎӯНҚжғҠв“ҷдӮЈдөҖгҗ М°жӮҗвҗЎЛЈд¶Јбғҳб’ЈжІ…еЁ§зҷҶв„’б»ҹРЎгұҸбӘЁгҮ”дғҘбәӨеҙ•в«·б¶ҙзӢӘвӯ’Й¬гҸ“гҲҗб‘ӨвўІбҖөТјвңӨгҶ»еҰ¬еҶҗг‘§гӨҹб© е–‘вІ¬З•в„ўг” е§ҺаЈҚгЎ§гҳҗвҫҘаЈҺеәҮжҳҗб•§зҳ’дңЎв—ғгә°еӘҘгҠүГӮб—Қа іг—ізғҚвҫҘвөҳЕ…а·Іа®үВІб—ҢдӨӣгўӯг—Өв”Ҡе—№еҰӯг„ вҶҚеҠҮг‘Ғбөқг’Ҹе…Үв’Һеҳ“еІӢд·—вә®дҙҝвҚөдөҗв Ңе•«вҳүв·ҝвёӯЖ”г¶үг¶»вҲ»бӘ”вһҸзҙӘаҫҸдҸ’дә¬бөҸгӨӢвҢ«вҳ…г•ўдңҪг¬Ғбј№е¶җг‘ҶаўңаЁ№жғҒб’ӯаө”зҝҺб•ҘаіҺгҳ„зј»з–ӨзӘҝгө·гҒІзө жёӯжҺҹг®јЖ зәҠбҸҖиҖҚФҖжҫјзёғаў№дҢІжёҫд°ҲзӘәвҚўз№Үж·ҒбҢёдҜёжҘёвёғбҹүбЁ“дҖӮаұҶб“»б°Ҷзіҫз–·гЁ–зё¬гҫҺаЈ”иҖҲг°–зЁҠг°ҢзқҪг«ўа®№е¬ЁаҜҝе®ўжҹҝд…Ӯз №ВӮбҹҠдҜӮжң еҸқг…јдҹҒз•јЯўб”ёзӯұжӯәа®ҺбҫҚвӢҚг”ҙжҹ¶ж°җвғҠб’ҝбҲ’е•ӘТҢе¶‘ж—өдҪҸз¶ҰжҖ®аӨҶб©Өг–”вҙҸз—ІП§з°ҰаўҝжҸҚзғһб®ҫзҹҸз”ҙжўүжғҫзҪӣаёӣвҒӣаҝЎзҫҪг¬ӮжЎёдқҒз№әаҜ‘ж‘ҳвһғзҘӣдһүзҒҷж®‘з”үг·•жҡңе–ҷз¬үб¶®жЎҪеүҜвҙҸгҜӣз’һгҮңзһңдҝ¬гӘҳвҸҙз—»вҜ·ж‘ҹбҳҳзјңзҫҜзҒ¶гҝӘжңҙзҸ°бө…дҚ№бһЁУҸвҲ“д••зңңз–Ғжҡ‘в—ңжҸівёҚе«ӣеҺЎзҰәгҮ–д «гӣЎгҺ…гӣқв‘ҪAж¶ҡеҲӢжӮҗдҮҹвҠҗзҪҲа¬–е»ғз№ҙб ңдҮҫж¶ вІҷд‘қе® зҢ¬дӮ·зһ®е»Ғе№ҒжңҒгө§гұЈдӯҡдҡ®гҜ жҶ–жңўа№ӮбҢ„вҙҳТ в…¬ж“§К’вҜҲМұбЁ”ЬөбҖҠбҷҠе„ҶЭӨаұӘзұ„г•ЎзЎ„дҚ•бҗөг•Ҳб ҠеӮӨвҡ”дҫ¬з’ЈвөӨб“»зҶҪдҹҖж„ӯб®ғзҳ–бңұеҶҫжӘҚв©ҷдӢңвҸҘвҸүе®°дҫ®зЎҹаҙ®еҺӢгәҺбҠҒг‘һгЈҳеҶ’бІ iбҲҝеҮ„ЛЈд©Җ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1805,"_status":"completed","_startTimestamp":1775055518057371,"_endTimestamp":1775055518062489},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"66","comment":"","_id":516,"_uid":"74e44596-63bd-41a3-83f7-1527b171431a","_cid":66,"_ctime":1775055331875,"_sid":75,"_stime":1775055511828,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39906,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:58:31.438Z","time":301,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9ZPzz&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"3"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9ZPzz"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"1:2"},"headersSize":306,"bodySize":3,"_status":"completed","_startTimestamp":1775055511438789,"_endTimestamp":1775055511452896},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","va