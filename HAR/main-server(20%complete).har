,"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9a_xU"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055929063728,"_endTimestamp":1775055929076521},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:05:30 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"4698"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":5924,"mimeType":"text/plain","text":"2108:43242[{\"ret\":0,\"compress\":true,\"serverTime\":1775055930141,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁКҗбғ г¬Јвұ аҙЁвЎ‘д°ЎбҳЈжі°вҲ зҢёжҖӨеқ«вёўе°ҰгЈӨдҒ©FаЁ§гҖҰгҹ аі Ы ТҖа§ З аӯўбҖұд—ҘЩ аӯҹгІөбӨІгҒұд“ЁЦҒдҢҖГҜеү…в‘ЎгҲңбіЁа° е—ҒжҸ К…жҖҜе•©дӮ бӯҙб·ұЮұКўбҖҒв…«зҘ”дҲұгҙөа«ҸбҚ дҠўзҶІдҰ«а¶ҳжҠӮзҙ©бўӘдұҝд®Һз…Ӯв„°Жөж° гһ–гңўбЈЈжҡӨвҹ жҖЎж‘°Г–жң°@еҠөдҫӮвҖ еЈҒа¬Ұг©јаә–д©•К¬г’ўвҖҜжҶіеұ•дҷҠвӢһе„ Ы«дӣ№жЈғб‘ еЈ г„Қ\\\"Pд®қаҪҠбјёК«зЁҳгӮӨгӘҜбЈӘа® СӮвҖ з§ңд„ҺбӣҰЫүгҳЁаўЁв„’в©ӨбҗЎО’ЕҫШ Нұвғ–вҷ“д„ЁЖқеўҹбҒҒвҶҗе°өа©ўзҢҗвўғаӯўбҢҗдүөбҫўв“©дҘҒбІ№зҰЁе°©бЈҜжҶҗеүҫЧӨб„ҙв–’д«ғвӨҘз• гҮҢжЁҢеҙ¶дҳ Пҷдё вӘ»Т бҠ©гҜҮжҘ–діҡгҰўж“¶вё„зҙ«д®җзҘ–б¶ӨеӮ’бұ®зҺөжҺ•в«ҳдҹ“ж¬—дҒҘзң§жё“з°ЎвҒЁбҢЈРҖФҙбҢЁвҒҙаҪӮбҠ«вү‘зҘ–б®ӘС з№һд‘„зӢӨзҢ¬дҫЎаЎҫе”ӨдүҒаЁүеёЁдӯҒзҠҖзіҸЕ…зҲ„жҢЎбҹӯб‘Ҡв‘•в§ҰаЁәвӣӢвҮІзҗ аӨҙ%зҺЈејғг«Ҷг‘Ўг–«в»…вҷ’а¶ зҮ—г’Қд·§в§ІзӣҷеғЈзҸҒзҠҳеәҖгҜ…жЁӣзә®дһёаҙ§дҲ’бҝ–аҫўМЁдҢӨбҪӨзңұжҒҸаұЎдҲӨаўўв—°ж”’в•һв•ұгӨҡбә¬вҶЈж“’б’Ҙвҹ е№җа° дҘ№гҶ®в°Ҙб–„б—ҪбЈҖжё–вҲ Зөз–ӨИҒб¶әеҠёг¶ЁРҢгӘәЕёвЁҰдғёдұ–жҢјгҒЁСҷбҸ…еҶјзҺ«еҸ”д®ӘзңёжҜӣеӢјеәўЗЁз®ўЧјдҹҶЕқдё®вқңДҙгҲұЩңдҚ„жӯҠвҳҒд—ҠдҚ„е°¶дҳҒз§қб„°е°«д“җеүҖдҝұКҲаіҚе—ҚвғҪвӢқг••аЎӣг’°бӨӯеңҚб«ӣЫҙд¬¶аҫ°в№үдҸўТҺд№Ӯв ұВЎж «З”е‘ЈеҠ•в®»еӢІб»–зһ жҳ«аҫ еҲ°гҷқвЈүзҗ’вҲҜаіңвҖ«дҒІбғ‘дҶҗгҖ¬д Җбүҡд•ұзЎ’гӢ¬зӨ¬дҢҖгҖ°зҶ‘зЎ‘д…ӯзҲёдҶҗжӘҖеҮҚбҒ®дјҪа  Л“бӮҲИўб§Ҳв“ҜдҙқдӢҜжӘ“е’“еҘ„вӢ¶д»¶еӨӯеӘ«е·Ёа¶”гҜЁгҮҫеҝ¬Л°еҫ’г«Ўе‘Ҡз„ұвң°е№ұд®ҘбүҲбҫўдЎӘаӯўвЎүаў·жӮІвүҶв•’аЎ§зҲҡФ в‘ҲЙӨаҰ“еҫ·вӨ°гҜӘдҶ–вўӨеҗҪа®ӮбӮҲФўвҒҗЧЁа·Ұгҡ…бҰҚв–ӮеЁҡЫ©б«өгўҜб©ід«өд»ҺвўҺв»ҫгҸҜв№®еІҠгҲҡMдөҒг‘•вҺұв–үвӮҮвғҙдҗҜдғҺеүҳв°’жЎҺбӯ бЎҗаҘӘдӨҡбҪҘзғҰаЎЎдӮӮаіҸДөвҲҠе•ӨвҖ§аӨ¬зҗ©е’Ҡзҝ•еҡҒжұ‘дәЈдүӢеӢЈзӯҫаІҷе©ӢжқғдҪўгҳҫзңәгҹҡг§Ӣаёҷб”§аұ°г„ҙвҗөдҜ“вүЁзҙҝЛҲб”ҘжҲҲвҜ’ж•©жҢ§вӮЁжһҘвғ жһөдІүе«»вһӘзӮҠв«ӘХҪд„ӢеёҰжҢқжӣҗв¶№еөёа¶«ж»’а¶ұзҗҙеҗӯгқҡвІӯгҰ“гЎӢвҷҚдқӢзҪ»ж—Ӣгғ…в–ӢдҗЁеҜ»жһұд·ЁвһјдЈҲеҷўвғЁг„ёеҷ©жӘӮжҗҖа·Ҷбҳёз–ЈжӢҪзӢ“в•ҡдҹқжіӘзҘұвӨҮа»°аЈҡгҝ—е ЈжҶ’жқ№вҚҝЦЈвүҮе•Јб§Әбј—ЧӘвіұдҫҙгҹ«еҪ…вҹғжғғдҹӯв”ӢбҪҘзё§бЈҳа¬ҝвҮЁзҢ·дӢҲдҡүдҰҪвўӨвҲөдІ°г°ҖвүӘв…ӣзҜ•еә“дҘЈе¶ӣвҗҘжҢҸа ҹж°«ИҲвҫ№вӮӮб№ғдҷқжӢўгҰҡеЁёвўјзӯұЙ•дӯ„гҒ®бҳ„з‘ҠжјЎбӮҪд–ұбҺҷзі‘дҺҸвҰҰвҳ«К°еҢ„бғўаҘ…вӣҘЕ“Е“зҖҫдҠ’в«·а іеҒ”з—ҲзјҢжҙңж»Ёдҗ С»еӮұОЈбўҹб§ҒШ°ВӯTе„ҺЪіж„јгғәбҙҒдҶҡеҙјШўа©җбё©*ж”Һд»®ЛҖбҲ»гіӨбјЎв»’гҗҖаЁ—в”ўд•°зҢ«б„үдҳ°гҲӨдЈҳН“в‘ҲдҶҗЫ·еӮ¶зҸҢвҳәзәҫжЈүв©Ҡз“ҳв—үОҘдў§вӨ•еҘЎај®г»ҶдҒ“жҪҷбјҰб·ӨвҰӣжӮғаЈЁе¬•вғ®бҖ¬ж”ҙе«ңв…ЎжЁ«бҲ„Зёдҫ°дҢ·вҡғд‘ңа«¬бӮӘе„ҡа§•Ц¶дЈҝЕ©вұ«еҜҳб®’бҶӣМёбә…жҒЁдҙғЗ°аҙҳгҸҲдҒёгӘұаҫ¬дӮ д¬ұб ёеј‘ж•ға§ зЎӨа№§еһәЯӢЦҰжҪүУұз°ЎаЎӘвӮҒИ№вҶ«е’Ҷеү•е©…гўЎвўқМҖз°Ја©ІКІвҢұеұӢб§ӣаӘүв–”гҢӘбҒҗ еӨёЩҷбҗЎГ—д®ҳг•Ҹзөјв–ҒСңдҢ’ЮҜаҪҺдҲұбјҙз§“жӣізҸЈеү„гәЁз©ҘдҺӨжһӨжҚҗеҳ№бўөа©•ж’ҒдӯҲгўіа®ІжҲҜбҸһб’ҘвҳҜжҳҖзҘ„бҖІаҫҚзЁёеІӘгӢҠжұҘВӣвһ—гҖЁв©ўдҫұб Ўж®’з•‘д әгҸӨвҹ—дқЈЯҜзЈЎеңҷбҰүжҰІбҗ…в…Җа«Ҷе•ҳгҶҰзӨ¬жӢҙдҳӘС°вҡҢвІҙж‘ҒжӨұбҳ’бҲ…гҗҰдҢ»б’Ўзәқв…¬дҒҚдЎқжұ°гӯҚд·Ңг—»вӮ·вҶңгЁҰв«һзҚ…з‘Ҳб»ңб„“еҝёПүгҳҶжҰ”з©«гҗ®гӢҝд¬әзҫ¶дҡјеҚ”Н’бҲҜбҪЈгҹһдҢёб«ЎдҳЈвҶ°дӢӮдұҶжҙ‘з’ўж…ҸеҖ©е…¬4зҡҰжҠ®г—Ҙдҗ *бЁ®жғ дҗ”в“ҹе°ӯдҖӣО°ЯҳбқІзӨҶдҜ…вӯјб©„е°іеө—ж–¶гҖҙб‘ гҮҡеЎӢз„ҙдҝ°а·ҒбғҰж’Қз°ӨзёҚдқүдҜ’жҡ·бӮіжҢӨдӣ°г°·з…ӯжӣҠзӯ…зҙ‘вёҡб”©жӯҢд·«вӣӣдёҫбӮҢз§Җбў жҪӮР“гҷҡаӯ·в—’зҹғд‘’жёҘд”№еҷөеҒӢвӢ—жұ„бӮіаәөдӨ°дҷ§бүӣжҺ№ж“Қж‘ҷбҷҖаҪҲв…Ӯа©–бўҶе‘°вҖ д§Ёвё Е©д№ҖОңжӨ а°Ҷд…ҡгұғбӘҮг“ҙе№ёХҜгҪұбӢ дЁҷвӢ¶еҙЎд“ҢдЎӣд¬ҰвҗҙзһҹбңӨвўҰв–ҳд“°гӮ®а·ҠМҖв‘һдўҷбү«жӢҒбҸҘбӮ вҰ•Р–дҒҜж·®жҺ«дҝ‘И‘гёҳеҖәбҖһжҮҢЖЎа§…еі№г—Ӯб“ӘзҮөдҜ„вҺ–б¶ҠеҰҺж°ҫжҪ‘дҫ°б‘ёд–’аҪӯв—ҘвҒ°б»№гҗҪбЁҝН’бҲёЫ°бңҘж’№е•ҰдҝҰжҺҲжҗЈжӨӮеҠ©зҢҝвӣ—аіӯжіҫжҗҖбҚҷз“’д—әвӣ·вғҝа·ЎеқҺг¬”а®ЁжёӮдҳҷвЎ№з №з§„б…’д¶№жҰҲгӢ©бҫӮж…ҘOб•Ӯаҫ еӯ’дқөгӘҜвҚ®дҝ”аӨЈбҒҪв¬Ңзө°ПҰгүҖжІңж©ҳз°¬бҰ„аі№ж¬ӢзҶҙаҘ®вқұаҘ®г‘ҒеҜӨвҶҗзң”жҖөд¬Ҫг–Өбҫҳд‘қвҙ©в®№д…ҒвӢқг‘іајҳе…Ёа®Ңе Ід—ҮжҜ’гөһжӮ…гҜҒЪҠгҜјг ӯжқӨбў…дўЁдҲӢбЁғгҫІвёҷгј§аәҲгүӘзһ–бҒҗд…үбҠ г®ғеҒҠзёЈв’“бһұдҳҙеІ“а©Јв¶ЎЛІаЎЎеөЁе«іаө·гӢҪаҙ©з ЁдӮЁбўҚжӘҲж¶ҶжҚ©жң“бі«вӯқжҚӢеҜ§зҪҒгҳјжЈҸбң–зЎ»гҚҶд №УӢжӢҠеҒҹдҘ„еӨәжІІеҺұеҲәб’һаӘҪзҒ§ж»іг»’бёҢаЁҜдҫҲгөҫз“ҜеҢҮжјҳеҢҠУјжҖӣд·іж•ҖеӢ–вў„ДҜвөҖеҶӢб…Ҷгј§бқөЪЁж©§д……дӮҒз«ёеЈІО…бұ·в·ҪМЁжҗҗгҖ вҙәЬ«Щәд·©гҫ’жҠҚбқ зЎҘзІ—жҪәжі»е¬ҷеЈҮд‘ҳеҮҙзі”бҗӨзһҗжөӮаӘјдҺӨвҡ§еҫҸжҒҠб’ӨвіӮвұ№з°ҙв®Әд“ҙе–—вҪҪдҘӘа»ӨМ бҳӨжҖҝвҺөгӨ—дҗ‘зёҚдіёајіеңҫвҜҝе®»зҷҝРҘгЎҮб”‘вүјб®ҡз‘’в¬„жҲ”аЎҺЕҶв……е„ӢвҜ—дҰӯдЁ—дЈёеёӯгҜғд·ҝОҶаҘҖдҲўвЎҗа  д’ӨвҫҡжҸ“еһ„в”ҠЫ©ж“•дҗӮжҙЈдЎҺдҹөеәӘж“ўеЁҡдҚ“Ю„д·ЈвҪ гҷҙдҚҲгҶҮв”ҙеҡЁвүҜдӘҷз”ҺгҮ„Зҝв’ЎдҖӨеёҠзҖ”дә·еҘ“еҫҳв һзЈҺеҒҖеЁ№гӣҜзәӮШЈеҒҢдһ ж“Ўеңҡв’ҙдҒ©бӯ©бҘҝбЈёе®һд’ҶгҠ§з Үд… дҝ®дІөг…ҹзӯӮдҒҖЭўШҘгј№еҖ»г·“вЎҳОұбІӯГ©еӢ«аі»ПөвјҢеҸҝв…ёаҝЈв№§зһ•аҘ°зҠ·дғһгҡІКұеҠ¶бў…ж…ҠгҗӮжҢҘдЎҗИ°аӨЁе«ўвӮҸзҡ—вә№гҮ©%бҷ…в“ҷбӢҘдӣҹзҺ·гҙҲвө«зҡ»зҷҪгңҷжҜҙбҠҲеқ·аҜүе…«Л¶зҶ бӢ«е§¶жіҜд•–гҶЈбҗ»бғ–жһ№гІҒбҸҫдұңдҗҹвҡ№Чҝб№ӨвҢ·бЁ д §зә бҗҹЕӣж—§жҲ»зҢҷбӮҳеЎҸзӣһвһҖдӮ№еҺЁвӣЁбҡ©аөҷзҲ«бёӘЕЁбё«гҲәаә‘НҺвә дҫ№еҳ вңЁв…Җб¶јжғӨаӘҝгҪ№бҖјж„ӯж…ӯг”ҘаіөвҶ”аў»б…ҡві©дҮ„зҸ°е¬ҘК°ж„Ёг”Җе’ўд«ҘбҠҷдһ§вүӘвҰ°гЎјП°в—°зј¬еұҝдҚ–вӨёвҗҪа©ҙд„җдәёе¬ҪеҒ¬КёгӨ зҫ»дү”аҰ·б„ҘвҜјаұ•зҮ«С§гҙәбҖјаҪЎг‘ еі дҢ‘AвүігҢ¬в‘Өдӣ¬в© бҠІв”Үвӣ–Кўз ўб„ҒУӣПҷж‘’г№ҡгҢҗе•ҒжҫҘвҮіеҲЁзөӨе—№гІҢаёҖаӯ§е–ЁвғңЫҫаӘЎбҰ©в©Ҙдҹ„г‘ўзӣўжҒҜзӢ°бқғвӨ·в„Ғеӣёж‘ўб№ұбҠҘајҠгғ гҖҫгә©г‘ҝг“ҷбҷ–еҶһзҒ·а«ӨвҒҚг…ӯаЈёз‘Ҙбӣ¬б“»аҰ“вҖІгҡ·еёҰЕҢгЈүе…Ҫд№ҶК„вҹүжҢҫв‘„д…ҡаӯҗЧ·гү”г—ӣаӯЈбЎ Вәд–©з® РҮвҗЎжқҒзІҺдүЈзҖ‘д¶®Й®жҚ»жҶёеү зүҮзўіХЁеў еЎҡвҠҝж§ҖФ§вҳәвүҠжң°г»Іе·”жҸҝжқҰгҲ©еү«жү°дң‘вӘЁзұёжІәв‘®еҡҙгҠ®дҢұдҷ©РҘа ҘбҺја©Җв°ҙб”ӨдҖҙдҰ”гӣІеҪүзў¬Щје„Өжҳ«дӢ„Кёв°ҮвӢҷж ҫб»јз¬·гҒҮе—Һв…ұбң¶вҫәдҚ·жҮҒгіҙЮ¶зҙ…бӨЎвҡ«з“ҖбҠ»жіүг№¶жҜӮЕЁжӣҗбі§дЎ–Нһа№Ҡж“ҮбҲ©ж¶№жӨ©еӘҮгҲҫвҖҙД’зҚӘб„·дҲЈб°ҒвЁӯа© вҸҘвҖһбҒ—еӮ„жі”бҚүеқӯдғңеҺ°вЁүз„’бўҒз¶«бҢҶе®ҶдӨ®вӨІдһҳбҷЎжҮҖг“ӨИ°б’§аіҸеӨғУӮб‘өеүӮгӢҡТ’дҫ§зҲ№жҒҖУ б«Ӯг·ҚеҺҠвһ®бҳҗбҠҗвҗқжЁұжҙЁбҷ«б’«бЈүвҪӯдӮҮОқб¬ІжӮЈбөҗгҸҚдҠ‘з•ӘбӮӘЖЈбә‘б–ІбҚҸе§ҷа®°жҢЈв‘ҠгҺ„б»ҠбҰ«еӨҘж„Ұа©°жҺўбҖҝбҘ§б№ӘзҮЁгӘ„зү©бңүгҫЁв©Је•«бҢұеҡ¬еҡӯбҙҜв ӨеӨ•д Ід•¶д№„зҙ…жӮ’дҶЈбһјж¶ӯгүҶд•Іжҡ©З°жүҘеҲ©в’ вҒӢвҸ“зҠ·ж¬ҷвӮЁв»ҷаЎҹбЎ№зқ®з№ІеҸҹб·ңжӘӮзүҖдғҜб…Ёз·ӯдіҷеҙІвҜ–б„ҘдҷҹД’дўҢЯІв…Ҝв¶Ҙж’№гҲҜбҶҶа¬ңбә№бҮҗдә–гӢҮбұӮб§Ҝжҡ“НҹбҲІвҡ©зәғг¶·вҖҷб…”гҮӮбұӮа¶ҙаІҘе—ғбҰ–жһўеҫҖбЎ‘дҒұж«’еҜҰвІҘаёҚжЎҺвҜҜзҠүНҚб’ гғ“дҳҫбҢӨе№–гұҢгӮҢзҸӨеЎҘвҝ®вғ”д°—ж№әжқҸг«ӢбҒЁвІұеҡ’зҲ©еўӯбҷјвёЈбҚҚз…ҹдӣҶзі§еӯқг—ӣб… гҳЎгҒҖжӮЁаҪҗгҺ зө…gбҹҘдӘЁжҡһбҠӨеҷ°вү©aа°Үб‘ҘжқүбҶӣдӯ»жүўеІ вҘ–аұҹЮҒж–ів ¶дӮ«а№Ёб“§бҙҘд’ҹЮҡдЁ¬еәҖз“ҮжҪҗж®ЎгҖҰг„°еҠөгӯ©жҶҮжӢ·жё‘бқЁгҰҺвӘјеҠІЛүв“–зҰүТҖдҷЎж“–вЎјаӯ•бұҮд¶–жЁҗаўңг°¬гё©жЎ–вҫҲдҰӘбҰӢвӘ”жҮ гҗўзҒҠГҷЦ…гҹЁж•¶вӯ б“Һг§ӯе«Ҳж°ҢжҢЎгқҲд¶Ӣгұ¬в“№б¬Җе–ҚеўҶвӯҠд®ҜжҷҷбҶғаўӘдҜ…жјҰвҒ–вӨөЕ«бҰҠжў»бҠ•ж–Әа¶ҳвҲ·б®•аӨ“дӮ’Х•дҖ еҙҜЖ бҡқвў 9б„ гҖ№жҖҙж–ұвҒҒе «г„ңЖ•гІЈб‘Ё  \"}]"},"redirectURL":"","headersSize":253,"bodySize":4698,"_status":"completed","_startTimestamp":1775055929350277,"_endTimestamp":1775055929355777},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":989,"_uid":"030e81d6-cc7c-41d1-8f51-57e2a7cdaacf","_cid":92,"_ctime":1775055887626,"_sid":21,"_stime":1775055929063,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:05:28.962Z","time":287,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9a_vu&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"h