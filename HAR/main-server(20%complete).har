Ҙҡв©һв“ұжҚҒеҜұд«ұа«¶з«ұеҜ–в©ёд—–жӣ«д•ҷе№үд¬–еӣ®в”¬бҮұв‘®зӣўв‘№б§№еӘүвғӣв’ҷгөҲбҗ№бҪҲж”ҠЫҙж”ҷзҚҺбҳҫе‘Өз©үгҸөбҷҷж№әз«ҫгҜәеӢҙ8вәЈгЎҗаәҗВ—вё ЗҢгҒӣЖқбө—вҳЎгҹ…вү‘вЎҠЙҒвҗ Э“е–ҸдҹӮг”ЈбҰӨгҒҢбӣҢгӢҸдҮҺбҠ¶О«з„ів¬”еЈӘеҲ®вҙ–г•ұгҡҰд‘җЗҷг§Ҳг„ҲбҰўгғҪвІҚдІівү¶дөӢгҖ«еӢ®вҒ—зҮҺг®өвёӢвӮҶзӮөвўҰгғ¬бһүг’қвӢҖВ®вҲЈе–°в»„гҹөбҹҺзЈҳзҗ ДӘеҒғаҘ·б»ҫе¬—зҒ„а®ўгӘёЯўдЎұаҰўзәҫеЁЈзӣІв’—зӯЈжӘҒг‘ҪбӘ”еЈһбі—зӯүаҜәбҷ·е ҜжЎҶФ–НҠвіЈе«ӘеҖ в“°гЁўв  а«ҡЗүз•ғвҡүг¶…вҸҮв‘ғбәҶв”°б· бҘһКңгҙғвЎёдҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1288,"_status":"completed","_startTimestamp":1775056045193358,"_endTimestamp":1775056045199790},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1098,"_uid":"0a29b843-bf79-44ce-95d3-f6182a6c8e7a","_cid":92,"_ctime":1775055887626,"_sid":59,"_stime":1775056044427,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:07:23.989Z","time":286,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bR_F&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"174"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bR_F"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"170:42270[\"handler.process\",{\"type\":\"hero\",\"action\":\"ev