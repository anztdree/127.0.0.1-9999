/?EIO=3&transport=polling&t=Pr9Yq1r&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Yq1r"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055356032735,"_endTimestamp":1775055356038765},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:55:59 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2414"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":2987,"mimeType":"text/plain","text":"1088:4385[{\"ret\":0,\"compress\":true,\"serverTime\":1775055359210,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГҗбғ г¬Јд°ӘзҠЁЗҒК жҚҗЙёЯ“вӮЁЖјжғҖа§¬ДӮбЈұдғӘВҚзўҘдҡ®ВІFжЁЎж° жҷӨЖёГёВ¬ЕҳXЖүгҲўбҰӨеӢҲЖҖдЈ»е«‘вҳӘгіөГҢбЈў8бһҶзӣ®бҮ”вҜ а·ЈдҡҘб•Өаҙ з‘–е№җвҰ бӣЎ-е”ўвӮ“дЎҘжҲәб ё3бЎІвІҢеҳ°еЁӢж–ҙг«Әв’№вӘҙеқЈвҘӮд…ҰдҰӘв© ГһгұҲдұјг„ЁдҮҖгҡҙв©үгҢҙгӣІаҘқа®ёе•ҫвҠӯе•Івӣ”еҒҢдҰҶд•№бҠ’еӣһеІЁжҙ¶г‘»б”ҙв ІзіҒе–ҢдҪўжҶҲеҷ–а¬«зҷҚдҸӘа·Ҫб…ҳз…ЈвЈҗжў…дӣҢдҶ•дҚ–зҘ§аә«вӯҜв…Ҡд«ҲвЎӨдҳӨбӨұб¬ёаұ¬еӮҲдҗ·ЛЁе§ҖеЎҺа® МҲаЎ”аёЈдӮЁгҗәбү®ж“ұе…Җгғ¬МЎгЎҗ,в©Ўдғҳе–ҫбҒ И”аұІМӨдҶ В…вҷҒдӮӘаҰ¬зҚ•д  е•ўСҲа ·д… зӘ”вҙҗeвҗәаЁҘжғҖбҒҶдҚӯж¬Ҳаі©гІ ГЁжҖҫајҫГ°вҙҠдұӯдҝҒгЁҗа¶Ўд§ҖГ¶еү’бҚҰа© б•ӯдҜҒе ҫг…ЁаҪ¬дҶҖРҰдғӯб…¶вқ«е°Ҳз«©еөҜеқҙгӯөз®ЈеЁҺд„ҖзҚҝеҖәдһЈзӘҲгөҜЩғз©ӘЙЁгҲҚзһқб©ҰСўгіЁеҢҝзЁ°аӯ§еў«ШҖг„ӯд’ізҰ”а¬ӨгңҸаҜ«зөЈбө№з«Өеҙҝд’·г‘ҡдҮ°зӢҖдҡІгҢҚб§әжӮӢз®ӯд„ҫд§§С”дҘҷеҷ”ж•ҢзҒҘж ·з әе•әд№ӢГӢеҺғаӨ¬зҰҘдІқжҘҜг«Ів„ҝдҗ“зңҒеҜҷеҹ·бҒҢд—қдҰ·а«ӨгҷӮж»ӨбҖҷе„ёвІ—е–ҶвўҹеЁ”вЎ»е…ҘД§дҘ…дЎ°дҙ‘б»ӘбёЁеәӘЧ•аӘҚдҒ”ең”дҜ—зёӨЬІж№ҳдЁ©еЈ®е—ідҲҮеҢ”бўӮЧ“а№ вҹІв“Җв——д№”гҪІвәҜеҗ•жҶ»дҰ¬бӨ”гңӯејҲвҹ°г№ёвҫ‘жҶ®еҳ”зҲҸе–ҜдҖ¶бЁ—аұ»еІғз№…бҘҘжЈғеӘ«зҲҗаҘғе„Ів¬”гӣӯдӮ§зӣ’в–¬аҘҜе’җзҮҠвҘҒжәҰв¶©iбһЁз¬Қе«®з…¶г‘ӯбЁӮвӢ®аЁ“бҷ©ДІг©ҜЕ¬вҘ„д…ҫвә•гӣ–г–ҶдЎүе¬®гә’а®“д ®г«ӮгҶөЗ©б‘»д“ғзёәаў©е”үгӢұеӘҲа§„ж„ б·ҙж… дЁ kг ·д…ёбҰңеҠўа«”ЙөгЎҚвҸӢеҺҒбҗҙв”ёдҚүж”Ҙв“үбҺҮв’ӢбәҚвҳ»з”ЎбҮҲдөҰа№ҙг¶Ӣв®үг ІжӨ»аӨҶеҳӢжҢҙж»әН·вғ©еҚқвҮҖе®„жҢ№жӣұеҒ№г«ҪаҫҗеҡҰеӣ”гҠҜв¶№дҒјжҷ№аӯүеҡ§КҪе¶Ҙг“ҶжӢ»зӮҙеҸ№з¬ЎжұҷЮ…а©ҡж“ҹжҚҷжқҲеҠөеңЁжҠҶжјҚжЎҰаҪ’бўҰвҮ“жҪёжҪҚжҒҮдҠЁж”ҶдҶ·бў¬аўҸж“Ұзј еҒўГөбЁҶеіҗб„§дҶёб©Өбғ„б Ҷе„ңбҰҘеҮ§ві¶бӣҗе‘„ж°ЈжҗәдҰ«ж”¬вЈҠбҫӨг’ўгғ§зӮЈбҚ®аІңбә„Ц»бҜ—зў§бҮғбҮ‘гҝҠеҮҒб•ҶдқҡгӯЁбҰәжғ…б“ҪбӢҶдҲ•б ҳбәҪб–ҶбЈібҝ®бЁғбӯҮЧғгҜҶд—ӣбӮӯд·§бӯҶж—ғбҜҶзҮӯгҫ¬ж§ҹбӯҮзІҫгҒўдӢҲеіҺвіЁеңөж·ҝгҶ®е”ҳе¶ӯе№ҘгӮЈбҠ©бӘ¶жңіеҪ«дңҢе«‘зҠўеұ¶дӘје…·бҺәе©өз«Ұеө„жҢӯвӣ·ж•Ҙв“Іа№ҙеӮ„г–Ңзӣ–ЬғвӘҲзң‘еһҲбҙјвҸіжӯҚеңёзөӨжҗҠд°ҡжў—з¬•е®ҰдҜҘЗҺжҺҸвӮәдҮҰз»іг§өеҶёбҘ“еҶ•жҪӢе„Ҳжјүгөӯж—Өб·…б»®бҠ¶ж‘ҘЯ»г»ҝб°–еҢҹең¶З•гң‘бҢҗгҸёг»«зҳ”а «г«‘вёӣгҢҷеј§бҗҫдҮҢгҲҢдҒ§гөҸбёӢгҗҶе”—гёҙаҪ…вҗҚвҳ–аёіз•ӘвӘҒбңҒжҝҲг»јжӨӣРҰвҝ”дҠ“вң¶зҢЎгҹ¶еҲҲгҳҜжЎҚбұҙжөҗгңӣд—Ҳг©«гё°Э©бҡІв ·бҲІвҜҒеӮ·еіҢеӮҷжІӘУҸЦЈвҪҪбҚЎжҰҸж°®вҡ„вӣҪдҢҗвө«жҝ…дЈЎв·—гғҜзҸ’зҖҖз»Һж°…зҝәжіқд№ҲжҒӨвҘ«г®Ҷд•°з–Әж„Ҷз№”жўҙдұІбөје©ӣеӢҶгҸ§бӘҗз©ӘеӣҠе«Ҷв©ғжҪЁЩ…бҙҠдӢҡз¶ҫг«•ві„бқ®еҒ бҢҚжЁҫд№јдқҝЙәеЁғЪ№еҠҒб¶”дҙҰз•Әвғўж»Јжғ”ЖҝжҺ¶д‘’еІһеғ–гҫ®дҡңжӣәбҢҝвӣ®дӮ•ж…Үе¶ғдҡҷвҡЎгҸҜгҜ„вҫ–жҷҫб—«д“Іа ҒзңҫЙ§бң«бәҙгҜјбҫҘд §ЙӮбӘ»в§җжҜ„гҪўв”һеҸёЖҙгҘўгҒ“бҪҸбҒңе“ҚЫқбҪІвҖ»дҺҳгЎ©ж’ҠжҢ°зҗҒгҫүг…ұж®„бҮ в„…гҝҙаұ„вЁ“вғҢаҜ“бӯ—бҢҙб—ўжІұдҠ°бҫӨгүҷдұЁе–ҮдЈҺдүұвёөеӮ жҹҒд°ІжҶ«вҶЈбҷ«Нҙд®Ёаў—РәУ‘аІҝвҷҒзҰӢеҠ„бҢЈб‘қв–ҙеҷЁв№§г°–в…©вӘҳа»һг¶ҸеҢҢбҲӯвұҮМҳг®§жіҲг°җжҫіаіұжҶ№РҜбӨҢбҪ“вұ‘гҺқдЁҰдҠ¬в«ңз° вӨ—зүұеӮӮајҸжӣғв©ЈвҸҗдӯҰжҸҺдҷҮгӘ’е–“а№‘в”Ҳж–№жҶӮб…ҷзЈҒгҪҡжұ§в¬·ЦҘв–ҺгҶ‘бј…вёҫбҚјвҷҮжӢҶеҮҷз…Ңж«—Ю…ајЎв¬©е“Ўа§ҙб•Ҡг…ңвӨӮгҢЁбүҝдЈҶв””д“¬жҚ©дҜғГҘдғңе®·бҲјг–ҡб»үв’Ҹб’’жјҪзӮүгё„жӨ§жӢІдҹӘб·ҒПҮе’ҷз¬ з…©б’ЎдҫҰЭҖв—Ёеә¬гҫЎж•ұгё д’…дӘӮз®ҶжӢёа©ӮвҖҪз”ҪШўеӯҮжЈӯв§үвҒЎаҰ”еҫ·дҡ®д‘ЎеҺөжҳІж–’ЖҰзҠәдЁ¶бҡ¬б••бҸӘаҙҮж‘Ғг…Үз°ҝб–„еҪһв“ҲгҖҶзІ бҷ©ЧҚжӯқбҳ’вӢҪбү…еӯЁж—ҡв”ҒгӢ–дңЎб“ЎвӮЁзӨ¬в®–бЈӢд•’бқҳУҲдӘүд’·в–№бӣҲеҗӘеӢҒбҮ…бҙөдӘҡбӘӮб§ЁжҸ—віҘеҰқв°•аІҗгҠӮв•„б ӨжЎӮвҘҚеҲҰЖҶб•ЈжӯңдҗҢбҺӮв‘Ўдғёб ӨгҒӨа®җжҲ¶вҒҺа¬Ғв‘ҖвғҙбҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2414,"_status":"completed","_startTimestamp":1775055358317983,"_endTimestamp":1775055358322778},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"56","comment":"","_id":364,"_uid":"c5a55bff-4ce8-46d3-a904-8d669fcb13fc","_cid":56,"_ctime":1775055045046,"_sid":99,"_stime":1775055356032,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39950,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:55:55.645Z","time":288,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9Ypxl&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"3"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Ypxl"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"1:2"},"headersSize":306,"bodySize":3,"_status":"completed","_startTimestamp":1775055355645886,"_endTimestamp":1775055355654526},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[