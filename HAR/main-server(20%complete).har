xt/plain; charset=UTF-8"},{"name":"Content-Length","value":"999"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1172,"mimeType":"text/plain","text":"464:43102[{\"ret\":0,\"compress\":true,\"serverTime\":1775055410639,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зҢёжҖЁбҢ¬вЁЈб·‘Kд§”ЙЁЕҗеҒӣ9еј гҢ б¬ бҶ вң Ь вҙёдҒҰаҪјгӨ вІЈа«өж•©д—ЎбқҖб–ҰЮ НҒеЈ•г„Ҙв ’еЈҖжҶҸ;вҲ°зҒҜгј©ж—ҠжӘҡб•«е–ӨвҠ’бҘјвӮ аҰ®в„¶бҶҙб°ғзҰҢгғӘгё вә®-жҡӨж…ҮбүӮбҗ з“Ҷеҳ г»ҺЖ№дӮ¬з”Ўб”ұдӮҖГ–вқ°гҶңЫҲдҹҜХ‘жӮ¶дЈёаҙЁб…үбўЎвҷ а°ғд‘°вҸ–г¬ҙг¶қИҳаіҳжңўбө’ЧҢз‘§ж ҡа ұзҢ©д Ёе¶“гЎ“еұ№а°җеҷ ж©ҮаәӨб«ҷж„ҙжўҳгҸңзҳ№б»ӣЮӮзһӨбў·жҢ‘жҲҳгҝңаҝӨМ®бҘҲбҚҖдҠҗвҘҲб•…дү д•ӢвҚҗвҒұв’Ӯд•“г‘–зҜңЦ¬жӢ¶бІүжҫ®жұ–Ч“жў”вҰ®жүҫбө¬жҺҺеӘҢжӨ—бҺ–жҝ„жң’гҸұдҝӢбЈ’Оұеҫ·бҫЁОҷСҒдҝ¬вЎЎвҶ„еҰӘдҸ…бўҲе»®вҗҒжҰӮбЈҸзҗ–еӮһж’Ёд—‘г’ңаҜҠзё–вҮҒж„Ібҗ•гҚ·ж‘‘а·ҺаўӯбҶүаў•дҷҘеӢӯз“№а¶ҮбҶүзӢҪгәүеЎҲе©Ҙбҫ…б«’д©ҚзӮҡеӘӢд©ҚХ°г“Ҳд‘өаӯәе¬ҝзүӨе’Һб§өвңЎКЁд„ҙбұӨг¶ҡгЎ“дұғб°®гЁ©жҡұб…қеЎҝдғӢд¬“еҚ№аҘҪа©Іеү„з¬»жҪ«гҠҝз¬»дғ·гһҪЬ»з„’гһәдң»бӨҹг©ёвң»в”„зҺ“вҷ©г•—вү№е°«дҳ‘г¬№вүҫгҶёжә°жұ„еұҮаҪӨгӮјж«ҺбҪІг—¶Чҫбіңж№Ӯв—өбЁЁж№»аЈҹаў…б«•вҚЎж©ҝбӣҚвҜҒжғәбқ„в»ёдҘ®жјҲз№°вҹ»д„ҖвЁ«ЭҷжҷҳдӨ©жҙӨдӮүжүӘжһ„бҠ©бҪ»жқҷг…Үжҙҳг„“вҚәб‘’вүҡвҡҠжү«жӨөж—ҒбҫҶжҶӨдғҡвҳҰзөөд№Ҙз…ӣв”үг•әб“ӨдҖЁдҪҘгҷҰб°»гўҫжүЁжҲҪвЎӣУҳбІӨвҲӨб«ҘбғҺбј№г–”б—ҰеҺ’ж¶§е¶Ңж®әдӯ•жһ«зҚӘжЎӨдӨӘжӢҷв®’жӨҠаі б·ҶгўЎбӣ»д®һб«№ФҚб”Ҙб“‘б·„в“…бө„гҚ№бҰҶе„ҚбЈ„У…жЁ©бқ„вӣҒг“®дҗөг№ҚжҸҡзқ‘дҗ  \"}]"},"redirectURL":"","headersSize":252,"bodySize":999,"_status":"completed","_startTimestamp":1775055409745971,"_endTimestamp":1775055409751221},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"66","comment":"","_id":418,"_uid":"f3bade66-611a-4685-a7d4-a3c7447a8aee","_cid":66,"_ctime":1775055331875,"_sid":36,"_stime":1775055408830,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39906,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:56:48.508Z","time":284,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9Z0ru&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Z0ru"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055408508755,"_endTimestamp":1775055408515372},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:56:49 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3059"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3805,"mimeType":"text/plain","text":"1352:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳжЎ”еҷҶдҳ„з“‘бҡ§бҰЁж§ідіӣгҳҒгҸҙгҳ·жңҹгӢҝвҪ»вё”ж»ҫжј еҪЁжҗ¬зқёг¶ҜвҜјг‘Әд§Ғж•җж¶Ҝжҳҗзҗ§бі·гҮҫжҰҗбј·дҸҙзҺ‘бұ¶гҜ»а»¬з”ҠбўңжҝҗдіҺд·•ж—’еһ®жҮ§вҡӣе»ҡзҹҡз„ҳжё®бӢӨгўҰзҹІгҰһвҜҘбҒҺзЈ№гӘәдҒ„зўҺгҹ«гҰҶе§ўЬҶз·ұг°–XзҜҺеҮұЮҫж·јЧёз§ҪЭЎвҸ№е¬ЎгӢҝЭҒе·Ўж…ЎЯҰЫҺвҒ”зЁҒаҝЈе®Ҷг¬ўжҮұзҝ©з§Ўбұ„ХҒа»јЫұбүһд–ұбҹўд–ҫеҷ’зӯ„еҜўвҜҫж№–ЮҒеҹӯеЎҫв…ӣеў©Х‘дҹЎеұ…вҗұж§»бӘ‘аө“Ф‘в•Ӯв“‘д§ҘСёг··з ҫжҚ‘вһұжҷ—вқұз¬Ҫв“№аұ‘зҜ№з…‘жҡЎе•“еҘ№бЈӯжҡұвұҒж‘Ғвқҗвҡ–дҺ«д—№вөҸдҷұвҘ…ШјжӯҺвҳһжЈҷзҘ‘еғҮжҳүжіұб”һж“–ж’ҷбЈҷвҡ…дҝіеЎҢг©ҷдҳөгҚҢбҷҫЦ©бҳҠе»ўе—…жөҹд•ұд«¶жӢөбҜје‘Ғд«ӣжҗ©б«ӣв ӯеҘһе’ҡдӣ—д”өг»ңТ•З—бңӯеҹ§е’…а§”еҳӯбі«еңҒз§Үвңөгҷ…Хӯг§өг–©з“ғгҷҚд§ҡгҳҚжғӢж‘ҚеӣҠгҘҚжЈҙз’№бғҗзҷҪж§©г“ӯзҜҙгҡ№е»’зһҚбқөжҳ…бҮӣе••еЈ’в–Ўжҹ’Ф№ЛҖаҫӯдҹ„а·Ғдғ”в–ҪП…еҹҘжқ¶еқҳв»Ҙз—¶гҹңд‘үж«Ӣзӣғж«өаҙӯзҘ•б–ӯв«“г•ҪжіҘа·ғбҝ–г–№з—‘ајЈжҸҸаәЈеў“в‘ЈеҠҲз’Јжү…дјізҹӮз•©дҡ–жҢ©жәңаІіаҝҹдІЈдҚҳвұ‘гҡҢвјЈаӘӣзҷҘгӮҡвә«гәҒдөҚГ—з”ҘгҜңз‘қв’қе“„г«ҲдІ«еә—вұ№ж’Җжә•в–ҹгқ•гЈҺв¶қгңӨз•»зўҶжҙЈеҪһвұӣбҜүжҫӢТ–ж·ӣз®Җг“Јд¶ҺаҫӣбһңжңҷжҸҒжҝғзіҷвІ»зӘҸжҫ»Юғвііеҡ…вә»з„үгҳ§ж”ҮдҝҪгӨӣгҰқж«°ді…жҺҮбјӣвіҹбҪівҺҶбІ·еһҢеҫ»ж«©б№·ж®җа¶§гҙҺеұ»вЈҳеҙӢеҙҷжӣөз¬Ӯеҙ·в¬Ӣеә·бӢһвҪ¶дҙ‘еҪӣжңҡеңҪж««дҙ§б”–бјҜгӣ—еұЎдҢҡбө—дўҸвіҸжҜ°ж°ҜаёқдөЈеҲ•дҖ—зҳ’гәҸг–Ҳз·ёвӨқжҳҜбҫҶеІөвҹҠбӯҡај–зә§бІҢжҚҡжҡһгҫҮвҲһз№¶еҖғжұҝеҫҡж—ңг  дЁ‘еҫҖаө¶з”„з»–Л”е»іж”Ҹд—ҳдҹҢзӮҹбҖ«бјЈзүҰбҖӢе»ҮжҲјеҸ¬дұ°вң“гҒӨЯҖд ӯеқҢаә”ж°…еҳЁбңңж“ұз°Ёг°ҘвЎҪбҘҸгҘ—еӮҰзҸҫбҲөЖҡвҳҳжҳІдҺүдҷәгўҺж„җе„«д¶һаӯ®гҲәдӣңбҰӯгҝ©Л–дҗҡеҶ»ФҖз”«жғҘеҠһгІҶдҮҳбәқеҒ…ИҙгҖүеӣҲдһ—дҖ”ВұбҠұдҗҪб№®дҡҒбҮ¶з’ҙгҚҘдўӮгҘёеҢ«зј¶аӨһЮҺбёёзҖ•в§ жҠјвӢҘвҪқд ҲзҢ®зӮ§гҲ¶в„Ӯг…”бӢғе©һжҶңвҸ§зІһдЈҖж®Ёг–—аұҫдң»бІұбўІгү”(бҮ гұӣx\\\"бЁј%еҒёд– дӮңдӨҗзһЎг„ҷбғ‘вЈЎгҲ’гӣ вҒ‘в’ҳД дҖјдў г ӯгӮӘж¬¬в…ҷвҢҜдҗЎе°¬бҠҳвғ’дҒўдҫҖзӣҠвӨ¶`жёҝбҢ®Э…е©ҙж‘ҳа№ӯеЎҲЫҗв «в©ӢбҸӮвүҠбҢјвҡҗбҳҜУёа№Ёз јд·үвүҠвҰҗИҖаёІеҢ®ЖӮа№әдҒ в¶Ўж“ҲНҗзҳ зғ№бҗІг“«еҠҢгӨЁг°Ўж• вҮЎгў–Я©ЬӯгӮҗЬЎв•ҷжҮҫаӘ…жҒҢЩҙзҹҜгҒ«ЪҗИЎзҖ«аӘҒбөҒбҸӢдөҮбҠңСҳе©©д№ҫаЎҫг‘¶г„Ҝа»ғеҷғМҚд№ҮаЎҰд’Іеҝ“дҪҢз”ҺеҢ»вҮҝа¬’бҸўдӯЁгӨӘв——з«ІжЎ©з“ҙаіҘгјөеҘ®д»“дҮёд©№гҷҘдҰғЬ’зҷҠгӘҠвӘ…в…°бҮ’бЈ«жұҷд®…в§ҘеҘӯбӣҹгқҜаӯҡаІұе‘Ҫб…ҳжӘӯеҳ¶зҲјЦҮзүЎПҗа№®гЎІд®җИҰгӮөбҙҖдЈҗеҗҶгҮ„г°ҙ`гұҚбӘҙдҝҘз°¶еј„еҚҠжүҷЦ‘в ҷжҘёвҗӘе№үж¬ҡвў°е…ёб•ёеҒӘвҖӘвЁөвҹ¶гұ¬зҸӘжҠӘдӣҗжӨ б•Ҫб•үеҮ¬гёҪзҖЁЖҒеҗЎв•ҙдҺ§б«Үв©ёбӯ¶гҒ•бҒ дӯ–бҒӯвёЎд°®вқҢзҜҚЫҗдәҗвһіжҮ¶ЦӢзҘ„гҠҳг“…в©°ж“ғг§Ӣж’ЁУ•еӯ°вҒҷбҒ жғ‘е¬Јвҹ„еҷҢвҒ вүІдІ§г ҷвқІзӨҷбҺІгҘ…жҶӯвқ…з©Јеӯ”еҺЈд»©жҙ…зҶҒбғ¶а» вӯӮгҠҪгғҶаёјЕҺеҘҜзҙ•жұҳзҚІг·°аўҙеӣ–жҶҒгӣ аҫҡе—»вҸҜбңҮв‘ҳгҜ»вӘ§бўӘжҳ еҜ»г„Үзҡ–еҮ гӢўеіҳдӮӯзһ№в•јбёҗзӮӣв«Үг№ҲдҪ®в‘ҢбұҰгұӘдӨЈбӘөзҒҰеў‘з«„аӯ®б§ жұ“ж… бҗ вҙ”ж®‘гҙ№еӨІе…Җдё§бҲјбұҒв…»дҢҺжҘӯе ўЭҷгҚәбёҷб”ЎвҸҢжЁ¶аЁ б°Јз‘ёбҗӨзәҜдјӘаӨЎж§ЎбҠ§ЯӮжҳӢгәҮбөҝв „з®ҰзӣҳдҠЈе—өв§–аҫІзҖЎжғ¬НҮз•ҘдҢ®зүҚд§әбө©гҢ·в„ҝж¬»д§ңвҜҝе№ғТ„г—№жӘҺеҰҰаӘ“г©ҷгҗҶб’»е»“бӯһдҗҳж’ұбңҷзұҙв•Ҹв¬өаҪҡдөҷв ·дәҢбҢІеЎ”Оңдёӣвү°дҡ°жөЈг®Ҳд©–гҗҮеҶҮеҢІеҜӯдӢҘдұҘд‘©зҢҗеҰ«е¬ЈбҸҠеӨЈг»Ӣг”Ідіүа¬һв¶ҶдЁ®в’ҹвӨ…вҝұгұҖДӣвҶқжңҠзӯҺе°ҙвјөзқ»дҳҶеІібҳ°з·©гј¶в¶Ңе°ҝвҚҚзӢ§е“ҘзҺҘж—®еҰ»ж»қвҸ–гҹ¶дҹҚеһјаіҢгҚ¶в·Қдҗүе—үгғӢУҪзЈ§Иӣг–‘гҡ–ж· г«Әвұ…жҲәгҫ„дҖ»г•ҙб®Қгңұг¶Ӣеҡ–жҸЎб«ЈжұҒзҲҙб°»дҶӣгҸ–дӯҝб –д·ӣбӣӘв ҫеҢӮв¶јеЎһеёҸе¬җвўһбӯҗз§–зҮҲбҳЎжҫҸеҰҮжјӘзғ»еЎҳгЁ»б§ЁвҺ·гҷ–гӨҲзҹҢРҢај”вқ©зҜҰжҸҸеӘіЫ—ИӣгҮЈб–”Д®бҪ®в§ҰбјғеҶүгҸ…в®ҮзҜҡвһңеөҶаёҙгңҰжӘҝЬҖб’“дҚӣгҗҷе«ӣзў•вӯ®а©ҸЮҸдјұж–Һе»әвұҳв©ҹбҳҡг®·гӣ•гӢ’зҷҜб¬ҹајҘз–Ҫа»«дҺӢжҪңж°ҺгҪ·б¶ӣзӨўзәҜбҙүз—¬гҰҺгҢҠж·Ӣгҹ вӮҶдҳЁеҗў Э„вҖЁаҪ Р№еҒ бӨіе ҜеұҲгҜҷзҲёЬ—з ӨдҖәЧ з ҜдҶүа   \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3059,"_status":"completed","_startTimestamp":1775055408786096,"_endTimestamp":1775055408792105},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"66","comment":"","_id":417,"_uid":"18cd3b7e-a214-446d-9f60-36202ab14cb8","_cid":66,"_ctime":1775055331875,"_sid":35,"_stime":1775055408508,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39906,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwa