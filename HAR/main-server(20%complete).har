\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳжЎ”еҷҶдҳ„з“‘бҡ§бҰЁж§ідіӣгҳҒгҸҙгҳ·жңҹгӢҝвҪ»вё”ж»ҫжј еҪЁжҗ¬зқёг¶ҜвҜјг‘Әд§Ғж•җж¶Ҝжҳҗзҗ§бі·гҮҫжҰҗбј·дҸҙзҺ‘бұ¶гҜ»а»¬з”ҠбўңжҝҗдіҺд·•ж—’еһ®жҮ§вҡӣе»ҡзҹҡз„ҳжё®бӢӨгўҰзҹІгҰһвҜҘбҒҺзЈ№гӘәдҒ„зўҺгҹ«гҰҶе§ўЬҶз·ұг°–XзҜҺеҮұЮҫж·јЧёз§ҪЭЎвҸ№е¬ЎгӢҝЭҒе·Ўж…ЎЯҰЫҺвҒ”зЁҒаҝЈе®Ҷг¬ўжҮұзҝ©з§Ўбұ„ХҒа»јЫұбүһд–ұбҹўд–ҫеҷ’зӯ„еҜўвҜҫж№–ЮҒеҹӯеЎҫв…ӣеў©Х‘дҹЎеұ…вҗұж§»бӘ‘аө“Ф‘в•Ӯв“‘д§ҘСёг··з ҫжҚ‘вһұжҷ—вқұз¬Ҫв“№аұ‘зҜ№з…‘жҡЎе•“еҘ№бЈӯжҡұвұҒж‘Ғвқҗвҡ–дҺ«д—№вөҸдҷұвҘ…ШјжӯҺвҳһжЈҷзҘ‘еғҮжҳүжіұб”һж“–ж’ҷбЈҷвҡ…дҝіеЎҢг©ҷдҳөгҚҢбҷҫЦ©бҳҠе»ўе—…жөҹд•ұд«¶жӢөбҜје‘Ғд«ӣжҗ©б«ӣв ӯеҘһе’ҡдӣ—д”өг»ңТ•З—бңӯеҹ§е’…а§”еҳӯбі«еңҒз§Үвңөгҷ…Хӯг§өг–©з“ғгҷҚд§ҡгҳҚжғӢж‘ҚеӣҠгҘҚжЈҙз’№бғҗзҷҪж§©г“ӯзҜҙгҡ№е»’зһҚбқөжҳ…бҮӣе••еЈ’в–Ўжҹ’Ф№ЛҖаҫӯдҹ„а·Ғдғ”в–ҪП…еҹҘжқ¶еқҳв»Ҙз—¶гҹңд‘үж«Ӣзӣғж«өаҙӯзҘ•б–ӯв«“г•ҪжіҘа·ғбҝ–г–№з—‘ајЈжҸҸаәЈеў“в‘ЈеҠҲз’Јжү…дјізҹӮз•©дҡ–жҢ©жәңаІіаҝҹдІЈдҚҳвұ‘гҡҢвјЈаӘӣзҷҘгӮҡвә«гәҒдөҚГ—з”ҘгҜңз‘қв’қе“„г«ҲдІ«еә—вұ№ж’Җжә•в–ҹгқ•гЈҺв¶қгңӨз•»зўҶжҙЈеҪһвұӣбҜүжҫӢТ–ж·ӣз®Җг“Јд¶ҺаҫӣбһңжңҷжҸҒжҝғзіҷвІ»зӘҸжҫ»Юғвііеҡ…вә»з„үгҳ§ж”ҮдҝҪгӨӣгҰқж«°ді…жҺҮбјӣвіҹбҪівҺҶбІ·еһҢеҫ»ж«©б№·ж®җа¶§гҙҺеұ»вЈҳеҙӢеҙҷжӣөз¬Ӯеҙ·в¬Ӣеә·бӢһвҪ¶дҙ‘еҪӣжңҡеңҪж««дҙ§б”–бјҜгӣ—еұЎдҢҡбө—дўҸвіҸжҜ°ж°ҜаёқдөЈеҲ•дҖ—зҳ’гәҸг–Ҳз·ёвӨқжҳҜбҫҶеІөвҹҠбӯҡај–зә§бІҢжҚҡжҡһгҫҮвҲһз№¶еҖғжұҝеҫҡж—ңг  дЁ‘еҫҖаө¶з”„з»–Л”е»іж”Ҹд—ҳдҹҢзӮҹбҖ«бјЈзүҰбҖӢе»ҮжҲјеҸ¬дұ°вң“гҒӨЯҖд ӯеқҢаә”ж°…еҳЁбңңж“ұз°Ёг°ҘвЎҪбҘҸгҘ—еӮҰзҸҫбҲөЖҡвҳҳжҳІдҺүдҷәгўҺж„җе„«д¶һаӯ®гҲәдӣңбҰӯгҝ©Л–дҗҡеҶ»ФҖз”«жғҘеҠһгІҶдҮҳбәқеҒ…ИҙгҖүеӣҲдһ—дҖ”ВұбҠұдҗҪб№®дҡҒбҮ¶з’ҙгҚҘдўӮгҘёеҢ«зј¶аӨһЮҺбёёзҖ•в§ жҠјвӢҘвҪқд ҲзҢ®зӮ§гҲ¶в„Ӯг…”бӢғе©һжҶңвҸ§зІһдЈҖж®Ёг–—аұҫдң»бІұбўІгү”(бҮ гұӣx\\\"бЁј%еҒёд– дӮңдӨҗзһЎг„ҷбғ‘вЈЎгҲ’гӣ вҒ‘в’ҳД дҖјдў г ӯгӮӘж¬¬в…ҷвҢҜдҗЎе°¬бҠҳвғ’дҒўдҫҖзӣҠвӨ¶`жёҝбҢ®Э…е©ҙж‘ҳа№ӯеЎҲЫҗв «в©ӢбҸӮвүҠбҢјвҡҗбҳҜУёа№Ёз јд·үвүҠвҰҗИҖаёІеҢ®ЖӮа№әдҒ в¶Ўж“ҲНҗзҳ зғ№бҗІг“«еҠҢгӨЁг°Ўж• вҮЎгў–Я©ЬӯгӮҗЬЎв•ҷжҮҫаӘ…жҒҢЩҙзҹҜгҒ«ЪҗИЎзҖ«аӘҒбөҒбҸӢдөҮбҠңСҳе©©д№ҫаЎҫг‘¶г„Ҝа»ғеҷғМҚд№ҮаЎҰд’Іеҝ“дҪҢз”ҺеҢ»вҮҝа¬’бҸўдӯЁгӨӘв——з«ІжЎ©з“ҙаіҘгјөеҘ®д»“дҮёд©№гҷҘдҰғЬ’зҷҠгӘҠвӘ…в…°бҮ’бЈ«жұҷд®…в§ҘеҘӯбӣҹгқҜаӯҡаІұе‘Ҫб…ҳжӘӯеҳ¶зҲјЦҮзүЎПҗа№®гЎІд®җИҰгӮөбҙҖдЈҗеҗҶгҮ„г°ҙ`гұҚбӘҙдҝҘз°¶еј„еҚҠжүҷЦ‘в ҷжҘёвҗӘе№үж¬ҡвў°е…ёб•ёеҒӘвҖӘвЁөвҹ¶гұ¬зҸӘжҠӘдӣҗжӨ б•Ҫб•үеҮ¬гёҪзҖЁЖҒеҗЎв•ҙдҺ§б«Үв©ёбӯ¶гҒ•бҒ дӯ–бҒӯвёЎд°®вқҢзҜҚЫҗдәҗвһіжҮ¶ЦӢзҘ„гҠҳг“…в©°ж“ғг§Ӣж’ЁУ•еӯ°вҒҷбҒ жғ‘е¬Јвҹ„еҷҢвҒ вүІдІ§г ҷвқІзӨҷбҺІгҘ…жҶӯвқ…з©Јеӯ”еҺЈд»©жҙ…зҶҒбғ¶а» вӯӮгҠҪгғҶаёјЕҺеҘҜзҙ•жұҳзҚІг·°аўҙеӣ–жҶҒгӣ аҫҡе—»вҸҜбңҮв‘ҳгҜ»вӘ§бўӘжҳ еҜ»г„Үзҡ–еҮ гӢўеіҳдӮӯзһ№в•јбёҗзӮӣв«Үг№ҲдҪ®в‘ҢбұҰгұӘдӨЈбӘөзҒҰеў‘з«„аӯ®б§ жұ“ж… бҗ вҙ”ж®‘гҙ№еӨІе…Җдё§бҲјбұҒв…»дҢҺжҘӯе ўЭҷгҚәбёҷб”ЎвҸҢжЁ¶аЁ б°Јз‘ёбҗӨзәҜдјӘаӨЎж§ЎбҠ§ЯӮжҳӢгәҮбөҝв „з®ҰзӣҳдҠЈе—өв§–аҫІзҖЎжғ¬НҮз•ҘдҢ®зүҚд§әбө©гҢ·в„ҝж¬»д§ңвҜҝе№ғТ„г—№жӘҺеҰҰаӘ“г©ҷгҗҶб’»е»“бӯһдҗҳж’ұбңҷзұҙв•Ҹв¬өаҪҡдөҷв ·дәҢбҢІеЎ”Оңдёӣвү°дҡ°жөЈг®Ҳд©–гҗҮеҶҮеҢІеҜӯдӢҘдұҘд‘©зҢҗеҰ«е¬ЈбҸҠеӨЈг»Ӣг”Ідіүа¬һв¶ҶдЁ®в’ҹвӨ…вҝұгұҖДӣвҶқжңҠзӯҺе°ҙвјөзқ»дҳҶеІібҳ°з·©гј¶в¶Ңе°ҝвҚҚзӢ§е“ҘзҺҘж—®еҰ»ж»қвҸ–гҹ¶дҹҚеһјаіҢгҚ¶в·Қдҗүе—үгғӢУҪзЈ§Иӣг–‘гҡ–ж· г«Әвұ…жҲәгҫ„дҖ»г•ҙб®Қгңұг¶Ӣеҡ–жҸЎб«ЈжұҒзҲҙб°»дҶӣгҸ–дӯҝб –д·ӣбӣӘв ҫеҢӮв¶јеЎһеёҸе¬җвўһбӯҗз§–зҮҲбҳЎжҫҸеҰҮжјӘзғ»еЎҳгЁ»б§ЁвҺ·гҷ–гӨҲзҹҢРҢај”вқ©зҜҰжҸҸеӘіЫ—ИӣгҮЈб–”Д®бҪ®в§ҰбјғеҶүгҸ…в®ҮзҜҡвһңеөҶаёҙгңҰжӘҝЬҖб’“дҚӣгҗҷе«ӣзў•вӯ®а©ҸЮҸдјұж–Һе»әвұҳв©ҹбҳҡг®·гӣ•гӢ’зҷҜб¬ҹајҘз–Ҫа»«дҺӢжҪңж°ҺгҪ·б¶ӣзӨўзәҜбҙүз—¬гҰҺгҢҠж·Ӣгҹ вӮҶдҳЁеҗў Э„вҖЁаҪ Р№еҒ бӨіе ҜеұҲгҜҷзҲёЬ—з ӨдҖәЧ з ҜдҶүа   \"},null]468:43138[{\"ret\":0,\"compress\":true,\"serverTime\":1775055535459,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зҢёжҖЁбҢ¬вЁЈб·‘Kд§”ЙЁЕҗеҒӣ9еј гҢ б¬ бҶ вң Ь вҙёдҒҰаҪјгӨ вІЈа«өж•©д—ЎбқҖб–ҰЮ НҒеЈ•г„Ҙв ’еЈҖжҶҸ;вҲ¬вҳҙжӢіб…ғвҜјж ғе”¬ж¬’В бҢёд№§жҝ«д‘іжЁ»зЎ•зұҖ}аё а·ӯУўвқ„вүҲДүвӣҢВқвёЈбҰЎаҙҠЩҠбҶ жҖЎгҷ®еҒӮзұ•вўҜдјӘгҮҰбҡұеЁҠаўҒФңе’ёвҖ·жҺЁеҒЈг’–б—ӣгёқзЎҸгҪһгӮңгҲҰаӘ№Гҙг«ўзҺқСҚаЈһгғӯгүүе»ёвӮ©зҳ·жҠғбұ•гЁӣв„ӯв¶җд•“вёәб№ӣЫҸд»•еў·жӮЈаҰһзһ®аІөг“–вҹңаҝЎЛ¶бҘҖбјЎдҰҒб°ҙдӮӘдҰұбҖ·дӮӘзЎ‘д•„ж„Ёеҙ¶еҰ¶жҪ“гі¶д”ҰжҒӘдүүеұ№ж•©діҺбҠһж җд°ҫз©ЎжҢ’гҲ¶еӮҶбЁ—гҢ¶бҫ·бҷЁд°ЎзәӮд°Әа°ҖдҢҜбЈҮПҶО¬бҘүд°Ғг…Іб“ҸбҚұгҶҡб»үжғўбӣңејЈж©‘гғһбӮүб®һгӮәдҝЎдЈ¶гғ…бҡҚжө…дҮ’жү•е¬үгҺғбҸ¶гҠҷдӯўбҰҺб¬ҷгҺҖеҳҺзҺҚе…№е…үЮҘз–јеӨ©жҙөвЈ«б»‘в«ӯг–ӮгҗҢж«ӯж¶ҡгӘ—ж¬ғд®·в“үвіӨеҸүеҫҝдҒӨжү®гҺЎаЁҚзҢҚгҶ©з ұбҪғгӣЁб©Өдә•гҲЎаӨЈз¬җг©ӘвҹӨжң„гҒҷзүӨеӨҒб№ңгҷіз«әг©қбө“з¬–гҪҹеҙ“дүәдЎәзӣҙгҢҡз•ёа»ңзҹҲж©“в“–аҘҺа§§е„ёвңөвӨ«е”әд¶әз”¬жё§вҘӢе…–жҺһж·ёвІ•е¬қеҝҒжҗҳж®Ҷж°’ж№•дӣ»дӯ®жӢҳдҒҫжЎ«з®ҸгҖҗб„ұжјҘд„ӨвӮ№вӮ№жЎ©жһ„бҲўбқўвіӣгғҢвҷӢбјўбҸӣвҘқжҒҘжӯўвҚЁз•¬вјӢдӯҘаЁүвғҚа¶ӘвӮўбҢ§вҘҳбЁәз•ҡбЎ©дүҰб¶Ұз¶һгҖҲжЈЎд ҠгӨҲж„ұзө„б—ӨжҚҹвҡӨТ¬б”©дүҢбҚ…дүјб“ҮзӮ№бүӮбј®д·„дҶӮж©»б®’б—ҶвЈҲвғёжЈҶжҝЁе¬«бёҰвқ¶б—ҮеЈҪб№ҶЮҗжҪ»в”Ҳж№ӣб®ҷб—Ҷб“ҪбӢ„гҙ•бҜҶг”ҲжҮҳб„ӯжҶ«гқҗеІ„а№іаўӣаҪұдҗ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":3981,"_status":"completed","_startTimestamp":1775055534583041,"_endTimestamp":1775055534589120},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"67","comment":"","_id":536,"_uid":"82897d1b-ebbe-4451-8830-36db91aaa2fa","_cid":67,"_ctime":1775055373090,"_sid":58,"_stime":1775055534306,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":35432,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:58:54.288Z","time":279,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9ZVZD&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozil