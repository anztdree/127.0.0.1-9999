ӮжЈёзІӮвҳ№бӘҙдқӘзҚ•дӮҖГ–вў–бүҢжҜұаөӣбЎәв»¬Д„дў“вҠ°%бҖЎеӘҲВІгЁ И•ГҗзҢ в•ҖбҚӘж ҰЗҙЖӯеҢЎд®һдӮ—зӢ”з’ҜгӮҗЮ°аҘӮд§Ҳ!!бҗіаў жҙ·д ҒжҳӘг¬ўЪ»бӘҝг»ўдүёЗӯаұ¶жҠ«бӘәвҺәг„°жғңФ°а°ҘбЈјВҪ&ЖҖ\\\"жҢӨКҖгӢүШўеҸ°з¶ҫХӯеҢЎг§‘CеҠҷзҫ°бҖӨг®җдў–ЬЎИЈг’Ўбў вҳўбӮӮб®ЁЮ‘в’–бўўдҖЎеңҢдөҺдјҶзҰ жҪҖЮ’вҖӨб…ҸЭҲв¬ д°ўг¬Ҫдҗ§вўҖ0д ¬бөЎжҰҢеҪҢв¬ҚдӮ„дөӢдұҒзҳёаІҢОҳжӘ‘Ф§еҲ ајҙбӘ°б—ізјұбҖ°НӢвҚҶе§ҖШ¶бҖ¶жүҹа ®б¬үеү‘аіЁеҠ’ж№һбүҶе°ұзІҒбўҘвҚҲз’ҚдҰ®жҢ„бҘ”жәЎвғЁаЁ аҪЎзҶҒжҠ®зӨүгЁЎеі–дҖҘвҘЈе»ҮгЈӨаў¬д“ӮдЎҗЗҸв—җж©°@а ҖаҘЁб„ аҜ©еҺЁдҷҚа№«гҲҲдёјгӣ®бғ–зҚ„бӘ©жҫ—а°ЁаҝҳбІ®жҺ©жӘ“б·®г” а«ӘУӮе ӢдңҠб“ұб’ҹеҫ”бәӣеӣ жҗӨб§ҒаӨҲбһӨвұЁИўаӨӢдҳ§ШЁаҘ§ЗЎеў бЁ аҘҰжҒҖгҖ вҺҗб јЭҫз… еӢ РЈаҘӨзҒӢб„„зІ°еҒҖбҠӨН”б ізӢўвҠ·а ҒзҒғРҢбүҲеҒұЩ…з  е–һBТӘвҘ зғңбҒӨбЈҲб«ҠдҢӨаҘӮд–һаёӨж“ҲајҰжҳЎаҰўд”Өа®ӮеӮ жҒҒдҒҶа¬Ҙг”җбүҒдҰ…дҘ°аҙҳвјЈд’җбұЈе ұаЎҶР ЫҺдғҖбҶ°жҺҢз¶ҙбҲівӮҰв Өгҹ«ЕЁЦ¶зҺәЮ°зҲӨгһҫеҢӨгҫҙжүҢдҖӘбқҪдҶҲвЁіеҪ„д’°жҠ¬зҲ«зҒ–дўғгұҺд¬ зҘӢбүүдһҫдҶ°гҲҙв…ұз—…вјўдұЁдҒӢдЈ‘вҲўдЁЁв“җдЁІдӢҠаІ’дҪӯдӘёШ«д©ҫвғңб‘ҡж‘ӢгҘҫж–“д•ҳдң°зЁҘвӘЁгҺқдҶӢжӮ•бҺҲгҖ¶гҗәдӘӢбҮ еЎұе…”дҙҙдЈёе—җ!гё§г°©ж„“бҫүВәЮүдіҰд»іб„«в°°ВӘб…¬в¬Җз ІжҺЎдҚёжҜ”бҡҝб ЁзҸҪдҠҚвҝҠзҡҪгҰӘе  жҙ¶дӣұжЈҲдҚғдғІа·Ўжҷ’бӮ”}гҮ°жҢһг¬ҲЯ–з°ҰЮұж„әвҒҖбҷқз«„е®…вЎ г“ҜзӨ©жҙ„Ъ‘ж©”гЁЁб‘Ҙг®”ж·¶з°Һз“„зӯҘгЈҖдҮҫз©қвҹ‘дҝіжҳһе…ңЬ–дҲЎЫ„зӯ©еӮҒеұҗдҡұж©‘з¬ғгғӣв ‘е••е®©жӯӘвқ¶дҢ№вҡөж№”г«ұзҺҸzгҚ“вҖ°аӘҰжһЁЭ’зӯҢдҪңжҘһзҪ—жҢҘжЈ„еқҒжЈ“дқҒж“қбңҳжіҹВ„а©–дңҚжӢ—жҹәв№’еҷҪдҘһжі¶бўңа»Ҙеө–дң”бҚ“гӯӯз…ЎгӣҚеқҹД„ЯіаәӯжҸ—з®Ҫзҡҡзӣ®еЈ‘зҹҒжұқзңұз°ҘаЁқдӢҷдҹ“жўқеҳ©зў‘еқғзҘқа»өжІҹеҳЁв–ЁдёӨаӯӣжҺәб“үгһҫзӘҷдҫҷз®“дјұбҸҗШ«ж»ҙвҝҪд“ҡвә…д–—з …з©”аҝ§з¶ңжў•дҙңж»©д•ҳжјӢеІҗв„„аҫ’жӣ«д„ҳз®§жҜәбјҚдјӣзӘҘдј’ЯЎдҰңвЈқжүғзң”г––еҫӢдң—дҳ»ж«“вҡ°ж§ҢеҮҝз¶•дӨҳдҒүзҒҜа§‘з–ҳП°е”…гә¶вҺқзӣҪвёҸеҪӣдҹҒгӘЈгҶҗвҪ·зқһзўҒвә’ШқЗ§зІүеҺӣгҹҡС§бј“гңІајЎаІҘЕ©жҢўгҹ°гііе¬ҷгҸҷЩҜбә–дҪ–аӘһв°әжўҫж®ўг»івҶҢбӮӨгҶЁдҶ е”ЁгӯҪзӢ¶вёҖг»ҹж§јвҖ©в…ҜеҘҷв—ңЪ“вҜөе®„а«ҡеҗ№жҶ бӯқбЎһг¶ҳгҶӣд®ўГҸВ‘аЈ‘аҙЎд ҢЗҚжҶғгүһдұҺе»ҒжўҸгҘҲз§җг…ҶаЎЎжәҠж…ҡб»ўаҝ«дӢҪеұёаұ®ХҸгқ–аӨ•зӣҒз„ҫеӣҚдӢҪзҜ П‘дҪ№жІҶдүҪвҺ«зқ»гҺ‘е”ігҡҫб…Ӯе©үе·ҳгҪҘвҮҖв”ёеҜұФӮа¶©дҖҚб…‘б„ІеҷҡбӢ в№Ҙв—Ӯд“ дІЎв“«зҚ©ај¶б№ҫб–іаҝҜжүҝд©»зЎҘгЈҲб…ӯаЈЈзң©жӮүвҘЈбӯӯз« бҙҚе®ўзҲ«Е¶гұ–еӘғбҠўбЎҒГ”ЙҖб©ҙдҒ°аЈғгҠӨа©ҢеӢ дҒёең¬еҰ д©№вҡ¬вҠұеҒҮдўӘвҒ—аҰұг¶ҮзңұеҸІг«„вЁівҰҒгҳёзҘҠе»“в«ҡзҒңеҙІгіҷЖЁз„ӘжЁ еЎӨа°јвҘ¶РўгЁҫдҗҳвҒЈвўҖд”ЁзӮ©а  вұҗаӨ©б…„ХҒеҲёаў•г„ҘЪһеҢІбҖ°б№ЁЩұвҰ¬вЎ•бұ«еўЈа©°ЖӮбҺ“е–ҲгһҲгЁЎжҺівҖұбүәФЎдӨ·вҘ’гҒ¶дҷ’дҖ з„Әв»®зҘҺж„ңЪӯаіўг¶№вҒўеҘ¬ЦҢдқүдӮҺв¬ в–Үж”ўеҒЎЫ©д©№в…ұеҘ¶вЎҚг№ҠдӘҫвјҫгҘіД‘ж–”вӢҢвҜ№вҚ·в–Ңе‘үв»Ҡзһқв№өж»„г•је—Ҡг“§в«ұд”ӣХөеӣҠд“Һб«ӣв»ҰЭ°вӮ°б“ӢвӢ…вҜҘгө¶жө¬ең’е§ӢвҚәаё•дҚ¶е—ҺбјӢдҮӣвӯЈвӮ б’“еҳҡз—ҠдӣңвЁӯеҚҝжҳҶеҫғбӣҷбӯҪгҒ–г–ҢгҹәзІҲеөҰвўӮНҝз•–еҒәб§һв©ҺдЎҙвҚҘгӣҶж“үбӘ°жіӯгӨ№бҒңдҮ“з…¶е”ӘдӯЁаә°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2298,"_status":"completed","_startTimestamp":1775056326423470,"_endTimestamp":1775056326428097},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1533,"_uid":"1b3f9ba0-8481-406c-b02f-f90ae431340a","_cid":148,"_ctime":1775056284934,"_sid":30,"_stime":1775056324859,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:12:04.378Z","time":428,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cWSI&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9cWSI"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056324378288,"_endTimestamp":1775056324390298},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi1AAme"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:12:05 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3003"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":3736,"mimeType":"text/plain","text":"1328:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“”гһ©зЈ—в–…жқҷжӘ•дҮҚа …жӢ—е‘…з»ҡг“ҫвҜ»еңҒж·үгңҚдЈ•гҳӯгқ„гңЎжҸ•е•ӯж»ӯгҗҘг§ҡзһӯді”зқӯдҜһзҘ•жұ•з—•ЗҷжӢӯвҜӢг“қж«ҷгҹ‘жі®е қдҹҗа¶үжӮҸеңқзҹҮбЈҘз“–аҙҚеҝ…СЈб»Јз—¶вҝҲеҷүб«қаіҡдІһе‘үеЈӣз’ЈеҸңаёіж«ҝз–ғдӣҮе“ғбҸһа¶Ҫа»Ҡд№ЎжҚҷа¶ігўҺз‘ғжү“г“Јдә•а·ҪдӘҹз’©гә”дҙөвә—жң«з¬©а¶ӯЖ‘дҙ«КҹзқҘзҡҺвұ«дҶ”еҹҪгҡҢвІ“з–Ғв№®КҚжҢіаҪ—вұҷз¶ӣгЁ»вҮҖвЈҪбҪӮбҷівҺҷж«із§җе–»еҜҠв№»жЈ¶вұҚбӣ–зҖүз®қг–ӣбһ”б’ӢаЈҡг”»вһҖеҡ№ж„ңжёӣд®ҠаІіеҺҡб·ӣе„ӢвІҚвҹҢв”§д—ҷбө…зҸҡе¬ӯФҚв»ӣеҫӣб““жӘҗбө§вҙҳеіҚеҢӣвҝҮзәҸвҫҮвө®еқ¶ЮңеІҘд¬’гҹӣеҙ…бҖЈМӣжұӯбӢ…б№іж«ӯбҪЈзҶҲеә—г®ҖдҪ¶еәҺеҫҜв”Ҡе°ӯбЁҳж·…дҢҒг№ҜбҙҶеҪҫбҳҷжұ·бҫғгІ·жңӮЩӣгңҶж°ҝв…•бұЎаӨғбёҸИҶеқ®а үжӯҡеҗҒд№—д«№ж«·гҲ‘бІ—дҲҮбІҹең•вёӣд Ҡб–№дҗҹвҫ‘бӯ•зҲһз°ҶгЁҝж©ңз·ібё—е ҡгјіз°ҮРӘД’гҚҰеҖөжӘ бӮўзҹҙа¶ҮбҗҘв¶®ЫҝгҖӘзқўаҘһжҲҫжәЁбҙўеҫ°дҸҸе»ҳвһІУҚв„Ҝдқ”а·ЎеҲҙбёӨбҪЈзҸӘРҗгҗ§з»ҠЫҸгЁ¬дӯүз ҒзҖҙбҲҢбҶўвҒҢж…Ғдҳӣж–»зҰЈбң¬вҚӘаӯһвҳҫжӢ”б«ўбү„дӢ„вғәдҒ ФӢвҗ®еғ°гғұз„»е№ҙбһўб“ дҠӯеҚҘдІҠдқ е’ғбЎғгҺЎгҳҪе…Ӯб¬јз©Җз‘ҙгҳҡбһ©дҡ«бҙ–зҪғаі‘ајҙгҲҰбұӮвҮҝв–Ҳг§ҘжҰұж®ҳзЁ‘ж№ЈеҢ©бӨӮеҖӨаӨҖбёҪдҒҢ!аҙ®\\\"жӨјвӢ вҒ–в’ҳгҜ еўҢдЎёзҝҖеЈ№б®ҖбҖҝбүңВ вҖҰв‘ б°Ұе өг“әбІҲжҲ–бҲ жёҰаҘңбӣ б°ҙМ„з¬ з•ўдЈҗИҰзғ№бўҗбҘүеҸҰвҮ гҠҚд… г–ўдҒҡе‘№б¬№ајҶбҮЈгҮЎгӮ„вӣ гү§дӮ„ж•Әб…ўд® ај зғ…бўҗа¬ҜгӢҙИўж°Ұв• бҰ§гҖ§Э©гјёЪҚб»ңж©ҶгЎңбһ…вҒҒжғҳг¬Ұж’§Ыҗг §ВҘбҙҒжјјгҢҖбӣўжұүвҡңз¬ӨеўҮ@ај еЈҶа«із“ҫвҢ·еҡ‘ж‘ЈгӨҳзҹҰзӮ дЈ‘вҡҖз ёе»ідҷӣзғӮгӣҰжү»жһңвҙ’зҪЈаҜҘд–„зЁҗб¬ғж…ҷСўгҝӨжҰҡжһ…вӮ«бӢҙв®©вҝўеҘ—жӣ’г©”вҚ©г–…жІ‘б•Ұб•ҲгҠЎв®‘жіҸв•Һб•Ҡді…г‘№гӘ¶бүўдҷҹгҷҢбӢ·дҝҰзҝҚгҒ·бҹІб•ҖдҮёНҮбұҒв—ҳДЈбЎІдәҗд‘»дҘ“бӯІбёӘ@аё¶аөҰеңҗзҪ·вӢҸај…а©ҫгЈ®е ізЈ“еҸқгҡ·е·җе ’жЈҢеў©в®өбғ»з—’е—ғзӢүбҺјдҘ¶в•Өгһ“гҹ§гӮ—дҒҖЦҰеҒҷбҷІаёёж¬ҚвҰҖвө№дҗҠзіӯдҗЈв® гҢЎдӨ«вҖӢжіҷж–јбј„ж’•дҶәзҷ¬аІ№аұүгҠҝжӨ°жІҠеҘӮЕӯгӢҙа Ұвҗ°аЎҢеӣЎвЈ№а¬ӘДҫДЎгҘјгҠӯе …жө«жҺ„дҷЁж’·Ы©е»өжҘҰжҪІдёјг¬§г©·бі•дҸҗвӢӯаіӣв·©дҺ§Гіе‘ігҪҒг¬®бЈҙзһ”М…б§Қе ёв·җд·°е–Әбһ’ЧҮб“Ҝв»үзҷўб–ёвҡҸеӣқд§№жө§Г«аә’з„ЁбЁёгҚ·аҰӣж‘„ж’Әж»°ЗҪаІ°еў‘аҙ‘в•ӣз©ҠвҜўбҡҳж”ҠеҒҚбІҮЗҗжһҘpаӯ“зҮӣаұұгҢҙзҰ—ж…ҳЩЁгўҗдӮҘжІ¶зӮӢеЎігҳ дҒ®вЈ¶з®–в• вҫҠбӘҘдҠ ЬЎгҙ¶ФЎаҝ–бҜҙг°ҖеӘӢб“Ҡе©Ҹбҡ№дҝ•вәҪдЁҺаіәз„°ЬҮвіҶв…јXбҰЎв’ҪвЈҗж»ҙд—ӮгҙҰдҝҚвЁјвұ—вҺӮгңҲзұЎжјұвҪ…аәәЖ–ОӘжіҲг®°вҮҘвҚ·бҡұеӘЁбғ№бҖіФІГҷв§«жҡғж©ҡгқҲжіёд¶ұд’Ҙж•һв¬Јбқ»з—ҷвЁҰгұҮж¬өеқҠаіідҙІж–ӯж•§бЁ“жқ—зҚ’жјҠжҰҢвӯңзӣ д”’еңүжӮ№д№јеқҠдіҳдӯ¬жӯЈдӨ бҳӘжҸ¬вҫ—дјҰд–ҫж–«ж«ӢдҷёвҜўгјҒжәӢа®ўз§ЎвҢҺб•¶жҠЁејҳеө«гӢӣаҜ®К·з–—жңәжң¬г«°вәҷзҺЈж–ӨжўӢв“ҷг—ігЁӢбәҲжұ¶жҝӯе°Ҫв¶Ҙдұјж¬§бҙһЧ‘бҜҺеўҗз„ЈгңәжҸЈб«¬гӣҠзӮ№еұ“е©«аҫ·г¬ұг‘іаҫ–бһ®вҳҸе¶©жҙұеҶјв·Үеҫ»зғізҜҸгү·в…ҡеқҡзҸӯжұӣжөҜвҮ вҗЁг¶®вўҷгҜҰгӨҜжјҰбҖҢз—Ҝб’җбі•дөҪвЁ„гә’дҺӯд·ёзҝ¶вјҝаәӘжҮ з¬ҚдіЎз…ңаё‘е««в“”дЎӨзұҶдё®дҫўжһ®бЁҮдұҳбҒҷжҰ¬гҙ§жҫ°з·…гёҰдҰ„г©№з°ҮжҮ бІқжҡја®«ХҮдғ‘в”Ҝж„ӮеҫҒбңҷзіҢжңўН”гҒҘвҖ° гҘӮ`зЁ вғӯИЎдўҪдҮ•ж…Ўе—Ҝбғ бӣҹдҒ„Г°вё§дӮңаӯЁдҖ  \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3003,"_status":"completed","_startTimestamp":1775056324799049,"_endTimestamp":1775056324806768},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1532,"_uid":"983ff5ce-538a-4eb4-887b-4380f0222cf4","_cid":148,"_ctime":1775056284934,"_sid":29,"_stime":1775056324378,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:12:03.940Z","time":352,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cWLX&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"201"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9cWLX"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"postData":{"mimeType":"text/plain","text":"197:4219[\"handler.process\",{\"type\":\"activity\",\"action\":\"getActivityDetail\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"actId\":\"3ad3406d-1c09-47f3-8ba5-86b0d5d90d93\",\"cycleType\":1,\"version\":\"1.0