me":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1193,"mimeType":"text/plain","text":"471:4320[{\"ret\":0,\"compress\":true,\"serverTime\":1775055118198,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зҢёжҖЁбҢ¬вЁЈб·‘Kд§”ЙЁЕҗеҒӣ9еј гҢ б¬ бҶ вң Ь вҙёдҒҰаҪјгӨ вІЈа«өж•©д—ЎбқҖб–ҰЮ НҒеЈ•г„Ҙв ’еЈҖжҶҸ;вҲҝе…¬а° вҳҫв…ҡгҠҷЬҠаӨ№вӘ¬дҜҙвқҢбҚҙвӨӘзҶҗвҢңд’°Nдң ЬҶдҠҒбҺІб„ҙВ”еҚ¶^еңЎді дҡ•МөаЈ гҖ еӯҮв ұгёәе‘§жһҘбӨғаӯЁжҙ•СҘбҹҒдөҝбӣҖШ‘жүҲбғәб¶Әж»ҫзҫңб…ҹбўҒбӨўзӯ¬дӮҠбөҫз§һд„Ғд‘ҝбҝӘе§ЎаӘҸгҳ°вҠӣд—ӨдІәжөўз»°дҚұеұӮді·ЩҜа»Јб°Үв¶ҢвңҳбӮӮбҝЈзҮЈзЎ з°ҝд”Ҙеҷ’в‘ҶвҶӨзҒІв‘Ҡв‘ӨдӮӘаӯҰгҖ№г©»ЛҪзҚәб‘івӯ«гҡӣжӮӨе©җг’ҰШҙз§ёдіҷд§·в№ҹг ҡвҡҜбө”д«°вҘҝгӯ–гҳҷбҰ«бЎқа°ӨзӨЈаЎҹдЎўаІўжұӘдә§д•Ңз©ҺаӨөдӨЁеіҠв№Ҙб–Әв©•вӯ№гІёдҘҮгҮӨз«¬жғӢжү…гҲҗв§Ҹз“өгҙғаё«жғ№бҳ–е—Ҳг„әжёӢвөңж¬’бҘҰдғҮв®Ҷг·ҸгӣҺжјҶг¶ңдҝҹаҜ—ЦҫеЈңбҫөг°°жҸ–в¶¬д¶Әжҹ…в№¬зҳҠжҹӢвЈӯдәҡзө„в‘•зҶҪвЈӯг„ұдёҡе—®гҲ¬дҒӮПңжҜҚе…ӮЯ’е©»г·Ҙжғ„в –еӯҪеҺ„бЁҚдҢҪеҰҠбЁҢжҚЈе§ЎбўҚбҗғж¶•бЁҸеҚ“дў«бЁҢзҚ“еӘҝбөҮеһҲдұІаҰ©в·ҶЯ¬гҢ№еү»Т·Фғжў¬бҺӘе……жӘӯвӣЈгӨүаҜ¬зҰңвҒ…вҰҹб’Ёз…ҳз–°ж»®вұұЭ‘ж•ҷг—„бһҢвҝҹЯҳгЎ—гҹ…ЗҺг„Ўз·қбҗҪдҡ б’ӨжҺӘајҘбғ”зғўвҖјзҹ„а®®а№Ҫз“ҠзҮўбўөбҡқг»„жғҚз“ҷбҮҚб’Ұе қзӮӮдҶҢг’ҳаіғжў¬аӨ„зҒ¬зҗўе“’аҫӮеәҝзҺӮбҮҡж”Ӯгӯ—а§ўдҢҝз Ӯвү·д„Ҫз’јдӯҘзҶҝзӣўЙҫаө„еёЎа Ід‘ҰдҘғжІҒгҢўб’ӣж•Ңжқ•аө…ж–ігҹҢг·ғаұјвІҷдёізҠ·гҢўбҠһдұЈжҷ¬дІ“зҠҷдҪЈзӘ„зҲҚв©ЁдӨұж©§вҲӘд¶®дӨӘз©ЁдҪҪг®ұдҫҙг®ІеҸјaзүқдһёжҲ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1020,"_status":"completed","_startTimestamp":1775055117303954,"_endTimestamp":1775055117309341},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"54","comment":"","_id":170,"_uid":"1d52f12c-2832-4827-b942-8b031003ecfc","_cid":54,"_ctime":1775055043431,"_sid":25,"_stime":1775055116615,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39938,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:51:55.795Z","time":782,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9XvO3&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9XvO3"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055115795881,"_endTimestamp":1775055115801334},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:51:57 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3015"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3754,"mimeType":"text/plain","text":"1334:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№Ҳ8бӢөзҖҰвҘЁВҗдҢ§е„°зӨүдҒҰВ–вһ еҡ—Lзқҹ;бЎҢжҖ¬жҖҘзЎЁв„җаўҖвҰҶМҫбәІд’Ӯг• ОҲЖ”бӢ¬гҖҘај б‘ҜДЈбҖӨзҜ„вғ©вЈЎгҙҳж…©віңеҖӨбүғбғөеҮ бҖӨдЎ”еҜҠаҜіж„ізҖӨзҠӣдҳЈжә¶вҘҗ$д»ҘвјӢвЁ”з  г§Јз№һгј©3б”ҙгўҹзңӯжҫҰгҙҠв„ҒПұзӮҳгЎ—жёәбІ®д’ ж”ҖеұӘбүҺд…ғбҷҠЫұжӯөвҗ·дёҘ ж№өвқўж„ўдҶҖе¬ҪдүҒдҶ®б•өЪҰбҒЁг¬ Ы”дҢҰжўҲд‘ҖбҖЎдәЁИЎгі„г°»аЁЁЖ„зӮҡаЎҘд®„вҫ”бҲҘ9зЁөбҙ©вғұвўҳд©®бӮЎжЎҙдғЎвҖҙеҲҫКЈж‘…зҙ”бҺ§в•ЎбҒңаҰҶгҚҢеө®вӘӯвҖ©дүұЙЁб–ұдӢұгұ№бҳ’г«№вЎҜбӣҘдӮ·е·ҰгҗҚв«ҺвҚІдҲЁвҠүвЎІб”°жҠ©в”«жқ«вң“г…¶дҚңбҠӢв¬ҮгҹӢб¬Үвқәзҗ»бјҸв“ұвҮӘа««вЎ–гҗҳбҙӣгұқеҗӘеҲ—гғөз•ӘзҶӨжӢөжӯ»зә…вө–а№ҡеӘ·вҪ¶з’ҡдҡҝг№–гҷҶЗӢв•“гһ·еіӘжү•ді·еҲҡжғ”жҙ·дӮҮеҒ’Нәгё®жҮҙзҡҮг¬қвқ“бҖҶЛҝг§ҡО®ж—°зҸқбҪ¶зҸҡжҪңг•Ҹа·ҹвҘізҚӢж®¬бө•жіҜе§Ҫзҷҗгё·зјҒж’ңдІҝгң“жӢ•е№§гёҷзҝ—гё®аҝұж¶‘ЪҸеҺ’еҡҝдһ•жӣ—дҷҙб№ӢдҖ«бЎҮе•җж№іеҗ©зңҖвҶ—ж№°гј’вҡғдё«дҶідҚ–ж»•дҲ¬вёёгҖ’жҶӢеЎғжҶ·дӮ«зҡӣдҮ”ж…ҚеЁ“бўҫбҠЁз№ҲгӮ«вҶ”г’©гӣҗвҠ¬вҲҳв°Ҝг…ҹд’Әб»ҘдіЈСҠе ӘвҮҪеҡ”а§”вӮ‘аҰҜеҘ“УҸдҒ°е»Ңвҷ©еҶ°гҰ’а№ғе—–гҶңвӘЁаҰәгў®жӨҜе¬®а°Іг•Ҝг»ЁвҚ®зә’г җв§җгўҒвҰҠдҗ®д§·дўҜвҮҶвІӘг„ұЦ©еӨҫвҺҜдҘҗвЁ–жҶӢбҝҜгҘҝдң‘б§°вў“ЦҮд««гҘ·д©ҢзҰјгҮӯгҡӢб·җбЁҠгҒҠа§ҫг®ӯгӣғбҠ¬дҮҷг»®аҘӢе¬ӯа°©г—Ёг©…в•ҠФ®вӢҺе©өг«ҙеҘ•вЎӯб•әгҷӢб§ӯг”•г—Ҙгў¬з•‘гә¬вҰөвҝҠж–ІвҸҸе–ҷгҜүзҘҚг”җвҶівіҠаөҫгҡҲгҶғг—Қж„Ұв»Қв…“в’Қж§©еәүгӨ·дһҚдҘҪгҫҢб—Үд ¬в—•гӮҺд¶…гҪҢг»җв«Һбҙөе”Һб§Ӣв’Ӣа·ӣКүеөігһҲг¶Ӣг’Қз•ҹг¬Ҹг–Ұв¶Ёз¶үв‘Ңбө–д•җд—©вҖҝбөјг–“бЎҸв·•г¶ҪеёӢеЁҠгҲҺзҙёз«ӢвӨЎгјҺвҗүгҳ№з·…д ҢжҸ—гҙ©в·°жқӯХҖж·“НӨзүҠвҸЈв”ёбёҳжҠ–ж—Өз¶јз¶јзҢүз·ңвҰүж•„жҺ»бҗҳзҪӯа®ңжҙҲдӯҗзјҝЧңж¶»д¬ўзөҺг¶һгҘјвҸҠзә№з–Ҳжү„бҸ¶в•әдҸЎв№ҚзҳҒаҝҲвҸҙв»ӯбҢӘзіҪб»ҙзҫ¬дҚ–з№ёгҸҗжӢҫЩ¶жЈ©г®Ҡж»ҝж¬ҫзёәжҜ¶з©Қз¬¬жҚёе®®жҲҪеҘҒзқ»дҙҰж–әбҜәж“јг–ҒзҢҢв¶ҹв©ӣеҸҶжҪәе—…д·ҚгҚ©жҹҪд ӢгҹҢеҚҫз§№дҹ№ж№қбҳ©жҘҺЯүв«қа§ҷжғҝжһ©з»ҳгҳ…в·»аө•з ҸОӮзҫҫбқҜвөңЭ’зЈәбһӯз ҝжҜ…дһҪаҫҘзӢҷвқҷж·‘б»Қж»һз°“зҸңвҝізӢәЮӢжҮҳвҝөжң®еӘұзҝҷж¬іж®ҪбқҳгӨқдҜ©жҺңе«ҡвҖ®е¬…з©ӣжҝ—зЈ–еӘәзҡҹгһӣв”»ајҸжҸәгҪ№жҝңв—Ҝз¶ӣдғҷгҝҖбЎҪР“б ұзғ®бҗғгәҜвәқжёҘгі„дәҳеҫҫбҘҖзҪұжјӘзҚЎвӮӢзә»вІўд»№зұӣд„ҘвҙІСӣ/аӯ°з ңдҡҶв…·жҷқжҜӨдҠЈаІҰж®ӘЮ ж·•вқҶаІ®жІҖжҮҳб’ўгҪ дҺ¶еҠҰЮЈзҘіФЁаҪ“з•ҒеӮҶбҮҮжҗЈдғҪжҒүе©§жҒ°б©Җд¬Ҝзҙ№а¶һе—®з„ҹж·”зқјвҺ„вҲҳвҺ ж«ібӮЁдЈҶаЈ–е”ёбҶҡбҮӮЩҶПЎе®ӨзҒҘжҰёеӣІв¶ӣа№Ғж”әв„¶жүҢб§өжҸҹеү№бҒҘеӯ«гһӯжӨ•аҘҒа Һдә–б°Ід©ӢзҗӨвҹӨвҒҜз °г§§зў–Фҗ$гҚё+вӢұдјЎДүб—җжңҪбҚҰа Ҡдҷҡв–ёРҰж”ҹ@а ўдӨ°Ь гё©вұјгүҮдҹһд“ңгЎҘЙӯдҢІв ©дЁҢЪӯгҘ“жҖЁбұғеүәжғ„жө¬аҙҖд…©гҢҘ^Ф е•әгүҢгҷҮеў•СЁвЈ§дЈҝЕ©зјўдҘ…бҠҳгё·бҢҖбҝЈИЎв—ҢвЈ жі•В гҢўдҘ°ајҒж°ёбҶІвҜӨвҠ‘д•ёжҢ©ВҹЭ№в ҰеўҫаҜ‘ж°ҪбҺўЯЎжҖјМ„ж»Ўз Ўдӯёг ӯДҘбҢ“ж°«жҶ–ВЈзұҲжҠёНҜеІ°дёҒд”ҙж§¶бҢҗз‘•ЛјгҮҰв№’б”җеҷҸУҗа·ҫдұёбҳІНқгҒҡзұұгҲҶж№ЎбһҖе…Ңдӯ д°Һзү»д—Өе°ңгЈҒжҺ№вӯҰеҰҚб—»г№Ӣгқўвё‘г®Ҡв”¬еҪўжіҸжӢүгһҙжҰҹб–—бһӨзӢ©в»Ғвә…жҶӯб“Әа©ӨВһдҹўдәҗвҚ¬з©ЁбӮ–Е©е¶«дЁҒaжё еҺ–бҳ¶гүёж‘ҙзҫўдҖЁКҘбөҙгҶҢб¬ҢгөҰв¬Ӯгү»еҶқе•°еҳ°еЈҳаЈ…зңұбҒңе«ңбӢҷжЁөеҒ·вҘұЫӘеҳіа¬ҹвҙӯдғөжј”еҲ»Uаӯ§б¶ўЕЎК¬бӘ ж“ўдёЁгө№гҳғаІӢжёёеҲЁбҠ„Й–е— г®Ўв“үдҜ•г№Ҫа¶«бӢҠеқһвҠңбғ·еҠ—вҹЁж№¬б“®дҰҡгө¶дӨ°ВҠвӣҖдҒІвӮ ЕҘгҗҰдӢӘж…©дҖЁа ©дӘЈбҶҚбҪ’ж®Һбө„еүӘвҹңеӣүв“¶дЈ–вӘҝгӨғеЎҡеҮҳгҜ¶дҹЈеЎ”ж ”ж—Ңж”ҖвәҪв¶©зӨ«еӣҗз«—гҜҖбҚҠаө№дҒўеҰӨжјҳжІҷд®·д·¶дӣҗжҹҠе‘–вҳ·еұҡгҹ¶дӣ«вҙ…вҺ аҰӨгҰЎа Ҡг“ӯж®Өг‘үдғәд•ӨеҖ•жәҙдҙёдӮЈг Ҙбҗӣд•ҹж…ңбҚөеҳәеҳңзӣҘжұҝЗҳв ҘДғб¬әжҪұв©Ҙв…»жёӘвңӨа®ҘМҗдҚҪеІ¶гҖӨаҝ“г«—еҜІвЁўз®Һеҡ¬бҗҰР«жЈЈдҹІгҮӯб©ҷз•ҲбҲұгҳҜб•№г–¬е—Қг””дөҳжӣёаЎ гқӣХҢжҮІвёЈЙӣдҒ„е«ҢзўҺж®Ҙб…‘МІбўЈдҮңв«—вҮөбҳ°вҲ»в’ҠгәҝвёһбҹӨз—»е‘ңдұӮбӯёгӢ•жҙҸз®©в¶№б§Һд“ӘДөз•ӘеғҚбҘөж®јжҸ®дӣҶвӘҡжҚҸбҮҺз“ӘжЎҷдёўгӘӘбҲіб”¬жӢ¬жҢғжҡ…вҺјбғ«б«ҘдіӮвҺ©г„’еҡ“б–ӨжЎҙг…ёгҹҚвҷІб•Ңа№“зқ°вЁ®гЁўдҡқбҡҹдҢ—гіёв¶’д‘Ҫж° еЁҪвғ”бҸҮајҶб–ҳбһ–а©ҢзҙҳвҪ¶дҳҲв—Үб®Ӣж»‘жҜүгҙ¶гҰғбңҗжҜҺвғјвјҢг№»дӣ„е·«бҚ»бҜҶбҲ б¬Ўз«ӘзӣҺв–ҰжҒ•зғҠг—ҷвөҒгӮӘа¬§г‘·вҖӯг„ўа¶Ҹб©јгҖҳвӯҝб—ҷеЈ»жҺӯгҜ‘г”–з¶‘еҹ®жЎӯгҳ«жҪ…е»©з·јеҪЈзҝ‘д°һаЈ–г–ҷгһЎз“ҺгҝҖв¶ӯдҜўжҮҚеӘ§еҮҳзӯёгҝ—ЦҠе«җд¬Ҝж»®жёҷжҒҠПЎгӮһгӮ®з®ҮгҡҜбәҚвһ‘зһҺгҚ№бёҷж·ӨеҺЁеёЁдҠҡдһ–г‘ҮеҪҶдјҰз‘ҖеЁҡбҝјгӯһб–ҫб¬Үжғңаў°зҷӘд”‘дҫҒзўӮз§°дәҳа©ӣжҰ»еЈ»зһ¶бқӮзӘ–аҙқеҷҘзәҪв—ўг“°еҷ№а¶§еҝіеҮ д„…ДҒв Ө а№ЁдҖ°бә аЎҷвӮ ТЈдӮ–Х—Ф гқҢдҢ вңһВ°НЎг ҫИҗвҘӮ  \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3015,"_status":"completed","_startTimestamp":1775055116571725,"_endTimestamp":1775055116577192},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"54","comment":"","_id":169,"_uid":"4a5ddb62-b3d4-40d6-86cb-5a3a9a0f164e","_cid":54,"_ctime":1775055043431,"_sid":24,"_stime":1775055115795,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39938,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:51:55.428Z","time":297,"request":{"method":"GET","url":"h