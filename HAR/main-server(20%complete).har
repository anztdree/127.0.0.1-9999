mpleted","_startTimestamp":1775055339039652,"_endTimestamp":1775055339044356},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"66","comment":"","_id":346,"_uid":"663d43a7-b0bb-41d5-ba63-9eead5965e5f","_cid":66,"_ctime":1775055331875,"_sid":3,"_stime":1775055338758,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39906,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:55:38.239Z","time":811,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9Ylhs&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Ylhs"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055338239916,"_endTimestamp":1775055338245537},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:55:39 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"1264"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1511,"mimeType":"text/plain","text":"579:4378[{\"ret\":0,\"compress\":true,\"serverTime\":1775055339942,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвһ еқ‘ж ЈбҶ б®¬ВҢЛүвӣӨв”Јбі°аҘҖКҒвҖҪдҖ¬жҫ бҰ а¶ аЈ бҺ О бҡӘвҒғВҺбҠ бҷұе•әд¬„жҢҒд©°а«Ј@Жҙж©¶е’ўд°ҷбұ°гҲЁеҹӘгғҺгқҲдҠ вҷ…аіҗе©»вӘҠгҺ°б ЁУ„жҷ’е°Ҙбһ¶ејҜж«Үб•ҙз…’еҮҳв”„д‘ө=бӢідұ Ч‘дҺҗб…өбҡ¶б° гәӯа°·аі РіЖўеҖұвғ•вүҗа°©вӢһаЁӨв°№О•ШҖг—ғеүӘаҘўа©ўвғҹдө“з ўзІ‘жҘғгҮӘе¶”зҡһЮҖвіҗд§ЁдҪ®жһ’вҘ•д ҝеҸ”г‘®б°‘жі®в¬қбӣӢб°©в·¶зёўв”—еәҙеЈҺвҙ·жҫҗвғ”гҫўа ©ж…¬бӮҳжӘҖдүҶв®ҙд¬«д°ұвЎЁаұҒвҗҖж„әб–җвЈ‘ХҺбҺЈдЈ‘гӨұбҲўе“‘в«ҷб«ҖжіҡеӮңаӯ©еҠҺд¶Јб«„гіҶжҹӮб»”зө№зҮҠд°”зҢ–з‘ҫд•ҜКҘдЎөж«ҒдҢҷд«ңб…Һзүүж’ҢеЈӘд ұеҢЁеҰ©вӯҙбұўеүҸжҸ•дүҫе•үбҸ•гҠ‘еҺҘгі‘еҹҷбҠ¶еӯҙТ”еғҶаҘҙв®ҝдӢҜеҲҫаәҚвҜ“д°¶аӨІжј–е¶ҷдҪўа „аӘқвәҡб ҶЙөбӨҚеҚҚа ҖгҪңеӨҫа«Ҫж•Іг ғвЁөгҙӨдҙәж«“еөәгҘҢеЁӯвіұеүјв¬ңеҚ¶гәҠеҹұзі¶бҫ»вҗ’аӨ°г…ғеҢҺзҮҮг№Ҝгһ»жҫҸеЈҲв¶»аЈ°зЈҪдҡіаҘҳеғәеұ„д”—гӮ§дјӣдҙӮзҗ‘жһҮаҝҒгӣҳдҰ«зҮјз№№жҪӢз·§жӯ№зҖӢбҸЁЧҶаІіж°ҷб—Ӯзҹһа ғеөұвіҝгӘјвҜҘг—әбӮҸвҝөеІҸб¬үбЈӢбҡ гЈ…б•Һе”„гӮҰз—ҚвҸҠзЎӣгҺҖдҗЎбҒ…д’ҮвҳҖе·һвӘүгө·гҹЎеөҸгңҚзӨ—б’Үдҗ©гҘҶг·һШҢвҸ¶вҖҪз§үЧҒв”ҝбӯҖзҳҲзӯ…в”§б”ұв‘Јб¬Җб’үв”ҚжӢ°дңҪб“үбҳұжҸЈг—ҶбөӨејҪзЁғгҙІд·ҚаўҫдөҚаё°ж—“в·Җвүҙе„ёеҸҺвҲҚбҺҜвўҫвүҙж”өеҠ»а«Ӯжҙ•б®ҒжҙёдҫҢжҚ—а Ҝжө¬з¬јгӢҳзҹ еӨӣб’°ж—ҮбҫҒдүңдҠәвҙҢзҠіжҙҗдң»е¶»вҡ·зү„аәұзҢ”зҶ°гҠӣбҶ·зҸҸвЁјНҸРҠдҠҢе„…вӨЎг°Ҡб әбҚ ЖҘжЎ—М еј Ю•жҖ б«ҰПҗеҝҜеҖ¬жҖ»бӣҙвҢөЛҖвҲҙдҖ зҢәжҖҡШҰеіўб ¶аө¶еҘҹжқҙвҘ—д•©еёӨвқғдҚҖжҒүвіӘдҜёб”ҙдұӮвёҰеЈЈеӮҶУўг«ҡеғ·гў’е‘ЈбўҶа§–гЁҰеҖўбІЁбӯ¶вҒҡжғ»вӘ®е—«вЎјгЁ ВҘв ұдқӢЮ—вўӢз ІЧЎжө¬РҒв‘Ҳд“ еқ·вҙ е”§еңғжҚўеӢұбҺӣбҠөб¶өбһәе—‘ж–ҳжҝҚжҝӣзҗі[д§җаәҒв¶ҷв  бҠҲбҙ§бҗ ХҪЙ”бҡӯеӮ”ж»Һе„ғеҲҝаёізҠЎзңҖжІҝОһвӘһе“ҢвҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1264,"_status":"completed","_startTimestamp":1775055339046192,"_endTimestamp":1775055339050701},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"56","comment":"","_id":343,"_uid":"79638caf-64d5-4bd7-8443-cb5564fcebe7","_cid":56,"_ctime":1775055045046,"_sid":89,"_stime":1775055338239,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.