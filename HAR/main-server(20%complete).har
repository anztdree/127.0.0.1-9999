:"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9arpm"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055888588731,"_endTimestamp":1775055888595404},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:04:49 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"5640"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":7070,"mimeType":"text/plain","text":"1340:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘ұе№ңд“‘а§»гЈҒж’¶зЎӘзҜҘд•‘зЎ—Х©Йӣеӯ„бҝҫвҳһдұңв”Ўг…•д–Ўж§»бҰ‘е…ҮдӣЎг№ҳЫүвөўжҲҺеҝ зӨүзҚӮв‘Ғвӯҡд“Ғбӯ“вҳҠзӯ‘з©ҷгө’вҡЎж·јУ№бЈ®ж’ҒжҪүв ‘д©җжһЎдҺ»д‘ҷзғ’ж ҷаҜҘШјеӯӢв–ҷдҷҗЭ‘жқ‘бқҒжқҘб’ҷзҜ¬жҹҘзө…жҹ‘зҒҒгҸұд•“бқүЕҹЦҠЦөбҡҷаҪӘеһҒУҗвҷҫЫҶз©өСҳеҳҷзӣ…Ъ•жөұеҳөгЈҡе‘ҘгҸ®еӣҷжқ°гқҡЛҺеЈ•аӯ„е”…в§–жғӯбі»еңҒе»ӣбҹ•зӢҲг—®а·Ңдңҷж·’г–өж»°г—ӯз»Ўг•ҷб•ҷгҹ‘жі°гңҘг“ҷе”•гҮҚе’Ҫж§¬зң–е…Ҡз”ҪбҜҹеқӯбқ«з’ҘжҒӢгҳқзҹ“зқҳдЎ”жҡӯеӣүг”ҚаўқгқЈгғ•з—ЈбҸҖгҳЈж«ўзққд·…а¶№еӢқа№ЈдІҳгһүж’–аё•зӮһз’ғдӮӢаІЈб’ңд·‘аҝ’дёівўҳаұ‘дҸӢб–ЈЪҲжҗівҜ¶бҡід—һдё№вҡ–жӮ©еҡҲе—іжҸӢдј«бҚҢвіЈЖ’вҙ«бәҶб•ғаіҢдұӢГӣд°Јдҹүеҡұвұһвә“д§Ҫа·ҳжҠқбҹ“б«’бқ©в¶Ҹгҳ“е–ҹв»өвҰҲжҙӯбӘҚдёӢжҜһж№Ӣв®ҡбЈ»гҺңгҗ№а¶’дј»в«»ж»ӣеҝқжІӢе·ҳжҪӣзҶҚв°»зҫ‘жҫӢбҮҹд·ӣа®ҚвңҚг‘–вөҮе„…бҝөб»®в”Ӣбһ—в’“г„ҚвҷідІҳбё·зҺӮг‘ӣВҡеЎҮбҠ–жҪҮв¬җжі·б’ӨжәҘЬӢбө—гӨ…е№§зҢҮж”·жҙҲвҡқж«Ҫбөқе¶ӮејӣеӢҚбј“б–Үж·қгҷқаҪ¶жҜҜеәЈжҢҮбөҸж®–гІ§ИӢеІ·дҳӮЫӯбҳӮв»§е”ҳгұЎвӨҺв№—гҫ”з№“е§№жӨҝбӨҚг№¶жқҘд¶ҜМҹе№·ж°—гғҹд„Ғз·»дҲҺз”Ҹеӣўе®ҘзӘҮај’зҪҒзҠ¬б ҠбјҷжҙҪзҝ·гөҹа§ұд°ҫг©ҮЮ—ДңгҷЎв»…еёіжҪқд·№Н—дҚҷеӮҮзҘҜбҲ©е№ҖгҺһг өг№„бҳҷзЎ”КЁгҠҡжәӯЦӣгҳЁзјҰаҫҰбЁјзҷҹвәЈгқ®зөҒд”§жҡ«ж©ҹ(з„’аҝ®вёјвҶ¬б’Јбғ®еөӯе®ҳв’ңбҘ ж…“зҪҠаІұбЁібҮёжққвЈЎг¶°г ӣг»Җдҹ дҗ¬ВҪаҙұХҸе…ҠбғӮзҹёж·ҙгҡ№СўХӯбҰҰб¬ёаө‘бІӢгҶҰбӣӮгҸөд·Өв¶Өв§…д’«ЗідӨҸа»ҺЬҝг„һбҺўе©Ҡб’°в§ӨС«дҗёдҳӯУ¶а·ЎжҘҖвӮ®ИҒж°ўжҖ аЈ°зҖ бҡЎжүҢИЎгү§дҸңЦўж’Ҙд’ҰЦҘд§–Д зҘғжҖЁИЈеүӨЗ г–ҰвӯҜаӯ‘дјҶзҮҝЬҖгӮіжҒҘдЁ зҠӣЛҚЕЁе ўОҗвІёгӨүбЈівҚҒжҮІгӣЎвҒ•д… Н·дҙӢаҝІеҳҢбҮҝГҗжҳ№жӮҢбө„гұҡв‘ҙе„°б“ҳДҗЬўвҰ§Г‘гӯҚвҒҖбӣЈеүҙЖёг¬ гЎ”дҙ¶г …зҶ©бҹңбё§гӢҖб„ҖеұӣЖ„дҺҰеЎҳО Кјз„Ҹа©’зҖёЙӘгёҮеЎ…дҚҳД з Ҙд•җбҡіаЁҶбҡӯзұ–вӢўгҒ№жҺҪЪҲз©ӢжҪ…діҒгҡІв„ІФівЈҒбҸўв№ӣаЈҒЦӮз«“жҪ§д¶Ўд°Ҹд–Іб…ҖгӢўдҢүг®ӨвІ’ЭҲзөӢгӢјвҰ…зӨізҮ‘З«віҸдҜ©гҰөдӮҸбқ·аөҚвғӘвҘһеі„ж—”е©ӢЕӮбҠҮбҺҰеӘҖе‘Ҹв‘–еЎ«дўҗзҰөдӨӨа»ЎжҘҷжҖӘв· а №дӮҙзҺЈдҠјдӘ№бӘұзҒ°ДЎеғҸв°Ӯв–…жұ®зҖӘеЈҢвӯ¬в ©бһјдӢјеҪӢб»•ж’©г·ҷв•ізЁ зғӢд¬ҡаё•дҖұбҳ•ж »вӯ‘д©Ҫв…·дҸ—жҸҗгҜ бҖҘдҚ°жІәвӨ®ВӢеӣүг…ӯвіЈд©ЎЛ¬жұҘж«ҳНҗз’·бӨ®еІңдҮүв¬ҺвҺҮвұ‘е–„зҪЁжІўдөүеә°ж«ҺЦібҘӮВӯвіҙаЎҡвҗ°бҒҲеӣ·аЎ…бҖўеЈ‘Д вҘҙгҺӯе°Үвө«жӮ–з©©г ҪвҪ©дәјгҡ•б”ҒжҸҗг®ӮвҶҙдҒ•дҸҗгі®аҙӢв§©дҺ§ГіеЎіеҪһг¬®Гҙзһ”Г…гҮҚеЎЁв·җа·ҙд—өжӨ«жӯ–ж„®аҙ”б«ҺжӣўеҰ§вӣҡж·№ж¶Ҫе’җаіҗжқҺбҲқвӣҰгһӣЮңб ҫвіӘж Ўж··е”«ЬұдјӨеҠҹгі…гұ–еҳјЫҲЛід“№д–Ҙе•°аө“гӢҷжҸғв§ҙжңідҸ„дҺ§Сҗв®җе—°в§–aдқҹв®ӣвӯ…вҒҸг ҠдӢўдҖ§Гқа¬ҘВҜе§«жғҰгҰәвЁ„е–Ӣеқ©бҰҠдІ»вҙүвІҫзҒӯең°дӮғеӯӘгӣЎгүјXбҰҰв’ӯвЈҗж»ҝЧўгў«зІӢд¶ҸеӨӨдҺ„е’ҡжҘҠв•Јб®ҺзҲӮв—ёе®өз„ӨжӢғв“Ҝвҙ„Чҝв’ҺбӢ§вұ‘жқ‘гҗҸжңҮзЈҘб‘ұвҒ”біөбқҒг№ідңҗж°іе Ҡаө„г»ІбҲҘб—Җжј¶е–ӮеЈ…бҶҝе§”в°«еқӮд©ҺдҖҶвҰҡв«Іж‘„еў—д¶Һд©ІаҰЁе «жіҳЕүв…ҙзҰ–ЭЁзҚәбҲҪд»ҷе•ҝгҰ«ж°“дӯҹд¬¶бҶӣж»ӢбӣӢг°Җвҫ—е–ҰжҰәШҮЦ«б№ҝа¶ӣжҶҡдҰһеҡ§вғҸб°Ұві•дҚҫајҺбӨ«з»–дҜ®С·дҡ“еҡғвҗ вҪҘвұІдҘәзҳҲе№–д—ҳзҺ…гңҒд¶ӢжңҶз•ҘбӮ’вҢ•ж‘№з§ҳд‘ӣе“–в¬ҫЗ¶еҡҒзңӨжңғжјүв·қеғ№з«…еІӣзҮҷдӯҸгЁ—е¶ҲзүһжҫҺгӣ·дҠЈдӣјб°ҜХ»ж“ҳЮҖзҙҜе®„в¬ҡжӨҺУҪдүЈз•ҫд–Өдғ§вЈҷеҜ¶аҙ—в¶ҮжҚҗз¬ҺзңҠж“°зүҰз¶ҙгўӣд·ҡеҚҳзҪ—б§ҺдёӘжҳӮб§»вұҳв•ҷе·ҶдҖӣе§ҷбҜҢзҚ–жһҮдә©ж§ еЁҖе»Јд“ёдҮЎг©§жӢһе®ёз§–гҷёвёҪеҗҶд»јвә©жЈ№гўҷгЎ«дөһеһ‘жЁ“жҙ”дҝҠжғ®в°¶еіҝТ вӮҶдҳЁеҗў Э„вҖЁаҪ Р№еҒ бӨіеЎҚеұҲЧҷзҲёЗ—з ӨдҖәЧ з ҜдҶүа   \"},null]1235:43224[{\"ret\":0,\"compress\":true,\"serverTime\":1775055888640,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘДҢа№ҲЖёГёВ¬ЕҳXЖүгҲўбЎҘбӢҲЖҖзғ»е«‘вҳІгіөГҢбЎӮ8бһҶзӣӯвҮ’д·ібҒҝаҰ’дҗәДҲгҹҳДҡе‘җбјўбҗ У§гҶЎе«Ёд”өв©ІзӨЁе»”дғёж„Іг•°жЎӢз–”вүҗаЈ„зЎЁбҙ¬вўҘа«•дҹҰбүұд§үз“Ҙвҷ¬бӯ—бҮҜдұҺбҗұдӮҖГ–в  а¶ІЯҖЭ„дҳӢдүӮAзҫ ЫівҖӨд§°/еҗҘдҺәЕҒзҫ зЁӢвҒүз“°аҪ«зҗҘа©ӢгҘ©жҺібҖ аўІбҙ г„ EвғҖзҰҡгұЈбәұв—ёбўӘа«ғжҠҰзҸҖеғЁбҗ зЁ°д¬ЈдҒЎзј№дҰҲО’жҙ а«…гҝ Г‘зҶЁб„№аҘҘбӮҖ[е©ЎгҢҳеҒІбҠ РҗеЈ„аў ШҖгўәжӨҰдҶ„вўҢдҢӯдҜ…жЎӮжёЁдәЈз„ҰвҗӨСӮбҠҖ'д„«бҖ°зұёгўҰдҗ д«¶И¬ЖҖзЎҗДӨбҖЈСҖбҗ жҘҗд–…гҗ ЛҚГҠгҳ»бұ Мҳа јгўЎж…Јд”’бӘЈвҡід‘ҚвәўжӢ”гү–ЙҰжҶЈвёҡа°ҫв•җвіӘаҘ¬еғҒаөҶе§Ӯж«”ж¶–зўЎжӘ”еөҗбҜғж©Ўг·јаҪҝе’ҳжӮғУўдҖ вЁҶж– аҘЁКүвҙ гҖҪвҖ¬гҡёНҚзҙ з …г»°зғҖД’бҳІа®©д…Һ$еҒ¬вүҪг‘һkжҜЁбһҸе ҚзӮЎВҰР¶Щўг„ҳг„јдӣӮжЈҪЫӯдңӮУӮгўұеҺ©Щӯбҷ§вҷҳгҘҪвҰІж—’біҺгһҝЙҲЛҒг‘ҫбҹЎбҢүвө¶Jд«©дҚҘгәӢгҖӨа©ғгҒӨЪ°Ф§г’‘аЁҙаӨҰе…•гҲӘвҹ©аЁёгҠҲбЁўв„ҖвҲҘд‘җеҲІГұзҲҘдқүвҒҸе‘ЎбҫәвҲңзҫҰвҗўз©ңв”ўб…ҳаұЁеҒ¬аёқзӮӮаҫ¬зҙ»б”ёб—”ж“ӯвӯҖШҠбЁ дҺ…вҖЁlvбЈ П©зқҚв§Ӯ!дӘ—бҹғбҖ ГҢвҰ бё°д ©б»ҜзүҖЗЈЙҗеҒ°О‘ж” ЩҰвҶ®дҠҗд„ІвӢҳеҠҗд“ІбқҘдјҳеӮұбӢ’бҘҘжӘәаӘІв№–б©Өв әНҰж»ҢдўғжёҘДҗжЎ–бӨ–аӘӮеіҖе№’еӮҰеәӘеҘ¶гёҜдӯ°вҖ¶Э°еӨҸе©ўвҒӮбӯ®е“№ФӨгӘҡбүҰдЈҠбҘ§дЈ‘е…ҲвЎ–аЁҜд”үг…ҰдЎһеіҒВҒвүҺдә‘б©Қд—ҡб№Ңв—©вӢҘвҳ’бөҢвҮҙе№Ғж—ҪКӘвҷүдӨӮді«ЦҮа »бҖҰз·ӘВҳвҶҫжҒҖЬ·аӨ жҮүжӢҷжӘ»ж„ҳеҒӢгҢЎбң Э·б°ЈЙ«зӣІг ҙдӮҖеҖ еӢҡВ–бҶӘд¬Ҫж©ӘбқӨеҡӨв—ізҺ©бғҗеәҘд—ұб“‘еқ’бЁӨв–ұаЁӯд·ҪбІЈдЎЎдЁҘдҶ“вҹӣдӘөбәңеҲ’зҹҹдӘқзҖідҪ“жҝ…дў©жҲҘдһұг©ҷдҸҗзҳҫдүЎа№‘дҷұа©ҷдҳңг…ңд„°бЁӘЦұвӣҢд—Әб‘ҳбІ§е„ҢбЁӘе–Һд‘§гү’бө§в©ҡб§‘бӨ–б·§дӣҷаұӯдҚ’гӣӮвҒҢж‘№вӯҖТҡШ бҮ”жҖ®в“ҙKзЈ аҘӨе”ӮдңігҶҖв¶ ЬұеҷӨеҢҖГІбҫ Н»бҠҙаіҸбҡ вҗӘж”ҒжҜ•е’©жў–б‘Ҫб”•жІ·еҸ©е»Ҝең„в”ҝе–ҳжҪҝб°®ИҚвҚ«еј«ЭІб‘ӢеЈҒв§«бҠӯжҠәдј–дұ«ЖҖвҮҠвң°дҗәе№Җа§Өа¬ҚбҗҜгҳҢгҗҝгҷөз·ӢПғдјҖзЁҢд‘җз—ҷб«¶г•§ЫҺгҮ¶1вІҖГ…дҳ дЈҷвҖЎб‘·а¬ҙ$вӨҗвҗ гӮўд®Ёвҗ”вҰқжҠӢвҘӣвҙ®дҖЁе’Ҳ-дӘ…зҖўзҺәе”‘жҮҮеҶӣеҚҳз…ӘКҸеҘ“гӮӣб‘«гҡҳгі»дҖ”бҒҪаӨҸбһҪвіғејӨбғҖа©җе«Ғг“ӣеҹҖг‘„Ш№б‘Ҳд«ҒбҒӯТүвІ‘Ъ°вү©дІҘзӢҚзҰ¬жҒҪзҝқГғзҠқбЁ»аәһвҝЁгҢҠжҝҳЫ®д©ҺжӣЈві‘8ЭҒеў аёҶзҗ г…”жҖӨдҺёгЈҖжў“%аҜҳвӨҘд¶Һбқ б‘Әе„Ҳа№ Р§з…„еҝҗгҜҡжЈ¬гӣіжӯҒзҒҡв§ӯбҒҮвҝ…д’©еҮӨбӢӘжҗЈж®үгҢҒеү©зҹ’зҺҲгІӘЧўзҸјеҒҳа»ҳСӮз«ҫЧ’зҘ§жҸңбөҜгұҖа¬Ёд ҪжӮ°г®ұд”әб…Җа¬Ҙз„һаҰ зҹЎаЎҳжһ”бҳҪбӮӮд„ҡзҗівӮЁгҶҘгёҙдқ”б ҒжӮ№ЗЎзҲ¬жүҢбүҳдҒҡдҡҲСўжўӯЧҶб©ӨМҡбўӮб„ёжҺҙб“§дІ…д‘ҳдӯ–Г¶еғҖзӣҠеў Х—бғёдҖ©зҠ”В—еіҢжғҢв–”вӮғдҶ„еҫЈжӮҲбҰҗбҚ»вҒҖа·ҡаўҖзҸҚвҖўзҗҠHPЗ„зҠ аҫӣа°ҫз·үеҠ–аөўа®ўжҮӨбӘ“вғ•в“ғгҠҰдў…ЗһгҳҪбёЁаөҖгұҡжөҸаҜ©ж¶ӘеӢҸг°ўХ°гҒҖз©©дӣӯб»ғжЁўжӮ°Э бӨҪеү…бҲЎжӘғЖҰб„ўдҒ«д‘°з©һзөӘаҪҲдҷЁдҶ¬дЁ діүдҜ°Ь°д«ӘаҪ“еҝҪжө‘д–Үдҗәж’ёгҫ©г”®гҳ©б–Ё(вҚ а •вһ•вҖӨб•үжүЁЛ«гғғxв“ҳб¬ғВңШЎбҘ•г’•д’ӨзӣҲзҗӢг„’дә‘Щ–И¬ж“–в•қз®ЎЗӨбҸҮдјӯеӨ”еҢҗг¬ұа ӘжӮғе’ҸдҒ вҒӘж–”ШЎаіӮвӯЁа®Ўж…№jзӨҜбҒ·бўұзҲ¬б‘үг·Іж‘•еҺҡг° гҪўгҷјдҢӘв—ҝжЈіб“ҹбҮүг•ўжҰқб‘ёеҚҺгӘҷЦ…еү»гҰҢж іеҢЈе—ЎбұҶ!жғ°ЕЎд©‘бЁ’вҢҪаҘҺб®ӘСӣдғҗв— в“һЙ©б’°*еҗЎеҡҳбҜёе«»бҚЎб°ұдЎ№вҹӮНғдҠ°eжҹҢдҳҗа«ҲвҖ°вҘјеәҳг…ҝжӨЁдҹҸз’·жҡ°зҹӘж–ІеҢ г„»з·„ЦөзҗӯдӮҗб•–вҗ«аө°б„ЎгҮ©аЈҖвҲ°ж‘ҒдӨӘгҷҘЖҰжІ дҡҘдәӯдҘ»аё‘еұҠд”јжҒігҡ¶гҲҰгқҲбҡүд«јзҺҠе©Ӯеў Яүзҗ зјӢгҰ”зҙ•вҡҠз«§б’„П°дғ„аӘЁгҗ°зҜҹгӘҙдҮ“вүЈЩҡзҲҠг«ӨдҫҒб’№вҮҺд§ҖбҘ–д©’гұүж№ігһ•вҸҘз•Үд–ҚжЈӣеҗқг»ёеһ®б”Јг”ӮаІ°Ц–зўЎжғәвӮғзҮөД”бӣұзҷҪбӣ¶ж–ЎвӮӢЙ’МўзҒ®вҺӮбҹ‘вғҸгҪғгҲ©жҳҢзө…г®Ғвј°жҹәзҡҸеңәд№ҘгҲўа Ҙж№ҫгў•в»§гҶ•вұЎжҮҮб’—Д‘дҢ«ИӢКӢе№Үжүјг“—вҖ®ШҘдӯ°вҮҖе‘ҷзҘҳеӢ§гЁөбіҢбһҜвӯҜг«ғжј•вҝ…ж§ҹвҡЎгөҸж–Ҝв§әз‘ӣзҺғг ІгҰ…Тқж©®гӮҡбјҪдҳ«вҸ¬бЁёжҘ‘зҰҗз‘”б »а°ғдӯғгӮўгұӢдҠҸвҮқеұӯбҚҙдІҹвІәеөҪЯҚбҖҙгўӘе“Ӣ2ЭҲВ°У #д§‘а«Ңзі©гҶҢ&еҸҺжҘ©гўҶе»ҚПҶж®•дҳігӨ®Тҗај дҖјаіҖжҪңд‘қај©ж °бғ…бҘ»а ҜЙҙдҘҮгҙјдӢҡеҷҝдүҷЖ…еҷӯг¬ұг¶ӨаҪ“д®ҺдҝҺз¶қжҫғвұ№з•Ға©ғЕјжҳ•аҪұз”°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":5640,"_status":"completed","_startTimestamp":1775055888874020,"_endTimestamp":1775055888880697},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":927,"_uid":"3bc93f70-1c64-4ef4-98f1-39a7fe144f44","_cid":92,"_ctime":1775055887626,"_sid":1,"_stime":1775055888588,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:04:47.455Z","time":294,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9arnE&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"140"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9arnE"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"136:42224[\"handler.process\",{\"type\":\"activity\",\"action\":\"getActivityBrief\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"version\":\"1.0\"}]"},"headersSize":308,"bodySize":140,"_status":"completed","_startTimestamp":1775055887455214,"_endTimestamp":1775055887471834},"response":{"status":200,"statusText":"OK",