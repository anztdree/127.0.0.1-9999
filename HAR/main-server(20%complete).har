"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aJRd"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055746804643,"_endTimestamp":1775055746810353},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:49 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"15874"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":20330,"mimeType":"text/plain","text":"7042:43190[{\"ret\":0,\"compress\":true,\"serverTime\":1775055769864,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨvжҢ«б® еңЎд№җеҖІвҖ©еІЎж°Ўдҙҗаі Ы ТҖа§ З аӯ бҖұдӣ©Й аӯ—г’ҘаҘӮгӮұСЁЦҒдҺҖГӯеҒҒвҒІбәқгұҳвҖЎе¶ёбўіб‘ӯбҖ®дҝҠжҒһе”Ұбҡҳе„ҸСҷаЎңзәҒгўҙеҷҫв“ӮеҚ°жҰҠзҗ¬дҷҶгҢ«Я„бҳЎаөӢдһ‘вҢұЦЁж„ҢТқбҷ°дӨҫжҰӢз„§гҜӮаӨҗГ¶YбҲ бӣ®аў жҰ Пҳ(ГҠвҳҙгҒҝП ЖҒеҺҒгҚ•бҖЎжҡҚбҒ‘дәҹдјҙдјҚбҖўгҲәдҹҰГӮжәҺа°ЎаЈӢбҷ”дҺҖД«а  б№§вӘ а¶¬бӣ¶зҶ¶бӢ®еЁұвӮҸж»іг©ўв·»а§•еқҖгіӨаЁ°дҖЈб–ёеӯӢа ізҮӨOдӯӮд…ҒжЎҡдҚҚеӮЁЙҢд°¬в… Eгү•аҫЈв”ҲжҷҠе„№бғ–<вҫ°tгЈјвҜҠдҲҘдҖӨвјҶвҰ 1ШҝгқЎзҒҗаөғвҡҲбғҖб®Іе ’ЙҖвңәвҶ жӮӢб¬§дҚұд’ҢгҡұвҲұд”’бўӯг Җв“ңКәвҲҒбҒЁбјідҷ•гҷҷЭҗдӮҒвғ—бҲўСүаҰңгәӨвҷӣбЈӨбЎҢХўгё«г„ Ж°гІҖвҹңЗ’жҗҫжүҚж®ғз¬ҫдҫЈЭҘдҒ°гҒҪв°•еөғДҮж”§ж‘җвҲІаІҝз¬Јбҷ¶в·Өб…Һ\\\"діҸгҒ§гҰӨ-еҖўзҗ«вӢўг’№вңЈжҠөв’ЈГ бҗЈаұҠе”ЁгҖ¬аі¶зқҠе…ҝдҖҙз·°гЁ°ејӨзҒ‘Х“дөҖаҘ№жӨҜг№Ҳж“’а§ҙзғҮжӨҮжҘӢбӣ‘в»§в„ҡзҘҳвҒӨзҙ«д·…гҺҰгҶҒзҹҰб»ҮжҚёд«Ёв ҜдӮўдҫҡб•№жөӢзӮҰжЎҹзЎһд–„ИҜзһЎв“•в…ңВӢб”ҖвӮҮа қВҺМ°вҒ«жӢҲбҜҮз— вҲЁаә”вЎӨаҫўвҒ”д„Ҫг·ҖвҹўзҒІзҷјгһұаі©еЎҙз—Јж¬ЁаҪёв’ҺЪұеҹҲзүӮзһөаӯўзЎ«зқӮбҘӣзһғбӮғајқеұұбҗңзұӯаёўдүўз қеЁӯаәўбҠҢаҙІдҜӮаўідўҳа»Ӯд®ҰаўІеўҠдӨӮб¬Ёаё¬аӘҺНёж‘«аЎ дҡҹзҒјжӯҖдҸҪз®°дӯёжӯҹзҶҪдҷңз‘ҪЪ“аұғвҷ»а»ізұЁНёеұ©дЁӯгұ·д·ўжӯҖеҖ’в…ЈаЁ“жүёв¬ЈвЎұбҒұаәҫз–ІжҶңдЁӘз®Ід¬ӘвӘҢвёӘб©ёв«ІеҘөзҒғвҜңТ”зӮ“дҒ°еҹ‘дҫ“д–…аө«г ҝЗ“зәқвўӘз°»д©Ҡв¶“в°’е•ҝР«зҘҪвҙӘеөЁд·ҠвҒҖд„ЈЙ“в©ӘеөӘвёӢдҺҡв¬ӢбҘ®а«ңгҘ·вҜӘа®ҺЛјвҒ¶зӮӘзӘҰж§ӢгҶһа§ғе®Ҫа»Ҫжҡ—вҫјдҜҶжӮіЩҹз’•еЁёдҡ“жқҙв«ӢзЎ¬вўўжһҘзҺӨбҪ¶вӮҒа§ҡЯ•в·ӣд”Ҳб©ҡгқ $еӯ–бӮҹвӯ„НЁб »П—бҹҙеҳ вӯ…дІЈе¬·вҒҗа°ұз°ҘбҒҒе…ҖвҗЈжғІбҘҘдүӮХібәңб®Өв ¶бҺ дЈ…а№ дЎҰг®ўвғәа¶„ж ёд¶„в…Һеіҙе«¶еӣ·е¬Ӣа¬ӢбӢҺе·ҙз©ӨеҺёвҚұдЎ—з·Ғеұ‘дғӯе©•дӣ¬бҮ•еұҷдүҝзёүеҝ—вҒ№д•Ҫвӣһб–·гўҘд““бҡӨЛҗдҜ•е»”еұӘзӯ№гҷ№б·”зҷЈе’—зҡЈдҹ”б–§жҖҚд”ўЩЎаЈҺбҹӘвә”дҖҗаЎӮаҜ»аӨ…гғ«жЁҹеЎҷгЎҒзўҚа··гҺЎгҘҖбҸҠб•қг–үДқвЈҢа·ігҲҠб•ҸвөӯжҖівЈҠдөүзҡҠбҳ“гқҷkвЈүв¶…зјӘбҙұг©Өе•Ҙг»ӣеңӯвЁҸеӨҰвјӯг–§дҰ«еһ©жҜһвҹөжөҡзң№ж•ҳвә”вққз№’вә¬бҹөзЈҡзҹ…жҺ®д өжҜҡеқҡв—јФҡвўҠбҰҡгһҲдҶ¶гҺҰд§¶вҪ«гқҫвҸјвҝҫж©ңеҰҡгҸ®д·һвҪҜзқҡгӮҹвҝЈжіӣвұ№з„•дҖҶг№ҺШҷзёһдҪҡгҡҹвҫҷзң’г–ӨејӢжӢқе№ұжҘҰд·ёзӮ№вҰЁгә§дӮӨаұЎдҗөаәңГҪгһ§гі«е»Ҡдӣ‘зӯӯаӯөа¶Ӣз…®ж»Ҡб¬—ж„ЈаҝЎДҳбЁҳгўЁжӨ©бЈ·гқівҮҒдҖҒД б№ўдҒ—ЦҒб’ӢдӮҺаҜҚбӮҙж¶–зӣәбёұд„№ајЈжқ·еІЁеӨүзўўдӮ зҺҰЭ„а¶ұгё®гӘ„б‘ЁЛ«жҳ•аҰ«дҝҢд‘Җжј„гҶқОһг„ҫбјҗДјж•Јз”•е°ҲжЎ„бҘҙг‘•дҺҗгқ‘В„Ы„ЬӯжӢ§вёһд”ёб әбўғбҷ“зөқжҸҰФӘвӨҡСҖдӨўвҖ©еҷўб‘—ПӘТўвҖ№вҶ бӘҮдҒӮДіб°¬вҮ„біЎзҒ—зҶ«ЧӮеЁ»вҸ”вүҒеЎүвёүдӢҘГқб—ұж—„еўҰг–ЈШігҠ‘вҝҖең‘дў№д«ЁеӢөдҚ’г—ҒОҶб…ҜжҷҠдҒ–еӢ ж„…дӯҚаЈ¬жіәвҮҗж©өеӘңв·’зҳЈж’–з®ӮВӢж№ҳбҒ вҮ—ајӢдҪңг§Җе„ІдҘғЪҗвҢҘзҮ–вёјзӘЁжҢҠдҷҷзЈ‘еҮҢгҗҖжҙЁе‘ұдЁҪзӢҡбӮЎз©—ТҹеҒӮбўҺаӯҗдҶЁд•°аөңг¬үбҘӘбқҪаӯғб„ӨгҜӘжўӨдӨҖдӨ”зқ¶бҲҺг©Ӯв…”вЈғд’®е·®вўіз‘Ўз©‘г—Ёж‘»дұІг©ҠжҲҠвқҘбұҸгҘҫвҺҳжҫ§ж”ҰбҹЁж°ҘжһұдҚӮж№Ҙвһ…з»¶гҚјЖ‘зң б’ҷСөеҪ»б„Ҙг·ЁеҲҒв»ҪвҝҜвҳ”в• бӢҒд§ўеӮҖвӢЈбҹҷзҡғв•ҜбҗёжЈҺе•ҫв“Ҡд““дҸөХөаөҸд®Ғвү»гІҹбҰўе“ҳеҗЁгҢҰд’ҷЯІеҪөаөід®ҒдЎ»в…ЈвҪЈаө§дӘҶе’Ӣб…ҪвЁӘжұӮжө·дёҒвҮҸжҲһвҹүжҷёвҸ”вөөб‘©Я“ВҘвІҘдЈҡзҪҸдӢҮбҪҪбүңдӯқгҲ·б»Ҷжҷ§гҶӘзҙҝеҮ‘д¬ҝгҮ¶бҺ¬еғ®жҚЎе°№жӘ’б ®в®ӯбӮ—а°ҢдјіеҘўвҫӯгқ¶бҸҳбҚ°жҰ©еҖЁвҠҰжў”вҚ°гҳҰжғҘе·Ғв”¬вғӨС бҗҫД№аўҰв№ҙдјҶаІ·жҳ»ШҘгҘғжЁ’вӨәЦ®в„ҙдң–д®’д»–вӘЈаІ‘дҰҢд§ҠеҮөеҚ‘бӘҖжңӢг§җз“Һд©үеәҝеңқб“№аЈҝз–ҰгІҮз°ёжқӣа ¶дғүжҖ°бӣҮжғӢбӮ“аұҜжұ„вҷўеұ‘бЁ§бёҸејҳзҺөзҳҺгҲ»аәӣеҮҰдҸҺдҡҶа№ҜЬјд ¶ж«Җб„ўд®өЙҗв„өзқ”жҜ«еҢЁеәҚгҜ—г¶“е„№в©јвҹұд Әеғңд«ӣеІҖз§ҙеҗҪгҰўиҖҢг…ҖжәҘдЁҮбҠ•жҫ“еҲјЬ·е”ҙжҘҰбҳҫдә¶жӢ“бҗӮжүҰбҒІдўқгҷ№Э д”•дҫ…б•ҝаөҺг«ҝбҮ…дҷідҺұв««бҝЈдӘңд®өеҳұеҹ“бә·Ж°аҜІж…јб«Ӯе•Ұbв«ҝг”§в–“в©Ғз…ұгҮ–а©өзӣҮвҮ®е·өдөұвүҲг§Ҡз•°а·өбқҺбӘҶеҹҷгё®РҢбҚЈгҠӣдҢҚв…ӯгў–бҹәеҙјг«ңб‘ҡдҜӮвҶ«жҢҒе®ЎвҠ®еҹ¶в’ҮП‘зҡӘЪҪаҰқзҙ гҰҝвҷҡбҮ–б©Ңг№”бІ„г‘…жҠҢжј„жөҰг“№дҳ№еҺӯеҝҹж‘ Г жҷ©бӨҳд’Өвҫңжұ°гё§дҒәЬ”вӘ¶вўҖбҪ жҖҘТұеҚ—ж№¶жҪ©еәҒвҢҡОІдӢ§еЁӘвӮ–бҶ°зҡҙді’дј—ЬҪд–ҖбҘЈгҚӣаөҷеҢұе—…еһҒеӘ”зҮ–з“ігҸҢгәұгҡғгӘ¶ж¶ЈеЎҰвң‘зһҗзҖҫзҰ°а Өдәҗз„§ДәбҝҖУҸХҸв•§жӮңзҸ“в§ҝдғҚаЁ’г„ҮжҠҸв«’еһ·гӢңеҒЎбјәжӨјз®‘бІЁе’ҘеҚҷб‘Җг»јжӮ‘зҚҖжҳ®еә‘аЈЎзҷҠгңёбҪіз©ғПҲгӢҠаҜЈЩ•вј«гғӨб–Ҝб’°бҲҸв©•бү”д–•жЎӢаҜўдң”д§ӯзңӯа¶ңжұҖгҮҶб¬ӘбҷҗеІ§гІ–зһңзқҸеӣ«бҲҗЮ‘е©ҷХқб ғбҷ»гҠ зҷҶз©јвңҷв©®ХЁЭ•гІҪб––гҠөбЁҝО•в»Ҷдө®дҸ”ж¶ҪеЎҫд·ғд”Әж¬ғбҙәдӮҗг–івҰҶвӣҷе—ӯг»ӯвө№б·Қа®әзҙқе„ұвҸҚзҸ·г»җвһ”зҳҫжҹҙМһжұ“ж¶ҠгҺ§еүҡзҙІз®·дҙ·дҺ–бқһа©”бҺңбҘ…дұ–дңҳгҲ»бң¶зҶ№г¶ӯбҫҜвІҚб—ҘгҘҡД’бҪ„жҢ©ж №ж«ӯзҳңж’Җг•ҫзҒ…е»ҷж…’жҝҳб¬ЎдҒ„иҖ„д…§вҗҫд®‘бҢӘЕЎбҚ№зҠҮжҲ°гҚҰеһәМ гІ»жЎ°ЭҒз¶Ұд »ж·ғз•һзЁёгҡЎбӘҳд·ғдҢңвјёЯЁКҘеҮ«зӯҗжҘ–гҠҶЩҰдЈӣе©ЎдҪҒвҫ№дӣҫбёҹд§ӣзёөз°үг’әвҢ”ЭҢдҺ°еҫЎ,д§°дІҰгҝҶа ұз–ІбғӮгӘҡе”°ЗЁгІҰZЗ·бҲҘе«ҠаөҒе©‘зЎҹз№§еӘүбһ©бҠҰвЎәдғҺЫҒз” СҷдҖ бҒҪВҢЗЁcгЁҝТҸзһҗа§ вҳӘгғ“ЭҖгҹҒбҳҘгӮ«ж‘ҡаҜӮдё·г„ӣСҳбҫҠбҒңгҖ·Ыҳв„ӨзҸ§вұ“б–ҳгҜўгё»зғҹа ҳаӯЎжҳёаЈҖдӮӨаЁЎв„іб©өЫҹв…ҒдӮ»аўҳдҒ„бҹҖвӨҰГҙдҢ бөҒз„ұдЎҲЪ„вІӣеӨЎб№…зӮҝб”Җд”Ҝаұ‘бҷҙбӮЈзһІвӮҶЙ аўўе”ЁвӮңЬ©бўЎа°јбҲӘpбўЎзҖЈжұ“б•һб§ға ӯбүңж“©б©Ғд»¬вІ•з‘ҖзҹҒа©Ід…өШҪвӢёвЎҹз‘ғгӣүЬҠе–«бҖігӢ¶аӯ©з–ҪеүҰж„Ҫг–ғжІіб„ҡOЗ’вқұаІҫвӣҪвЈЁеҚҝг©ўвҒіг…ӮеҫЎжә·гҸәФ«К©зҳҝгҢ°б–ұгҚұе”ҹдҸҙбңЁз»Ёб“ҺД°гӯ“аҙөМ•вҒ°вңЈгңҰгўјМңвҖҠдӘұжЎҮеҸҙЗәжң вғ¬жӮҲжё Зҙе”Үдӣ°аӯІг ІвүҚв——в№ӨбҗЈаЈ гҲІв·«б°ҫбіҖзһҺвғҠгЎ»жІұг…җзөіеҰ·в…ӮЫ“аўЈдәәЫ…бҖҲжғ§Щ•КӢајҠг¶Ҡдў®Ъқа¶қа«ҘжІ¶е¬Ҳд“ёдҲ№жўівҷ“а©јбүҡдӘЎгӢҲзҶҳеҢҖгҮјвЁ«бҸЈгҷӣд§»г°®еҖ®б»Җж§Әе‘„еҸғгҚҗжҗЈдӣҢзһҳжҶ°г§әаҘһвҗғбұҶз§әб”ҹдғёаұҲзІёвёўеҶігҚіг…өКәзҮҒгӣӣдіЁж«–еӢҠв®№в»°Сһз•‘вҝұжӢ¶жүҒзҗҜС“вҘҖбё®бңҜаӘҠвҸЈжӢ№гғқгҡӢбҗӘвЈ•гҸ°еӮЎРҪгӮ…гҒҗдө’бҰёе«өаіҚВ аҰ№еӘӮЬҖгҰҰвұқе©ӨвӢјбһүг«Өвҙҹв’җжү