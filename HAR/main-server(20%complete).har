26 15:11:44 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3486"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":4351,"mimeType":"text/plain","text":"1569:4312[{\"ret\":0,\"compress\":true,\"serverTime\":1775056304959,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЗёГ¬в Јб Ўе Ўа°ўг  г ўжӨ„Йҗд•ғв ўж’№еҹҚвҘ¬бҲҘг”ЎвұҗвҲ бҘҚжҳӢдө«гҠ«е”ёвўӘlб‘»еҪҚЪҠб‘»вӣ—еҪ©вёӮб…•е®ӣдҲҙв©җбҘ©гһІеүЎвҠ№гҢҒвҒ еҮёгҖ б–ҲбұңбҜ дҰЁбҳҒбҺІб…”В”е®—бЁўбҗ аҝҺдҢҙвҢӣзҙЈб«Ўе„җе»„г©үв¬ҝаұ®вӣҮеҚ’еіҚгҖёMдЁҪд’Ҝб¬”вӢҜжҡ¶в°“YбҲўж“„а Ўа ң#з”Ўг„ҶдҒЁдҖҖаӘҺв Әгө”КҷбҙЎжҫ’жҸ ОүеҢ–г© г©ҡгҸӮзЎұд“јвӨ¬ а ӘжҲ®д„ҘдөәдҝҒж…ЎвөЁд©ӢвҰ…еҰҢбҘӢвҚғж§ңеҰЁдҢҘзҒҲвЎ®бһЁж°ЁзӣҹжҚұ зЁҜа¬ЈдҒ б“ а®ҝв Ҙ&ГІгҘ бј–б…ЁMеІҗвІ©вҠ°гҖ б·»жҹ‘ж©°ЙҖа ҖаҘЁб„ аҜ©гҺЁзӘӣбҚҜб“үвЁ№Х®бғ©гҺ”Ж„дҚ°б‘ҠвҶ«в‘’вҙ–в®іж‘ғдӢӯбҫ°б—ҙKбҗІд’·в–’еІІж“‘б“ӘдӘҰв””е‘Ҡвҡ©вӣҰз»«бҲўИів•җ#жӮЎдЎ©её§бұ аЁ в”»ДҰ)е°ёТҪвҷҗбҒӮеҳ дҚғвўІвқҮдЁөд”ӨаіӮЛ”гҒҜд…Ҝд§Ҷб§Ңз«‘дҲҪзҰІеҚўв“әuгј вҳҸеҖЁжҺ“бҘҶзјҢг„ёдҠ бӮІбҲҪд ҖдЁғж”ңбҫёТёвҙҒЧ‘жҺҖбҲ вҢЎбЈҒдң„дӨіг ўв«әеҹҫвҲҗгўӨд№ғеЎӮвҫҗвҖЎе—°вЁңа§һеһҸзҜҝгҖҰвЁЁб”Ў'д« еҲўзЁҫаҝ®зЎһД·з«Һд„ЁЫ¶аҜ К«в•җб«ІгҪЁбҖҰв‘©а»ўЬёаЁҘеҪҚжҸҷдҖўдҸҲг®‘ГӢдҗ§ЛҖеҶҠбүӘж¬ұаұҰжҶҳа§ҒдЈ«аҪғб•…ЗӨгўҘж…ҷвҖ аұҖТЎаЁёеіҖЕ§еҳ‘аҘҠж¶‘гң„е °гҢ°е“Ҳеұ¬б“”бәўв‘ҷЭЈЖЁб…ӮЖҶгҳ°еўҗаӘҖб’—вқҰжўҗвӢӨв– +зғ“вҺ¶жқ’вҒғвһ жөүзҡҙдүҚдҰҲвҒҶдһ“жөҮв”Қе–ўдңҖзҰҘг•Ҳв—Ҷд¬ еәүдЎёзҡҶд”©ж…ҜдҙЁе·—yгүөд»“е– дҗҙдҷ·дөҒдҗ д—өж°Ўді«аә•гӮӘд’ ЫұбҰ‘в«–дҠ©гғ–еҮ–ЛЁГҡе“•еҚҷб„ еҗЁдәҙе‘•жіҙдҒ зӣҳжңөгүјвқ¶вҗ·е •Р«е•№бүӘ(зҗҘВҙзҹөеӮЁеҫҝзҲўгғ‘К¬4д°Ёгғ©hеҡЎб»”дӮҳвў©аӯ”вқғХ№дҒҲжӮ”аҘ гҰ•еҖ°дҘӘЕҳд’қдЈӨдӮһбЎҷвҶҮеё©е»ғдҠ•б„ҙвә—гұқИўеӢҢв‘·гіӘжү«зі еҒ»МҠзҖ’зў•еҠ…еіӮеҙ¶гіЁгҮІж”ҳеөәд әеј жҗҙеү«еӢЈбҮөгҠјеһ·дӣҢгҡҜд¬Ӯеҗ…жҲӨе’¶д©Ұеі¶е¬Ҡг—ҙз«һеҶ·д§Ңг‘—аӨұеҷ”з§®е“·бӘ№еқ”бӣғжӮ•еҡӘЧ”зӣ¬бҝ•з№ЈеңӘдӣіеҗ®еЁ«еЈ°дҰӢе®—ж»ӘжҰҒбә·е ”вЎҪдҘ®жһҖвёҡбҠҘдҷ зҡЎГғг»ғгҳҗе–Өв ®е„ӯгңұдҶўЧүгҮ®д¬№зІ е»»вҮӨгЁ·дӢ”гЁ гҮёеҺ®зҙҠеі®вІӮгҡ·ЦӘг®¶жһҠгӘӯдІ©е…¶ж“ҮУҜбӢҶеү®дӣ–еўҝжҒ®гЎҸг§’гҒ–дҘ’аұ–е©ұеҷҫа«©еҷҺжңҷеҠ§бӣ…гҚҢгӣ»а·–зӣҘг«–УӨ-дј—г—Ҹв¬Ҫгһ”бәЈгөёз»·е”ҺбҒҝж© Oгң¬Р бӮ№дқҖв“ӢвҠҝдңҹгө·вјҗбҙ“вҰҲбЁ–а ӘеҖ–зғ©вӢҠдЈӘб№ҠжҮ§дҰ«дҹіа·ҰгҮўЙұзҮ«в©Һжө–в№ҜзҘ§з§ҹжЁ‘гі®вҷүеғұжҫӯдіҰвҲҠдҪҷеҠЎгў“гқөбқҙзҗәв¬Җбҷ•ж‘Қж—ўг•ҘеӘүбҜ„еӯ¶в®•зқғеҺ¶жјҒе№ҳбіҢгҜҘжҙ§еҚ№вәӯжҰҜг»”бӯҝеҶҫбҖӯз° д» бӣ¬ГЁаё гһ¶з§°д„—в¬«еӢҙв§…ЗІдҖЎжҲў)вҫӯе…ҲбЎ§г ҙЕҘбһ·аўұаҪёжӨӮжҮ»д» =вҘўз«ұзҙ¶д“ҲгҺҝзЎҢгІ©жқҶбӣ¶г”ҫб»¶вҡҪг©“еғҠеҗҰж“ҒдңӢгҶ«жҒіаҪёгҫҢзёҰбүңдҷҹвұ¬вқ§еҷүзҘҳз’•аҫ•а ЁеҡҸаәёж”„ЧөжҳҹеұҡвҸ“дӣ”вұ”ЭЁд«һе„ҶаҰңбјқвЎ’аіҹдӘәзҝӣвӢівҖ¬ж №Г‘КҲе‘ҲдјӮеғұз¶’гҰәгҗөаӯұвӯ—жһүвҶЎвәҸЖөж№©гҢ¶еІҖг…Үд—“г§һбөўзҶҢаә¶гјӮГЁд—ја«°дҸҡвӨүгЎ»еўҡаӘ еӮ»а·ҠбЁҪбјҸвіқжҘ© б«¬YЙҘж»җбҢ‘бҲўдӨҺВҢзҳёзңҸвү’жўІжғҲеҸёдҖӨбЁ е•¶д“Җеҡ®гўівҳ©бӣӯжҘ•бүіеө…г‘ Яіб’—жЈ’дҝҠг¬¶з§ҘбҝӮзҲ®е•ҠгҫҰаҜ’в’·гҲ«еқҫг…’зәҚеӢ•б‘ја·ЈЙ…дҺҗг©Ід…«б®‘з”‘ФҺзҰҮеӘЈбӘ«дҚ—г¶ұаұӮеЁҫдҺ д“Әе„ҳЩӨжҰҪеёҫв•ҘдӮ вҢ¶ЗәжўһжҳӮз«җгЎҢд‘©еӣ„б…ӮбҚӮбүҠвҸјдЎҶвҹ—бҳҲд®ҶбҒ…аөұдҰұе…–гҖңз“ЈбҢ¶бҒ·гІ•дҡІзү„б’ЁеқёбҠөг…ҺбҷӢа«”вҙҳвҙ…ЖҲвҷҘвҪҲд”Ҳз“ҷзўҚгҘҒж®“з«‘ж“№вҲ…д¶Ҝзӯ„жҰ«б•Ңд§©гҫұв§ҝб‘іе…өв¬©еі„аӘ„У•гҗӯдӢёа¬ҘгӘ·бӘЁбҙӘзҒҹж©әгҢҰж’Іб“ӮжёЁеӮҹеҖүвұҪвұ«в‘“д»ӯв°©вў¶гіңеҹҲзҘҢдҪқд©ҳгҰ¶гҒ«бӢ’Вӯгү–в®„зҷІг’җжҚҚб„Ҷв№ҷзӮҒаӨ·бҖјеқ„б–ұе№„в¶…дҜје·ӢжҢ»вЁӯдІізӨёжҝғзҲ«зӢ’гҷҖгәҗеҒҙдҝҸгҺҹвҰҘв»ҝв§өж“іжҮ‘е°ұвҰ«вҚ·в”Ӯд’ жҠўа©ӯвҲҫж»§в“«ж§ҳд«“г¶ҲзҺҶзЁҶд”ўаәәвҜ…е¶°жҳҹв“«вҚүвҮӨа°№еҰЎгў’ж’ӘзҠұаәұдўӢбҶІбӯӢа©–гҘҘг’·вӢҶдҳ–з“ӢбЈ•в®өз•°е—ЈеҲғжҷғзҠҜгӣҲЙҝЮӣгҒ©гҘ»зҗ…гқіЩӯеҠҠв·ҡзө зі©в¶Ңзҷңж·Ңб–ӣв»ұгқҪзӮ®бҰғУ©вЁ№дҸөжҸ„зҳҡдЎҲЪҘж¶Ҫжғ°жҘ“еҪҪжЎҡеҘәвҢҡеһ’гҹҺжҲўе„ӨжЁҺжҲ·еө•еә»вӨӨдҜҙвҷўбұөг”јвҙЎаЎ•ж•Җз§ӮбҖ¶ж–Ңгӣ ФҚеәҙжҡҚз“¶еҜ—зіҫаЎҖбөҙвҰӯеәқжӮҶзҚЁзӢ¶гӯ©аҫ–з •зӣ©вІ•ж‘·дҳӨж‘ёг’–в’„КӣгІҳзҳўжҝҺе”үж¬ӯеҷ•ЦӯбҠЈбІӮб®·гҜЎзЈ®з—ӮжңҲаҙҚжҘӯбҲ¶д·ҫаЎ«Я’Я„зҷӯдҫӮ б’ІДӮгҒҶбҒ©ШӨ еҳөб·ӨдғәгҘӘЭүаЈЁд”ҮбғҜжҷҳзҮҲзҳјб®ҚзұқгҢ°е®ҶжҘ•дҷ з¬№бЈңдҗҲеҶҶдҮ—вҙҪжқҡвҰ•в„ЈдҝҸжҡёжҺӯе«јз•Җд¬ҪЧ…ж®үаЈҷжЁңг¬»а Ҫа®Өз¬¶еӣёд№…зүҫаҪ¶дҳ‘з—ҒдҗҙеқўдЎ°в…ҲИЈбўӢЮөжң«еј“еҶӘгҷІз·јејӣбү“з«ӨвҒҙзІӨдўөдӘӯгӨ‘в§ұЭіРҖг•Ұг№Үзҡ„жҘөгҳӘе—Ўж©јб·Ӯг–•ж•»зҡ°зҝ–в„Ҹв„°з„ҷгіӢвЁҠжҜҝзӣ¬бӯ“еў¶г–¶гҮәв“әж¬ҢзЁ…г«Јб©ұд®»г§Ҷб’ҶжҮҗдҒҠРҶеҸ’гҳўжӣ¬жңҲгҳҰжҢҸдӢ–дҜ°дЈҹаӯҖСҮбЈ„вһ—в®Өв”ҖгҸЎеҘҢвөҷбЈҖХ”еҚҠгӣҶа¬әжөЁбӣ»ж·•з”үжӘӢжјӯг•ӨбҺјгҸҪгӘҶг…”жӯ»гіҙе¬ҒбёұдҫүбҺ§вҖҚбҪҜеҲ…бҘҜеҘ“жӣҲзІ•дӣөвңўжңәд¶ӘзҺғз§ІаҜңжң«еІ’б°Җа®ҝбӣҙвҙҪг«ҝзҸӯеҙівҶ”дӯӨеҹ–ЮҠгҺ“вң”вЎ–вј…з№әб–ІеөңжҜқв¶Ҡж©“е–ҒзңӨвЁҚгҫ—бҡғжң—гёҗб°қжҝ–б• г…ҠбӣҠв¬ҒзҖја§җбІҠдғәеһӨгӮЈд’—вҪҲзіҙвө»гҺҗең°бҒһбҜҗг¬ЎвҠ°жӮ вҰҡбӘҚбЈ•в· гё°еү“жҷ’а§һв©¶зҖҜМ’бі«в‘‘бҡ”С·г ёе’«дЈ…аӘӯжҙ¶дӘ•з¶ІбҷҶжҲҫд§ӨдәҶеІӯбҲЈеҷүжҳҳбЎҘз’һдҢЁаўҘаЎ‘Ь°жЁЎбӮІХҒеҲҰвҖӨаәұз…ұб“Җж¬Ғж‘ЁЕ°е№Ҷж„Ә6вұҳжӣҘбәёИҡдһ„гұ‘г‘Ӯв‘ҫвЁ Эғаў«жҘңв«„)дҖјж‘«в»Ӯб§Јдё¬ЕІдәҰвЁҖдҸ•гҲҹж…°а°®зҒүб—җбҝ з«Із»’Йһж‘ЎгҗӯбӮҷОҮаҘЎвҫҒдўӯКғаӘЎбҲӯвІ¶Кёб®ЎИўбјІПЎаЎЎеҡҰбӮҡЛҳб»”аЁӯжӮ“в ҙа«җбҗ зҲҘзІ„жҶЁФҰз ұдғҙа¬°б ӨдЎһдҒЎдҢ ж “б…‘д…„а©җб„ЎНҹеӮ°0еӮҖвёІЖұдҠёдӨ§в•ңг„—ж“ӨбҷҮеЎ’б„”ЩӨв”ЈдңЎЕ„Оҙз§Ӯв…қаЎЁдҮҳаӯӮ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":3486,"_status":"completed","_startTimestamp":1775056304063584,"_endTimestamp":1775056304067772},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1487,"_uid":"e29000af-3330-4ab1-85f5-37e0b0df559d","_cid":148,"_ctime":1775056284934,"_sid":17,"_stime":1775056302839,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:11:42.096Z","time":704,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cR09&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","va