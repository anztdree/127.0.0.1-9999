,"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056321544740,"_endTimestamp":1775056321551121},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi1AAme"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:12:05 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2178"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":2679,"mimeType":"text/plain","text":"988:4319[{\"ret\":0,\"compress\":true,\"serverTime\":1775056325122,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЗёГ¬в Јб Ўе Ўа°ўг  г ўжӨ„Йҗд•ғв ўж’№еҹҚвҘ¬бҲҘг”ЎвұҗвҲ бҘҚжҳӢдө«гҠ«е”ёвўӘбҘЁвҠ…зӣ№ж‘ӨжӘәб‘»бӢһд©ҰвӣӮеҒІвүёжҢөгҷӮд¬ұбӢ’вҘҰв—ўдӮЎвҸҗжҖ в«°гўҳвҡЎбҢ°вҜўвқ„вҠҲДүгңҺгҗӨв  бҪҪЩҲдҲ“з ҘЙўж„ұгөҲдұјв……в’ІдӯЁж–„аҘәжҒҗ{б‘ӣаӨҫгҳҲдҢғд№Ҹбқ¶гҖ гҘ„Л©вҗ°ДҜз° РҠЖҒжҡ дўҹзЈҖб””ж ӯз®ҙПўаҙЎвҠӘд·ІвҲ‘зұӯв“ӨдӮ 0а«ӨбҗӯвңҒвӮҹвҙ¬РҳДҠа№Үаӯ•г—ҫвҺҘЛ•б…ҲеӣҶд®…еў„з‘Јд§‘аўҖеёҘа§•гҳ‘дүҰжӯ—вҒ°гҲҘ'еӮҳе јИЈвҳ а·ҶдҖҘб—°ЮӮбЁЎеі–дҖҘвҘҰд  в·ҳжҲЁдҷӨе…Ёб  ајғбҺЁFбөӘХӨДңЕүЙҖЖҷбҷ«Х©гҲүб©«бұ§бҶғбӘүв№ӨеҠҚж ҘдӨӯвӢіз“ҰаҰ¶ж–“гІЎвЎІб–«бҠөаҘ§в  еҷ°в”©вҘ¶еҳӮв–©вҺ°ж“ҡз»җжә·д‘“а ӨдҪўзЎӣРЁв…ҙжҖ ЮўЧҚд¶ҳгә‘а№ҲВҙгҳӨа° бҺҗгҒ№дӣёж”өгҖӨМөдӣ¬гҘңеғҢвӯ·гҢёбёҖеҗ…ШӮз““аІҖдқӘж“ҶвЈ§вә б•ҝдҖІд Ҳв©“еҘҢв§ңг¬ёдҲӨбӮІбҲҪд Ӯжң“еҒүбҫёТёа¬ҒЧ’гҺҖбҲ вҢ зё°гј–г„іг ўв«әеҚңб„ӮвіёдһҖд“ғжӮ Н·вғҖаҜ¬гҙқг»§9вЎҖвЁЎ#ж–ҖвӨҜгёҖИӢзұҝб°ҖбӮ дјҲбҮ ж®Ҷг° вўӘеҲқвҙҝзһЈвӮ„д’ұжұ„зҶ еҒ¬а¶үг°ұз…ңХҷеҖҪжүҳдҲёаёӘд“Өдұ«г…ҙе‘Іб•үг’…дһұгӘІдҳғгІҡзҒјеҖ Ш¶бғјб’ЈxвҺ’дҖҘбӢІбӢ“бҹҗбү§дҰҶеӣ”вҪӨгҮІдҚҜе №дҷ“зҲҪШҰбӮ„дҗӨжІӨвҶҒж„ҷеұ¶бәҪа·ҒжӮ«аІ¶ бҹҫж‘ІзҰЎгҮ№бҖівғ”бЈҙдЎ°бҫЈдҗңДҰГҖг№ёзӯ°гҫІвҢ°ДҜз„ҲзҫівҲңдЁҪЙЁаҘһа®ҷдҗҘа§Ӯб«»аЁҲВігҖҘаӯҖв…№вҮўб‘әзҳјжҷ№дҪқеғҷгү ОӢві®дҶӘЬӨв· бҡ”жӢҒбіәеөёг“№д©ЎбӘӨаҰғжІ аҜ„зҠғаёӮе•Әз№°дғҠзҪ¶вөЁРҰбЁӘзӯҘв’ҠбҶҪб®Ҷд“Ҷв°Җв“ёзҠҰз“Һв©Ід «зҸёгҫёа®ўдӮӘаҜўж‘Ҫа¬һг“ҮаЁІеүіаұ©ЕҢд’°в©Һд•‘вҷіе’’е«ҫб°ҖбӯӘвӮӘд¬ҮбҜӘд¶әзүҶзӯәвҰҢНҪж®әз°ўе…әеёҰЪӯаІҘжӘҡжҘ бӘҰжӯўб©ӨвҒ‘е«ҶдІҢзӯ¶е№ҝбӯүг•Һв”‘діҪдқ–жҺ°вғ’аҝөзҢҫжҲ гӘ®еҒІаӘҖбЎұа«Ӯжҝ§зў„а·ёд®©б»¶дӯҫеҷҠжЈ’д»»бҰ’з«»з°һдҘөзӘ©ж•әЪғЭӯвұҒзүқЮҒеӯ°еңҠжқҙбұұеҪёб«ҘзҸөдҡ…д“»дқәг№қдҹҢжӢ·бӢ©д…һеӯүеғ·еҶ–зөҹе«ёвҮ·з ўзҚҡгӯ№з§ұж һбәЈжңҺжӯ з¬¬дғ‘д®Ҙеәӯаұ‘еҮӣвҳұб“һгҳөеі‘еЁұзӢқеқөеұҗдҹ…бү’дҝӢб©ҹеқҰе’ҷб©¶еІҗе©©зӢҪгҷүжғөвҷ в–Ёзң¬жҚ–зһ®дӯ–жҷҺжқҷгҲқеҪ”зҷЈеҜ¶аёҪеЈ•аҪ…дӮ¬вӘ«зҒқвӘіж‘’дӣөзұ‘еҷҡз“ӮеһҡдәңбЁӯзҰҳвјӣдӢҷгқ©ж§һв “д–”б¬„а¶“зүҪеҚ’г«®зӯҷг¬„б®ңд©ӣзҸҫд«ӣеҷҪвҫӣж…һв¬һд„җЩ·д•»гҗ…зӯ§в®іжҚәдҝөж ‘жӯ“д ӣгҺҫеЎҸбәҗгјјгҷҫзҖұгҷ…ж§җжӣ«гі–дӮЈдҗҫзЎ“И—еңҜгҷһжңҸзӨӮаәқзқҝдіҸеҒ»е»ҺзҜҝУ”б–Үзҡ¶в ҝајҸжўјеҸјаі§е ҡвҹҹзӘҙбӣ’ДҳЧ¶з’үдҷ«жҷҪвҝёдІ¶еҳҰгҹҳЧ»г©”дЎ©ж…јв„ўзӢЁбҲ вүјв•ҮбҒұз әФҝбҹ—гҺҢаәӘеёЈдҶЎжһўвҪҙбҙ”бӢўд—җж«ҹбҗ”аҫҺаЎ®б«ғвҶЁжӯқжғҫгұ‘еҶҷгҹ„Т°зҶ•зғ»ајҡг®Ӣб ¶дҠ№зҰӘе…Ҙа¶«жҰ¬зЁҲдһӯбҖұбқӮдҪҒзҢҗНҒбў дӮ–е–Ұг…ҡб¬ҳвј…бҖҙЖ аұҲгҷ°бә¬бЈ»дҲ’ЦЎдҘ—вҜҗг¬Өе№ҳжҒ¬еЁўбғ‘бјІеЎӨв„’в–ҖвҖәаЈҶгіӨжҶҲбҲәжёЎз„…в№№бҖҝеўөеӣҗжҚҷа¬ҫб ўзўөбҸӮдғ§бӮ¬в“Ҙв‘өеЎӨбҜ„гЈҖгҺ‘бӮғз……НҢШЁж”ӢИЎеҙҝж„ўбЎӮдүҳвүӨв’Ұд‘ёдһЁд’ еғ©аӘұжӨӯбҒғд©Ёж“…Е»вӯҰФӘдҲІдүӮдҖ а¶ҚбіҪд«ұбҗёдғ аәүеІ»зўЈаҝҙеһ—д®’жӮ¶жЎҲаҙ”<вҚЎеЈ№гҘ·И„в№¬\\\"зҸ©Көж Җж·Һв¬ҹб© дғ…зӢғеҗөең®дҘҖХўдҠҙвјЎг‘іcвҚ¬зҪҗа®Ўг”¶жҶҳбҡӮж‘ҺдӢІв¬Ҙз®Җд—ӨеҺ«жӯҜа®ҶИ·г…¬б“Ід„ҰеһҲз‘Ҙж‘¶жҳҲеә’б“•дҜүвёҙаЎҺзҰ’зөҚзҢ’в«Ҙв©»д–„е‘”дЎҢвӘұв’ҙж•ёбқ’дғҺд«Ұв¶өз’Ӯж—ҜбҖ жүӮб№ўб«…в®ңгҙўд”ЁдҰ©Төе’ўЭҡзўёд§ғб®ҒзҷЁ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2178,"_status":"completed","_startTimestamp":1775056324287224,"_endTimestamp":1775056324293082},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1527,"_uid":"682d332b-e445-4d9a-bf60-09502b3755d7","_cid":148,"_ctime":1775056284934,"_sid":28,"_stime":1775056321544,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors",