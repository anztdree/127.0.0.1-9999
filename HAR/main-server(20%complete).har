text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3167"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3946,"mimeType":"text/plain","text":"204:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":false,\"data\":\"{\\\"_curMainTask\\\":{\\\"6021\\\":{\\\"_id\\\":6021,\\\"_curCount\\\":1,\\\"_targetCount\\\":2,\\\"_state\\\":1}},\\\"type\\\":\\\"Notify\\\",\\\"action\\\":\\\"mainTaskChange\\\"}\"},null]1335:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“ғжҘ•жұ“б •ж§ҶзӨҶж»—Ь•Уҷгһ–д»җгңұзіҳеҡҚеөӢб”©б·җг—ҷбҮҳФҪеӣҠг–ҪжЈҪгһ©зЈҳзһҚж§ӮзҹҫЧҲеҳ•гӣҖгқҳе§’зҳҪзҮүгһқеҹ’Ь№з“җаҪөбҸқдһҶг«—з—ҒПӢв‘ЈвҝҚд“ҒеўҮе§қг«Јзһұд•ҶеӣғбқҪаҝөХ–бҷҚдўӣг“ЈзІҡе¬қаІ‘е”•в’ӢгңЈдЈҷж§ғж« б—ӯЛ”жҡҘзӘ–з’Јз·Қд¶©дӢҒжққЪңдјқб…ҒајідҝӢдјҷбҶһжғҘзӮ„дҪғжҰҸајқжЈҢа¶ӯЦҠвұҘж§•еҖқд’ғвҙ«б’үді„дҠғжҹ«дҰҖж№®гІҚж„ӯгҰқвҫ»бҜүвҙ»ж®ҷжӯіеҮ‘з“•бҪӮбһіжһ”аҫ«гҺҗвұӣвҫҠжёӯзўҸдёӢз®“зҖүж¶Ҹз”ізҫ“дұ»в„үжјӣг„Ӯв°§дӨ“зҰҪе„—в»ҮзӨҗбө…вҺҡе¬ӯеӨҺж·Үд§‘жІ•з’–жҝӣа§„еҷҮа¬…дө·Ж—бҝҮзӣҺе““бҺҚб’·жңҢе··гңҳж»ӣзҡ„б•қгҙғбҫіж««бј·ж¬Ҳа»ҪгҲҠз©—аәҳгі—ЗҡеӯҫзЁҲгІӣбјҹбҝ·аЎӢе—ӢвЁ”дј«гІ…гҫҪгҳҡз•Ҹж§ібұЎИҹдұҸаё–еө§а°үжӯҡеҗҺдұҮзҙҷжӯҮжҙҺб№Ҹдё—гӮҹжһ…зё•д’ӣбІ№дҗҹаІ•бӯҺзҲһз°Ҡб»“дҲңбҸўР—е…№г–ізӨ·ИӘгқҲа·ҰеҖ»еәһжӨўзҹіН вӣ№зҹҡШҖе‘’зёўаҰ–дҖұа»ҹжӘ”еҶ дҸҸеұҡдҜ”Т д„©жӯ©зҷҒб¬ғвЁ·жӯЈеҹ«а·ӣдҰӨзң№дҢқвЁ©еҢӯе–һжҖҪЫҗб•¬аҪҪдҸҮеҮәТҮз§җжёҗзғІаӘһгўүвҶ¬б§Јаі¬ж…ёвҙҘб’ҢдһҺв°ЁГӮаҜұРғбәҰбёЈб·ұН•еҪӘжў•еӨҲж–©дЈіа®ұж®ҸД®бҠӮдЎҶжҸ¬гһ№гҝҺЭҲеҘ—бЈ‘г…®зҖӮвҲһбЁЈеӣЁж’җв«Ҙеҫ¬Ъ ж®ҜдөәгҲЎвҳӢбіІбјғеҷ…вҖЁбҮ гұӣx\\\"бЁј%еҺҲд– дӮңдӨҗзһЎг„ҷбғ‘гҪЎгҲ’гӣ вҒ‘в’ҳД дҖјдў г ӯгғҠжӮ•гұғЙҙвҲҖж…ҮдӢёОўдҒўдҫҖа»ҠвӨ¶`жёҝбҢ®Э…е©ҙж‘ҳа№ӯеЎҲЫҗв §в©Ӣбҫғз…”вҢІгӘӨв‘ўжҲЁд¶Ўж’ҜЗ©еӘҙвӢ…бң бёЎж…Ҡг„Җбҳұж—ҲРҘе јдӘ гҢ®жҖ®а¶іЕҹз“ҡв‘Ҷаҫ§дҲјеҗӨб°·ЮҖзІ°зғ¶Ь зҖҙеҺјбёҒвҷјЛёв¶Өе’ҝдҫҖд¬¬зҖӨИҖа¬ҙж…ҡв……вўҹЭ„зҶҜвҪҹаұһзЁід»ҪвҖғжӯҗгіҜе®„жңјв’ІеўҜбҫҸдң‘д”ідҳҡбЁӮжҪҺдӯ©гҫӨжңӨв”ӨжҫЁгҢҢеҳұгһҲз„ҫб¶өд“Ҷзёүв§ҰбҺҘб”ӘдӯҢжЈҲж—…еҙјбҳңеҲўдіҶв©…вҹҶжқӣб”ҳе‘ҜаЈ§зңҳбёҫд”әб”¬вҖ·з—ҢајҶЩӯвҗ°г¬Ўж”ҮХүгң вӮҶаҘідёҘа¬ӘгәҶб©§д… РӨвӢ“вҘ©еҘ¶дҰөд»Ӯзұ’в°•вҹ¶аҰҒзЁӘдҢӯз¬…в¬өбғёа¶ҶбөҠж№“жҜӮг§Ёб•¬г•Ҡзҫӯв¬Ҷв«…гү№а¬ҢајҗРЎгғҙГ…в©ЈдҒәзҸҠвұ»вӯҗбҚҙе§‘аӘҠзҖ¬жӮ’гҰ„гөІгҳӮзҸ¬аӨӢЫ•зІІбҰўб©Іе•ҲгҺҒдӢөзүӨЕәе·ҲбҖјдЎҖзҒ·в¶үе««ејҘгҶӮИўзҠҙжқ»NгӘ·дҹ©бІідҘҺаҫіПҚж„Җб«»б©ідҚ®жӨҠжҙ‘жў°ж¬®жҒӢб…“д»җеҢ®аёЈжқ№вҗўд¬Ңб°«в©қж «д«¶е®Ғзғ–ж„—вҢөзөіжҡ¶д№ұе»ҡеүҷж‘¶гӮҷеіәдқҖзҸ•аёЈбҷ•ж—ӨбЈҲзіјвјҶжҫӯНҡеЁ»зөӨВҜвқ„бҳјвҚңв•¬Жәд¬җб–өбҰҰеЁ«вң№жӮҢбЁҒвҖҙLдӘҢжҚӨбІӯв–„зҒҷб„Ғж„әа°’в·ЈгһүвӣёД еҙ“в°ҪзІөВЈеәҠа¬Ә<ај”в°ҙПһж»үг¶Ҹд„үгәғНјеҷҗг—һгүҪвҺ—зҠӣдҸ–еұ§З…ж«үбЎ·.ЪҖбҘҗж©Ңбҝ–еҶ”дҪұжҹ«дҮ’аәӯе№әдҰ‘еҒғвҜ»а°ӢвіҰдҒҪдҗӮзҒӯдҮІеҠһУ№гҸ‘е№ғгҒ–вҗЈг“®в·ҺвӨ’ж•Ҹж»ҹв·Әжқҷж•ӮеЁғгҘёбЁ©гҝӯПҺв®ҰжұҪгЁҳе®ҫгӯ–б·ҒгҒ’зәҷбӣӮзҷ№еӢЁвҪҠж№Ід§•в°…вҪұбҮҷв№ҙзҰғз©ҙвІ§бүҳвҝҠеү«е»Җејөз“җвҜҺЦ·гҠҢеҹјб·ҺвҢ’а§ҫжү№гҰ®еҰјгҜұгҸЎг•·з№Һз©ңз’Ҹд”Ғз¬©зқ»д«®е©Ӣе“ҝд°ғгһҠзҺ”еҡҰз«№ең•дІҚеҚёдӣҳеўһеЁјдЎ‘гҒ–г¶Ңг„®а№ҒгӣҰеҷ©дһЈе–Іе»»жҜңг¬ұгҪ–дҺӣзҚҺзӘҙв‘ҷжІӯзҚҫв¶№еҪҷгҹһдҙҝгҳҒзҫҖз© бҙҺбңӮе“•зЈҫвҢҖгҙ«г¬ЈЬҘгӮұз„ңгҹҢбңҚвіөжІқзҜўвҺҰгҮӢг—үвҜігҠӯЬ§вӣ‘жіҰаЁҠб¶ҷзҜҪО·дҷҮв–Ҳв қг”—ж®’вҡЎгӘҝжӢІвҚ“е‘әгЎ–гёӢв…ҷжҹ®вЎ®б–’бҢҺзҙҫдҮөдӨ“еҘёеЎҪе©«дҮҷбҚҺа©ҺдҺҖжһ…з©ҪжЁқвҝҶеңӯдғӘбұӯдўқдқ“дӮЎдҙёб…°Р <дў бҒқ0гҚЎВ„вһҖбҺҗе„ҡзҸЁгҖёзҖҖаӨ гҗ·ИҖбјҘеүҖ  \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3167,"_status":"completed","_startTimestamp":1775056028796160,"_endTimestamp":1775056028801756},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1081,"_uid":"4860edda-199e-47d8-b96e-3fa5e9a74c69","_cid":92,"_ctime":1775055887626,"_sid":51,"_stime":1775056028519,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:07:08.096Z","time":291,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bO6n&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"583"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bO6n"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"579:42266[\"handler.process\",{\"type\":\"dungeon\",\"action\":\"checkBattleResult\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"dungeonType\":2,\"dungeo