IFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":4471,"mimeType":"text/plain","text":"1607:43247[{\"ret\":0,\"compress\":true,\"serverTime\":1775055933363,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁКҗбғ г¬Јвұ аҙЁвЎ‘д°ЎбҳЈжі°вҲ зҢёжҖӨеқ«вёўе°ҰгЈӨдҒ©FаЁ§гҖҰгҹ аі Ы ТҖа§ З аӯўбҖұд—ҘЩ аӯҹгІөбӨІгҒұд“ЁЦҒдҢҖГҜеү…в‘ЎгҲңбіЁа° е—ҒжҸҘз— аҝҠдҰЎVеҗ»е„ҫвҲ°еғҫвҠ¬гҷ”жҘӘзҰҷзӢҠгғҺбӣҸШівҠўбҢҖЕ’ві…вҲҡеғ»б®©аӨЁдҖ¬еһҖЗӣе§ҳаЎўжҰ—бЁұбјЈ'б… Л»бұ ~бЎ©гҮҸбҪҖЖғеҢҖзӢ”еҮҲб‘ЈвҗІгҝһаІӯжҪҺдө—жҷұбўЁVвё¶зӯҘбЈ…СЎЭЎгҲҜШЎвҢңзёёв„ўбЈҪж‘’дҢҖДЁд  б№—зһ•д°Ҙг¶ҒЪҺзҚҠбғҖРҙдј„зЎҗ:д”®еҘ‘дәҷ+зӣЎз°ЎФ«дҢҖе‘Іг©·дҢ©г‘ӮвјЁв•ізўёдІҘЭ©УҰг…ӢдҢұг ІгҶҝдҢҒвӢ„з№°е…ӢдӘөвҒҰе„ӨдӮҺгөұеӣёг©ӯа° Юҗ(uб¬©Х§е…ҮПҙгңёг©іаіЎеһ»ж”ҡг©ҫв…№еҡ»бҪ—гӮ еўҖа°өеҳҙГўз—ҡЗӢеі®а®өжҳ§гіҷз®іж¬“е«јдҝ—жӮ вЁһдҒўЛ…Иёдў”бҙҮвҗұв’ҖвһЎвҒ°зёӘХҮз…”в…”гҹҒвЎҙеёӘвҫЎбҠ„вӨёдҹіаЈӨзҙӨдҷҒвЈӨзёіб‘өб’°а«Үа»ӯе“ҷбә“вӣ°зҗ д…өд–ҜгӮ°МҙЩІбҰ¬бҚӨб…»бЈҠвЁЁеҚұеҰҢз—ҪгҪёг’әжӣ”Лҝг•»бһӢеё«г«®аҫҮдёҲеІңејёа ҸВЁдүҜв ҝП…г»¬бҝіЭөдҮҺгӨёдҗ‘з©Ғбә¶бҺёгҠңСҘг«ҲбҲұС¬вңҗвү№б’јдҰ©г°ӨдҶ©дҷҠбҷҢвІ№гҺ…е”өгң„аөҚгҮ№а  ВұвғҪП“д«ҪдҗҘзӣӘдҙ в°Јдҡ“гЈӢбў‘жӘЁбЈғжЁҰдЈөб¬ҶдҸ—бҙ“еӣ·в»«еҮів№«д—ҙж»»дҸІзҲ д„‘з©јд°өб»®Х ејһб‘—в’№бһ–бӨүШЎдӨңЙ§вЈҠбјҰг№ҝеҪ‘дЎјШҰбў«бјҰбЎҸе№ЈаӨүа°ӯбң…д«ҮдҖјд»…д…Өвҗ vгҲӯ`е‘ӢеЎҠзҳ©в§¬жұ•вҜҠвҮ»вӘ®жү”д‘®а©ҡгҘұжӯЎгҘ‘Эөгӯҡеқ«г¬ңб„ҝгӯҡб№ҠаҰҫз ҝвҖ©вҜ№В°г„ӨдҶ МҜеӢЁгұҷдЁүдЎҺд“Ўе№Ҫж’ з«ӯЖҗжҰ бҢӘзӨөв“№зҘІгҸ№г»©ж“Іб”өж’®зЎ„Мҷб©ҷжЁҘвқ·б’Ҙеҷүд’‘дЈҸжӯҘжңӨвҸҘеғәгҚ…е“ҹвҲ”з’Ұвҗ”зң«бӣ’а«№жЈ¶еҚҲе’өбҲ¬е‘өг§һд—ҒгӯҡгҮөЦЎе••еҚҚе“әа»ҳг„Ҙж»…дҹҡг»Ӣж¬…вЈҖбЎҖеёҙг‘°зҮ…б—…гұ®вҢүд—Җж•‘б—Җе—ҚеӢӢдҺөаөҠеҹҒдұ‘жҳҪдҮҪжҖұгқ…еҡҪзҪ’жЈҺв»үд”•бҜӮбҹҪдҮ‘зҹ вӨҘзҷҖгҹ’гҳ”зҙөвҺқаЎүгң…зҝ…еҳЈа·ҳаұөдӣүаә–ж«Үе«өвұҠаҝів№¶аҪ•аәЎа»ұГӮз“ға·ӯжӨҺеҜҖзҘ‘ЯҶб‘ЁгІ‘б‘ӯаҝ–б…ЁеҠҹвҳӨгҝ„жҗЈжӢҲаІЈзҰҒдјҚб«ҹгӣ“зӨЁз“Јвө«дұ°бәңзқғдҷҗвәҘжҶға¶«вІҶб‘өвҰҖдІқеёҰв„үз§„еӨқв–ҳж …вӘҚвіібӮҚжҙҚеӯҮвұҷб• жІ“вҺ„з‘“ж©Ңзң…д»Ӯж¶’г’ҡжҝ‘гҜ–жІҫвҮҒПЁзЎұа©ҫгҮүбҹқв§ӣзЈЁв„Ўвҙ…ж–Үжұ–гҫ“гңёбҢӢвј§жҡ—в№Јз¶ҡаұ§дүҖеҡ»гӨҹдұҮжҷҲвІЁбҶҖгҹҮжІ‘гүӣзҙҗдҪҶМҙеҫізҢҺЩ·з—ҡжҖҲгӮҸгҡ§з«…жҖҒдӨқеҪ§гҪ—дұ“дҜ•аҪҪж”Қжҗ•дІҗгҝ»в„Әвҝ„зё§зҜ„а¬ёдІһв“өвғ·зүҘРҲбҗ¶бЁ—еұҝбӯёз‘ів¶’ЧҢд°№вҚҚвұҠжӢҙКӨв§Ҙб¶ вҫҜзүҸаўҗбөҘдҷёдҺҶж№ҚвүҘжҺјд“ҮајЁбҙ¬г©ғгҙөжҪ«гӣјв§Ғдҡӣд·Өзӣ¶аЁҳдқҡТӘбҚҹаҘҮд ёжҶ°зӨ®еҢҳдӢҖе§¶вҒ„бөғгҗЎдғ гҷўдўқЯ°еёЈв№қаҘңZХүдҸҖXе—“еҒ”С—гҢ‘ж„әзҷҡаёҸвҠёб·қеЎҖвҙіеҫӣзҗ·аЁҝвӘ–бёЁвғ®з Әе‘ІжӨёРӨвҒ„бқўжўҺбӢӨаӘўзӮқП°г„ЈД’аӯҖеҲҘвҲҗа¬ҖжҖ¬НҶг•Ҷб ЎаіҢд№§д©“ж… =в¬ӨбҖ§д„ӢдҰёгӮ«бҘ—вҢҜгҚ•з‘Ўаә¬дҶ„вҘҷб‘іг·әеҸӣд·җв§Ҳд’ жҺҷЫұе№үд№ғвҷўаҘ«дғ‘Й‘вҗІдҶҲбҠЎд¶”вҹ ТӯаұІвұҪд„Ҙз¶іФ в‘ҲвҠ…Я—зҫҸај–гјёдҒӨЩ°жҙҪгӮЁаҙ еҖІГ гҮҘФҗгӮ©б•Өе «жӮўзғ®бҚңе”Ҙбүўд–Ҹб§җгҶ”дЁ¶жёігҷҷбҜғзҲ№зҗӘвҪҳж—Ғг®ІТўзӨ…еҳЎеЁҺеҳөвҠ“жҚүг¶Җгұҳжүјж’»гүӯдқһгҚ©вҜӢжјқжІңг©Ҳг¶‘еҫ„в °аЈҲа°Өе°әзҺ°а®®в’¶б…ҖбҲҰвғӨаӯЁбҲ§Сёгё§зҖ¬вқЁдҢӯаҰҹжЈҢеҒ§жҺӨвҠўдҒёеҒӘKдҖ»дҰЎг¶ҚбҰ’б’ўаӯ‘бӢ°бҒҷе°ҰУҢж©«вҙ—д«–еІҘеҘӨбҠқгӮІвҙһг„ўдұ“зҒёб’ўдӢҒШ°Тўе„үаӘұеғ„вҲҗаҪЈжӨұвһЁбӮўаў•вӮ¬еҺёгүўбә’бҗ eз–јаЎҳб•¶в’ҳвҷ—гҫҒгҘ№д№–аҪӮдҶҙеәўзҺҘзҠ—д•Өз®өеЈҲвҷ©вңЈжӣ©еҷҪзҘ‘в“җвҸ°зү”е ‘еӘҳаўӮд•‘в«ӨЫҶд·Җг•ЎжҳІбғ¬бө·еҺ№вҸ’ж“„жҜЁгӢқзғ№дҫ¶д»®е №е§ӨбЎҲбқЎв“үвңҗг…”аЎҺВҒгӮ¬гӨұдҝ дҫёжӢӨд•Јз‘“д—©бҶҮг®Ҹв§ӘдҖ»зҮҶв«Ҡвҗ°д„ӘШў1бӮ§вӯЈв§ӘдҰҒеҷҰдөҸб«Ңа°Қгһ·аө–е’ҷзӣҖгІів„ЈТ»еҗ·ЯҚгӯәзҳһзҡіз—іж«”е—¶дҙ№аўөв‘ҪжһҰз¬—дҺҮд ҪзӨҺеҘ¬еӮ»еӯӣаө©бӘ–аҰЁдҢіХҙв¬…жө¶гЁӢвӣ·еҮӣг«ҡвҺ»е©„вҺңдҳ®еңӨвЈөд§Ўе”ҝаөҢеҲҒд‘’гӯЁг•—зҮҲз§…бҖ…еғ”вұҪгҢ…жҘӢеҫӣж•ЈвҒӣгҠ„еһ»з”Һзқ“ж»…аҙқеҝҪг–ҳбІҡд»—бҢҜа№ҠгҰ”еЈ®ж№…г¬ұЗқгЎ—г¶·бҰұдўҸвӯ°жІҙгғҙг‘әзҠ®зқ„зҹЎгҮөзҰӨгҰұжҹӮЫҒг№ўвӨ•гһ…б”–еҮҝгҒЈвҙ„бҸЎе…’аІҚдІёжЁ„еӨһз–—вҲӢжҶ бј¶дғ§е§Җг©Ұбҹ“зҰ–вӘӯeгЎ°ВҲгјҚе”қж¶үе¶ҡжҫ“жҝ—г¬ҙж¬¬аҫғбӣүеңјвҡҫбёҷвө”зҷів№§вұҹв ӢвҡҜз·ӮжҚјз’Ҫеі«б»Ҫеў°еҺҝеёӣз“ҮЩҳзј®Г»бҷ®дқӢгЁҗбӨ“аіғбӨ«еҚ»вҠҖжҹҡгғҠеһӮа»…еҰҝеһҮж«Ҫг‘ҡа®ЁЗјгҮҠбӣҙвҷҸе”•вҢёбјёз§Ӣж «КЈМ№гҗҮжҠ’зҗ•еә¬еҪөдҝҒеЎҪеҢҲжі•зҷҷв®Ҡгҗ§ЩҘб®“еҳүбӢҰдЈӣбіҺзЁҢгҖ•біҹбҒ“г”ӣб·Һвҡӣвҗ•з¬ӢаҫҒе—ҺдҳҒе®«дҚ„аұ„гҜ бӨҝД ејўжү”дүһгғүгҪҚНҚбһғаЎ§г¬ӮжӘЈзҘіб…өжӯјжІ вӯЎбҒ’С…дғңв•ӯж“җеҠҒзҠӯвҗЈжү·д§ҖеҘёа¶өбј”дҲ№еҮӮжҠҡг…¶в¬Ҡзҡ•С”аҝ…жҝіаҰ«д°“б’ҷжӯҘгҪҮв–“Ъҹг®ҚЫідҝЈзҺЎвҸ„г№‘жҢҮд°Ҳе¬§бҰһЭҺгЎҖзҲҗвјөжҸҜжҸ»бұҮдҮҹзө„зҒ§г©ҳбҒүзҫ¶Зӯбі•зҜҫбЁ’е”°вҡ”ж»Ҫгү·вө дҪӮжўҪгЁҢбҫ®ж„ҪаЎүг‘ҘвҢҰв·Ҡв”ҳе„ЎбҘ©ЫҘв‘ӢзӢёеҮҪбҲ©РҘз”ІаҰүгүҮЙӢа¬қвҗўзҶҳХҖб«ҹб°ңеӨӯб‘җеў„дһҘеҡһгүӯгҜ«жһҳв·ІзҘҝд®»вјӘжәӣа¬іеў…бӘңгӣ з·¶в„•з«ӯд·қаҜҘдҡ©Э®гҺҘгі®зӨҶвҝ№ж№ҫг§ұзңҚеўӣдҡһг№Һдӣ”б ҲзқҜгә“г’ҠЙҪдҚ«бјЈд‘ӣгҮҲг¶Әв«’бӯ•Е®еҹӢжӯҚжҜәдҜ»вёҷеҡ”еҹҰбӯ»бӯ—з қгқҫаә—з„»жҫҢЬЎгәӮбІңбЁҷеўівЁңеҜҺз¬ӣжЁ–е»–зӯһбҙӮеҫ‘жә¬гӮӘг¶°ж…ҪбҪ№гӮҫз°Ғгҫ„жҰҹз°“аёҜжӣҝеЁҒжҪҝвҗҢзҚ»зӮ—аҰҡб№ҪеҶҸз қбҫ—жҝһвһўеҘ»еҗҡж»ҢзҶҫб үвҷЈе—ЎвӨҡзҸ°дҷҠНһаӨ»еіЈв“Өж‘¬в°ҷдҜ¶діҗа№ҹбқёдӢҜз№ӢзӢҹгҖӨбҜҙЕ»з„Јв’ӣг“ҝдӣҺжҲһбҚ№еҮЈе»Қг“§вӮҠаЎ“з№Һз…ҹб“ҡеҒ–вёЎзҚҝа ӨдҸәеңҗНҚајҡе¶әд»ӯг…ҸвӨҘаіЎгҷҲеҳҸв«әзҝҰеә”аІ§аӨҡгҒүд…ғгғҗб¬ҘбҢ®ЕҪз“әг’ҘбҒ—аәҮзҳӢгҫүжі№вӣӮаҙғЬҷжҝ»аұ©дғҮаҜ“в”ёвҡҫжҚҷаҙӣгӢўвңҡаёӣЦәв—ҘЕўаіҜгҙ§жҜЈвҮ—з•ҮгҹӮеі·Е°аІЈвӢ ж‘Ңд„Ҝеӣ…в”Өж“№ЗөзҳҚЫәVбЁёаҝҗеҡЁз§»в„©гҶҗж“ёгјөвҖја№ҖеҶӨаҝЎгҡ…е ҖеҖҷЗ б…ҠаӨҮб¶Ҙдҹ¬б№івҺӨ\\\"з—јШ б“ӮдҲ В„дҗЎдҒ жҸһб· ж°®еўһИұе•ұжҫ§СҖ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":3581,"_status":"completed","_startTimestamp":1775055932565563,"_endTimestamp":1775055932571286},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1001,"_uid":"910213a4-bfcd-44fd-b124-7a5d2a1dcc47","_cid":92,"_ctime":1775055887626,"_sid":26,"_stime":1775055932285,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:05:32.178Z","time":332,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9b0i5&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"124"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9b0i5"},{"name":"sid","value":"ZIF