t-Length","value":"1005"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":1179,"mimeType":"text/plain","text":"465:4323[{\"ret\":0,\"compress\":true,\"serverTime\":1775055123940,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГ‘дҒ®ПёдҖәа ЁгҒ‘д°ЎбңҲПҗвҲ зҢёжҖЁбҢ¬вЁЈб·‘Kд§”ЙЁЕҗеҒӣ9еј гҢ б¬ бҶ вң Ь вҙёдҒҰаҪјгӨ вІЈа«өж•©д—ЎбқҖб–ҰЮ НҒеЈ•г„Ҙв ’еЈҖжҶҸ;вҲҝбғ¬е“јд…’Вёзү…зҙӮз•ЈвҶҙдқ§дҸҰбүҗд¬Җж•ңж¬ҳеҪҘб“Ӯдҗ аҜғдҖЈг§ҒбЎ©ж’Ёд” бөүе– аҝӢдӮҶгҒғбө ж•ӨгҖёMд§ҙа©ҝПҠбҲ“ж…¬гў…еү–бҚўСӘвҷ„вҰ°МҳзғІбөҖз¬ҺжҠҝвӮҲгјҜаӘ№Мҳб…ӣе·һв—ЎдүҸеіҪгү…е®әзңӯзҷ·жӢҶз—•вЁңж„ӯвҰҗдҮҷжҲ»жҝҜзӮҰжһҫз«ёдҗӣеҢ°з»Ҹа ҝдҖӨб„ңгҒқгҶідҮӢб‘ҮКІж…Ігұ„Сіе«»ИӯаҘҰб‘“ЩһЗ§гҶ»віЎзҹҰзҡ“гӢҘзқәб‘Үг…“зӣҮгҶ—вөҒгҠӣдЁӣвҝәгһҷбҰёзҹөдҘёдҶӘгҝ«дҝҘЗңдҲ°ж …д…ўжҠІаҙ·е§ҲдұҠвҰігҶЁе“ҷа¶ҙдҶ§вұҗз…§бүәжӢ¶вҘ©е’Ҡг«·жү…зҮҶдҝӨгҢәвҷҳвҫҰдҪ”д‘ҡжҚңжҰҮзӘҢдӣ“дҪ”зҰҺеҪ„ж°·дөӮдҝ’д·–вҳҶдіҲб®¶з°Әз§үвҪҙдөҠз§Қвў¬д…Ӯг©ҢзңҠеҸ е…Өвҳ“а»ҳзӘҳгҹ·бҸ§б§Җеҫ зҚҲдўҫжӯҚв®өзҸҶе¶”вҰ’дўіж§ҸгөӯдӘҹж§ҺМҪзҮҙб§ҸдҸқдёӨвҡ¬жҜ‘зҶҳгЎ¬жӯ©е„„НұеҚ„зҙ…аӯізҺ«еҶүеӯӨжёіУібҺәжҠјгҙұдҠ’жӘҮвҚҘе•ҳбһҝвҪ жё“жқҙжұқг®ҶзҙңвҶӨж«ҙзә§в°ҳг¶Ұб·’з—¶з–Ҙа·ӣеқ№в¶©бһҚдҒ®МҢв’ҜгӮЈвғҢбҗҪгӮҲз……жҸҢзҠјв’¬з–ўжўЈзӣңбҸҠб•јз“ғзҳ•еҚүг……аЁ№б—Је’Јзҳңб’қг•ӮдҒұаөҘвҒҪбңўаұҪеӢөе’Ңз—ңе«қаё¬б¬іа§ёвІҸаёҗеӮҮжҳІг«ҹг……дҫ®еүЈвүӘа¶ЈгёәаҙІбЎЈаө¬гҫ®аӨҚе§ҺгҳҪзЎҰг‘ғгұ®гҲқж’ҢзӢҢгҫ§а¶ўвүҚаҙҳбҡ…г ғдҚҖдәҢвүҰгҶўв©Өд«’аЎӘдҰІбҰјдҘіа©ҰгҷігІңзҗЈжӘҢаҘҪ~дҝҘвҳ¶зҮјбҢ°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1005,"_status":"completed","_startTimestamp":1775055123044952,"_endTimestamp":1775055123055265},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"54","comment":"","_id":179,"_uid":"c0f76398-9f16-41ca-98df-3c08b13047c4","_cid":54,"_ctime":1775055043431,"_sid":30,"_stime":1775055122725,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39938,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:52:02.408Z","time":275,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9Xw_Q&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Xw_Q"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055122408588,"_endTimestamp":1775055122414282},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:52:03 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3041"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3780,"mimeType":"text/plain","text":"1344:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—г№ңг‘ӘдЁҹгӢҙаөҠжҰ¬жҮ¶бӯҡбәҚвҪ—аәҡдҡҝві·зҗҰеҡ°зө—гҡҶбҮҮвқ’зҹ·дӢҰж…”ві—дЁ–жӢ•жө·дҒҸеү’НӣеҳЎжҸөзҳ·вң“в“’дҫ¶бӢ°зҜҡП®з—ёзӮңеҪ–жҜ–жіқг–Ҹб·җжӯ·гҚҡгӘ¬бҪ”біҸд—із•‘г№·жҲүжҡқд·№вјӣжҮ”г№ҶеҮҪг®®гҹІгўһе§ҜгЈҰгҝ°зҘ–дҒ„зӘ¶еҹҘв©ҫб·ўЫёг¬·б ҫв—¶Т®зЎғг®ҫв‘қзҰҶг§ӯЧҒд— е¬ҫеӣЎЪҺЙҢФұг·ЎжҶұдҹўд–®гҸЈеЁұб»»зҜёдҷҖФҒд©ҸЧ‘е©Үе«ҒЩ“ЮұгЎҸд’Ўб©Ҡзӯ¶е¬№бҮҫаҘЎзӨ‘е—ўвӣ‘а§әвҡһжі№бҢһХҹз®Ғж•…дҷҒж·ӘгЈ®е»ўжҺ‘гөҷзҘұзұҲж’һжүӮжҗҺжЎӢЬ®зөҳЫүеҒқвӣҒзӯӣвҳҠбЎҷжҷ№з№Қв“ҒеҚ…бҺ№гҪҲУһж©Ҷжҷҡе‘җзҠҘвҹјб•№ЕқвңұдҺЎж”үеҪһбңҒдҘҠб’‘б“ҹеӘ©вҷңвҗ№дЈҷЬ№вҝёд‘Ңдҷ‘а ҷжі”еӣ№жқЎгҮ…бҪғжӯөУҖбҹҷб·ўеһҠвӣҒз«•віҚж•©д»Ғеһ•еҜӘеқұб«Җг”…аөӢеӣҫзі‘жҷ©а§җж—өг©–жү•е§ғЯӯЗ‘г’өзҷҡгңӯе§Ғг өг»…в•Қе·„жһҶг—Һгҹ…бӣңг—•е«Ңзң–дҜҠЭҪЧҺзҷӯж—ҲвҷқвҜҷеӣқз»”зҳ©е·өг“ҡжҝ—еӣҪгҝҮгҗЈе‘‘еқҳбғҖе•үж·ҡж’қг·ҲаіЈа·…зҳөе№ҳеҷғе·ӢеӣғбӮҒе¬Ҫбҷүв•ӯеІҸеЈЈзҘҮз’ғбқӮбһғдўӢзҳғбўӣжҡЈзұҒаө…вғҠајЈе«№зҷізўҚз қаҪңеңӯбўҗзҡҚеәңа»іЖӮзңЈб…”вұ№гәӮа№«еҠҢж—ЈгҰңв·“гӢҠвіЈеЈ…в¶Ҙг–җб–өаәӣд№үе–„з‘ӢвҮҲа·ҳб»—вңӢеҺӮвҫ»дӣ’жәӯб¶“бӣ»з–ңЦқдһҹаІ…жҷ•ж “вғҠвәӣвҺҡжіӣвІҚжіҚЮӣе—ғбә„жә§з¶қжё»вҫүж’§еҫҢжІӢв»’жҙ§жҫҲе“Үг®Җж¶қвӨҳжі»еӨғе•®в»–еЎідҢҷбііг„—бңӯе«©дј§бҫҡе·§з„ҸеӘҮв”үе№…бңҶвҷ•вәҠж¶ҮдІҮбі·ж’—еі„д”ҢвҳҜжң„еҝ§зҙҮб§Ҙдјқеҳӯг”ҺеәұжһҒгҝҪВҢеІұа¬‘еҫҮвЁүгҝөвӮ–еЈҫзјғеёҸвјҡг»—жҗӣе‘—ИҡдұҝРҡбӣҜбҝҫгҫҝдҳҠг’№зҸҺгӯҡе ’гұҹбҠҢжҶҪбҳәж–ұгӨҜгһ•ж№ҖаІ–жҖҸгјҸж’¬бҒІП§дӘәе§ҳЦҹвҖӯеЎҷзҚҫг ҒеёўжјўгҜ®з¶°гҢӣв¬әШҖеЁ“зҪёа§ҰдҖ»б©„б…ңгҒӣРқе°ҡжӣҚзӘ°жҙҜгҙ§е—Ўдҗ¶бӣҺжҠўдәӯП»дҡӨаўғзӘқб’ғбЎҶаёҡвёёв„°б№¬жҚҘдё…еқӣе·җдҷ“гҗЁаўҜзҲҒбўҮж…ЁбӯғдҸҫНұдҘҰг’—Я зӘ¬бҚҗаўұзҖ…Е§вҳӯжүҗвҢ–діўв·Ҳд–ҚбәЁдўЈаёЎз’„гҲӣжӢғдү’ж°«дӮёвІ‘гҘёеҺ©а¬·аЁ‘жҢ·з…ңбҰҢгӢ°бҠ„вҪәбІҲв–‘гҰ¬д“«аҘұз өзҶЈд¬ғзҝ©аҙҮб©§еҹӢЪҸДӨг ҜЮҖа¬ fдҺ Г”б¬ұгҖ°ЙІбёҪзҒҢУ„бҳ¬бЎҢаҘӯе ЁГүај вҖ°аЎІбҖ®ЗҢбӯәгӣҠвһ°еөҗг°ёв”җеҘ…В…б»ЎвӯӘеүҢВЎе°©вҳјв…®з“ҷдўҗдҠ»гҒ°а¶ҖеҖұе‘–гғҘЙ»д— зҹ в°ұа§җдҠұзӮҘб“ІзҳәжғҠвё г°ЈдҮҙжҮ вұідӯ°а «гӮҘб” жҳҪдҖјГҮдҠ…б°”еҙ«вңҜЕҷв ЁгЎҺа» в•ҒжҮҢаёЎжҖөвқҳгҜЈдіҳЭЎгӘ°ШҢаҰҒдё дҒңЖӮд°ҝв”Ңе©ЁеғҪаӘ©бӮҫгЈҳеӮІзӯҒз„©гҹ§еұЁН„зҢ®вӨӮвӨ ВҪа»ҖбҜ’аҪўвғһгӢҷгүҝе§ҮгӢ‘ГҠзӣҘдҶҪз»„е°іж“ҶжҗҷгҶ¶зҰҢвҢӘдҪҢв®ҳдңөЖ№б•ҢеҜңж‘—зҗ„вә’гҰҡбӘҗеҘӢжіҸзҸ‘бҫҪд§©вұҢдҪҒжҒ–в“„аЎӣИҙзҺўе“—@гҢ§в§®аәӘж•ҷгӢәвҸЎвҖӨГӮд§Ңж“Ңа§өвҮҚб–Әе‘ӨзҷҚвЁҘвҡ·е‘ҝе’ӘжӢ”еҢһаў‘зұ»в•ҫеҲҠж§®в°җгұ—дҘӘеҹІзқүд¬–гңҳзҳ®з ӨГҗжЁҙеҗҠвҮЎд¶ғе•Ңг—ӢбЎҰдЎҖг–»аЈҰең жҳ°еҸ¶в·ҙб–”г•ҠзҺ§гІұа»җдӯІвӨібүӮе•һеӢҰгЁ№д¶‘в‘ ЧүеӘўСүИӯЧ•еӢЈжіүв©¶бҷҖвҒҠв§¬ж—‘Л§вҰҳбҠёвҰҘбҢҖдӣҗеӢјаёўв¶§в•ҳаҙӢајҠвӘ…е©ҫжҖ»бҚ“а»ҢеҢ®аё бһ•в’ўж¬Ңбұ“в»җзҳӯГүвҰӢгҳ©а®Ңбҫ—жҚӯб—ңзҶҺг©ЈдҮқдӣҠгҰҲеҡҖг§…еӯ®гӨҮг”јНҢг·«д‘°жҝ‘гұёд§ҝа¬§е«Ӯг©ҙИ–а©ўжҮӨгҸЈе”ҖбІүвјЁг–§а¶Җеө„еҚ®б§ жұ“ж… бҗЎвіӨжәҶгҷәд№Әе”ҒХҒжҮўбёөе°®з•ҙж¶ бҖ»дө•вҮІвҘ°СӣвӣҒгғҖЗЎжҪҘд… а ҸдҶӯвјҳеәұа§”гқӮвЁәе®¶в§¶гқ©вҹҳЮӢд‘Ёб№ҪзӘ»гҒ…бң аё¬жҶ’гӮ¬в° з’ӮдІҝгӘҙбҙҡз ·в—ҢеҡҶз’—гҲӮб”ҷдҚӨдёҫжҖ©гҪ¬аҜҚзҚҷзҙҗб¬әе““з©Ҳг…ҖбіҰд•ҷжң•в–Ҡа°«вүёг·үв°ҠгҮҝж©Ӯз§ҘбҺҢд¶Ҳе’ёжғҺвЎ«жёұбғүв–ҮзӢңг®ҢзқҠеӢ—д№ҷзЎҪзӢҙеӣғвіҗгөҘг®ҒеҠһбҡҢж№®зҢҠжҘҰдһҪв„ҹбӘ«Щұб–ҪвһӣвҶҲбӯәжөҷжҫ“вҪҶзҹҚжҳ—ЯӢбіқбӘ—е¬§б¶…бҜҡз’•еҙ–віөдЈҫгўңе¬«з•ұаҜ„г‘—гҺ–гӨҸгӢҸвҙӣдјӯз«№е«өеұ«з“ҷгңӣгҡ¶вҖёзҒҡз©ҸОҠгңЁзүӨЪ«е¬ӢеӯҲгў‘аІ—е…қбҷңбҹҺеӢ«жәҪд·Ұг¶ЁжІӣгҮ—г¬іг“Ӣаҫ“бңғвЎҺб—ғжұҚзЈҝз–ұе¬җбҝһв–Ҝг§—в–—жҡӘжҙөжҮӯбҗұз°Һд·’еј§ТҰдңұг¶Ғжҫҡеҳ®з”Ҹеёҫб·ібһҫв—өв §жўҡг®ҡгҷҜж„Ҹб°үзәҰаё«ж…“зқёгўҹеҰӢдӮ”вүҢзҲ®гәҢаҫ№жҘҒе§°бөҳгғҷзҗҒб¬·еіҗзӮөв–ҜдӨңбҖҢеүјдӣҘдҺҪеқһдҗ•еҰҗд–һеҹ—г«Ҹз—Үд№ҢбҺҪз¬Һеұ№дј©б—°гұӢб°»б°Ёаіұд„ө`!ж’ЁДЈж ЎН”а ҰвҠ–К—Ф«гқңдҢЎајһВ°НЎг ҫИҗвөӮ  \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3041,"_status":"completed","_startTimestamp":1775055122677334,"_endTimestamp":1775055122683095},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"54","comment":"","_id":178,"_uid":"eb5468f7-c00d-4dfc-96c3-e7f33b044593","_cid":54,"_ctime":1775055043431,"_sid":29,"_stime":1775055122408,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39938,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:52:02.082Z","