ri/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9cc-U"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056351153601,"_endTimestamp":1775056351161005},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi1AAme"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:12:32 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2990"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":3699,"mimeType":"text/plain","text":"1325:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘ұе№ңд“‘а§»гЈҒж’¶зЎӘзҜҘд•‘зЎ—Х©Йӣеӯ„бҝҫвҳһдұңв”Ўг…•д–Ўж§»бҰ‘е…ҮдӣЎг№ҳЫүвөўжҲҺеҝ зӨүзҚӮв‘Ғвӯҡд“Ғбӯ“вҳҠзӯ‘з©ҷгө’вҡЎж·јУ№бЈ®ж’ҒжҪүв ‘д©җжһЎдҺ»д‘ҷзғ’ж ҷаҜҘШјеӯӢв–ҷдҷҗЭ‘жқ‘бқҒжқҘб’ҷзҜ¬жҹҘзө…жҹ‘зҒҒгҸұд•“бқүЕҹЦҠЦөбҡҷаҪӘеһҒУҗвҷҫЫҶз©өСҳеҳҷзӣ…Ъ•жөұеҳөгЈҡе‘ҘгҸ®еӣҷжқ°гқҡЛӣв–ҘгҮҚеҷӯзҷӣбЈӯбі»еңҒе»ӣбҹ•зӢҲг—®а·Ңдңҷж·ҷгқ®ж»°г—ӯз»Ҙе‘№бӢҮб•ӯе¬°гңҘг“ҷе”•д—Ҷз”ҚвҚҖгң–е…Ҡз•ҷб•–з’•бқ«з’ҘжҒӢгҳқзҹ•гҳЈдҹүеҡұвұҡзҳ•бҸҢзҳЈг‘ҳаұ‘дҸӢб–Јж—“зқҳб»ўзққд·•з–№еӢӢаҙғжҮһг’…еӣҚз‘ғаўӣаҪ¶жІ—аІЈеҹһа·‘еҸҡдҙ–вў„г‘ҚаӘүдөҘд’ӣајұб’Ҳеҷ“жҸҷдј“е¬Өвҗ«еҮӢдј«дҚ•дІ№аҰ“д·ЈжҰҖбҡ«бЈ”жҷ«д–ғаІ«е·қд¶іг’ҶеҷҘжҘҡг“„еҠқбҳӢзҮҖжҳ»зҜҳж¶•еөҙа»өбҶӮа·ҳвҮһд»ғеў—зҹ»бҰ“з•ӣжЈ¶б‘ӢзһҖж·үдһҲгқғвҹҶајүз’ғжҪӢж¶Ҳаә§еһңвҖӢа§Ғж¶ӣдЎҚвёӣвҸ“вҙ“аў„бҪЈгӨҮж‘§Дһе”–гҘҮбё«вҰғбҪӢвҙҶбІ·з–ҹж№ҮдҫҲжҪ¶б¶”ж·ӣз”’бө…ЬҡжјӣзҠғв·—еіҠж№—в¬ғдҫ—е¬Ӯж·үе·ҡе®ҮвҲҢжөҚв”ғжҖ“еӨ”еҙ—М’е°—аЎҳеөҜбңҹб··д®Ғеқ¶жҜӨжәҘжҲ•еҪҸб—“зҳҸжһӢеҪҜдӘӢв№ғзҗ…ж№ҸбҲ”еҡҪбҡ–гӯҡд°“гұҮеҲ—гҚҡб”һвҙҝвёӢзөӢа ӣг·ӣзҜ§г§’гҪҮвҳЎдҲӢеҳҝжёЈзҪҘзі¬а ҡвһ¬Ц дҙ”жқ·зқҫбҗ·дәҝж‘ӯаЎҶжҙҹд¬ӣг§Ғе©Җе»өДҢа®ЎзӮҒд„·жӘҪзҝ§РҖвҗүзӮ”Э—вЁ®еҫҡз…ҒвңҲгәӨб“ҢжҸІРҸдӣӣаҝ–зҜ—бҰҰжҚ¬аәҒзҲ¶д„өж¬ңз“¬дҢҚд”ҷгҪҗдңҹМ—зӮ аўЎвЈ еҮЁбҷғгүҗвҚҹбҲӨгЎёг®Ёж¬®бӮ°а§ҒвёҫвәЎж¬ңд»ҜдӢід•§жЎәд•ӣбәӯжқҚа°ЎеҗҲд…®жҮғбұ–Й„гіҰеұөзғЁеғ“бЈјеҚҗвһҺбҷӘб¶Ӯз‘’дҠңв№әдҠҚС°дү—дӨ—аўҶгҢӢжәөд ӮдҘ„зұ Вўб°§дҸҗЦ CвҮ zбҒЁе ЁIај®з ¶rа¬»а°¶ГҶж°ӨВҙдһ бҖЁЧ©а §Г¶а«ҢС“жҢ¬гіҘе°¬бҠҳбЈ’дҒӮдҫҖзҜҶвӨ¶`жё еҢ®бқҮе©ҙж‘ҳв№ӯеЎҲЫҗв  ж©Ӣб„Ӯаҝ вҺјвҡҗбҷҗд“ёв№ЁзЎјдҜүвүҶвҰҗИҖаёӘеҢ®ЖӮа№әдҒ в¶Ҙж“ҲНҗзҳ зҒҷбҲіе—¬бҺӮвҘҳг°Ўж• вҮЎгў–IЬӯгӮҗЬ ж•ҷжҮҫаӘ…жҒҚдӢёб•®зҙ–Уҗжң вҖҫГ‘вҳ«еүёвў§еҜҠв•ҸгҡӯгҘӢаҰ©вјјдҢӢбіғж…Ҡдұ ЕҶбІҹдқ„жЁ—дҪ—дҜҘбәјдӢҸбҮңжЈӣдҺ°д©„жҰүдҷІзІ¬жӢ§з—‘е§ЁвҳҸбҫӘеҚ¬д©–вӣӨвҠ•бҷ’дҶҜвӢјеӮ…в°ҙзҮҠбӯҷвіңв®…гәӨеҝҺбҹ’з©«зҚ»дўҗб–°вӨӨа»ЎгҘҷжғӘв· а №д…ҙзҺҰвӢӮдҫ№вҡұзҒ°Д аЈҸв«ҷгҺҶзҒЈе’ӘдҘҚв¬ҺдІөеқҮж—”еҲӢвҹЁвӘ©вҗҶг¶ёе“Әд•ӢдӨҸдҡөдҙІа·ёеӘңа«ҳб«Ів©”еҝӣПңД вұ•СүжӘ°зҖҰе¶Ҡд¬ҙж«¬бӣ„а ІжӣӨв»ӢдҒ“Ч©ж–јз—Өе’Ҫдё©зҺӨг«ЈаөЎв’¬зӮ«б”ҠдЁ№ЫҠзҖҘбҫІбҖЁж«ӯвӮўзүЎЖўзҰҲЫ©аҘёеўЎIв•’д»ҝзҸҚвҳғе®Һв“ҳа»Қж“һдӘ–бҡҙзғғеҒҡЛҠдҜёЦ„вҡ•е”ҙжҮЈдҒ©жҪүзҫ»б¶§ВӢеҳҪдҮҖХӢа¶ҚдҮўж¶Јв»ҡвӘәгЎіе§–аўҗдҹҒе”®вӨөд°әгӣ¶жҮҜжҙҚвҺ ж–ҘгҰ‘а Ӣзіһз«Әе°ҒдҘҜж©ҡзҝұSж·©Ц§аЈҜХібҝ–еӢңбӯ¶а№•дҮ”д…ӯбІҮЗҗжһҘpГ’гҮ’з‘ҫд№•гҷёгҳ„дҺ§СҲвЎүгң¬е¶…б®ҖРјзҗ•вҹ”а©ҙД–з»ҲвұҲВҗбҸұгҒ°Юҡг»…зөҡг©…е•ҙг’ вҰҸдІ»в°үКҫзӮӯеңұзҝқеҜҠгЁөжҖЈдҶёвҷЁжҶ«МҚб‘јбҗҺеіӘдүЎдҗӮбҫ®з“®зҸӨИ—жЈ…вў©бҚ–з•¬еҖІзӘҚвҸЈвҸ§вҙ…бӣҹвІҙбҰ»бҙ б“Ҡб„®г…ҠдҡҶгЁ’е—¬гҰ—жғ…бҹүа§’бў°б“ҢПҫеҗҮЖ—жү¬вқӯеҙҸд¶«гҫҪЫҗеҝҗв“ҹа·ұг‘ҶжіҺбҳўж•Ңв«Ңв№ҷжўҸдўӯбҚ«жңІGеЁҶжҡ’бӯўжіҺе°©в·ӘдЁҺШҢе№«б«‘аӯҒгҪ·з·ҹбҹңз№ҺМ“дҸ№ж•ҪбҲ–е©ғвҪһгҚ„еҠӣбҰ‘в«Ҡз·ҚзҢҠб–•д№»б—ҮгҸӢб№јг өг№ӘОҷвӯҖгҘӮб«Ўвә©жҮЈд‘ҘеіҒе·•гҸ“гі·г®Ӣгһ®зөҚдӢ·ж ҚжЈҝб”Ӣе©®е·—жҜӢг–«е–—гҡҰзҝҸбјқвІҳгЈҪдҡҜе©»в‘·г®ҫжә§гҹ“еҷҰзјҢбҲ б№ЁзЁәб·°г°§зһЎЭңбһҮжӯӨаҪҶзЁ®аёӘдҝЈзҲівҗҲгҘ§П’з ёз¬„жӨ•еҡәжҢҚд¬Җб ғжЁ“вҸ§еёөа«ёЭ®а№Ҝгәӣд үзҒҢбұ”жҫүзӣ№г¶»бҠҮгғ‘гҒӢгөҜПңжҺһг¬ҪеӣЎжІүеқӣб–«ЙҮзҡ‘ДЁбҰҖдҙғзҗ°б§ғЙҠВ #дӨ°И§еҖўЪҲбҖ¬д”ҢЗҺаЁ№вәҷШЈеҳңЕҖЪўзҒңРҖе©Ө  \"},null]"},"redirectURL":"","headersSize":253,"bodySize":2990,"_status":"completed","_startTimestamp":1775056351758837,"_endTimestamp":1775056351786296},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1565,"_uid":"f1da9899-6283-42de-b5a8-ffbf5f8b090e","_cid":148,"_ctime":1775056284934,"_sid":43,"_stime":1775056351153,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:12:30.834Z","time":281,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9ccvV&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9ccvV"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"headersSi