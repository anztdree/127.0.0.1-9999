36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Yhi8"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055321876968,"_endTimestamp":1775055321882342},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:55:23 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2712"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":3320,"mimeType":"text/plain","text":"1234:4374[{\"ret\":0,\"compress\":true,\"serverTime\":1775055323791,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖӨбҖ©жә¬Гӯзў б— гҺ¬а¬ дӨ бҢӘДҢа№ҲЖёГёВ¬ЕҳXЖүгҲўбЎҘбӢҲЖҖзғ»е«‘вҳІгіөГҢбЎӮ8бһҶзӣӯвҮ’д·ібҒҝаҰ’дҗәДҲгҹҳДҡе‘җбјўбҗ У§гҶЎе«Ёд”өв©ІзӨЁе»”дғёж„Іг•°жЎӢз–”вүҗаЈ„зЎЁбҙ¬вўҘа«•дҹҰбүұд§үз“Ҙвҷ¬бӯ—бҮҜдұҺбҗұдӮҖГ–в  а¶ІЯҖЭ„дҳӢдүӮAзҫ ЫівҖӨд§°/еҗҘдҺәЕҒзҫ зЁӢвҒүз“°аҪ«зҗҘа©ӢгҘ©жҺібҖ аўІбҙ г„ EвғҖзҰҡгұЈбәұв—ёбўӘа«ғжҠҰзҸҖеғЁбҗ зЁ°д¬ЈдҒЎзј№дҰҲО’жҙ а«…гҝ Г‘зҶЁб„№аҘҘбӮҖ[е©ЎгҢҳеҒІбҠ РҗеЈ„аў ШҖгўәжӨҰдҶ„вўҢдҢӯдҜ…жЎӮжёЁдәЈз„ҰвҗӨСӮбҠҖ'д„«бҖ°зұёгўҰдҗ д«¶И¬ЖҖзЎҗДӨбҖЈСҖбҗ жҘҗд–…гҗ ЛҚГҠгҳ»бұ Мҳа јгўЎж…Јд”’бӘЈвҡід‘ҚвәўжӢ”гү–ЙҰжҶЈвёҡа°ҫв•җвіӘаҘ¬еғҒаөҶе§Ӯж«”ж¶–зўЎжӘ”еөҗбҜғж©Ўг·јаҪҝе’ҳжӮғУўдҖ вЁҶж– аҘЁКүвҙ гҖҪвҖ¬гҡёНҚзҙ з …г»°зғҖД’бҳІа®©д…Һ$еҒ¬вүҪг‘һkжҜЁбһҸе ҚзӮЎВҰР¶Щўг„ҳг„јдӣӮжЈҪЫӯдңӮУӮгўұеҺ©Щӯбҷ§вҷҳгҘҪвҰІж—’біҺгһҝЙҲЛҒг‘ҫбҹЎбҢүвө¶Jд«©дҚҘгәӢгҖӨа©ғгҒӨЪ°Ф§г’‘аЁҙаӨҰе…•гҲӘвҹ©аЁёгҠҲбЁўв„ҖвҲҘд‘җеҲІГұзҲҘдқүвҒҸе‘ЎбҫәвҲңзҫҰвҗўз©ңв”ўб…ҳаұЁеҒ¬аёқзӮӮаҫ¬зҙ»б”ёб—”ж“ӯвӯҖШҠбЁ дҺ…вҖЁlvбЈ П©зқҚв§Ӯ!дӘ—бҹғбҖ ГҢвҰ бё°д ©б»ҜзүҖЗЈЙҗеҒ°О‘ж” ЩҰвҶ®дҠҗд„ІвӢҳеҠҗд“ІбқҘдјҳеӮұбӢ’бҘҘжӘәаӘІв№–б©Өв әНҰж»ҢдўғжёҘДҗжЎ–бӨ–аӘӮеіҖе№’еӮҰеәӘеҘ¶гёҜдӯ°вҖ¶Э°еӨҸе©ўвҒӮбӯ®е“№ФӨгӘҡбүҰдЈҠбҘ§дЈ‘е…ҲвЎ–аЁҜд”үг…ҰдЎһеіҒВҒвүҺдә‘б©Қд—ҡб№Ңв—©вӢҘвҳ’бөҢвҮҙе№Ғж—ҪКӘвҷүдӨӮді«ЦҮа »бҖҰз·ӘВҳвҶҫжҒҖЬ·аӨ жҮүжӢҷжӘ»ж„ҳеҒӢгҢЎбң Э·б°ЈЙ«зӣІг ҙдӮҖеҖ еӢҡВ–бҶӘд¬Ҫж©ӘбқӨеҡӨв—ізҺ©бғҗеәҘд—ұб“‘еқ’бЁӨв–ұаЁӯд·ҪбІЈдЎЎдЁҘдҶ“вҹӣдӘөбәңеҲ’зҹҹдӘқзҖідҪ“жҝ…дў©жҲҘдһұг©ҷдҸҗзҳҫдүЎа№‘дҷұа©ҷдҳңг…ңд„°бЁӘЦұвӣҢд—Әб‘ҳбІ§е„ҢбЁӘе–Һд‘§гү’бө§в©ҡб§‘бӨ–б·§дӣҷаұӯдҚ’гӣӮвҒҢж‘№вӯҖТҡШ бҮ”жҖ®в“ҙKзЈ аҘӨе”ӮдңігҶҖв¶ ЬұеҷӨеҢҖГІбҫ Н»бҠҙаіҸбҡ вҗӘж”ҒжҜ•е’©жў–б‘Ҫб”•жІ·еҸ©е»Ҝең„в”ҝе–ҳжҪҝб°®ИҚвҚ«еј«ЭІб‘ӢеЈҒв§«бҠӯжҠәдј–дұ«ЖҖвҮҠвң°дҗәе№Җа§Өа¬ҚбҗҜгҳҢгҗҝгҷөз·ӢПғдјҖзЁҢд‘җз—ҷб«¶г•§ЫҺгҮ¶1вІҖГ…дҳ дЈҷвҖЎб‘·а¬ҙ$вӨҗвҗ гӮўд®Ёвҗ”вҰқжҠӢвҘӣвҙ®дҖЁе’Ҳ-дӘ…зҖўзҺәе”‘жҮҮеҶӣеҚҳз…ӘКҸеҘ“гӮӣб‘«гҡҳгі»дҖ”бҒҪаӨҸбһҪвіғејӨбғҖа©җе«Ғг“ӣеҹҖг‘„Ш№б‘Ҳд«ҒбҒӯТүвІ‘Ъ°вү©дІҘзӢҚзҰ¬жҒҪзҝқГғзҠқбЁ»аәһвҝЁгҢҠжҝҳЫ®д©ҺжӣЈві‘8ЭҒеў аёҶзҗ г…”жҖӨдҺёгЈҖжў“%аҜҳвӨҘд¶Һбқ б‘Әе„Ҳа№ Р§з…„еҝҗгҜҡжЈ¬гӣіжӯҒзҒҡв§ӯбҒҮвҝ…д’©еҮӨбӢӘжҗЈж®үгҢҒеү©зҹ’зҺҲгІӘЧўзҸјеҒҳа»ҳСӮз«ҫЧ’зҘ§жҸңбөҜгұҖа¬Ёд ҪжӮ°г®ұд”әб…Җа¬Ҙз„һаҰ зҹЎаЎҳжһ”бҳҪбӮӮд„ҡзҗівӮЁгҶҘгёҙдқ”б ҒжӮ№ЗЎзҲ¬жүҢбүҳдҒҡдҡҲСўжўӯЧҶб©ӨМҡбўӮб„ёжҺҙб“§дІ…д‘ҳдӯ–Г¶еғҖзӣҠеў Х—бғёдҖ©зҠ”В—еіҢжғҢв–”вӮғдҶ„еҫЈжӮҲбҰҗбҚ»вҒҖа·ҡаўҖзҸҚвҖўзҗҠHPЗ„зҠ аҫӣа°ҫз·үеҠ–аөўа®ўжҮӨбӘ“вғ•в“ғгҠҰдў…ЗһгҳҪбёЁаөҖгұҡжөҸаҜ©ж¶ӘеӢҸг°ўХ°гҒҖз©©дӣӯб»ғжЁўжӮ°Э бӨҪеү…бҲЎжӘғЖҰб„ўдҒ«д‘°з©һзөӘаҪҲдҷЁдҶ¬дЁ діүдҜ°Ь°д«ӘаҪ“еҝҪжө‘д–Үдҗәж’ёгҫ©г”®гҳ©б–Ё(вҚ а •вһ•вҖӨб•үжүЁЛ«гғғxв“ҳб¬ғВңШЎбҘ•г’•д’ӨзӣҲзҗӢг„’дә‘Щ–И¬ж“–в•қз®ЎЗӨбҸҮдјӯеӨ”еҢҗг¬ұа ӘжӮғе’ҸдҒ вҒӘж–”ШЎаіӮвӯЁа®Ўж…№jзӨҜбҒ·бўұзҲ¬б‘үг·Іж‘•еҺҡг° гҪўгҷјдҢӘв—ҝжЈіб“ҹбҮүг•ўжҰқб‘ёеҚҺгӘҷЦ…еү»гҰҢж іеҢЈе—ЎбұҶ!жғ°ЕЎд©‘бЁ’вҢҪаҘҺб®ӘСӣдғҗв— в“һЙ©б’°*еҗЎеҡҳбҜёе«»бҚЎб°ұдЎ№вҹӮНғдҠ°eжҹҢдҳҗа«ҲвҖ°вҘјеәҳг…ҝжӨЁдҹҸз’·жҡ°зҹӘж–ІеҢ г„»з·„ЦөзҗӯдӮҗб•–вҗ«аө°б„ЎгҮ©аЈҖвҲ°ж‘ҒдӨӘгҷҘЖҰжІ дҡҘдәӯдҘ»аё‘еұҠд”јжҒігҡ¶гҲҰгқҲбҡүд«јзҺҠе©Ӯеў Яүзҗ зјӢгҰ”зҙ•вҡҠз«§б’„П°дғ„аӘЁгҗ°зҜҹгӘҙдҮ“вүЈЩҡзҲҠг«ӨдҫҒб’№вҮҺд§ҖбҘ–д©’гұүж№ігһ•вҸҘз•Үд–ҚжЈӣеҗқг»ёеһ®б”Јг”ӮаІ°Ц–зўЎжғәвӮғзҮөД”бӣұзҷҪбӣ¶ж–ЎвӮӢЙ’МўзҒ®вҺӮбҹ‘вғҸгҪғгҲ©жҳҢзө…г®Ғвј°жҹәзҡҸеңәд№ҘгҲўа Ҙж№ҫгў•в»§гҶ•вұЎжҮҮб’—Д‘дҢ«ИӢКӢе№Үжүјг“—вҖ®ШҘдӯ°вҮҖе‘ҷзҘҳеӢ§гЁөбіҢбһҜвӯҜг«ғжј•вҝ…ж§ҹвҡЎгөҸж–Ҝв§әз‘ӣзҺғг ІгҰ…Тқж©®гӮҡбјҪдҳ«вҸ¬бЁёжҘ‘зҰҗз‘”б »а°ғдӯғгӮўгұӢдҠҸвҮқеұӯбҚҙдІҹвІәеөҪЯҚбҖҙгўӘе“Ӣ2ЭҲВ°У #д§‘а«Ңзі©гҶҢ&еҸҺжҘ©гўҶе»ҚПҶж®•дҳігӨ®Тҗај дҖјаіҖжҪңд‘қај©ж °бғ…бҘ»а ҜЙҙдҘҮгҙјдӢҡеҷҝдүҷЖ…еҷӯг¬ұг¶ӨаҪ“д®ҺдҝҺз¶қжҫғвұ№з•Ға©ғЕјжҳ•аҪұз”°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2712,"_status":"completed","_startTimestamp":1775055322893995,"_endTimestamp":1775055322900225},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"54","comment":"","_id":330,"_uid":"b67bf0ce-0958-4e8f-b1c4-7868c591035b","_cid":54,"_ctime":1775055043431,"_sid":98,"_stime":1775055321876,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39938,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:55:21.555Z","time":284,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9Yhd8&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9Yhd8"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055321555520,"_endTimestamp":1775055321560730},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 14:55:22 GMT"},{"name":"Content-Type","value":"text/plain; charset=U