ўеўҖдӨ№дӣҒг”®дЎөж…“еұ бҲ№дЈ„ЛұеҪҶжЎ–дў”гҢ№дҪ„бў°в‘ӢбҡӮжҙҙзӘ–дүЈжё„г”ЁжҖҘжЁ°гҗҙбҳ жҗ…бҠ°а®ҺжҶҗQгӨӘбҸӣзұҖ?вғ§бҒҗдҠё&вЈ«зІҷгӮ«е ӢЪҜЭҖдҠ бҰҳбҗӯеқҪе  СјдҮҒвҖјб„ўТёе…¶гҡўжҰ•дҠұг‘ҫХ…Н…бҮһдҺ·жҒ¶ЧҶдҖЈв·Ёаё§НЈе© зҫ–д–ға¬Ҫб¶„а¬Ўд‘ҚзҲҪж–№жҷҚв№ҲгҢөаө“в—–д©Ҳжҹ•ЛҜдј№ж©«бўҪг©ҲеҷӮвЈ•гҚҫж«ёгҖўвЈҝбғ’жіҡгһёгӘҪзӣјгҶӢвҒ°еіҳгӮ«в”ҶзҰәз»ҹдІӢеҙ”з©»дё·бЈ”дЈ…в—„б¬Ҹдүңж¬—д—әд–ҒаҰңб¬„дәҳв…„дҜ¬вЈӮеўӢжөғзјӨЪ•зЁӮз–Үв‘ҷдҙғбЎӮбҪҰЗҖгӯЈб°ёдӣҗдҠҷеӯұдәҶШ“дҷ•е©ўз»ІаӨҜгәӨСўз№ӮМ©еңҮаё©дәӘај¬б„’а°—д ёгҖ¬дўӣбҲ¬вЎҖв°«еҮҖвіўж№ід·•бӣҚеӯізёЁбҢ¬жӣ»д¶©д“‘б —жә‘еҖ®жўҚЖҜеҮ”вҗ©аЎ»дҙ”бҮ…дӯҙзҮўвһ«в Ҝе№©д“ҜдЎҜз№»еҗ—вЁҒд ’в§әгӮҘжүҝеңұбҶ№е”«жҰҠбҙӘжӨЁаіЎзҶӣа°“жұЁг»ЈбіҮд№©жёЁбҹӨвҘјвҰ•а«үб–җжё»е”“вҰҫвҝӨжҰҰг®ӯб»ҡвұҚз ҰгҹЁг§җгҷҢвҮ–гӨ¬бғһбӢӯд•–гүӢв•ҖаҙӮг§Өг•ҲгҰ„вҪӯз ҙвЈҸеәңгё«еІІбҒ©ж•ңвҷўз№’біӘаІҡвӮҮб§Ҫа°–з‘Ёг¬—г»Јбҝ’вң„аҙӨд°јвҖ§г¬ёв · аҘӮЗўжәҺбҶӢдӣӮаҘ•еҖ№еқ”дҚҫж®өвӘ·вјҠг¶Ҹв°ҠдӯҡжӨёжёӯеҳёвҢҪвҢӢвҚҰГ”з•ЎеӘёвқ°Щ№в¬Ҷж‘»зӨҗжқ»д¬ҪвҘәгӣ•Чҡг®ҮеёҖжјҠеҮёНҺжҳ”зӯ“еҝҙвөЎжұҡаЈ‘ж„”дҒ¶б°®жқҙе¶ӣзі еҗөеқҚжӘ„з«ЈжІҡдҪҮбҸҙжҪӣжЎўдӢ—е„¶зіІвҸӨжӢ—еј·б“ бӣғдӮ©б„Ҙвғ©МҘгјҙеҪҙеғ”бәҮгғқб®Өв«ўeдӢўе—®дӨ’бҘҘвІ…дҚҘб§үб“ӨеЈібҮӨбӢҚж•ҙжқ•ЭҙбӢұб№…жҳҶгҚҮаІҜбң–бЁ“б«ҶдІӘгі„з“ібқӯаі¬ж’¶а·®гіҸаі¬еўҸгӢҝбҫҶдҪөг§ҲгҳҒб¬Ҷб’—б”„зҙҒбҡ¬еқ¬г°·еӢ’гІ®зұ“г¶ҚжӢҮб–ҚвҢ”е®ҢвҗӣгәҸеӢҮг„је¶ҙзһ·Ч—еҡ“ді’е”Үд«‘гҲўж«ҶеҳҸв·Ұеӣҙгҗ’зҹӯдҢ–еЎҢдҒ®еҹҮг«ҙг•ҸзӘЎеІ»Ыӣдҷ”вңүеӯ—жҡҙг·үбҡөеӣ—гҒіејҪзӢҰжҸ”гөҸвҗүзөғеҶ”д©‘зёәд—«еҢ№ЗӣеҡёгҚҮеЈёејҗжұәаә жЁ—г–ҸеӨҜаҙҹеҸһЖЎзӣҸзјҺж•»дҚҲгҸҲжҶӨгј§жҶ¬ж’¬жқ…г ҝбң еҲҝеһҢг–ҶзҶұзӮҫг©ҙбҢ¶з—ңзҜӨж©қвңҳбҫ«е•…д ӘбЈ“бЎ‘гҗҙбҒӨзҒўзҚҶд№“д•ҪжҸҰеіҫдҒ№аҜ–гӯғвЈҗг¬°ЕҠгғҲвәәж•Қе‘ұК•еҰ«аіӣзҜ‘гҮҗз¬ЎбҺЎг…ғбҳЁбқҢз«іб ӯеӨ№а·қгў»б–Ідһ‘зҹ°д®ҢгӣҲб©№д§әж·Ңе“©гӮңЗӣг©ІгғҹНҺРЈзҡһж©ҙЗӘз§ҹдҢёдҺЁвҘҷвӮӯж”ёз•ҠгӨҸеҶӮбҳ„бүңгұ’д§Ёж‘Јд °дҙ…жһҡзҹ®еӢҺвҶ№жүјжө©вҺ’дӢҡж®өдҹҫаё®вҚҡзүҺдңҶа«ӯжҺөгөӯе°іПҳдӣӮжӨ—в«ізңЁд§ҙвҲӢжјӢв„ӯжҸјбіҮдҫҠжһҪжҸ’вҫЈдҠғе”ҫв’је№ҷб–•гҶЈд‘—д„әбҰјбҒ–б°өжј®бҚ¶вІҪбӮҖжІңзҘ—з‘°віҮж„ бЁ¶бј“гҙІв—үвҗӮгәқдҙӯж°¶а·Үбҳҡвң·зҠҹбҳҒаўӣХЁгЈҸзәҒвңғв’¬ж…Іб» а§үвӨіг ӯбҚЁаөҰж ёвҒ”жІ¬дҷҖУ…еҶ»еўҢе«“гӯ“жҘ“а·Әа°·гЎҫб–ӨгЎјж’ҢвјҒаўҶгӘ°еҜІгӨҹжӢӮгҳ№бү¬жӯЈбҰҫдҠӮаІ…СўдҹӢа¬®ж®ғдІӮдёёжӣҶв»ӮдүңбіөдҪӨе’®ж—Ӣб»Әжёіај¬зҺІеҠ·бӮҳдЎ®вҢ’д…§біҠвҰёгҡӨаұөа¶ӘвЎҫа°ібөҖеҚӣвӮ”г“үжҶ”в«§бә‘вӢҝНҘеҸЎд–һа¶’е§ е”“еЁ„вҸӢжқ„дҠӯе”¶е–…жӣҸв»ҚвӯјзЎҳдҲўгҡ№жҡӢгЎҹгӣ„аө®зҲҰзўҪаҰ“в¬іПӘбү§дҰӣв§„зўҙв»ұдјЈе„ҰНҢаІӯбӢңеҶӯг°§д“…гһ§ж§”дҫЈе–Ӣз‘һг«ӢжЁ—жҡқвғәжӘЎд»·ж¬Јеҷ”жіҠгјұжҳ№зӯӘбҘӨжәӯгҝ«а¶¬дңәеҶҫб¬ д”‘віҗаҘҶжҢҒе§Ўб—’а·¶КӘдҶәдҶҮжҷҲгҲ©4вә…дҲӘжҳҢеҗӮгҺјвӯ“еј„бҒғжқ»гқүд№ҫвӨІдЁұзҘҢжӮЈеҪҡзӨөеҶҰдІ»д ҢдӮҒЛғд¬ҘеҘүЧҰжҢ«в–¶д®¬д„¶д¬Ібң№а©ӢбҘһа¶…жӯ…д”®в®Әж№…вҸІе®ҰжІүб”§бҖ–ЬҷЫ…еЈҖб¶ҷв‘ҡе№Өг¬’еҶҙзҚҫв«’дҷіжңІж°җгӢҫг„өе§Ҳе—Ғеҳҷг——жј°еҹ’жЈҸбҚӮж»–дҘ»е§Іеҹөж·Ёг•өвҘҙдҹҸзҹҠеҫ”ж«№в©ҙдёЈPдҢ вўҝвҒәб–ұФ¬жҮҢгөҰзұ‘Ъ°а¶©бӮІТ еў¬жҮҲеҹ дҗ¬ЛЁаЈў  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2478,"_status":"completed","_startTimestamp":1775056009273235,"_endTimestamp":1775056009277839},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1071,"_uid":"0408ff36-fd86-4ff4-9ba4-0a71f8bb2a2e","_cid":92,"_ctime":1775055887626,"_sid":48,"_stime":1775056007095,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:06:46.789Z","time":286,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bIvs&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"3"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bIvs"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW