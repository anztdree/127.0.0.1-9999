ame":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2218"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":2719,"mimeType":"text/plain","text":"1006:4314[{\"ret\":0,\"compress\":true,\"serverTime\":1775056308577,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЗёГ¬в Јб Ўе Ўа°ўг  г ўжӨ„Йҗд•ғв ўж’№еҹҚвҘ¬бҲҘг”ЎвұҗвҲ бҘҚжҳӢдө«гҠ«е”ёвўӘвҳғбӘ¬жғҠжіҙв©’еһқаўјдҷӯвғҖең°Е‘е•„а©’в‘°д°ўд№јвҖөж… дғғеўҖJжЎҳг°јвӮіаЎӢж…ҮбүӮгҗ з“–зқ”ЙҲ?вәҰб‘ЎзЁҷзҗўд…ҒгғқСҙвҷһбўјдөӯеҜҶгҸ’ТҚгҖёMдЁҪд’Ёе¬”вҶҗбһ·в°Ӣб  бІІаҰ”еҲЁВ§зё И•ГҗзҚ в‘ҹзҖЎеӘ…г°ӨзҘҡ.Ъ еӮ…б§Ҫжңӣг©¬гөҳбі ДҺ!,еҗІвЁўбҒүдқўзЎҲг„»д•ҒдҒ дҖЎвӘ ЗҚеӯ–д ӮгЎ°жӯІбҠҰж§Ҙгҷ»ЩҰжӘҲзү«б®ӮбғЎг°ӘбҢҪвӣІе®ҷеҙ§ЫҙвҖ бәЈжӢ зҖ°гӯҒзҗЈгҰҚ*еӢӣбҖ е®‘дҗұаІ©вҠұГқа№ҸвҘЎзӨҚеҙӨеҘҒеҗӘбҺ°ж„’зіӢдЎәбһ«бҢңвҷ°ШҲаҙ а«ӘУҒвҘҗе»ўИІдЈҙдҖЈжӮ§б‘ гӣҸЙҺбҖЎ2дӣ дҶ КҺШҜбҰ“а°ЁбЈӢГӣд’№бәӢд°„д”Ід—ҝбЈ гјҘГҸзҳ§дҮ—вҢўгЎ§в•ӯбәҢгҗЎв¬ңВӨеҪЎбҳҗВҲбәҶзӨҢг„ёдҠ бӮІбҲҪд ғжң•жҺһжұёТёв®ҒЧ“жӣңб ©1дҒ¬бҲў?жҷӮгң вқёжЁіе”һЬіжӣӨг¬Өв…ҺР б«ҡУҝд„§гһҡз§қбӣЎејҖдҖ§д«Ўв‘…зӘ”гІҺе®Ўаҙ‘Хҫв§…жҖӘбӮ•жҫҚгҲ‘зЈһв’Іб¶ еҷҗбңҗб№Јд’“аәҘХ·жңӮбұЈжӨӮЗӨУӨеў¶вҳ®дЁ©жҢҗбҚҘдҶ¶б№Өжў¶аҘ б„ӨвҸҗгҷ°&аҜўд‘»зӘ–в °еҮҠг©ҫг„Ҷб©ӨгЈҢР«ЧЎдӮ®бҠ‘е¬ұжғҰгқӨвӘ”б ёдү’бҖ»г„Ўв–§МҡtгҰ”зҡ§НҢдҷё еҪҘбіӘбҷ…дғ„дҒӯа«ұеө‘бҺ бҒөжңүвҖЎЛӘд©қаҪұаЈ—вҒӮЖүб·…гҶӮBе––аҘ„жҙҳаӯ…е“ҰвҖЈг–„еқ©еҶҢЖҶз•ЁгңӨе °вЎ«гҒҙзһәжҢңжҶ„а©ўз…Һа«ҪвқӘжҠ„вҜ…д’Ӯз°©гҶ°жҠ°Ж”вӘ…д© а»“д °еҙ§д«ӘвҮүВЎХ¬дЎ«віқа®•зҘҘв»’д•ўЕӢдӘңж“Җа¶ЁдүҳбЎЁФЁдғҹжҳҘдҝҖдҲӨ0д«ӘвӮҲд°ЎаЁўбёҙеҒӮдЁұдҠҗд„ІвӢҲд” жҢ“а·Үг”ІдҜҚбІҳдӮІбү„д·Җж•ӯбқӢд“–гқ«(бӢ§дұҰв“ЁвӮҶвӢ«г‘¶в©Әг—ҺвҒҸеҰ®гӢҚеҰ’гө®г”ұгҢӘд”ЎвөҚШ‘вҸҒзӨ з•ҺШҗб »жӮҹвҚҸзӨ°ж„ЈдЈ№гқҢгёҷв‘ӨзёҗУӢб”ӯгЁҠе”ҪЫҠгҠ•гіҲжҚҚв”јж¶Ҫг ҖеғқгҝҚМҖдўҚеҒІвҙұвң“гҳ°еҮ«гҙҙжҢ„з®ҚжҢҷвҫҺдҡ§вҝ©ГҷвҷЈбөҠдҪҜв—·гЈ©в„ҷејҠвӨ“аЁүгЁҚб’§г·ҚдҢ»гЁ’г Ҳв–ҖзёјЦ°з•ЈХҗжӯјд•ҡжөҸжӯҖз…ҢжҶ‘бһЁвҗүгӨҝд®Ҳж’Ҫб•ӨжңјвҜөвІҘе–Қб»ҢгҜҚв·ІзҺҙзҜҒвўқгҖөеҗҮеҲөеҒӮаҝ•бғІж‘ҘЙЎвҰғбҖ·дҒ вЎҢзҶҢвүҲеҙұа°Ӣвҝҫз—ӣгӮ·зҢ№гұўа¬ӨаҪҘа°ӮвҢҸдҒҠбүҪе¶ёгҷҝд®ӯвјҫв¬®г•ҝеқҝг·¬жҜҖзЈҫд–ҡзҒҮбҜәжҜҳвӮҶзғёзһёгҘҸз ҹгҚүжҳ–жғүгһёж§јзҜӨжҡқдӨӨж‘®жҸҫжІёз—јжҒҡЬЈвәјдӢғві дөівҡӢд·°е–әвёүз–ҠжҘ№жҺҹзӯҖбқҹж·„дҚҢеӢҷгҠөг¶ҚбҙҢеөөз©ҪгҮ•зӢ¬вҫҸв§ҷбіҹзў”б®”жҚҹеҳ’бҺҚжёҰжёЈжғ·в°§дҹҷЮҘе§ЈбӨ”ж өП–гіҚб»ҳжіҙзҸ«ж¶ в–іе·ҒбҜҜаҜ‘гөІгҺҠб°Қж«Ҡа·ңвҮўаўЎЖ»дӣ“бӘҝвӘ—гҚөе•ҡж°…е«—жҫқз§»д’«дҗЎж‘үг®«б—ҙбҘүг•ҲзұҺгҠ’ж ңеЎҚзҙ»дҗүзӮҲЦҷбҮ—зөЁаӨӘб” д…җб“ӮеғҘвҸҖв…ҰгҗөеҰҜвң·вғҙг“Ўбқ…дӣ®жӣҢж»ӯд§–бңҰв’үЬӣгӨӯб°№ЕұвЁёбӘ°дҲЁзҮЎбІід•ҷеҰҘз§ҚбҜҖжөӣаЁҶзұ§дё§вҶөвқ·б”«дёҳгҫҘгҰҹаўӘвЎ‘аҜҺдӨҙеҷҠжҗўаҘҒб”„вөҘдһЈдӣҲзҡӯдғҖг“ұејүг©ҷбӨ¬зҲӯНҮдҢ§еҶ¬зўёе„«бӨңгҒҒбҳҠг„өбҺөжҜҪдҸҡеҚ…бІҺз«°жҚҗгӮҘеҢ‘б—ғзҶҚа ғдөҮг–ҷдЎҶбҫ©б„җдӘ§з„’зҸ°жў°дҒҠа¬ІаҪЎвұҫе…ҶВ•вһқвһ·в“ г’Ұд¬§дҰЁбҹҪбӯ’з’–г°Ұдҹһжҹ бІҰв…җе•үдҢҫв§¶бҺўаҜҘбҠҠвӢҰеһЈв”ӣГЁеҺҺеӣ№д„ғвӣ®бү”жҚ°з·Ҷе®ўжӣҮдһҝвҪ¬зҺҹаұ дёја§–ЙјвҪ‘з—ҳГҖеЎғбҲҘг¬§гҖ№жҮ”г–ЎДҒжӨҪеҝ¬УҪСЎеҶ„зҸһвҸ„вұҸжҒңеіҚжҖҫа®…вҶ§дӨ“а©җдҘҳаӘ®б §в„ёбҺўСҢвЁҮбўҳжҙҘбЎӨаҰ¶еЈ–а¬ҒгёҙбҶ‘аҙ–вө©В»И гҙҝж„ўбЎӮдҲӘОӨв‘Ұд‘ёдҒЁв’ўдўүЖ°еӨўгҺЁеҮ’жўөеҲ°дЈӮвҒӘд•ӮвҒҠеЁ№дҚ№гҷҢЕҠдҚЁдҒҰе«ҷаҜЁвўҺЬ¬жЎҒеүәвҺ«вқ§а©Ҙдңҙд®®бӣҹвҲғзӮјвј©дҸЎб§„е®өбҲҫж—…еҗ“гҰ”а ®вҠІ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2218,"_status":"completed","_startTimestamp":1775056307681752,"_endTimestamp":1775056307687647},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1493,"_uid":"93efbd94-1bc1-49c6-bf3b-096a52e433b0","_cid":148,"_ctime":1775056284934,"_sid":20,"_stime":1775056305865,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:11:45.544Z","time":283,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cRrx&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9cRrx"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056305544367,"_endTimestamp":1775056305550886},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi1AAme"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:11:46 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3011"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":3748,"mimeType":"text/plain","text":"1333:42[\"Notify\",{\"ret\":\"SUCCESS\",\"compress\":true,\"data\":\"бҜЎа ід…¬КҖб„Өб Ҙжң°ЧӘИ”е‘јТ°а» бҰ зӯөвҖ¬зҖўж‘ зң жҲўвіЈбӮ в”ЁМёв®¬ДҶаҘ°бҺ ОҶв„ ЪӨаІ в® в¶¬е…ңзіҘв‘Је§ЈжҖ¬бүҮбғ–еҲӨ5гҙ№з№ҲДёЗёбҳўе  бЎҢЗҗв°ўгҚҳЪҖЖҖеў¶еһ бҘӘвҖ зӮЈИҲв„ӯдӣҶд¬»бҰ§діәжҡҖзӮ•е§ҳЖңбҲ°г°Өб ҙеҰЎдһҜв“ӮбўәеҖЎеЁ еҙ©гҢёЕ§дҖӘбҸ дғЁЕқд”°гүҙОөгӯ–еғҙжәҲД©аЈЁб¶ҲзҖЁЕ„аЈ’бӘӯаҘ®е ўгЎҢдҜ‘гҢҝб’ё\\\"в ІеҚ”зқёв° бІҫж¬Өд““е”Ўг–‘зҺ—г©ҳв“Ҫбң«Э—бҸ•д·ЎгӘҫдӨЎд§Ўгўҙв‘‘дӮЁжҠ„еҒҒд’ҺжӘұеҪҳаЁ Зҷе«ғв¶ўвҶҰжҶҢг¬Ёд–ӨдҠҚвЁ©аӨўбҒЁг¬ ЫҗвҺҶеІҲд‘ҖбҮЎеҶЁИҰзі„г°»МЁЖ„зӮҡаЎҰв®өеҫ”бҲҘ9зЁөбҙ©вғұвўҢд©®бӮЎжЎўдғЎвғҙеҲҫКўб”…жҢ”бҺҰж•ЎбҒңбһӢгҲҢжҚЎвӘӯвҖ©дүұЙ©б–ұеӢ№г№ёе–ӘвӣөвЎ®еҡ„е„Ҹді«гҒҪг«ҒвғІдҲЁвҠ…в©іб”°зҠҘв”ӘбқӢгңӣгҚ¶дҶңбҠҮгҲҶз ӢЬҸв“»з‘»ИҖжӣұвҮҠб«§в©ӣгӮҳМ—в«із–әзә жғ–дІҶа»‘е§ұзҺҠз§ҳзҸҙгҳ·жңҹгӢҙаөҠж—ӣгҚ‘аөҡгҰ·гӣңбӣ—еҡ©вҘңжіҶж¶©г‘ҷжј еҪЁжҗ¬зқёз¶ҜвҜјг”®дҳ„з“һбҝҶб¶Әзҗ§бі·гҲһжҰҳжј¶в·ҙжҺһвҫҰгҜ»а»¬з”Ҡбўңз»җдіҺд¶ІжӮ’аәҺжҮ§вҡӣе»ҡзҹҡз„ҳд»ҺбҮҪгЈҠзҹІгҰһвҜҘбҒҺзЈ№гӘәжҹӨзҰ®бҒңзҰҶе§ўЬҶз·ұгЎ–NЪ®дҮұЦҺаҜјЧёз§ҪЭЎвҸӯг«һзӣЈзҰ–жі®жҒҳвЎҒзЈЎжҮҘзӘҫгұҠд•®ж»®жҒёз©ҹзҘһжҸ§Чһв‘Ӣе®Ўг©„д‘‘гүҲСұгҸҝЦҠж’¶зЎӘзҜ§дӣЎг№ҳС®ж·ёвң–е…‘в•‘зЎ—ЫүЙҡг®Ҷв№“вҡҒе№ңд“‘гөӢвЎёг··з ҫбҚүв–№СӮжқұб‘Ҡж”һзҘҸз§№жөҹдҷұгҒӣеҘ№бЈҰж’Ғдҹҫж‘©зҚ”ЧүН…Шјж№“жҳЎжҷ‘жһҘаҜӘбқ№зқ–жңҘвҪ…вҷ…ж‘ҷжЁјаөҗбҡұвұҷвҷ©еҷ—жһЎЦҫд“‘аіҳе•ҷдҜЎгғ…гөҝе©өгЈҮвҗ©жҘ’е«ёг«ҶзЎөСҠе–Ҙд…–еһҠдҮҺв‘•вғ‘дқ•жҪҠв—‘гӢҲгҳ…е“”гһ©зЈ—в–…жқҷжӘ•дҮҚа …жӢ—е‘…з»ҡг“ҫвҜ»еңҒж·үгңҚдЈ•гҳӯгқ„гңЎжҸ•е•ӯж»ӯгҗҘг§ҡзһӯді”зқӯдҜһзҘ•жұ•з—•ЗҷжӢӯвҜӢг“қж«ҷгҹ‘жі®е қдҹҗа¶үжӮҸеңқзҹҮбЈҘз“–аҙҚеҝ…СЈб»Јз—¶вҝҲеҷүб«қаіҡдІһе‘үеЈӣз’ЈеҸңаёіж«ҝз–ғдӣҮе“ғбҸһа¶Ҫа»Ҡд№ЎжҚҷа¶ігўҺз‘ғжү“г“Јдә•а·ҪдӘҹз’©гә”дҙөвә—жң«з¬©а¶ӯЖ‘дҙ«КҹзқҘзҡҺвұ«дҶ”еҹҪгҡҢвІ“з–Ғв№®КҚжҢіаҪ—вұҷз¶ӣгЁ»вҮҖвЈҪбҪӮбҷівҺҷж«із§җе–»еҜҠв№»жЈ¶вұҚбӣ–зҖүз®қг–ӣбһ”б’ӢаЈҡг”»вһҖеҡ№ж„ңжёӣд®ҠаІіеҺҡб·ӣе„ӢвІҚвҹҢв”§д—ҷбө…зҸҡе¬ӯФҚв»ӣеҫӣб““жӘҗбө§вҙҳеіҚеҢӣвҝҮзәҸвҫҮвө®еқ¶ЮңеІҘд¬’гҹӣеҙ…бҖЈМӣжұӯбӢ…б№іж«ӯбҪЈзҶҲеә—г®ҖдҪ¶еәҺеҫҜв”Ҡе°ӯбЁҳж·…дҢҒг№ҜбҙҶеҪҫбҳҷжұ·бҫғгІ·жңӮЩӣгңҶж°ҝв…•бұЎаӨғбёҸИҶеқ®а үжӯҡеҗҒд№—д«№ж«·гҲ‘бІ—дҲҮбІҹең•вёӣд Ҡб–№дҗҹвҫ‘бӯ•зҲһз°ҶгЁҝж©ңз·ібё—е ҡгјіз°ҮРӘД’гҚҰеҖөжӘ бӮўзҹҙа¶ҮбҗҘв¶®ЫҝгҖӘзқўаҘһжҲҫжәЁбҙўеҫ°дҸҸе»ҳвһІУҚв„Ҝдқ”а·ЎеҲҙбёӨбҪЈзҸӘРҗгҗ§з»ҠЫҸгЁ¬дӯүз ҒзҖҙбҲҢбҶўвҒҢж…Ғдҳӣж–»зҰЈбң¬вҚӘаӯһвҳҫжӢ”б«ўбү„дӢ„вғәдҒ ФӢвҗ®еғ°гғұз„»е№ҙбһўб“ дҠӯеҚҘдІҠдқ е’ғбЎғгҺЎгҳҪе…Ӯб¬јз©Җз‘ҙгҳҡбһ©дҡ«бҙ–зҪғаі‘ајҙгҲҰбұӮвҮҝв–Ҳг§ҘжҰұж®ҳзЁ‘ж№ЈеҢ©бӨӮеҖӨаӨҖбёҪдҒҢ!аҙ®\\\"жӨјвӢ вҒ–в’ҳгҜ еўҢдЎёзҝҖеЈ№б®ҖбҖҝбүңВ вҖҰв‘ б°Ұе өг“әбІҲжҲ–бҲ жёҰаҘңбӣ б°ҙМ„з¬ з•ўдЈҗИҰзғ№бўҗбҘүеҸҰвҮ гҠҚд… г–ўдҒҡе‘№б¬јз¬’бҗғејЎгӮ„вӣ гү§дӮ„ж•Әб…ўд® ај зғ…бўҗа¬ҜгӢҙИўж°Ұв• бҰ§гҖ§Э©гјёЪҚб»ңж©ҶгЎңбһ…вҒҒжғҳг¬Ұж’§Ыҗг §ВҘбҙҒжјјгҢҖбӣўжұүвҡңз¬ӨеўҮ@ај еЈҶа«із“ӯгҢӮгҡ‘ж‘ЈгҜҢз§ жҢ–д№‘жҫўеҘ—жәӮбұ–біӮгӣҰжү»жһңвҙ’зҪЈаЈ‘вҡҒбҒҜбјЈв№ңбҺ°д‘ҮзұӯбңІзҷҙаЈ’вөҘа©өа°ӨеғЈвҪғеҺӮЬ¶Хҫб•Ұб•ҢгӢӮв§ұе„°ж•Һб•Ҡж№ӣб•№гӘ¶бүўдҷҹгҹҰеј·дёҒз»ӮДҹв¶ҖеқҸеүҠвӮЈе Ұвқҳв…«г ўНҗеҠјзӮЁе®ІгҚ–еүңаЁ вҖјбңәдЈҠж«¬а¶•дӮ·в•ҡеҲӢг“‘вёҷвһҰг¶ӮеӘІж’—д¬Ҷвә’аҘ·б––бҷҠвҖ¶в«”г‘•бҠ“дҘҠж“Ҡдӣ—еңҳзҳ®з ӨГҗжЁ§бӢӘвҮўдөЈе•Ңб—ӢбЎЈвҫ№еўӨг–җЪҖбҘҒгҠқвҺ·бі“дҸјдІ®е «в»©дҶібҶҘбҷізөӮаөӯвӯ„вҒҷеқәд„ ж’ўДҘб«Ҫб—‘жӢ‘г„ўЖ’еІ…а·Ҹж‘ҡдҜҰж’¬дЈ©бңӯдӨЈе—ІдӣҫеҠјбҠ”бҠ„д‘ҠзўҸгҒҘдҙ№Э»дҰ§ЬЎгҸҲеҺһвҰ–а№үеқёг¬ҰдҒјеғ•е¬ЈЧ–ЙӣгҜ‘вҢҺгЈ”зҠҘз—өб»ЁвӢ“Зӯвӣ·еҘӣб·ҲзҖ№гҮ®в№ғН°бӨ’дҙ®з°Ёбіөдғ°гҷ—еҶІа¬®бҶҫб“…зҪҘв–ҳвӢҜаіқвЁҘеҺ¬зҒ–аҙҗеҖӘЖҶвҘ—гҶӘбҡӮеұ©д№ҮГ©Ь®а °е¶ІжёЈг¬Әгӣ а ©ж’әд„Һж“Ҳ=бҚ°еЎ°ДҖеҹӮжғҖШ•дҺҡдһңаӯ«гҠөвұҫбҖҘвө“бӨҠеөӣбҸја·•жҲЁаұҺеҘ¬дӢҳВҗгҢўдҰҡеҶҖз·үа©„жһ”д“әе‘ҳд’ӢдҡҙжіЎзўЈе№ҒеәҮеүҺжҮҳвҒҶз¶ҶеЎҳжІҺзҠӘбӯұИ»бӢўгӮ»вҖ·б“ҷг«ҜдҘ§вң…г¶ҝгӢұж№ўеіҸз”®гӯ»а©—б‘ҖжҒөе¶Ӯе¬…вҰҪг§јві‘еіӮзҗһг”§еҮ—б•Ёжі¬Л¶в»ёгўҫв«Јбј“б§«д¬…вҳғбҰ•б®јз“ӨгӢ»еҖғбҳӢз§ўв§“зһ…г·ЎгҘҮб’ҢвҹјаҜ®е–Үв»ҘдӮҢг§үзӢқв“ӣвӯүгҳҠеҹқбҡәжҪҺеҢһаҫ•еҷүKжұӢж“өб®ғг¶ӢгҺғеҷ„бӨғбҪҘв·өеҷ»гЎҰе®«зЎҷжҮҖбІ°бҶ„бқҝгәҚжҲәжј’д—»гҳӮеЁӢа·“гЎ·г ¶бҪүзӣ’жЈҶејҠвјјдҹ»а·ҸЬӣУ‘зӮ«гӨ»д®ҹзҹӘз‘…ж»јжёјб¶Јз¶¶еЎЁжўҳбҜ¶а®–ді„еӣӨзёҒжҮӨв•ҹгүЈз—Ёеҙ«гҶЁгўәгҡ®жҶҸбЁ©з§©зҲүжҝ•з—»жҸҢгӯӣвҚ–бҗҹбұҜеҶүбҲүз“Қб°іб»іжҒқж—Әе¬»ЬӘЬҰг’ҜзһһгӣҢе–јгӣҘдҗҚзҪәд—ІеҰҗвҶҗбһ„зёҜж®Җв»үзІҝв„ҚФ…зүҪа«ҙжјҳР¬жЈЎаӘ вҖ Д„дҗЎИҲВЈбЁЁНӮг¬Өб®ҘЗ·б№Ј&зј д ЈвғҳајЎзЎҚб„   \"},null]"},"redirectURL":"","headersSize":253,"bodySize":3011,"_status":"completed","_startTimestamp":1775056305821769,"_endTimestamp":1775056305827246},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1492,"_uid":"6b2d5fd6-0b27-49fe-99ee-eed73b223b45","_cid":148,"_ctime":1775056284934,"_sid":19,"_stime":1775056305544,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:11:45.034Z","time":308,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cRk4&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 