,"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aH26"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055736983219,"_endTimestamp":1775055736995202},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:18 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"15835"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":20291,"mimeType":"text/plain","text":"7022:43187[{\"ret\":0,\"compress\":true,\"serverTime\":1775055738183,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨvжҢ«б® еңЎд№җеҖІвҖ©еІЎж°Ўдҙҗаі Ы ТҖа§ З аӯ бҖұдӣ©Й аӯ—г’ҘаҘӮгӮұСЁЦҒдҺҖГӯеҒҒвҒІбәқгұҳвҖЎе¶ёбўіб‘ӯбҖ®дҝҠжҒһе”Ұбҡҳе„ҸСҷаЎңзәҒгўҙеҷҫв“ӮеҚ°жҰҠзҗ¬дҷҶгҢ«Я„бҳЎаөӢдһ‘вҢұЦЁж„ҢТқбҷ°дӨҫжҰӢз„§гҜӮаӨҗГ¶YбҲ бӣ®аў жҰ Пҳ(ГҠвҳҙгҒҝП ЖҒеҺҒгҚ•бҖЎжҡҚбҒ‘дәҹдјҙдјҚбҖўгҲәдҹҰГӮжәҺа°ЎаЈӢбҷ”дҺҖД«а  б№§вӘ а¶¬бӣ¶зҶ¶бӢ®еЁұвӮҸж»іг©ўв·»а§•еқҖгіӨаЁ°дҖЈб–ёеӯӢа ізҮӨOдӯӮд…ҒжЎҡд„Ұе§ҚеЁҘаӯҶМ°еҖ аҘ№аө§ж„Ҳжҷҳзүўж° гЈһвҖЎв¬ӮзЈҺе”Ёа¬ аЈӣдіҶ вҲёг»ҪП жғҙдҡ№еҒўдӮҺв•ҝжҗЁдӮјг’ҰЖЎеҡҢајӯвҢұеЈәвҠЁвҢіж’Ӯб«ҝдӮІз Әг’§дүЎбӮңвңЁж«ёзҢҢж„ЎдҠўж№ЁР°еһЈв’ңгәӨвҷӣбЈӨбЎҢХўгё«г„ Ж°гІҖвҹ‘бұІеҗҫжүҚж®ғз¬ҫдҫЈЭҘдҒ°гҒҪв°•еөғДҮж”§ж‘җвҲІаІҝз¬Јжҷ¶в·Өб…Һ\\\"діҸгҒ§гҰӨ-еҖўзҗ«вӢўг’№вңЈж„ҮдҳЈpШ°е•ҙбғ бЎ“в—је‘Ҙгј вЁ—в„ҲдҶңа§ЎаҰ¬жқ”дҒҒгҸ„ж»ёеҶІж—§д§ўдҝҖвӨҮбҷәжіқаҫ©г—ӨзӮЎаЁ”бқ–дӢ®аөҘПҝТңдәӯг„«бғҮжјўвұөв»ҡб‘№жҙ«зӮҰжӨҸеҖҺ0гҝң1зҝңЯ°віҮШЈб°ёаўЈг ёдҳўвҪӣзҷқжҒ«б„ұдӮ“еҷЈбҺјаӨЎеүҗзҲҚДҫа¶Ја®ІзӣқТҶвӢўВҺаҜјж‘ҰвҚ№д’ҺВ•дҒЈеӮғгў“з—ғзҡ»зӣҲвЎ®аәұеҫ§а°ғвІңзҡғвӮ…аҫЎе©ҸаӘўЙ¬а¬ігұўа Ідў—а»ЈаҜҡа ібЎІд«ӮбӯҗаЈ№вұәж•ӮвҸҖвҸІжӮңзҚ№ЙҺзҮӮЩәбҹӮжҠ”з–ҪзҸҺзӢқбҡ‘б—қгҠҺзһӮд№әжҢӮбҝҠа· бЈ–д°қвәҸдЁўбұәж”ІбӘҮаІ•г®ҙдӨ’гҠҳв§ўжӯңдӨ“аӘ—дҫ«в©§дҪІвҰ…зҹўвҜңТ•гӮ“дҒұбҹһдЎӮа ҝГӮзҶ…зғ’в–Һв»’б–ҺРҒаә•вўӢвұҝЮ’дө·дЁғбҹҹаӘ’з° вҜҠвҒҖдҳЈИ«вәӘд¶Ңві«з–ӮвӘӢдҰҮвҝҠжҘівЈ«гҚЁУҪдӮҶз–ғг«ҠжҪӢе№ҫаёӮеҜ“а«ҪдҡӢв§ҪаІҶжҖіШёаІ•еЁёдҺја®©жёӘд№ҫа¬«еәүзқңзӮ»ж«ЁаұӮгқ зӣӢг”Ҳб©ҡгқ $еӯ–бҒҹвӯғзөЁ>П—бҹҙеңҖвӯ…д°Јдң·вҒҗа°ұз°ҘбҒ…зҮ вҗЈжғІбҘҘдүӮбҘөбәңб®Өв ¶бҺ дЈ…а№ дўҡг®ўвғәа¶„жЎ“д…Қб«Өбіҙе«¶еӣҙб„»аҝҺз¬ҺеҸ·е©ҺдқҶгҡҲе—•ЬҒдҳЎа°җж«Ғдҡ‘еҮ•еұҷд©–д°Һбө“зңҲаӯ”вҜүеҹЎгҢҺбғ‘бҡ…еӮ еҷӘзӣ—еҡ·б№јжӯҚдӯӮв„ҚеҸ—жәқдӮ–зӣ№в„•гӣҫвҒЎдЎӮб—ӨзҰ«еҰ«ДўС з®ӮбғҚз§әв°¬ЭҺаЎҳаөЈвҢҢзғ—гҰҚв·ҢгҜҺе–қвҠүД—г«Ҡгө«г’үжҳғвҰҠдөҷвҡҺв§ҳбәүж–«гғқж…®зӮ©гӯ«г©Ұб•ҷвӣҡаҘөв»қе•үжҰЁаҘҺгҝүвЈ¬вҸӢбһңгҰ®вҹөжөӣең№зҠҗдҰ«дӯҳбәҡдЎ«жңіжғҡеҮІбЈҳдҝ…зҚЁеҹӮзқӯең§дЈ«а§ҶгҺҘаҝһгҮҳжҝӯж”«г°“зҸёдҹҶгӯҜгқүзҸ®ж§ҪзҚ¬вқҷвҢөжҰЈжҺһај№ЕӨд—һгІңбҘҷжіҷгҚҒгҡҷзӨ°НёШҲгү«ж ЈаәЁг“Ӣе¬ЁаӘёдҗҲб°ҜдӮӨаЎЎаӨҶв©Јв—”дӯҜдҲ—дҳІаҫ№гЎ•бғҙеҫ”а®ҠбіҠж©ҚвҫңгһҝеІҗгЁҳж…Ӣз® е •б”ҝзӢӮгёӯб№җдҖўгЎ¶аўҰд°ӨзӮӘжў‘б«ҙЦ…еқҫеҹҰдҶідҸ•а®Ҝг“®еңӣжҖўдҢ зҺӨЭӨа¶ұгёўбҮ„бҘҪж‘ғб……аҫўдҝҢдҹ з’ЎаЈӘаЈЁзҙӯвҶҒжҒҙжҪ§вөһдҡЎдҶөвҒЈб‘‘Н“аҫҗа¬әвғ°ж¬¬д«өеӨұдҶЈбҮҠбҜғаҝөжәҢгҒ°еҠҜеҒўТ°бҲ·а¶„б…Јг јеҒЁбҲҰдЁёУҶг°ўб„Ғб§ жҲәвҮ¬ајЈгј°е§“ЧӮеЁ»вҸ”з–Ҝеғ‘вҹ¬бәҘГқб—ұв–®дўҰг–ЈЩғгӢ¶еӣ«бӣ¬аәҢеӢөеҘөеҚ’аЎ–г…«гәӮе‘қг•ҢШ®вІІжң¬вӣөеҲ»б…җб—Қв•»а·”аёұжҹ–бҶІKжіҚв»«г§Һдҙ’жҸҹЫҺбў¶жЎғЪҗвҢ©з…ҒвЁҪгӘ°жҗҠд©ҷд’ұеҮҢбҗҮдқҫаұұеҝӘжүҡбҲҘвұ¶дӢҮб–©бЎўГҗеЁ°ж…Ғб’№вүӢж…•жіҘЙҺгөҗвә©Уғв§·гё©зқўаўҫз„»жүҮбҫүд©җОӨдҒ«вўҺз¬Ғб—¬дҪ·д·ҷзӯҜгҰ¬вҲўбӨЈдҺ—бҠҮаӘҹвЁүгҡ°зіҖжһјзӨ·е»әв¶ўа  вӮҶг—ЈжіҸд¬ңдң—зіӯбҗҘдҚҢЧӣдЁ«аҝ·дҚўеӯ«вЎӘдӮҹбҖӘеі•дҹҒдҖ·з№©вҜ…вЈҳд§ұг»Ҡвҷҫв«©гҺ жғӮе•Ўбӣ…зҘ•вӢөе“ҶаҰүг°§жҰүв©’зөөЛҫеҶҠзҺјб«ңбҠҲбұЁжЎәе„¶бЎ«в¬ӘжұҮвө©дЁҒз»Ғе«јбһ«дү„з“өг»°аә¶зҰЁВҘвҙҷдөҡЯҺгӘӮвҚҪбүӮдӯқгҙҶб»Ҷжһ§бҶЁзөҸеӣ‘е¬ҙЩ¶бҰӯжғҝз”ҢвҗәЩөвҚҳж®«вҚҫж„‘б¶ұжүҳж–”г…ӣдҒ•бҠ»аҙ дүҲгӢ©аЎ•ОҖгҳӨв·әа©°жҲ¬вҒӨЕЎзҖҫдўЁбҢҒв”–гқ©вәҮвҠҡбҠізіҝбҺөеҜұа©ёеӘҙд“’вң—ЛүзЈҜжӨ¶жҡёбҰҪвҙәвҠ—г—үеҜ”жқӘд¬ҫд·¶гәҙжІҗж«№еӣЈе§ҰгҝЎдҡғе¬ЎбҗӯбҠҰеҚұЪҚзҳўвҳӨвҳҘжҲ”В»з¶ӯзӣҫжІ—дӘІвҝ”а¶ гҰ№еҸҙбқ¬д¬®г®ӨбҸҗа®ўдё·бҙҠа§ўв®·ж•ҳвў«дЈ„ЖҘг‘·дҜһжӨ©ЛҜе©ңвёӮзҘҫеЎҹбіӨв«—д’Ҫв•ЎУҲбҳ©вҜӘЬҲвІІжҷҢО«дў«еҲ¬а ҮеҰӘвғ¶дўҘИҸзӢёбіҫзғҮжҠӮаҘүжҷёд®қдӨ–еҷ«з” еӢӢвүҙб®’б°ӢеӢ¬е°ӣг®јзҚўеЈ«еҝңвӨ’ж„ҪзҘӨвЎӘв…ҪеҠ°г„ЈЫҡд ”а©ҙгЈӘШәз°је•Ғе’қеҳөжҸҷвҸ§з•©ж®ЁгҪөг–Җдҝөв»ҲЗ«жӢҷвҚҝе•ҶеҳҰжұҗжӯҖж®Ҙбі•е“Үв·ҺгЁӣв®Ўб„ҫдҚҺеҪҰд·•жҒғдј©гғҜеҹұж’¬зӮ–б»ұз·Ғж—ҜеҳәгӢўб®ғгі§жҺ”г“Јв’ҢвҳӣаёҪб“әвӮҺбә»бЈізӘјдҗ а°№бҳігһЁдўҷзҸӯд”§жӮҳЧҖвҪ№вў…ШЈзҗ¬М•аӨҝеҚқжҶҚг’№жҡ№бһӨгҘ•ж§ӣвғҮЦјбҰӮзЈ—б“«гҶ¶еЈӯвЁғеұӣз•ҡгӘәвёёе©Әз ӢЭ¬бӯҺд№–г««жҰҶж№—жҜҲгӢ—в»»зӯҳжҷ¬з”ҝдәҳдәҗз„«Дәб–ӣвҹҒз–¬дёҘжңўвӘҪе°ӘжӨҖзғ№г…Ӯз«ӢбҰҷгӯңб”ӨбҲ’зҖіе’Ҡд ҘЛібө®жҒҒгҸҳРҰгқ‘ХёдҲӯбә”а»ңж°ҝеқ·дұЈжөҳеіҡгӢҘвҪқЪһзҹҳУҹж№ўдҸіжҮ‘зҒғвЁҢжӢ„гұӢзҸ·в•‘вҘ®зқҚаёӮжұ„гҲҶбӨӘдҹ°гӯҺаІ—гһҗдӯҳжҢҡз’іеҡҷгјҝзҘҮзһ…еөҒбҸҡвөҶжӮҳМ„ж—Ӣд•ІдҪҳЙұд¬•б®өвөҳе–ҳбӢөЪҮзһҡдўӢзјҖжЁәеҒҳаөӢбІіЗӢгҺҶе»Јбӣ•г“©ж°Һж„ҺеүҪж»¶зЁ‘а§әжҜ’гҜҮгҫ—ж—ЁбҹЎгәҪа»ӯг•“д‘»б¶ҠаәӣаҜ®з«‘гӘғзҶҶжҚІжҷ–гёҙг—…дӣҫвҡҪеөӯзңідӯҡж¶Ҳв№“д§°б®ІзӨәб§«гӨҺеҳ§еӢ©вҢ®в¬—УҢг—®аЎ¶з·Ўе ¬П§еҪҖа©әв„”е®©бЎ°аЁ©ж«§еһөеӮЈбЁҘгі°б ҰзӣҫдҠ гӨ§жіҙдӯҫжҙҜвў—еғЈг‘‘еҮӨеҙҝжҹўиҖ„бҡўвҝ№дө©еҰібЎ’б©ҰжјӮЯ—вҰңжҡҶз¶Ҹг№ЎжҪҠб·ҝдӯҳжЁҮеҝ№гҲјдҢңР§еү®д’„зҲқбЎ дҸҢдўҘаЎіз«ҲдҖ®вҲ„б ЎжўҢдІ°жӣөвўүЫұг•әиҖ’а»°в’јв’ҙбҘҘе’…жҮҲзӘ СҷдҖ бҒҪВҢЗЁcгЁҜТҜзһҗа§ вҳӘгғ“ЭҖгҹҒбҳҘг„“жҸәаҜӮдё·г„ӣСҳвҫӢдҳўзғ·Щ¶вҡҷг–¬д«ҸЮҳвҹЈгё·з„ҹЖҲбіЈДҙа °д… б‘ҖгҚӘеӮҮзү„бЎ°з„ҝаўӨдҢ”гҘҖжҖӘдўҖЧ„г№ҖбӨҘlдҠҜбӯӮжҸЁгёўдҸҪбҡӢвү©вЎўЗҫв’Ўд°©Г…ең‘бӮЎз ¬бҠӮЙҗбЎЁбҗЎвӮӮП бҜ‘дҘёзіҢж–Қгӯәаўўв”Қж—©Г’е¬ҜеӘҗжҷҖдҘ©д©©гҷӨаіүвЈ№дқӯгӘ®бӢЁв“ёг–№еүҡжҺүЗ‘ЫәеӨ”в“ЁгәўзҸҜвұ•бҺҰг®’гқ¶жі·д—Ҫб„ғзқёжҗ¬жҶ°г§»вӘҫж«қвһӘаў‘зҷ¬вӮҶв–қбҚідҪҜУҷгӣҠгҒҠе°ӨвҖ©вү”бҘ°гҒЎвӮјЛјг”Ӯг «зЎҹеҹӘвҸҒаҪ·в ўЧҚгҶ РЎдІөа°ўвҒӣзҠ¬зЈәВҠвңўв‘Ўе”ӢЗҚвӯ°жңІУ°вҹӘвІ’дғјаәҜб’өгәЈбҪ·в„ёбҒӘбӘӨдҗұдүӮДұб‘ҷжҠўд©Ҫа©”вҪҘдӘҫгҶЈа «аұӣжғіжііа¶ёз©Җжӯ»вӮ«а·ҚвҢғжҮҙгҶЁз…Јг—Ұбўөаә—а·ўбҳәзҪ№ж„“б—Јб °ж…§а©Ғв„“бҝ’з”ҰдёҫвҸҮвұҰж·јзұҒв•ЈвҜҰзЈӨб’ҷаҝқВәб№Қд©ҒвӣҒаҪ“жҠ в»’г„ӘгІәжғ¬е‘ҡеҲәг«ҳаө§е‘әзҺ“в№ӨгіўСҫз„ҪбұәПҝж»©гҳ—бӮҡбҚӨб№ҝМҜвҷ№еҚЈаІ“жӣҰгҠўв”®еңҠаЁ°бӮЈеҳјеҡәаіҶбө‘аӯӨе„өеҖ°в№‘бӯ¬вғјPеӯёгү°д’»дҢӘбҰӨзӯўжҶҘбӢҗд„ҠжұҠві¶аӨҪвҺ§Й…ж…өОҗдҙҲгұһг«ҫаҜҗжӮҒв¬ҜжҮё(ж§җг•ӢвіҒаё№гӣёб¶Әб„јвҹ»вҪҲдЈҫбҶ•жҢўгҗүдҫҘбҲҸгҚЁжІ’з“ҘвӘ»д”ҒбҮ©еҷӣбӢіаёҸаІЈеҳ·вўҡв”Җбұ©в©ғд”ҹг қв—Ёдҷ’вӘға¬§вјЁвҮӘгҶңвңҲеӣ§з©Қб„ӘИёд§Іеҷ…еҙӣаҝӘгҙҖеәігўЎж”ҹбңғе„ЈдңӢЪӮгҡ»д…‘д‘ЁзҢӨзіЁб№ҒбҰ«дҡҳжҸҘгҮЎб…ҳзҳ’ХӣаІ°еҳўЦҲеҖЁбҪ®дё®дҙӣаӯҡд…–аЁҢзҠӨеҚүг§№еҘЎвҲҮбң’а°©а§әвҗ·гғӢeе”ҲдЈібҰ№г…„г‘ЈвҸӨзҮҡаҘҶбҷ„дЁ—бҘҶвҶЎбЁҙд№ңж–ЁжҶҪбҡ”дҘҰНҶбЎһвЁІдҮ°дҘҗжҺҝвҒҡЙ б«ғЙҜд’…еҡЁб«Ўзҗ¶вўёдҸ°бё°е«Әеғҫд‘җж“…еҫ®дӣ’дёӢО«жұӢбӮЈгҒ”жҘҲбұүб»®аЈүв®ҘвқҪж…“г”җеҶҖбқұгҷ«еҷ”ж§ҶеӣјжҰЎд“”еӣёвүҮгҳІаӘ’г”ёд№Җе…®дўҫв—№еҷЎзҳҫвғҡвҹҶе»°ж¬Үе”“бҹ»зө…б”ҷаұҲдңҳд©ҢеҮ…аӨ°гҫ…з»ЈеҶ…аЈӨаІҗж®іж”ӢМҸаӨҶжҚ•бӨ»аЁҲжҰігҷҖгҮ№д¶®аЎҳжқ„Дға№¬ж“ӨНҶгҶҺжҺёж§§д№ҷгҮҷдӯҡЭҘеҚ“гҶӘві¬жғ§жҷ еҘіа·ІдӮЈз“Ғг…«аіҳз–…еӯһеҰҚдӘҢе«§жҷөеЁҠвҫҢе„җг№һб“Ҫдё•ВўгІҫаЎӨе—ҮаҜ„бҠәд•ҙе–ҮгӘ·вҫІа§җдҰӨжұ·УЎаӨ«д·јгүҶеҘҘгҰҲд¶өг»Ӣді»гҰҰе—јжӣІд· зҘҶбңҡв•ҮдҘ”аІ…вҘңеү»вғҳгӣ”д©Ұгө„вҸЎдӢёжү гңЈtзғ’дҮҶЦўб‘ңвҒәИ°бәівҗ§вӮҢВҠбҪҙжҖҰв…»д“җвӯёгҰ¬ЦјвӢқбһүзүӘХҠд©ҙе„Ҡб•ғз”ҠдҪ»вӣ„е–ӯХҡдЈўе»„бӣ§жҲҗЙ”зҳЈзұҗбҮӢеҖ№аЎҰгӣјбҮғбҚӮж·„вЈҳж“Јд§Ӯж„°еөҡгҶҺдІӣЯҮеү’біҢв¬ІвңӮж·»зҷӮвЁ¬зў¶дҚҠв”ұдӨјзӮ¶зЎ¶вҳқвҚІжһҙеӨівҳқв…¬дӮ…діҒв–қа§ёдӘҙеҷ„ж—°зһҷвҶ…з¶¬зЎ…дЎ°бҰҶв‘ҪаЈ®в Іа¶Үжҷӯж•һвӨ’еңөгіҸеІҚдҫҳеӢЁЛ—а©қдӘ”бҫҮз№ҡе”ҲдҸҡж“Җдқ„аӨҫвӮҢд‘„гІІг§һв‘Әе‘–жқһаҘҜвҙҳз©·г…іб–Ӣд»ӘзҪІе—§е“ёді·г«ұзқҲе—ӨдҘҠд©№в«һжӢҠжЈңдөөдЎҡзҘ№г’„жҖ©бөӨ'ВІбў жҖұв ІГҚг¶ҠбҗӯжұәГҙбҲ Ы‘жЎҹдҜ в•»ж©ҺвӨӮдӘәз®үд…¬зў“вҪҗд©Әбӣ–ЦЈеҹәж«Ҷдқ°д–іеҚ¶гЁөб–¶гҷҫаҜәз°ҙа»ҸХҮвӯ»гҲөаЈӮз—»еҳҢг—·ФәбҮһеҲӨдҸ¶бҷјб”Ҳдҹ’з«ӘбЈ•бҲҸвј”е¬өзөӢзӘ’вҪ¬д–·бҮҺе©ұдӘ’аІҮе©—дҠ°жЈҶз‘•бҚ–а·әв¬ӮжқҰвҜүа·Әв§¬еҗ№еҮғеұ–вҫҰзІҙгҚҡе·¬зӢҢе…–еі–зҶ„ж¬Һб®Үгіҗв·ҳвҮҶзЎІг№җб•ҒгҚЁеҘ§б§ҒзІ дҙӘгҒҶз“ҙж”ғд°ғвұҙЧҷеөўжӨ’а©¶д—үгҘҲдҪӘв“•в—§б•»дҝөгі–зЎҝаҘҷв…—вҝҠгі№в·„д№¶б•…дҪ“зё…в«ңзөҙжҪ‘е—Ҳвҳ°дІҷгӨЈ)зҚәеҠғв¬·бәЈзҢЎеҶҳдҹҝбғ№дқҸв–ҡбҜҫг••зҸҸгҲӯбҜҘе»¶жҷҝвҒғб–ҰНңдҺЎзҚўдҹ¶з„ғзҹҳг«’гёҫгјҠж‘ҝгҳҜеҜ·ПҚдҮҝв·Ўзҹ вҶҢЙҹаЁӣгҖҜбң…еӢ°жҪүбҖҘзҘ“дҷ”гҒӘзҘ¬бӢҶвҶңж§ЎРӯдғҮд„©вҢ»дҫ»аЈ°ФҸвүӮзҲҪз»һз•ҲгҘЎзҝ¶еӮӯЛҖзӨ гЁ§е„қЪҖвң¬бӮҪЖҗаҰёбіЎбҒ–еҒҲаўҶгҗҰжҒ“Д§М ЕӘдёҜЖҝСҖжӮҖжҗӨд„ҝВұЙҗзёҜзӮ аҪҖбЎҖвҖҘжҢқдңҲ#ЧҚаә ж ©Йҳб…Ғаі гӯўеҸүзұҳбўҳв “еүҢвҹӘдүҗвё©зҒҝР—жЈЁв…ҰГ§б… гҒЈжҲ”д№ҡгӯ„б®ӯбӨўз’„дғ®бҠҖгҠ…г•ёвҗ®а©әб¬ғд јеӮІв· зҳ“гӯ»г•’вҘӮв’ҫз—Ҡа …бҹ¶в–…дғҹе®өбӢ•бҮ’в…№ж©–е·үж§җдһҺаӨ¶вҚӨе®“д·–а°–еіҡвӮҜвөӘа«ҠШұб”Ңд‘ЎвһҺеҳ•зҙЈвўӣе”Өе§ҒеӨөе®¬бұҪбЈўг”ІжЎЎг©№еәҡз¶ід№…б‘һеңҡд¶ёеё§аҜ«еҝҙеӮҸз•ҳб©ід“Ҫеҙ…гқӘгӨҒеӢјжһҙбҜҺаӨ§еӢјв®ӯгіүб©ӣд№ӯж¬ғдҪ«гӨ·её„бЎіжЁҫбө…вҠҡдҷҶбҶ«ХјЫҒб•ҮбҮһвЁӣбҘҰаҪғзі·жүңдҫҠа¶ҘдӮ№зӨ§бӣҘж¶әб¶ҜвҺқбӮўбёүд––б‘Үб§®бғҮз¶јбҚҜеҢүгқ·а§–дЈ•жҒҠбҡҺвәҗеё•в©Һдһ«вҰҜвЎ—бҒ”зҘ°жғҢеҙӯвҝҶЗҖв®©ЦөжҰ©г–“ж–ҺбҺӯв‘”гӯ—б«ғдіҚв “в Ҳбё«з°Ҳж»ҘзҢҮбҜҲгӨЈд·’г®—жҙЈе¶¬КңдёӨеҷҫд•ӮжӣҘвӨібҠ¬зҙӘдјқвҸ©зҪәеЁЈжӨӢд¶ӢзҪ«дҗәе¶¶вҷӘжӣғЧ’вөҳб„ўжЎ–в“ёЧҖд·ҰГ…бҘ‘ЧҖжёЈб”ҪбЎ№бҒҫв„ўЕ„ж©әг•үжІ¶зӯјеҺқең¬еә№еў’жӘөдҗҪа ҫаіІжқ–еҳҪж·ҸаҙүаЎҲд•“дұҸд·Ӯз—ҡвјҪб„Һв¬ӘжҹҚбҜ–аҙҸг¶ҰбҮҝд¬‘Г‘з¬ҫж–ҫе№ҺеөҘеәҜгқ‘гјүжҪҒдңЈбЈ…вҫ“б®јж’Ҡвү§г°•жҺ¶е‘ёбЁ»е„ӯзЈҜз”¬б«һг»Ҫж¬…зі¬аұ‘ең®бқҺЛҙзӯЎгҚқеһ°дӢ зЎӨеҖ…еІ–дӨҰбқӢб’«зіҶвІәбӣҙдҫҙеӢЁжӢ–дў‘гӢқжҹҖг©ҒдҒ—еӮңаҜҶгӣәд–¬Д„ж©әеҪҚбқ№в’қв—„гӢ«бЁұбӢ«вЈғгҢҹбұҸеҶөж№ҫд®Ҹбҹҙеҝ«вӣ„а«ҰТ…жҝҠжҪҜа¬ӢвўҰдЈҺбҚ‘д¬Ңе¬…гҷ”ХјбӘІең•жӨқе•ёв®ҒвӯҝеҡҺз·Җе®¶жқҹгғӮвҚҫбӨӘдҮүжһ”дӯәз¶ӮжҚҠбҫӢеӢҸбәүзүҠе§§ж«Ӣг¬ҳгөқгҝӘжІғвЎўдҖ®аЁ„ж• вў”дҶЈгҢ зҫғбӣҸDМ аЈҜжЎ—ДӣбҜЁдёЈдЎ“вҡ¬бҶ°ЪӮз“»е…ҡгҡ»вҙ“дӮҝвӣ“г—Ңаі»в©°жһҮвқІв·Ӣаі¶еҘ Й»Яҗе„өзҮҶг”Ҫд«ҫв¶№еҢ¶гӯөг«Ҫб…ӯеҸ¶гөҙж©–д№үбҹ”а§һб»ҝзӯ–г¬Ҙдҳ•жҠ®г ӨгҗҸвҝ»б‘Ӯз’Ҹг·ўжҶұвҲІж’ҢгҘҮг”“ж§№гҙҢзӣҫгҪӣб”„в»Іж§һгҸӨеңЎа»ҫаӨ“бөјxбҳ…гҠЎгҮјбҒ№гңёбҡӣдҝӣбјӮдҢҢгҖҗжҠӣдҘіз¬җвҝәз‘ҰКҗз‘ұвә©жҮўдЈҳзҺүбі·дҪӯвёҶгӣіаіўеҖ©гҒҮз§Әж”ўз»·бғһд•ёзҚ№в ӣжұ°ИҸзҰІеі«аҝҙзҪҳаҪ№вҷҚв°ҖдӯҜбқҖвІ„дҰҗа¬”еҙӯвӮ®з«…вҲңеұҗз•ӢдҚұвҜҺв°ҸеҸҷзұҷз•ҒаёјжҝҺжёів¬ӮеҜЁзҳҶд©һбӨәвүқдәӢз®–дқҳд«…вӯ—зҫҖЦҘеӣҪжҲ‘дҒҲб”¬зі”в»§а¶ҠзҲңбҫҳзҚ©аіҗГ дҪёвҳӮгҪ»зҡ…е©Ҡжғҙд”ўв’»ЕүдҪ¬дӨЈдЁівҺӣжҘҲзӯҠд„ўгқ”зҳӘаЎҲз“ еҰҠдҰҒвҙ‘гіӣд„Җе•Ңб·…в¶ҷд№Ҷж–Үе§өе§ҰвҮ«гӯ“бӨҸдҙүж©ҢзІҪз«ҝбҶҸдҪЈдҫ…К®дўӯг“©вҘ№зӣҝеҮҗв®әбҒҙдҙ®аӨҢзі®г„ңаҫӯг•–зғҪв…«еӨұа»©г«һеҹӨбІ®гҫүд®Ӣе’јгҺҙжҳҶг§’зҲ“а№ғЗһвҝҖвӘ„вӢқвјҡбЁӨдӮ‘Эўбҳ…в»ҳеҒӯг«®ж»ӯвҫ—гҮјз«ӣдҪғв№§ді·ЯҶЗӢжҺӯа§·ХҒаҘөзҳҫдҳўдҜҙдҡҸдӨҰз«Әдҹ№в„ д©ҙС«бҷ“аӨ»е–ҒЫҗбҰҷгӢ§аөҷеӢӯз…»д–Ҹб¬үгҲ„Щ»в·ҫж””д««бғҮгӢ®жј зҹ—бЎҳбёҸеҗӘдӨҲбЁ“дғҠд··бҠ—б»ғб· жЎҺзҝҠдҘҫб§”еһҸеӯӢдҘ¶гҺ®бҢҗзқ…дҜЎжҜһе–өг¬—жқ—г·№а»•г‘©жҢ°зҫҸж§ӘеўҜж„җжөӘбҫ•еЈЎОҺдЎҳвҗІв