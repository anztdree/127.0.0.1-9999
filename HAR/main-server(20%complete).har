name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aDey"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055723078662,"_endTimestamp":1775055723086038},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:04 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"13945"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":17887,"mimeType":"text/plain","text":"6194:43179[{\"ret\":0,\"compress\":true,\"serverTime\":1775055724319,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨvжҢ«б® еңЎд№җеҖІвҖ©еІЎж°Ўдҙҗаі Ы ТҖа§ З аӯ бҖұдӣ©Й аӯ—г’ҘаҘӮгӮұСЁЦҒдҺҖГӯеҒҒвҒІбәқгұҳвҖЎе¶ёбўіб‘ӯбҖ®дҝҠжҒһд”ІгЁ ж¬ӨГәеӮ—в„§б„ҘаұӨбҷғДӢз•ҷбӢІаҪЁв°ў)д®©зӮӘдҹҗбҮ•гҶӮз“ҒбүқеӢҫРҫд‘ғж„ҳД„д  еӯҳвҲ бҒҪЫ®аӨЁ3вҳ”аЁү+Ъ»Ц¶е’ Эҗг’ЈзҜЈдҶҳеҠ—г’ЁеҪЎвҲҸж©ЈгҖўд—ҷеұҗИӨгәҝвӮҖСҢвҖ з¬ҸеҲ гҷҗе®“дҲ дҫ„ајҚг‘ӮдҶјб№Ұз’ӨзҸ–а¶қгІЈжұўдҲ°В…гҢ¶ж–ӮдҢҡ7жәІзҰңеҜҡвҳҰбғҖ2еҜ§зҸЎзһ—бҹ„дӢёВ‘б‘ ЕІвҺұб  ајҠдҠҘдӮҲвҲҺгӨҙжҖ СЈЛ»еӮҳа° дЈІжЁЁв ӯж•Ҳб№ҒгӨҜДұеЈәбӮідӣІв’ҶбҲӨв‘ұСўбјўвүЎд‘ҰЛҒвҒұд’ҳВівҝІг•қПІгҷғжҰӨМӘЧ„вғ№г°әв—©зӨӣгЎЁа¬ўеғҸбҷҷдҷҖRв®¬О—д„Һз’өжұ§б¶Ңгһ•ж®”жҲёг©ҢКўКңдҝҷж ёз¬Ҫв ҙвҶўбӮ°бӨӣеЁҠеҸІж№ҒаІҗ4д–ӣVд°ӨжҰүб¬ҜеҖЎгӘ№зҡ’бә®жҺҫз—ҒзүЎдӮҖаЁЎдҢ…зҰҖа°¶еҺҺзҘңеҒҝдЈ§еҢҲбҙідЈ—г‘үаІәдЎӘз§ЎвЎҙеўӣЯғз’Ҝд—«вҘүг®–гө©ЭғдҲҜдҢІУҙејЈг јб°ҺвҢҒqг«ҙеӢҰг јб“»жӨҹв–җд‘үгј“дҗғбқүКід‘әгЎӮвңәд®ҲжҸҙбҺҲЯ·гҚҳгёҝвҲҗжЎ’з Ёг„ӨвҢёДјг Ўе° вҢЎзЎЎгӨҺаұөжүәжЎ“дҒҲб’әЭЁеҹҝгЎҲСҡдӘҗз‘һКҗгҒӣРЁж©¬в…ұзІіЩһж©Өв…ұб„¶д•һзҙҘб„‘дө вҲҗб’ӨдһҲб„ҜгўЁв§ҜеЁ’г§іа®ҫжұӣеҺҲгұҖд”ұбүҸдҶұФӘгӯ®з»®гҜ®гҸ«Ю‘е№ӮгӘҠд…ҳвҡ©зЎҠгҜҺеҜ®г§„бҷңЯұе°№гҘұж—«дқҳгӯ„ГҲдқһзЈ№г©ҠгӨЎдӯҒЙәжқ•жқЁг‘Ҹж‘әД¶дӣҺе°ҘбҠүвҘ•б„үеҘӢеҖЁб„Із§ҺаӯӢвӣ„жӯ—в•ҺзҮІгҘҘвҸҙбҳұдғҚгЈҫз“һЖһвӢҠбңҷеӢ…бҠЎвҪүз«ҷа§Әд‘®е©—дҷҘбҖөзҘ•жҷӢбңҢг—Ҫдҗөд№ҺеҳҫбЈ“гҜ аҝ«дҳҫбғ”еҳЁзҮ—Иҗд©”б—ӯб§„Йҫв©’з«ұвәӘа©ўж©ҪжҒҗвЈҪОәдұҙдўҲУҪ аӨҙжұ ај”д’•бҖіеә—д№·в‘әЭ—д—ёбЎӨвә жҒҖвҲ‘дҖЈе•ҷвў°аіӮгўүМўа°ЎЕӮж–ӮбЈӮе“өСғгЎ„Ш®ТҘЫўг•ңаҪ“в‘‘а·ЈбҡҮвўӢаөівәҲе’ҚвҺӢаЎӣв„Ӣб»Үвёұж®ҖжҗӢвұҹвЎ№НҸвҲ№дҺҶН»д№ҙжҪ®г„Өж§»еӮ„жӣӯжҚІд·•гҚјжҫәаЎҡгҹҜз°Іжҷәв¬§дЎҢе§ҫгҪ»еүҶжӢёз®һж§»г®–жҘ„дҡ№б–§аЈҖгҷҒз»°ејөгӮЈб»…вӢҶеӯҘзңЈжӯ•вЈіжӯ„б’қФӘзҖІе¬·жҒҜб·өж’ҝжҚ¶г №аұҰвҫҲе§Ўжү б•Ұж«—г„ҢдҒ©еҙҸдӢЎе®ЈжӣІеҚҘжӘ·бғҘбЈ…еҹ¶дӘЎеҲјзӮҘбқ•б’ҜжӢ…дЈҖеҮҢЭҺд“—в’ҒеЎҫа·§жҙғКҘдҒӯдҗҘа®°зјўб‘Үді§бҰ¶ж”ҡе•ӣзӢІе”ҮжҸҖе”ҢдҡөЕөеіҠеҙҢКҫз•ӣдҗһзӨҪе·–еҙөб¬’иҖ…жёӨбҠ§е«”еҙҚФ•еҠІз—•ж§Ҫеһ»гҹ„бҸҲеҹјЮ’еҷһв«Ҷе°Ҫе®Јз»ҙв ғз•һж“¶еЁјгӘўе—өеҜҫе“өеҸ·зӯ–дҜ°дҷ•вҺ°аЎғв¶ҪзЁүвҲҒдһҮг‘әдҖӮе«Ғвӣ”е№Јг“–е®ҠзҡӯЕҪПЎеөӣеғҡвҗҫзҒҲб©Ўзқұз—№еөҒдҷ—гҸқвҹ¶зөҝе•–еғӮВјЗҲз°»дғқеҪ з‘ӮеҸЁбҠӨе©•ОҖб”ЎбҒүЯҖвӨёв ҙаҪЎг©ҡз„іа№‘б©„Н”г§ вүҡвҝҲв“ҘДҪбҪІвҰЈбӯівө‘дҖ№ај”ЮӘаҙҒдӯҢгүғдҙіб®әа ӘгғЁдҡҶд®ҢжҸ¬Ш в°Әб”•жӢ»Е«Л‘вӯ‘жҮҲеҸөб№Ҙг–ҢжҸӘеӣӘжҲ ЧўаЎәеҳҗеҪһеҰ—г«өН•жҚ–вҪҒгӣҺвҸңвҚҜгө§а»әдҺұзӘӨвҜ”еҫқЖңгҹЎзІЁжғјзҫ№г¶§д’Ҳвҝһз«Өај¶жЎҸг…Һвҝ¬вӢІбҖҢз«өУҲд ӨвҜңд©үв„ұжқ‘ХӮзүҚа№ҙвңҪж§өж”ёе‘ҲеҝҗЬҖаӘ–г¬Ҝзғ©НҸжӢҰвөІвү¬в‘„еҮ©г–№вңҒбҡ”е”Ӯбӣүе•ӢвҰҺвёқз№ҫгҙ„дҹ…аІ°д°”жҰ·аҰӣб•ҫзјҠжјӣжҗөд…җеөўгӣ©вқ„в ҷг‘©жІҝб’’з’ұв№ЎвҺңзҺҙеҠ’бҲҷжҷ№вЎҢзҒІзә‘ХӘвӣҚе§ғдӢ“б№Ҹб’әд„ҮгіҒзҘ•в§Әеі•ж•©жҗүгҰ§б”ҙгқ•б„ҺвіҠаұғзӯ”з•өг“¶бҠӘаәІб©үЧІвЈҹзҙҫг ҳдҺӨжЁ еӢід¶ӢгӮүеҖҢеӘҜбҙўж»¶Л–еөҖбӮһж§ҳзҲ®бөҢаӯЎз©ұдҶ¬еҡ”бқҪвҢҗгҳҠаЎ·жЁ°аҝ°дүЈж ҡвҗӯжҖёе«‘бұҚдүҢб©ұдўёдҶҲбӮҰд–үЗ°гҳӯК’еҢЎвҠұг…ҢбҫҘаөҖдңЁд§Әд…ӮгӮұвӨјз’ӘбҰ©гәҝжЎ¬гә№б‘®жҘ“ТӮдҷ¶г”…Ю©жҷ©д·ӮзӢ«д Ҙдғ§ЧҲеӘҡбҰЁеЈүгһҗбҰӢг•Һе©”а«№е јгң‘бІҡеҘұаЈҜзҘӯзқҰвјІб№ҚвҸӨвӣҪеҳңв·әКҖе‘Қвҙіе®үЫңе—ҢзҠ№бЁҚе»ҜбҢқдҒҡзҖёб’ЎбӢ¶дӢҸвүәеҖІб©„еҡ“г ұа®ҪеӨҙз«ӣв’‘бәӢаҙңбӮ№еҙғбҘҪаұ“д—ұзү«е§©вҜ—вҮ»в¶—еқҘдҲІб’¬жёҰжЁ“бғҚж”–вә“зәӣгҜ№гҮЁеӘҖв®ҪдӯЎгҰЈж°өа№¶аӘҮеҲҮвӢҡж©ҸВҰвҪҒб„ҷаё…е»ҹбҒҙдҜҠзіҹа ¶Юӯв®ҝРҢеңҶеҢ’а ҶеІӯеә«д·ғаЈҝеҝҠаҘ®б‘ҢжўҗВҘе–ҘвҒ“вөҮдқәеЈ’НӘдҠҙбӢқе§ дөӢж¶”аіЎзҷ°з«Ёгӣ«еЎһжҜјбјҘе»үД°еҪүб„…е ҡж¶«дўӮМ жҲӯдҒ„бӨёбҗҫЙҲвӣӮжЎ‘ЕЁвҗ е–°в»ўз ҜВӨбҳ©еЎ…аӘҠж№’аӨңг—Ёг„јзҗҰеҷӯеүүз•Қг“¶гөөбӯҲз—үеЈјаў•дҙіжӣҡбңҠдӢЁжүҘеіөд–Өе©ёзә®еў жҰұг¬Іа·®б°ұжҮ—еҘғг¶ҲзӢ–гҹ№вҺ·гўЎбҗ‘ЛҺгңӣдҗіеӣіб°ҖзҮәзҺңг®ҙзЈ®вҘүдӯІд„ҠаЁ°еҗӣд•”б• жҠ«жӘҖзӘһд„Ҷз»°зҚҘЗ©дҳҖвЁҮб·ӣжҡҠгҪҷзӯҝзў·вҺҙЖ¬зғүв“қбҰңаөҡе·¶гЁЎгә–бІӯзң—Ю¶ж»’зҖ’Гңе¶ҺвҘ»д…ўбҗҫвәӣеҡәеҮӯвҗ”жҙғз‘ӢдӯЎбІ¶г»ҙаҜ•б…ӘзЈӢжҫүзҜ•в•»б–Ҡе·қбҹ»ШҸе”ҙбҶ”б…ҝаҰҲгҶӣз°һз—”ИңвӨЈдүҫНҹжӨҰв·Ңдӯ¶еЁҮж„•бқҲеҲ№гҠҙб»Ўз‘ӣг©¬е„”еўҮЪҷгўӨЦ–ж«ІбҜҙгҠ”Ъ„еҷҘз«ҠбҖәД·ж«ёШўе»»бӮ’б…ҮеӘ“дҲёв ЁУјжүҮбў°дҶҠбҗјж ёhдҖҘвҘ бІӨзҳўвҠ§Ъ©д‘ҹг —жІ®е„Ўж•җаӨӘг…ҶвҸӮП„ж‘§ж’–ж’ҲзӨҲзҲізҒҖТідӨӘЗҗг№ҷаұҹдҡӨеӢӮВҢЫ жӘігІ°бҡҘбҹңе…Ҳвңҗв©ўб—Ғе–ӨбӮҢГ‘е°ӯдғӨбҺўаЈӮвҚ НЎжҰҗд’Ёз№ёз’Ҙаұ°б®је…Ҡа ғдҳөвҶІгӯ§дҸҶЯҮаәҳжҢӣа«җдҢҙгҮҰбҪівҷҢжҶ•ж»Ӯг©өдғёв¶ЈеЈӮгўҗвңұжҘҺЛҙз’іжғңаҜ“жӮҜдҢҳв¶һвҒ д„ жҪ«е§ә#Цүбҙўж· бҢўвЎҶгӮ“вҗҖгһіТҲд—ҳајұаЎұХңвҙҝв„Ӯа°§жүҗЙ„б‘Ұвҗҙд¬Ҡбң®дҰҫж¬јгӨӨг–°еёЈең№rдӨўбүҶаЈҒзЁӨвЁөб®ғв”©г§Ёгң»жӮҚЬҖжҙӯдҘёжё°ЙҸаұӨг„•з•җдҝәв’®г®ӘгҠҡг„ўг•”жҡӢдӣҶд®„жҪӯбәҰд–“бҠәгө°Ъјз§Ўгүқг Ӣж»Қвӣ„зёЈзұҸе ҡж¶ғгҖҖж©¶дңәз©өз©ҙеҮ…жё”аҘ°С“дҗһв«Үе¬ҜзјҲгЈҝж№ҚвҶҚдёӯвӨҢжөҙдіідҙӘв…Ӣд°ҙз“Ідҙ«д·”Оәв ІвөҲж·ҠжөЁд«ұЦҪв•ўд·–дғ‘Lж°°Ф¶гҷғгҡәвөјгҖ„а •Эҡв°ӯд«–а¶ұгқ‘гӨҡжҶҲв—ІбіҷвіІж©–еҲғжӢқдӨҠжҹҡвҲ¬ж·ҹдЈ°б”ҳзҮўд№ҶЙҚФ¶еңўвЁҙзӮӮжқҳгЈ–ж…үзҳҗбңӘЧҗб»“ж–ҳдқһв“ібәЎвӨӘж©ҡвҢҘгҝһа§ўвЁһб»‘дҜ•зҗ¶ж«ҡбҗ„гҒЁжІҝв ңдӣҖб”ҙжіӨЮҗг—ЈгҒ№вЎҳбҲҡд»Җв¶°дҚІЙҒвҒ—аў„аӨ§дҲҳб—”бӢӣвІҹдЎ¶вҒ”еӮ”аӨ©в«ҡе•„бӢҲжұ·аЎӘд«¶дҙҝзў©вғ”в¬ӯдҙҜМ—аЎӘг¬ӯаҙЈдҸҸа№Ғг®Ӯвө”а¶Ҫд¬Ұж¶…гҰ»дӨ¶аұ’з—·дҒ•вҗҙбҖһаҘҮеӮҒдӮҜвҰҳб„ҰгЎ”еұ„дқ¶дҠӮзӨҪеЎ‘вҢ„еҖ’г’қе§ҙдў–б·Ҷб·ғе…®жіӘдәЁжҶ§б•ҸжҢ”ИіжҮҸб–өжәЎдһ·зјјзёқдүҖб„ўжЎҢвғёЧҖзӘ®дЁ°дҮ”ГҖвҙҰзҖ§з„Ғд ¬еҝ’а әаҰҳж·ҠзІғе¬Јв—ӨвҘһдҚұдҝқбӨҮжқӮдҳ—а§ғбЎһжҶһзҘ—гЎғе“”вҸӮвё“гҘҹдҘЁвҝһдҶ„бЈ‘д’„вӘһв¬ідҰҝбҘ‘аҫӮвҚ“зӢҚзө¬жЁҙа ”аҘ’жҢҳМ„в“°а»ҷеӨівҙҖгІІдұІбҺұбӘҡб“өдӨ·е§§ДӨж Әе¬ҰгҗўвҒҒгқ•дҒҝзЁҖб…әбҠ¶еҡёвҙҹдҸЎж°ӯгӣҲвӨІбҫ„з„Әбңәв°§в©ЎгқҖзў”г‘Ҳбү¶жҢ…вә зӨҲб—ҡг“–гҒЈвіҮЖҒК¶гӨөвҗҢдҸЎз’ҶгҘҹгҙӨбӨ„Ь®г ёз“·а№Ғе№„дЎівіңдүҖж—ӨбЎӣжҗҙбәҢб«Җв ҙбҺ¬а·ңгҫ¶жЎ°жҙ”бӨҡЛҖвҒҙб’әдҠҒгҢӘд”ҘдҚ—дғ–бёҜд·ҒдҗӮбҶӘдүІгўҒЛҸд¬ҒЧҶгҠҖд§ҚдҳҒдҸЎзў•ОҶеҖҒгІӘЖ°вҸӯвҖңеӮ®вӮҹзЎҢбёўгҙ«ж№•еЈүвҖңзў¬вҹҠвҺІбЎЎжҜ§бӢһжІЁбҺұО„в°Ҝдҳ—ЦңвәЎб‘ вұ«дӣҲжҳ„в•җж–ҒвҷӨг§ҖвҶұжҙ°вҠ–еә«вҶЈгүҺжӘҰб°·зұ·б”ҰбҲ”жҶ¬бҮӢбҢ°УҲжёіжҖ·зҮ”ГҲг•Ҝдұ¬ГҶбіўеё д ¬ИқдӢҫбҸөгүҮД„аЎһНўжӘЁзіҠж“үзҲ•е©‘жҸҮжӣ№дҪ жҙҘжҺҜжә‘бҘ‘еұҪеҳҡбҫ‘д•–г«Һд‘ҫб–ҫж“ұеәһв§ҫбўһвҫӯбў№з·Ӣа«һг®¬ЙӯзіөдЁ©з°•е„ҝзҶҝжҙҖжҙ§дұ’бҺұбёһдҢҶВ’з…ҠбҳҢдҖ«вјӨвЎ·а§ Jдә®бҚҖбқұзҖЁбү¬аҙҖбҗјбү®Ц№бҚ°б“”д©®вқҺПідҮүг©ӯв–ҫдҺЁб—јді”в…«бҸЁбҡ¶дЁ®зң№а«ҷбҲ№зҺ°бӯҳгҠ—вӮҢбҳ¬аӘғдЎҳбҘұжҒҚз…Ёа«ҘбӨ„гё®б…»дЁӮбҪҗб…Әб“ӣвӨөбә№вЈӮдўӣд–¶бҗ¬дө®е•ҒвҙҹбіҒдҒӢз…ҙжҲӯб—ҒдҢ©жЎіа«ҜдҡүЧ”д¶«вҘ¬бӨңеӯӘд’ӣв Ҫбў№д—“з»ҳвӢҪб»”вҮғгўҳвҺӣбЎ„дү°ЩҝдҸҚдҜ…иҖғЩЁвҲ©вёұбЈ«бҰңгҲ¶дў№д”–еӯҚбҺ¶дҡ№е’¬жҷҜд—“б—©гі©дғһзҒҠб•ҘвӢ®аІ вҙҶдҺІаЎҮвҘҙжҠҒб·Ҳд«Ёд•ҸШҹжіұз”ӯеҡӣвҗӢбҸұбӣ«б·“гҚ°в––гҸ©е¶°жҢҺжҸ–дЁ®вҙҝзӮ·дҚҰаӨЈзҒҹДҷжҸҫд©”б‘ҳеғҲжҳҢбҢҰж’°б ӨдҸҰд·©в№ҝаІ•вҷҳгҲ—бҚ‘б§—бҰҙг…—еҢ©гЁҮжҪӮбӨ·жә‘зҺ№дңҷзӣЁвҰҰзөҸбҙ‘бё‘в§ҮжҸҙжё‘бҹӯж§Қжү–ејҖаҝ«ЪЁбҸҷЪҶвҪ…бўӮгө бөІжҚҢв–•дІҖвҒҖа§ҰжЎҹзөөСҺвҡ«ж—үТ бҳ„Х…вЁјеҺ¬uз®ҶжҠҹзҰјжҠҘгӮҚвәЁгҠҗд ҶеӢҮЩІКҗе¬јгұҠвңҝзЁӮбӯүдүғОҸг–“бҝәаі’аәӘзҲ’жүңвјЁвҠӮв¬Ҳе №гқ„гҶ‘гЁҲб«Ҙз№Ҝз¶ӢЛҳе ҙзҹҰзӮҖд¬“в№№е…үаЎ«д„’ГүвӣҶдҰӣвҰ„еқұгҝЎв јдҺӣб»ңбҜҲаӨ«з„…бөІг®ўеҶҶдҸҠд№ӯгҜ°б”§дӯӯбөҙзғӘбў•вҰҒвЎ„вҜЎе©івЈ¬е”ңв‘өеЎІжІҢе¶Ңа ‘гЎҺеүЎе“ұв©Ңз©ҙж§қб”…гҪӯдөӢдҜўб°№дӮ®еӯҳгҺ ж•”еҒҗд„ЁЦ©в»әгӮҲХҙжўўеІ№еғӢеӯҠжҰҷеҡұбҮҖж‘ІзҖ®жјўаә«бҢ·вҠ»б©өд«ҚжәғеӮҠе—№г«ҸвӮҠз“јд’ б Ұд §аөҝЕҖг°Өа®ӮдҮ…жҪҖг ”дЎ”вЎІЫ‘бёЈдӘ°дғӨа®ҺзөҰаҝҹаҙҮа№ҳг”ӮбІүбҘ‘Э•гәҒв¶ӣд…„жҮҶдҪўб№өе‘Ҝб әзҳ’гӘіжҗүд·һеһӯеәңзҲҸбҹ•аҪөзқ·ж¶һб»•дҪ КҒдөҹбҙӮз„Ёгҝҹг·…жҢҖгЎҖв„Ўв«‘еҙ•д©өд‘ӮгІҳеӯјз•ҺдҶҡб–’е—°д¬„гҶҰв©Җбҳўдіөз„¬П°еҲҶб»–бүҝзӨұе ңа¬«бҰһа«ұеЎҘд°ҮвҢ¶б°үбҜӯзүүаҪ…а©–дәҚбҖ”в–ҸгҺЁд‘ҡаҘҲгӨЎе§©еј„ОҖзҰҶз‘ёеұјеӘҺдҪқбЁӯд·ҘвҢЈдҫӨЫҹжҒ…ОғзҒұгҗҗгҫҢб»—д°¬еҸ¶д„ӨвЎҶзҚЎвҰҷеӯңЛҖві„аЎӨа¶Іаҙ©а®Ғвө—еҙҙбқҮд„ҪжҶәбҳӯеҰҚжјұеҢөеғ–еҮ‘е”ЎдӯҚб„қдЎҮбЎ®е°ҚбҺҒвқ¬бӯјгҺҢеҢўзӯҠзӘӣдҺқбҢ…ж®ҮбҺҠд§јеҙҚЧ…г®„гҺјдҗ•жЈ®зӯ«з®қеҢұДүЦҠгүЈе„өг·’д•ұв®үвә–д”ҢгӨ…жІіеҷ¬б”ҸжҶЁжҚ–д©ҫвҹ’гҲҰГҫжӢһжЈ РҘаӯәдҚҖа®ҘдҫЈеЎҲе©ӮеӮ№еҲіж§“вё–еҝ“зӨҹжІ‘ж”°б“ЎОёбҙҒж·ҷдў–дҸҡвҳұж’®вӣ§бҸҸжҒҚбҖҢгүҖжӢҳд„ЁдҳҢз’ӨжҸӮвҹ‘жӯ°еІ—бұһбөҺа·¬аҜЎгҘ„аЁҗгҸ„жҠ–зҚүбё’гӘ®дҠёб’ёеҮҡаҘ‘в»“вңөб·®Н®вҢ—еҸғб·Ёа·ўзўҖа ¬зҺҲв№ҳз’„в ІВ»ж©Һгү•г•Ёе“Ҷбӣ бӨ«гҖҰеҒ Л®жһҶвҖІЖҘвЈҲжёҘв ҫзҮҳаҪ‘жҝҘвЎ„еҒІЕҖбҘөд‘ҢеҒӨд§Ұеў…дҜ’вӮҸбҶ°в–—вғҠеұҠа»ҺаӘҰеҗҪвҮҰаЈ°зһ гҖұбҮ‘Ц¬еҺ–а°ёжҮЁаҰҺаӘҰе®Ҫеў¶КҺз–Өжұ–жғ аўҠе–ўбұүжғ©дјҺгәҖаҘҡвғқжӘҫжұ“зҜ—жҖЎг ҫж„•вӯҳгөғжҙҫдҒЎИӘГЎВҫв”җгұҢбҮұаӘҳз”•вҲјбӮЈвҹҲбҙ“жһЎг¶үжұҫзәҶзЈЈбҶңгӢЁв’Ҫаёөж«ЁвҢҳдЎӮбіІЖ§б«ҠзЎ„в «зҶҺгҚҪг•Ёд ҜаӨӘЯ гҢӨвһ дҮҳа»Өе¶«в№әз–Ӯе••б…’а§үжҚӣеғ©жјҲвҝ‘зіӣеӢӮг—үбөІзҜІД‘дё“аҫ•зҺ—зҖ„бЁҠбҫјз©Ҝж’•гҫ«е¬ғгҒ·еҶ•вҝ«а«ҜзҠҖв’қЛ®в•ҺеҚҚд¶ҷжј·з¶Һз©јд®Јд…Үбҫ‘зҰҹб…ҳвҹ зёҫЮәбҸ¶бј¬жӣҢг“°еәұзӣөгӨ»з¬”бҲқгҙӘзҪӘб©әвҒҘб©«жӣӮвӘ гһәж…үДҹгҰ№бұӨб©Ӣб…№бӯҷбӯЎгүҺеҺҡЮ—вҒүзӯӮа©әЙјЭ”вҢҝвҢ«б°ғдҰӯеҲёбғЁдӯҲгҢўеңўзөӨЩ”б•…ж•¬г„ҷеҘҚТҖвҢҝдЎІдӘңвјҳеғҪв©”а әдҘЎдӢҶжҰ‘еҚ©віҚгҳ…в®Ғд¬ҠбјӨбҚүдӨҒдүҢеӮҚжӯҢвӨ‘е©ҘбҰҚSвЈўжӨҚжҖңЮӢдҷіеҜўбҳ…зӮЁбӨҸд©¬г‘ҘгҢёвҷјвҚҢг„ўзғҲдғ„в®ЈгҙөеІҜбҰҪжҒҖдјөз•Ӣд„ҒдҶІеәҢг…Ӯг№һзӮ еҜҘдҖ№е‘ҫз“…жҷҖгҘҜеЈ¬г¬®дЈ№дҜҖе•«дҹҺж·Әе«ҲбҶ е“Ңжҷўеј—а «Ъұд…Җд—ӯжӘӮдҶӢе· г®ҫжқ§аҝҳжҷҺв„ЎдҒӢж–’віҷЬҸа¶ҺаЈҮд«ҪвЁ—гқұе–ӮгҫҢПЁз¬ҹгҜҚгҺҠеӯҝдҳҘзҚ§еҹ¬зҲүе№ҫзіҪг”ҷзӘҒзұ®д·қгӨҲзҸүвӯ…ж©јв¶•гһға©ҹгёҗз·Ҳеҹ§жҪЎеЎ—дҒӨзұӣеңјдӢұб–Өб—әдҠ’вўІдҡқв‘ҸеҪҪвүҮФқеіёз§Ӣвӣ§г•ҘЛҪбҠұгҡӮвҰҲеғ•ж…ҘбҚұеҹҒз’ҸжҺҖЭЁе©Әг«»бқҒдңӢдҷӣдҮҫд„‘бҜ“гұ¶РҪгң’ЫүеҜ©гүҲж„ҢдЈәдҒІЪҸдңўаӨўзәҚзҲҝаӘ‘ЩёгөүОҖзҚ аӘҝж©ЈбҰҸдјҒдҗҷеӘәвёҢгҮӮд«·ді…зј—а©Ӣд…ҫеҫ©е»”б©ЎзһӨгўҒе„Ҫб»ӨдӣңдҫӨбЁ…бҰҢдһҝд®ӣж«…Ц„а ҝгіғгҖҖгҘјгҺҚеҮғЧӮжЈ·зңғбҗӣгЈ«зјҡгҰЁдҳҚдў«жҡұдңқеҳўа¬ёвҙ°гҜ зҹҒг„Ӣеё¶гү„дҢөгІ¬аЎҺвҖ еұұб‘ӣгә¬аЎҝжҪ·г©©жҲҶг’ЎдЎұб…Җж–ҳдЈәб„ғгүқгҡ“дқ»б…§д»ЁзЈҜгҗһдүҠгёҘаЁўдғ…аЈҖзң”вЎҺв…ҙбҖҳж¶ҰгҲҡе„ҳМ дҝҚвұӢбӮӨз«ҷдңүбі„жҜӨз…қв§Һвө¬дёҫПҪбӨ·д§ вқҜбһ‘Эҫжөіеҡ—жң‘вөҳб¶“зҲ·е“ҮгҠ„б§§гҶ¬з»қеҝ«еқҖжҝҹа№ҖеўҰЖҲа¬Үа°ҜдҜҘгҫЁдЈҡЫҒбҖ—з„“дҪ§а№Ҳгү„еқҢв”ҸеҲІв «зЁҳг©җжҖҶвұҚб”ҙгү«гҙ·гӢҪзҪҘгңҗбў·аІөеӣібҺ«дҰ·зҷӯж—әвөүеҸ©гҗ»зү·гңүе§Ҙж°ҫгӨәеҠҠзұӣеҸҳбҺқд§№е•Јжү…з„ҢзһҲгөҙзЁјзҳқзЎ‘в¬ІЫҮг„ҳе№ҢиҖһгҝ©д°ҹаӯҰз—…бҚ©жҘЁдҳ¬бҠүгҸ»гӯ…з„ҚдөғЛ…жӯӯз „гһӣеүів·ўж§Ҫб©үжұІжё•гә–зёұаҝҫеҹЎжҝӢз’—ж¬ҷбё•гјңеЎӘзҢ№ЗҪж»Ңг”ўе„ҢдҲҒзҜҖз®№гІ®вё дў•з–өжӢ©г”ҝз„Ёд„ӨдёҮвҘ¶вӘЎиҖ•еұҮж–•вјЁзүөеӨүбҲҢбҪҗжөөд©қвһ•бҖҠжҖ”г…ҒдҖҫдҒҹаё¬ж„Өд ІдҒёвһ“з•јдЎҗеғҶбҚҫвө№дәҳдҮ©зҷ•з¶®зҠҒеқ’г‘¬жҡңвөІз„«в§ҺбҮ•д¶ҫеҸҲгЁҠеҸҡгғ®е¬“жІһвәја Ҷбө¬Вҝві®еҗ•дЈ®ГёдҙҶТЈвұҝд…һбҖҳМңзҢ•еҸ¶в‘ЎбҮҮзӣ©аө–жҡ©бҙҸгҢҪвҢӮд…ўвҰӯб»ңвһЎгҰўбҠ—бӨ”б„«д·„г„ӮдҘүз»ҷбҠҡаӨҹв¬·вҖ•д°®жҚ«еІ—в•ЎеғІајәг““бёӢвҠ§бҠҺз§–ж’·ЮҢеј—г…»еӯ—бҶӣгңІд«ҺбӮҠР„вҮ“дЎӯжҠ§жҘӣгӘ‘з»Ҙв»Ҫеңів”ғзӣ¶бөІаұІз¬Һд”§Ъ©еҺҖбҘ‘аі”зҜ—дӯ·бҪ©её“зүқеғһе®ғбҷүг¶№гә«г°ӢвҘҝа«Ҫвә·в·ұеҲөа·ҚеҶқдӘҲгҹ»вӮ©еҶ»дЁ«вӮҷвӢҳаҜ•е№·в¶ҝз¬«е·ўб ҸеұӮд„үа ғМЁз»–бҘЎж¬—а°ҪгҺ•бЎ»зқјж‘«бҺЁбҗҺдүҖгӢ„дҺәз№ҪгӯҲвҷҲгңңз“ҖвқҘжҺқзҙҡбҸҳе·Ұж»ЁжӨ„вҢ№УјРҺаҜҖвҖөбҲӨбҗәдүҘДҗГ§е‘јвҠҷвЈӨвһјзіҠеғ„ЗҲбҗҷвҖ“жұӨвүёдҲ•вӣјеЈ¶ең№гҜ„жҹҳвӣ«зҲҜв–ҰРЈЗҮв§ЎзҘөб§”зҢ¶аҜ¶дҳҲаҙӮдҒЁеәҲЦ«зҖ•вҗұеҘӮвҜ®СңПҫг—–аҫҗзҹҲд’ д¶јжі”вӢ·вӣҲбҢңгҗ©зјјж°Ҙд„ӯзҸңбЈҫзўҠдёҒаёІб«®жҺҹвҢ·вҘҲзҶ•еҜ§аөҰв’ӨаӯӮд‘Ўжӣ№дҗ°жҠӨд…ңХЁб‘·гҹқбЎ•зҜ«еІҺб–ҺаәҶд•ЎбҮ№е§ҒеӮ…зЈҸвҜҢдҘ…аҪ”аҜ–е”№зүқжғ“вүҗвҸҢеЎҠа°ҜК«Ы§ХҫдқҚбӮӯе•ўвӯӘгһ‘а¶¬бӮ“аәңеҢӣвӘ®вҫјдҷҶдӯҡв«—бҠӯбЁӘг»ұеҫҶКқб–қеһҺв§ғзңғеҮ—зҡҒЬһжҗ…бІ…гё–д‘ҳЭёдҚ з’ӣдҲҺеүұбј…аӨ«жә”д§қж»”бҒ‘еҰідҝҰИјЙјЛҚдғҒеҘға°®Г„б№ӨгӯҪЯҹг‘ңа ’е‘ҲзҪӨгёҺжҖөеіңд’»е»Әwе“ЎбӘЈП„гҷҢз®өгҰІбҺҲеҮӮгһҗа·ұаҜЎв„ҜаҰҘгі©бӨЈдҡівұҳвҠ…г¬Әаёёг§Ўж’ҝаҜҶб’җв§Өв§ҹвҷҶЕ…аҝҫв„Ҳајўе“ёв¬әдҙҠгӮүеӮјеҮӮв©…бё§вҡҖГҰбҒігіҷз»ЎжҸів ¶аІ‘з“үдӨ жӘ’зҰҒб§ҲжҒібўҲа§Ҳбі¬гЁҰд”¶зҫ…діЎд•№дҳ з–әдӘ…еҰізұӣб§Ғаҝ“аЈ°вҜўбӨ§д‘®жҸ•гҷ°б·Ғаө б”©жҒҮаұҙгӮЈаұӨгҰЎгҚ–д ®в©·дё…жҶӨбҚҖдјёаЁӨв Ҝжҷ“дӮӢеҖ“в…ӯбҗҘбҖҪ(ЗЎгҗёбҲ¶а®“бҙҘгқҡВ“LжҠҳдҸҳвЈ“вӢӯдҖ¬віҪжҠҡаЈ гұ»бё¬дәұбҳЎзүҖРҫаўҷг” еӢ»жҒҠв¶ғж—…е№ңвҖҖбҰүзҒҶгіЎжӢ’ж„ӨзҡҳзўӨбҲёдў‘дөүВӣаіңв…әеӨЈвҰҪз°§б®ұд‘„в№ з Јбқ°еҒ»д·ҹШҙаө вҰ“жҗӘдҷ•гү•вҶҮв®°бӮЎдҢ«ж« дұ·гӮүзҚҠвҖһжҘҡ8гІЁЖӘг©ҖбіҮбӣөбҖҜгҳ·г•ӢаЁ–е– вҺҒдҶӣбҹҚгҪҹеҡӢжӘ№жә©гҷ©бҒ Е¶её¶а¶…з—ғд©–вҢҳг…ҠзјўаўҗвҒ©вүҚСұЛұбҚөвҪўе“ңзҹ·дҒ„жһӨзҺ„гһұбҠёвҜҹв« зҶҚж°ӯбҠідғҹдҸҳа«ҘбһЎбҲғВҲзҹҗд…ӯеҘ…жӢ»гўЈзҰҗзҜ«е°әг–ҒаҘӢд¬ҰСӨд•ҲеЎ’б…ҪжҢ°жҲҝФҚа¶–гӨҫСҢвҺҳдҮӨвҸҺб•©е¶ӨбҲІаЈ№г§Һжҹ·гҖ„бү¬зҒәв“җгІұб“ІдӘұзҮҳжӨ·дҝһдӘҰаҜёб–Өаәҗдё©гү…жғ•з…Ңе„„вҸЎе¬ҷдҠҙаҘ“зҡ®вҜҲжӢҝвҒЈа»ұа©җзқ‘вҺ®зӮҙвҹһ[в°ғаЎјгҠ‘ЦЎж¶ғРјдӨ«аҝӨеӮӘдҗғе—ҝдіҠдӘҰд»ҚвЎәг©Өа°қЩҲг“ҳжҢғдҫӯвҒЎвҲҶбҚҗО®вҗўг ӨдҒңеғјРҲа·‘в”үзғЎдҖёб•ҪвөүзӢҖдұӘбҮҲвҮЁжү№жӢ¬в’ҡжҰҠКҪзӘ“бҢұгғӢж—ҷз’ҫдҳЎаҪ№жҖҫгҪӣаҘўз®ҢбІҶвЈңжү¬б•…г іжЈ бғҘаЎҲРҲб°Ҫж јеүҜз…јбҒ«Дўа¬§гө еү«г‘Ғе•ӯТҺжўүеёјзҳўб«ҶвҡІдҶҸЬЈгј®гҒҹзғ’б—ӢгҲӨв’ўвҮІзҲӨаҜҒб©»бғӣж—јвҲӯжј—гӣ°еқ„е¶ӘзҶ“дҹ©бҲғгЈғбҒҸаўҚб ҘбүңбӮҙзҒ“Яҫбұ…вҒ№дӘҜд©ҲбҙҘаҫҮеҒІзғ°ж…ҒСЁеі№ЦҶд„ЁжӮҳб–’вҶ№fз‘ұв°ёг·“З§еҜӮдө—НӮЕҶб„ёе“•з…№а©»д·ЎгҳӮгӨ№зҒҰбҮҫЦ дҺҚгөІзҶөгҹҜдӨ–зҙҷаҙҸдҫұжјҷзӨөб‘јгӢҪвқ·жҜҙзіғзө¬г·ҙгҪҳбҘ–дҡ®дһһжүӣдҡәб©ҜеҰ©жҜЈж®ҰгҲқб№”дҚ‘ВҚв¶¶г’ға ёг”ўе»ӢвҢҪгЎ’еҚҗдіҳбӘЎеЁЎзһЁвҙөжӮӢжғөТҠж…ӣзҶӘд·ҳжҮ„жү¬бҖ жІјд°…вөӯд“ҒзҳҚг…ідҰҒжҹҶзў»б»ҒжЁўзўқб‘„жўүв ӯаҘғВ дҰҳдӣ·д„Ёбёёдё°еӨәеҖҘбғҷГҙЫқг®ўдІ ХҖгҒ’еҷҫбҚ–б‘Ӣж ёв“ғЗҰвҳ¶жә¬зҢЈбЈЁеҘӣаіҢвҰ‘д©«еј№гүҲбІәгҜүбҰҘжҮһжјЈХ’зҰ’зңҘОҲвҺүд¬’гә№зЎҰбҰјзҲ©дӮҢж —З¬дҚје·Ҙд©әвәӮгҢҷд»ӨвәҰеұҘеһ¬зӨЎаЈҠдӢүбІҝа®“а¬ е‘Ҫеі№гҚҢа»„в¶ҳе©Ұж°ҙеҷЎв§ғд„өбіЁеӣ“в•Әзә№гққгҚҠдӘәа»һб№Ұе’Үв© е„ӯвҳҚжҗ°е“°в„®еӯӢа©—г“ вҠ¬дүӮв§ғзіҲзҷҝбҮ®жҷҠбғҲзҢўдӘЁеёҘвӨҢд“өа»ҙвӨЁдӢ«б„үдўҡжЈңбҸЎвқ”гә‘зӘ¬б•„в’—е—ўдЈӘеәЁжҚ§г¶әг’Ҹе§„гҰҙбңҜвҲңаӨ‘е‘”зҫ‘вІөФҙРҗв»үбҠ©жҒӣвҮ«бӯҝжҠҡб¬Ёз°Ўз¶Івё¬гҒӨЩ°аё вҸ„д”Җе§ҺгӨІгЎҪбҺ«б—ІгүҒв‘ёеіӣеҺ§е’ҳдӢҷб№„з“§жҠӢжӨўв—·б–һО’г¬ӘгқҲбӯҙжӨӨа ңбӢҳе•ҒжӮӮЪқб§ҸдҮӘвҒІвў“ЦҖзўҪз••вҳҒд·ӨдЈһаЈҳаІәзЎұдҘҶзў№б¶Ҙб¬ўеҶ’жҚҠжҪҺКҚзҸҰв»ҫбӯҮеһҙдҜҲбҲҹж§ жҢ„д‘Ӯж№®еҚ“жјёвҠ„аЁ—дҹ–зӢӣеҺ®бұүвңҖзҰӮб‘ӣа©Ӯд‘ҙзҚқаӨқз…ҸвҠһвҷһб Үе…ҰзәҚгӘҹдҶ«бҶҙвЁҪзүҠзЈҖЕӘвҢӨгӣӘв Ҙеі„е—Ҹв’ҡе©«е©ҹв·ҚгҺЈеҹ“гүҲз¬ӘеҠӯеӢҠвҺҺЬӣбҒҪеҜүе§өз®»бҺўж—’гЎҺжғһе•»гүӢдҚӣеҡҲз®…гӘіб‘ҜвҰ’д–°е¬ҢжӢғж»¬ж‘іжіӨб Өвў…аЎҘбҮҶеІүдҗҙжҘҮзҜҮгҖ”гәЎбЁўзҗ·зҷәаӨ—Ф·а¶®аә“дҶ дӨӨдҖәж’ӘдҠҡЪ вүўжҖ·вҢқд“ҰаӯҡгҖһбҮүа®ҫг–Іж©ҜвҶёеҒқвҸӮа¬ҜбқҷвҷҠзҸҪгҮҺвҪ®д¶ҰгәјбҠғгЁҲвҡӢЛҙаЁҲзӣЎгӨ§е©ҝа«һв‘ўбҳңбҰӢз®Ізҷ’з„җв§ҠДЈвҝ”аЈЁбҒүаІҰН©вҠҖв¬ҙгғҷжһҫгҠ“Ж¶в”ғб¶„д»№гҷҜзңҫж”ҖвҸ’вӘ’вһЎзІөбҢ…вҡ„д…”ж”җбқ¬жӣңаіҜзң»д”«зҢЁгҗӘвҪ”дҡ¶дҠіжёёзңғе©Ҙбҙңз‘іаҜ•д·јв¶Ғг—ҜвҺқбІөз«ғзҫ¶б®®гәӘж–ӮдіҢзЎҲбҚӢвјЈвҙӯгҚҖвҪҘбӯ№ең§еӨ°еҮ•г№јдҳ»б§—б«ӘдёҗжіҸдЈҚд°ҠеҮ№г»Ҡг¶·еҒӢд…Ёв”ҳб’јеҹЁз„ӘгЎҚбғӮдҢ’а«ҖжҮҷгүҡг®өжӯҠвЎёжҘ®б®әб…”еҲўжҪүЭүТҝаұҫжҹ”г–ҫвқҰдӮӮа§Ӣе…ҸдҗЎ8з•¬ДҒв“ёаәҢдөЈаўёгөҖаЈӨзҠҚаұҫвӣ‘дң”жүёжӢЎгӘ·ж„ӘТҖзғіаөўг»•вӮ‘гҢҙжҰ®гҶ‘Bnвқӯб·Ҡбҷқд„Өжҗҡе’ўбҖҗд«§в¬°дҠ„жҡЁН¬жЈёеҖҒд¶¬віҪајөдө…ж”ҢвӘӨж»§гҡӢеҰ з„ЈдҖЈГ„в“ҷе¬өв Јвўңгҙ“дҢҰб¶үгЎӮе‘јвҹҲе„ҹдҶ”а»®а¬ғг””в®«бҖ¶в§һг…ҲаіҖгҫ№гјІYж  Жҳз‘ҫбјӨбңҶзҚўжҶҳжұҢеһЁбҢ®еҙЎд„ҸаӘ—бү®з‘әе·Ҙд—ҳдІҫзҸһбҗҺбҜЎбҫ©бӢ»зЈ’вөЈжӮҜ)зҫЈвҰҮаҪҳбғӣдҶЎб“«ШҖаўҰбҲіб№ҡбӢҷгҺўгғңгӘ’бӮ»г‘ӘаҘӮеўІеәҡз’ дқ–е’»г„Ҙа©Ӣеӣ°ЖӨзўӮвҗҜзұқз»ҮбҰҮв»ўб·җж¬·аЁәд”ғеүҙЫҮдҠңгңүаұҫз‘©д—“ЮёеҒӘж–«а»“в§№ж¬ҫгІ‘вӯёвҜҙЬ¶д®»з–ұб•Һб’‘еӢӘаҘјжӘ¶е’Іе°іВһв’ӯе№”ВұзјӨз°ҝв«ӣжӘ°бҗІд‘°зҒҘж©җв‘…Иҫа·јГҫжўөвүўдҷәвҗҝТӯаәҸГҠеЈӮа«үгІұвӯҰб•ҫвҘҺвІҙз ідҘ¬еҳҖд—ӘеӨЁд¶іЯӘв«ҳзІөвӯҜдӯөв‘ІвҡҠг•ҫжҡ–е•—ж’ҜаӯүгјҖвҗӘз§ҹдіҲеҺ”аҰӘв…Ҳз»ЁзјЈжҘ№в јбЎ№еҫ§аӘ дҘ еЎ–ж«ғж·ҢаҘ”дәұзі„жң„вҝ—зӮәж’ҡеҙўзҲ‘ж•©з«ҸдЈҹв°Ӣв•№вҹЎбҗөз°ёб‘ёУўдңӨбҜғб“ұз©—г•Һжі®еҗғвӯҷв§№а®·бҚөгҘҘЦүеҗ°вҶәз…ҙе§Ҹзӯңеғјж«Ҡе“”гұҘж§„дё°ЩҢв“јгғ—дғҠвҘғзЎӯвҢёгҘӯеү«дҹ®д–Ӯз•ЈбҷҢЩҸ[аӘҮб…ҜаўјбҫЎгқЎвӣЈа¬ұвөігӨөвҖ§аұ·бЎҰб–ҮдЎқбҸ•Ф•бӘ•ж§ҸдјҪб°¬ж«ЈбЎҫжҝҶзҳ»зӘҳХ·бҜқвҙҙв»„дҪөе§®еҶ„е…ӯеҒүаҝҷзҲҰбҶҙдЁ«дЈҚжҹүвӣӘд‘«гӣҰаҘ№аІҜбҰӨеҲ…вһҢг№өг…ҜбәҖе–«ж”Қдіңдҷ©аЁЁдғӘе¬¬дӯҘв¶«г„…дӨӣзӮҒдҜ”е•–вӣӘеҸ зіҠеӮ¬в«Ҷж”…в°Һв“«гғҳвҡ„еҗ©гәҒгЎўв ЈжҲҙжё“зј—гҫөді’еӘӯвЈӢв“өд©іг®ҪбҘӘз ¶еӣҶдҶ®дү„вЁ§дӣЁгҢҷгҢ вҪҘб Ҙгі„а°ҚжӯЎИҲжҲ•еІңвҹҠж•ӯдғқаӘқгҺ¶в¬җвҒ•а§—еҷәд…№еҰӯвҡһжіҙдһқвөӘзҹ©гҡја¬ғвҙ№а ®дғҲа …б©қж№»гӣҶеЎ”дҹ“дҚ®б·ҳвҢҢжҜЁзҢұвЎҷжӯӨзӣ«жІ«д‘Қзғ—дӣӮеҡЎзЎўжі»ај¶а¶ҙвө°бҢҗзҙ гҖҸеұ—вӮ‘в“©еүҮвҳҒвһ§е…ҹбіёдіӯгҶёгәҠЪӣе…ІвәҶб–јв•ҢбҢ”е№ӢзҖЁеЈүжӢҖв‘¬жҗӯе§ёа “еіҫз°ӨаўҠд…«жӯ„ж¶әдҖӮзӨ®зӮғЕҝж“©аІЎгҝүе¶¬д©ҹеЈҫг’’ж‘ҝвҫјзәҺеҮ–бҢ—дҗӮвӯ—д°Ғе«Ід®Ҡв©ӮгҲјз–ҙдӯ»г‘әг°ҜзҸ”в¬ҳеӯҘжұ«гұҪж“–д•әд®”еёүгӣ«е№ІеҝқеіӯаӨҰеҠӯб–’ж«һгғҰзө·зІҫеӮҺеҳүжҚҙдғҗбӣӣвөӢвј¶бҪӘеҜ•дҒёаәҲгҳ»а·°г‘·в•°д®ҳеӯһжҡңзӢ®бјЎвІ©еұҡжӨЎвҮөгҖҙвјЁзӮӣе•Һзҗӯеқ–бғәеҳ‘а·ҖжҙҶдӘ°вё—вЎ•зҫ–гҷёаҪ»г»Ўз•»бЁҫд·“жҲҸд–ЈбӯЁз«ҳбәҜгҝәеӨ•дҒҜаҫҗз№–бҘ дҢ—гјӘЮҢаЈҮбӘұа©ҚаІәв«ұаӨөвҚҝзЁ«ж’әОӘаӯўвІ бҢӮві а«әз—¶дЎҮд җеё вЈҰвҢӯг¬•зӣўеў‘[г”җзқҜеҙөб® ај§гҜқдў•г…ҪЭҘе„қз “жҫӘжӮідҗҚвҪҙжӣ§вҮүж Ібҗўз®ӮзҖ·бүҪдөҘзўһајҘбҗҳв‘Ҙг§Ҷз•јдЈҢжўһв§Ӯаі»еҘёвӘһдҰ•Эҹв•ңеұӘгҸЁв“Ңж“„дЁ·дҘ©в«©г’ҙжүЈгҫҸб·ғаҜҝе©‘вҗӣвӢӢаҜҶж’©г©ІжӘ·г‘өбҰ—жҖӘвҜңдҲ‘жҲһИҮаөӘд¬ӢдёҜд…ҡзҘЁгқҒд®№з”ҖбӮ«жҷ¶з»әз—”еІҠе№ӮбҜҘгёўдЈғг«•бҸҲеӯ°д…Ӯе°Јбһ«в·№з§•еҫҠдәӣб¶ҸеҜҚвіҙж§§Ъ—вәҢеһ”жҒ»еҷ§еёҗб– дўўеҮ’в…Ғбӯ‘дҶ°ж®ёбЈ–г–Је¶·еЎ“д…Ўж•јаҫҪжЎўеҫңж®үбғғгӣҲбЎів§»бҠҘдҷөжІҺб„“ж—Ҝбҳ§б®–гҜӘбҸӯгҺ«гҚ„гӮӨЮғаӯ еҝ“еҗЁеҒҮУЈдҜҠаЈҰб·¬аҙҜвЁҜУіТӣжүҗз’ңдҘҷгқҮд№Ід·ӣгҳ·б°®ж·іжӘӢбқ—ејҢв®Ңв»Һв§ЈдҲ•г…”гҺ“д•Ҳзӣҳе№һжҡүеҡүг ҘзЎӮж–Ўд·§в·ёдҷ’з•…бү©гӨүв–ҖгғӘз ҖзҒ ЕөЦҗг“үж«ўбҮқбһ§зі·вқёбЁ¬зҹҖв“®д»ёвҙӢЧҚдј”УҸжјўаӨ…жІӘзү”вғһвҚҜдӮ·а§ңе–ұж“©ајІді·зӯҰбһҹвӢғеҖ•в©ҡе–ңе¶Ұб°һбҖһдҫүг–“жҡ°вјңаі‘еһҲж…Ҳб¶ӣгҗҫв®ҖеЁҗа¶ңдІ„г»„е…ўзҪҮеӣ„еғүбәӘбҹӨд®”зҒқгһ‘зЈ–зһ¬е—¶жӢҰРӘв”ҘгҮҙдғ¶б°»г·ҪжҗӮг·°дҶғзӣӣаІҫаҝ‘е“әжЎҠа©ғЛҗаЈҗвӯҳзҫ…дёӯвҚіжғјдЎұбһ¬в®‘жҠӢзңәгІ‘зҲ”з’–жЈ”а©ҡз®ҙв‘ҳзҘҙдҗүзҡЁеӘ–еҡӣзҲәзЈҰдў„бү«вёөдҮұбҢ…КҒвө«еҶҒбЎәдҗ•вҹғд…ўеӣҳГЁвҶӢвҪ¬в’•е’№бӯөаІӮд¶ңдҺ®гҶівЁЎЦ©з“ёеӨһд¶ўдҷҗбЈҚдіҒЭІб—ҶгҮіеӣӮжҺёд¬ҒдҡҪг¬ҝбЈҷжңға°үе«’еҫҒж¶ дҲӘз—ғбЈ¶бғ®б¶ӮбҜҲгҷ–гҺҚжЁ¶г–Ңгҫ•г–№аҪ№еҰ©зҳқдһҖа«®а¬Ғе§¶зҺұгҒӣдёқдҒөбҙҫзҙўвЈ§дҹ•жҳўЖҢжӘҖбҡ§vдӢҚб№ҷгЈҹвҪјв°Ҷв·§зҪ°еұҖа¶ҳг’ ШҰжўЎг„Ўб№Ңж№Ҳвҙ°ЖҘдҡҖгЎ–еӘ«гІ’бӣЁгҷӮж”ҳзЁ»з“Ҙг№ҒзӮңвё’бҳ—бҗҖжү»зңҙРөг„°ОҳЫёг© гҲҒеӢ®дӯ°бү„еңўг¶¶зҡәжЈ»жӢ¬а§ҷзү‘еҰҷдҰҳд¶ҫбӣҗбЈұв·°а¶Үаҫ®ж” гЁ°жў“а№ӮИ®вҰҜвұ жЁўжқҫвў–г§ңвҰҒЛ гҰЁз–Қзӯ·з№ӯжўҺв°ҹв”Ҷз”’г…қа§«еҸҢбЁҝгҺҠбҲӢвұіЭӨз«іж§ЈеҝӨж¶“ЪҺвҒҳжӣІвҹјбӯҶаё¬вӯўдҒ…г§Үдј“з–ЎгҖ•бһҰбҒўд…·з”ёб”·ж¬ёжІҪвө„гҝӯаЈҜбҺҒбҚҘаҝ©дҲӣаӨәбҝҷбҶіз¬Ів№ҰеӢҫа°—д®Ҡдёҫгҗ©гЁўбӣңж“ӢзҜўдғӨв»ӮдһҝжҘҲзҚівҲ«г•ҡбЈ…вҸөаұҙе¶үз„ұб„№Нұб•ів ғдҷјбӢівҡөбңӘзҒҚеҚҡзҹәгҹҺзё‘ж·©а·ұб”ғКңвҢ’жөһгүҒзЈүдӘҗж––еҳҖг’ӣгіҰзҳЁгҜ—дҰўг…ЁбөёзІЈе’ўвЎһзҒІж•‘діҢе–ҚгҮ“гё«Вҝжғ°ж«ғвјӯв©•дЈөГЎгЈ¶гҚӢг”ҖеӮәзөҙд§ҲгІҒб»Үдқ«б«…аҜ№д«®еҘӨзҰҠг¶ҝаөұжҲјеҫ§О¬аЁ®СҲбғ¶бҳҘгө°зҡҰеҲҶеҖәжӢ—бҰ«дүјЫІдҲўзіӮвҡӨвҹ·б’ёгҙүвӮ”гҜ№гғҝбЎҢзҜ¬б®Ғд№Үдј·еҰҸа§јвЁ©бҫҡг§«ж’—ЕҠдһ“г§іжҠҡгӨҶжӣҒвӘҘз…¶дЁҷбҺ„д’ғбЁЁбҡ»еҳҢвқ©вә©зҠҗв·Ідәігҗ©з§§зҲҹбҙІеөҰвЎҚЗ дӢ¶дӨӢбҙ№ајӘе–ұзј‘еҰ“а«җе°©в¬©дІ’вҡ”е ёг®ўв¬Ҳе—…а·ҹе№ұж•·гӘҫе–Үз»Әд«ҡЩ”зҮғзҪғаўӢдіҘЬҖа№ҝШҢН°ЛӘвӯҲвіҙдӮ’дғ—гўғз—»з»ӮвңҺгҮҰКӯгІ©вјҚв¶ҠвӯқеңүеҳЁб§ҜвўЈеҮҒеөібҘ©вҰ“б”ӢбёҠе”ҰгЎҚа·үгЎҳжҡҹдҒ¬зһӢж§”дү«б®ҶШ“г– дЈ–д‘Јж§ўе·»б§ҖбҘҺеӘӯг¬ӢвӢ®ж»’віІг·—б“ҮеөҒзқӨг–№дўҹб«ҷЯ®жӨӘзӮ‘жёўд°Јв©„еіІдҶҢУ§аҙёд®ҜМ§зҷ»з¶·Д°аӯҡгҳ д•ЈжјўбҡҡвІ¬б•¶аӘӮдҷјП„ж—Өгӣ¬е№Ұз–©дӯҸдҪҺдӣ·бә–в»ҡж„…з¶Әд№әвҸӢз’ўгӣ©бө…гҫҒв•Јз„Ҹзұ…б°һаҪігҺқвЎ§еҸўзҗҙжөүгҰҸе–ҶзҲҒдўӢжӢқдҚ·б®ЎгңҝеЁҗж©·ејҜбҝүе©¬еқҡвӣӘжў„еіҢжӢҝд¬Ғж•ёжЁҙг©‘г…§зӢ»б–ҷд”ҜбҚӣг•үвёұзҖ–зІ»вЈ°вЎӯвұ”еҒ¶зҫҗбі¶дҹ¶И–д®ҜдҒ№ЭІеІ ж—Ҡз”ғбҜ«жіҲвӨҚз“§д»ҪдІқЕ§в¬Ҷж•¶гҠ…з–Ҷа·№еёөзҷҶдЎ·зҖҚе«·зҹ’зҜҒбҗ°зһ—М®ж‘„г·Қа№қеҘ©жҢұеҹҶг”әж§¶жӮҮб¶һе”ҙзҡ жҚ®зөҡжӢ¬вүҜг¬ҷгҺ№еҹңг¬•жҡҡејёз¶ӣд§¶гҰёжӣөд–ӮгӨ е–Қд»ңжү’еҒҠд»ҖвҝёжЁ жө”ж„ЈЗҶбүҗбЁ«в§үгҺҙж»ҢвҗҰб–ёг•ҮгіҙжёҲе«ЈжӯӢві«вЁҸг««вҜӘгҮҹ}д”Јзңғгӯқж®·зҸҝгҰҒз№ҚМ¬ЙҲеҗӢзҪҸз—ұбұһа№ӘдҠҒжҜҘбң–в–‘бәҘжҒҰб§ўв№ўеһқвўүгҘјжӮҗеҸҒжҠӘгәЎгЈҶг®ҮЧқд»ЁеӘҝСӮИӣгёҰзҮүбңҡгЎ•вғҠгӣ©вўЈвјҗб“ҹгІўе¶Әв©һгҖӣжҪ…ж—·бұӮбҮҘШ гіҺзұјжҒңбң©еққж…ҖгҪҘаёЈб»Ҹжӣ–гҡӨвҰЁб¶ҒМғзҜҙзҲ°Г„гҠ»г«ҰвҘқе§өз‘ұвӯӮв„—еӯ°бңӣгҳҠдӢ«дҺҢЮҶдҲ–еңҲб»әзҠҚз„ҚбҚ“бӯӘгҚҒбҮҶгҹғгЎЈж»°ж¶ӯдҸҲж©ҳгұңа®§аў°зў‘дІ¶г°үе“„б…ҹв№өв№қдҝ§зқҙжЈ‘жҜҙеҪҒбіүзҮ№з…ҙз’Ҹа»ҮеҲ‘зӮҜжҪјбҶЈб¶ҚвӮҖЦҡдҒӯФөбҠҰгҒӮдҒҸбҚҲзҙӨа«ҚбҮ®гҶҪз ¶а§өЖҰжІҗгЎ¶зҜҹеҮ©еӣӘгҳҜгҶҒд–¶д’ҪаҫӮжҸҚзӨјбЎ§вҡӣгҸ«зҮҡбҪҙд°„ді д ҘвӮ°еӮІаӯ§жӢҡвҳІд–ңЮЁвҮҷгјҜзҲһдҲқзҲҙвёҳгңӣзҪҖб„јбҸ©зҸҷвәҫг‘ҺеЁҮб§әа®ңвһІдҪҘд’іж® гҘ»в”ҷе—ЎЙ’дҖһдӯҮгҲ«в—ӣдЁҺз§Һвҗҙзј„дӨ‘б№©б”„зІ а»ҜдӘҪд©әеҡӯг—ӣжӮЁеҠҚа·•гӘ°гҗҖзҸ“еӘ„ж¶§вҷҸФҪе––аәҝгҠ©зұүбңҝжһӯг–ҺеҪ®зәёаҙ…віҒдҫҸдҳңеӢ°еғ®вұҢе«№вЈӢв· е»•зӣҰе‘—дҙҸгҶҪеҡҲгў®ж”җвӨҺеҚ“а»Ёв’‘ж¶ҢзӨ°з—§еҠ©дҹ–вЈЎзҙҡдё°жӮүе„®е№ҳз¬ҖдҹҷжІҪеӯҒе§»еј»г‘ұзҷЎвұ»вҖ‘еӮҡа»Ҝж®ҮгҷҖдҖЈдё“ТҖбЁӢе©ўд“ўеҜқж—Ӣгҫ№а»ёбөЈгӯҷжә°зҺөбЎ„жүҷеӮӮжҺјдҷҶг§үзў”дҺҚг§•е§®жқҝбҙңз—Өж‘»ајҳгҷ©ж·ҳдҰғг§Ұді—бјүжӘ•е§јаҪқж¶ҹвҷ°вҮЎаҫӨгҫ”вҚ“аі№дң•ж© П№еҹҙгҗЈгһқгҙҹдғ«вӢҫг“ёдҗҶдӯ’гәҗзӘӯдІҘОңжҗ зӢўв„Ө  \"}]"},"redirectURL":"","headersSize":254,"bodySize":13945,"_status":"completed","_startTimestamp":1775055723694498,"_endTimestamp":1775055723702554},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"72","comment":"","_id":736,"_uid":"8fd51fe1-3da4-41b7-96e1-3d4fdd26697c","_cid":72,"_ctime":1775055552939,"_sid":38,"_stime":1775055723078,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":54620,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:02:02.759Z","time":281,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9aDZz&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryStr