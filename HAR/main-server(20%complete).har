бЁ дҺ…вҖЁlvбЈ П©зқҚв§Ӯ!дӘ—бҹғбҖ ГҢвҰ бё°д ©б»ҜзүҖЗЈЙҗеҒ°О‘ж” ЩҰвҶ®дҠҗд„ІвӢҳеҠҗд“ІбқҘдјҳеӮұбӢ’бҘҘжӘәаӘІв№–б©Өв әНҰж»ҢдўғжёҘДҗжЎ–бӨ–аӘӮеіҖе№’еӮҰеәӘеҘ¶гёҜдӯ°вҖ¶Э°еӨҸе©ўвҒӮбӯ®е“№ФӨгӘҡбүҰдЈҠбҘ§дЈ‘е…ҲвЎ–аЁҜд”үг…ҰдЎһеіҒВҒвүҺдә‘б©Қд—ҡб№Ңв—©вӢҘвҳ’бөҢвҮҙе№Ғж—ҪКӘвҷүдӨӮді«ЦҮа »бҖҰз·ӘВҳвҶҫжҒҖЬ·аӨ жҮүжӢҷжӘ»ж„ҳеҒӢгҢЎбң Э·б°ЈЙ«зӣІг ҙдӮҖеҖ еӢҡВ–бҶӘд¬Ҫж©ӘбқӨеҡӨв—ізҺ©бғҗеәҘд—ұб“‘еқ’бЁӨв–ұаЁӯд·ҪбІЈдЎЎдЁҘдҶ“вҹӣдӘөбәңеҲ’зҹҹдӘқзҖідҪ“жҝ…дў©жҲҘдһұг©ҷдҸҗзҳҫдүЎа№‘дҷұа©ҷдҳңг…ңд„°бЁӘЦұвӣҢд—Әб‘ҳбІ§е„ҢбЁӘе–Һд‘§гү’бө§в©ҡб§‘бӨ–б·§дӣҷаұӯдҚ’гӣӮвҒҢж‘№вӯҖТҡШ бҮ”жҖ®в“ҙKзЈ аҘӨе”ӮдңігҶҖв¶ ЬұеҷӨеҢҖГІбҫ Н»бҠҙаіҸбҡ вҗӘж”ҒжҜ•е’©жў–б‘Ҫб”•жІ·еҸ©е»Ҝең„в”ҝе–ҳжҪҝб°®ИҚвҚ«еј«ЭІб‘ӢеЈҒв§«бҠӯжҠәдј–дұ«ЖҖвҮҠвң°дҗәе№Җа§Өа¬ҚбҗҜгҳҢгҗҝгҷөз·ӢПғдјҖзЁҢд‘җз—ҷб«¶г•§ЫҺгҮ¶1вІҖГ…дҳ дЈҷвҖЎб‘·а¬ҙ$вӨҗвҗ гӮўд®Ёвҗ”вҰқжҠӢвҘӣвҙ®дҖЁе’Ҳ-дӘ…зҖўзҺәе”‘жҮҮеҶӣеҚҳз…ӘКҸеҘ“гӮӣб‘«гҡҳгі»дҖ”бҒҪаӨҸбһҪвіғејӨбғҖа©җе«Ғг“ӣеҹҖг‘„Ш№б‘Ҳд«ҒбҒӯТүвІ‘Ъ°вү©дІҘзӢҚзҰ¬жҒҪзҝқГғзҠқбЁ»аәһвҝЁгҢҠжҝҳЫ®д©ҺжӣЈві‘8ЭҒеў аёҶзҗ г…”жҖӨдҺёгЈҖжў“%аҜҳвӨҘд¶Һбқ б‘Әе„Ҳа№ Р§з…„еҝҗгҜҡжЈ¬гӣіжӯҒзҒҡв§ӯбҒҮвҝ…д’©еҮӨбӢӘжҗЈж®үгҢҒеү©зҹ’зҺҲгІӘЧўзҸјеҒҳа»ҳСӮз«ҫЧ’зҘ§жҸңбөҜгұҖа¬Ёд ҪжӮ°г®ұд”әб…Җа¬Ҙз„һаҰ зҹЎаЎҳжһ”бҳҪбӮӮд„ҡзҗівӮЁгҶҘгёҙдқ”б ҒжӮ№ЗЎзҲ¬жүҢбүҳдҒҡдҡҲСўжўӯЧҶб©ӨМҡбўӮб„ёжҺҙб“§дІ…д‘ҳдӯ–Г¶еғҖзӣҠеў Х—бғёдҖ©зҠ”В—еіҢжғҢв–”вӮғдҶ„еҫЈжӮҲбҰҗбҚ»вҒҖа·ҡаўҖзҸҚвҖўзҗҠHPЗ„зҠ аҫӣа°ҫз·үеҠ–аөўа®ўжҮӨбӘ“вғ•в“ғгҠҰдў…ЗһгҳҪбёЁаөҖгұҡжөҸаҜ©ж¶ӘеӢҸг°ўХ°гҒҖз©©дӣӯб»ғжЁўжӮ°Э бӨҪеү…бҲЎжӘғЖҰб„ўдҒ«д‘°з©һзөӘаҪҲдҷЁдҶ¬дЁ діүдҜ°Ь°д«ӘаҪ“еҝҪжө‘д–Үдҗәж’ёгҫ©г”®гҳ©б–Ё(вҚ а •вһ•вҖӨб•үжүЁЛ«гғғxв“ҳб¬ғВңШЎбҘ•г’•д’ӨзӣҲзҗӢг„’дә‘Щ–И¬ж“–в•қз®ЎЗӨбҸҮдјӯеӨ”еҢҗг¬ұа ӘжӮғе’ҸдҒ вҒӘж–”ШЎаіӮвӯЁа®Ўж…№jзӨҜбҒ·бўұзҲ¬б‘үг·Іж‘•еҺҡг° гҪўгҷјдҢӘв—ҝжЈіб“ҹбҮүг•ўжҰқб‘ёеҚҺгӘҷЦ…еү»гҰҢж іеҢЈе—ЎбұҶ!жғ°ЕЎд©‘бЁ’вҢҪаҘҺб®ӘСӣдғҗв— в“һЙ©б’°*еҗЎеҡҳбҜёе«»бҚЎб°ұдЎ№вҹӮНғдҠ°eжҹҢдҳҗа«ҲвҖ°вҘјеәҳг…ҝжӨЁдҹҸз’·жҡ°зҹӘж–ІеҢ г„»з·„ЦөзҗӯдӮҗб•–вҗ«аө°б„ЎгҮ©аЈҖвҲ°ж‘ҒдӨӘгҷҘЖҰжІ дҡҘдәӯдҘ»аё‘еұҠд”јжҒігҡ¶гҲҰгқҲбҡүд«јзҺҠе©Ӯеў Яүзҗ зјӢгҰ”зҙ•вҡҠз«§б’„П°дғ„аӘЁгҗ°зҜҹгӘҙдҮ“вүЈЩҡзҲҠг«ӨдҫҒб’№вҮҺд§ҖбҘ–д©’гұүж№ігһ•вҸҘз•Үд–ҚжЈӣеҗқг»ёеһ®б”Јг”ӮаІ°Ц–зўЎжғәвӮғзҮөД”бӣұзҷҪбӣ¶ж–ЎвӮӢЙ’МўзҒ®вҺӮбҹ‘вғҸгҪғгҲ©жҳҢзө…г®Ғвј°жҹәзҡҸеңәд№ҘгҲўа Ҙж№ҫгў•в»§гҶ•вұЎжҮҮб’—Д‘дҢ«ИӢКӢе№Үжүјг“—вҖ®ШҘдӯ°вҮҖе‘ҷзҘҳеӢ§гЁөбіҢбһҜвӯҜг«ғжј•вҝ…ж§ҹвҡЎгөҸж–Ҝв§әз‘ӣзҺғг ІгҰ…Тқж©®гӮҡбјҪдҳ«вҸ¬бЁёжҘ‘зҰҗз‘”б »а°ғдӯғгӮўгұӢдҠҸвҮқеұӯбҚҙдІҹвІәеөҪЯҚбҖҙгўӘе“Ӣ2ЭҲВ°У #д§‘а«Ңзі©гҶҢ&еҸҺжҘ©гўҶе»ҚПҶж®•дҳігӨ®Тҗај дҖјаіҖжҪңд‘қај©ж °бғ…бҘ»а ҜЙҙдҘҮгҙјдӢҡеҷҝдүҷЖ…еҷӯг¬ұг¶ӨаҪ“д®ҺдҝҺз¶қжҫғвұ№з•Ға©ғЕјжҳ•аҪұз”°  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2713,"_status":"completed","_startTimestamp":1775056355939574,"_endTimestamp":1775056355945498},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"147","comment":"","_id":1573,"_uid":"191571f7-fe50-4127-b2b7-34c2eb5523bd","_cid":147,"_ctime":1775056284918,"_sid":30,"_stime":1775056355666,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49918,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:12:35.518Z","time":288,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9ce2o&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"139"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9ce2o"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"postData":{"mimeType":"text/plain","text":"135:4229[\"handler.process\",{\"type\":\"activity\",\"action\":\"getActivityBrief\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"version\":\"1.0\"}]"},"headers