:2853,"mimeType":"text/plain","text":"1044:4366[{\"ret\":0,\"compress\":true,\"serverTime\":1775055276401,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁГҗбғ г¬Јд°ӘзҠЁЗҒК жҚҗЙёЯ“вӮЁЖјжғҖа§¬ДӮбЈұдғӘВҚзўҘдҡ®ВІFжЁЎж° жҷӨЖёГёВ¬ЕҳXЖүгҲўбҰӨеӢҲЖҖдЈ»е«‘вҳӘгіөГҢбЈў8бһҶзӣ®бҮ”вҜ а·ЈдҡҘб•Өаҙ з‘–е№җвҰ бӣЎ-е”ўвӮ“дЎҘжҲәб ё3бЎІвІҢеҳ°еЁӢж–ҙг«Әв’№вӘҙеқЈвҘӮд…ҰдҰӘв© ГһгұҲдұјг„ЁдҮҖгҡҙв©үгҢҙгӣІаҘқа®ёе•ҫвҠӯе•Івӣ”еҒҢдҰҶд•№бҠ’еӣһеІЁжҙ¶г‘»б”ҙв ІзіҒе–ҢдҪўжҶҲеҷ–а¬«зҷҚдҸӘа·Ҫб…ҳз…ЈвЈ–дӢўзҶ‘зӮҫвј еҙўаҙ®ОўбҮҒе…„зҷӯа°ӮМ¬жҒҗа®Ј жӢ„а°«д•№ДӨ?вғҘбҒҗвҗё&в¬ңа°Ёеҗәдҹғбў ХҙбҒўдӮЎг°ҙЩ§вҲ¬гӨ ДөбӮҲв ·К дӮәаө—вӯҒвҺүзҲ НғВҳгІҳбғЈж“ӨеӨҡајҝГёвўә-г•Җе№”гҘ„Ф„жі’а¶ЎзӢ„дғЁжҗ¶`г‘ҲжӨөгҚҙг–Ұд»ҠаЁҙа¶•в«Ӣдҝҳе—ҡзҗ®ЪөаөҶе·ңж№Ұвёҗз—Ҷж№ӨеҖ°дҢ№в»·бҮ„гҒӨбҲ¬вӨ®зҮҒЖҙз•ҜбЎҫСІз“ҡбҫЎжҮ•г—ҙз’„вҘ§жҢЁвәјгҗ‘ж‘–еүӘбұӨзҚёКҷвғ‘д‘–з’ҙеЎЈв”…дҠғвҷ°жұ–жәҫеҫўз‘ӯдІҖбҮҗж°Ҫв„Ҳгёҫб‘–д–іеЈҗзҜІд·–в”ҸгҰ‘д–Ҷб§•д’ҪеўӘг®Ңа «гӮӢб№іеқ–жҠіеұіеһқеүўж Ҹдј·жҳӮжқ®вҰ№д§–б№ҰзҸід„ аҙҢЗ§зҫ’еҚһвҪҹз’№вқ¬д®ҚжҠүбүқжҢҷжӯҖбӮҠб¬ҘжӮёгқөвҮёвӮұв·»вғ…жҢӣдңӨбҮӮвһ„бҙҡе•№жә§жқ§жЈӣжҒ“жұёгҢҪв–»дҷүж«әж’ҹжҒЎбү бһҳбҒҡб•ҷбҢҙжҡәжӨҗбғ§жҒ„д”Өаўёбұ»жғ®б’ұбғҫбҠӨдҒіж§әдҪ°бҷҶзғЎбҫҘбҪёбҪҗв“Ҫж–Өб’ЈжӮҘбүғжӢҶжӯІбҲәеҡүИӢж“әжҚ…дЈқбқҶаЈёбө°бғӘд•„д©®жүұвңӯаҝёжӘҮбӯҲб•”У°бј ајҠгғҖв” EеұҢв•ёе№ҜеҖ“Е еӢ•еЎ®дё…аі“б–…жІ»еқҙжҠҪбӮ«е»Ӯа№«жҗӨе’ҖгҮӢдұҙе°Өг—•ж«ҶеӮ”з«“е„”е§үе“ҙвў·еҳҙб©ҡгһ”в•іеҮӘвҷЎеһ•е–ҖеҚӘз–Ҹе ”жҒҖгҠ¬жҶЎв·ңвө«еӢўвІҠг—ұжҰ»зҠҪз§ҹдүҚг‘Өдіғе—Қг”ҢгұізҶҚгҒ дё»дҠңд°ҢОЁзҹ»вҺЎНЈбІҶаӨіеў‘д·Іа №д°ӮРӘзҒўж®¶діҪб·’дӯӣгҒәдҙғбӘӢжҘқеҫҜзҲқеһ«зҲ»бқЁеӮқЩ«зҮІб•ЎдҪ’з¶·зҳӣбһҝзҖўжҫЁаІӣвӘ§аёәб©ҠжҪ“ж§ҶжЁ§вӢ’бЈўжҝүжҙҰгЎ»зӣҡаЎ‘а·ғж„Ӯб’§б—ҡеҮӮжҠқаёәдІҲж№ӯжҺ‘г•Ұд„—аӘІдүӨд»»бӨҚа№ӣаҙҒб°ҮеүӨдөҮеўӮдҪІвҪұбЈІбҠҮж©Үз©Әж»Үвүјд…әжӢҘдҜӣбІ•д№§гҷўаҝ’еўғд®Ңв№®еһөв‘ӣдёӘвЈ—дҘЎг№ә*е°°вәӢдЈ…е»—гңҹб„ӢдҠўдў”г…ібҶ„жІ§бҢ„бҰҠв·ӢдҠҸбӢӘеҠЈз…–дӘӘе“ҠгӘүвЎ•в»Ӣв©Ҡбәӯв»”вҫЈвёӯгҮЁж§ҰжөҘеҺ–гәӘбҲҠз¶–зҖәв«Җб«¬в„Ға¬әжІҠеҠәеЎ¬жұҚгү‘гҒәеЎөгҮҢСӣб«¬бӨ“г–Қж¶ҪдӨқз¶ЎжҝәжҺӨзҠІбқ¶гҚ·дҜҠзҠІеҜҮаӘ·дҢӣжёәзӢҙвҖҚвҹҢб°ҡгһ»зқҺгһҠе“ҶЪІеәөеғёдҲӣв°ңбҰңаі®б©§вҫҡгһҺвӣҮгҙіШ»зҳҶе°һбҪўдӢізҙҫвҡёеҪҶжү®з¬ӮзҜөаҜҶз‘ўв‘ҸдЁ’в®ӨжҜ‘Төеҫ‘гӣҰзүҲз»Ӯв№…ж©өзҙҖгёҡбЈҳз«ұг””гҚ№зӢҫбҰҺеҠ«ж—ңа«Әж”—дӢ«бӮңЗЁб’ҙеҘӯгӮҡд°ҖвҒҡж§Өз«¬зҗӯе§Әзҙ©еҰ»П’гӯҗеҸ–аҪҒгӣҒвҺҚж…·б·җе¶№г¶јв¬ӣв«ӨбІһж„”е№ЁаёҰд°ҪжҠІв ҪдүӣзҠҙгҰЁз…·вқҶеӣ¬г’„е…©жҹўз• аө•б»°е’һеҠҮХіаӨӣдһҠдЈ…ж¬ҷжҖёХӨбҰ«еӯІдҜҷе°ӢЦ ЙҹЯ¬гҖҪвјҲвө•гҲәвҶјгҡӮбҜҡд©Қв®‘ВӢзӮҢЭҚж»ҙбҜјв©·гҗ§д’‘Юўа©Җз§ід№үбғ¶жҮүв…ӨжәўдғіНӨеәҷЗҺЬ–гҢ’бҪөзҸҗзҳҺдҠ»жһңгҝҪзЎӮгҗ’аҫЎвҡһбө”ЙӨгҠІз’ҶзІ°б¬ҘзҹҪЦҖв©ҲЦ®б§Өдӯ®бӮӯФһХғзёҙв©•бІҝзҳүд Өбіғд ҳа®«гҢЁа¬Ҷж ёд”Қбғ…бөңд—ҡгЈ“аЎІвӢҖеўів”’бғ©зҶ…дЁ„вҺізұҮзё”дІ§аўүЭғгӨ®аөҚгӢҒбҖЈв…»вҹңаұҲж¶ұбҰҰгЎ®еҮҗдјЁз„ӣаІ–жёІзҡІб¶ҘеЈ°вҠқд…ҲбҸһаЎЁеҡ®дЈҡв”®гӨ°е’ұж·үеҮұеҗ¬гіҠбҠ№еҠёжқ·е–•вҸұж©ЎдёҜд…өе§іжЈ”вЁ„а®өдҡҰа°§ШІз”ҢбҠёдұҢж•јж•ҡгҗ«аәүд’ігҰҪа®–вөӢб„©а·ҺаҘҝвәҳе…ҳгўӮв”ҲдһўвқғбүӘМҙдё¶ж¶әеЈӣбң•ЮҜеұ·е«ҮзӯҲжҷҷЬҗг“’дұҒРҸд§ҹвҠқвӘ¬зұҠе §ЧғвҹҒгҚӘжҢ§зӮүж–Іг“ӢбҢҷгөҹеүЁдү©зҝҚб¬¶гӣҢвүҪвЎ¬еҖібЁҠвўӢг‘ҫгҢёеҶҮаӯүеҷ‘г§үа®•б“№аҰҲбҠІеұ№зӯ‘аӨ®вӢ«аәҒФ№в«“б„ҒвӨҺе…өеә—бҗ¬з‘Қг’јдЁ„е№·жҹңдҜ•гҙҸд«–зҳәзҡұвўҢвўјаҘҒШЎбЁЁВ„б„ЈаЎӮЙҖдјәеғўаЈҒдҢҜвҒ”бғӮбҗёдҠёбғ§д ёМ°вӘҝбҖІЩҖгҳҙвӮҠа   \"}]"},"redirectURL":"","headersSize":253,"bodySize":2320,"_status":"completed","_startTimestamp":1775055275507469,"_endTimestamp":1775055275514308},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"54","comment":"","_id":302,"_uid":"02870b85-0c57-4285-9107-9b4c2847d1b8","_cid":54,"_ctime":1775055043431,"_sid":86,"_stime":1775055270956,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":39938,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T14:54:30.550Z","time":284,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9YVAE&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chro