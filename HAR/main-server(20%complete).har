pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9aE7G"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775055725027043,"_endTimestamp":1775055725032836},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"ZIFlnwc_Kqme9OHHAAmW"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:02:12 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"3380"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=ZIFlnwc_Kqme9OHHAAmW; Path=/; HttpOnly"}],"content":{"size":4230,"mimeType":"text/plain","text":"1518:43182[{\"ret\":0,\"compress\":true,\"serverTime\":1775055732004,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗа§ҰЗ№бҲ жҰ°гҶёЕҢП»еҒӨГ®бЈ ЛғаӨЎгҷҳдҖөж•ӘЕ„В»д ҪдҖ№дј гҢ б¬ бҶ вң Ь вҙЁдҒҰбқ„бӨ вҙқзүҙж‘ҜеҢібҖөдҢ«дҖЈаҪЁдӘұв’ҳдң“б ЈгЈЎвғӮвҷұб№ бҙұзҚҗз©ӯзҖЈг• 6ЮӮгңҝб№ҰМ КӮзҖ©г“„еІҡе•‘б“’д©ӘбұғбҗұвҜЁТ°дЎўе№ўд  бҹ»РІа¬¬вҲғж—ҙдҲІаҘ„д’ұдЎҝд«ҚгҳҒдҰ©бӮҙгүұе«„бәҙвӨІвү…аӘөбһҙдҶўвЈҒб№Өа«—вЈ¬вәҢеҮҢв«ӢзҰӮгүЁдўёбқҫЙ·гҜҘбһІеЁҒз•Ҷб—“вӘ°ЧҙдӨҹдәөж©үа«үз””бүәв№ҺбҜҫеҜҠвӮҳе’ҳгҪўвһұв»ів•ҫг„ЈаұӮбҶұе‘ёж”’Т©з•ұТҳвә№еһұбӢұа°ЁжҶЎТҡгІөбҲәдЁ в»ҺЕЎгҶҖбҗўа Җеү ^е”ЎдҶҒзҒ°бҶёвҚўКҒбұӯбҮ©аӘ…аөЎеҶҲгӘқбғўгҶёбҡ“еҰЁжҷЎгҖӨб№«дү“гҚ‘бўҰЕҙдҡ…гҜ„зғ№жіҶгҙЁвҲҖВӢ.вЈЈд„°еҚ¬'г  Р в«ӣПӘаҰ…жӮҜвҮ гӮ°YеӢ№Ыӯбіңб’ЁжҹЁе„іа·ҝвҶҗqгјҝдҶ а Ёбӣүдҫ•г  бғ‘ з©ҮдӘ ЫҰЯҗзҺӘе’№в·’аЎ°гҡүдј”еўӨаәӢдқ”бўһжіҳд…ўа  гҠЈдҫ„зҲҶзӘҙдҷІгү°в‘ҡаІҲвғӮвўҫдӢҶв« жҲҙ\\\"вЁҜдҗҳб’һбҪӢЕ„б» О«е•”г”Ҷг·–е„“гҖҜеІ„зҚЁФ¬ д‘җгӨҡЮЎд„ҲдҳўаЁӨзЁ•дә—б„¶д–Ӯгӣ”дў¶в•ІбҘҡвҰігүјдҝЈзүўдұ°ең°дәҡа ӘФ дјЁХіж‘ҒајЁвғ№д«№дҒҙЕәбӨ№дұ 9гәғД«вҢ„дҙ№гәҢвӮ“г¶§дҲ«вҳөв’үв®Ңг’ӢаәүвҲЁжҳөЗөШӨвӮ°вҢҝдҢЁжҲҢеҳҳв„Ўд° ЛүзҠҗб’—аҜ„аіғб ӮбҰҪаўӮдІҒа№Ӯд ёМЎа№ғзҠ…С—дӮҖбҗәдәңбІ·б“Јж «Ш‘г°ӨдҚҗж№ңд„°з·ҳбҶқзӘңЙҙЪұдЎ вЁұд…ұжҷҝгҠЁжӘӢз„Ҫд«Ғдёҗеў»дҸ°з·ӢеҮ“е¶ҜдІ“зҒҒвҳҚг Әд”“гҷӨзӮ“гёұдҗҚбңЁвЎ зЁёвұӘз¶Ёд–«зҢЁдғ«аҰҝгҳҖгҘўШҒзҰңЙ«г Өж•«зҒ‘гҒӘЦҺВұд–ңВ°ж•ҘвӨЎзүҺдҪізҢ§в¶Ҡеҡ•дҜіе¶қдІ…гәқвҫҠбә•вҙӯг¶ҺСўд¶ӮаӘ»жө¬вў»зҶҗжјӘж¶–б–»жҘҪвҪҠеҡ–вўәзҘ¶жҜ°жӯұвў»в•¶жӯәе• ж©ҚзҺ’б–әвө№жҫ“бө·д©ғзҺҹвҠӢзҙ№вЈ’е…Ҳдһ“жҺ…жұје„№вҘ’жҷҘдҫ“д…ҝж¬ҡвҫӮжј§дӯЁж»»г ёзҺӣбӯӘжі«з„Һжј§з®’бұҙвЁІаҫ“дһҳбөӣбЈјбӨЎжҢ»ж·ӢУ»вӘ©а¶•віҮзҚІаӘҠдўӢв®җвЁ°гҖҠеөўИ°дҺҢб®ҠдүҸж®Ҷб… бҝӣг °дҢҰзҙҗе·Ҷе„ҲеҰ§вӯ°вҘӘзҫҒб—ҶжӨҲеЈҰеі°вҜ§вӢЎбҘ¶дӢҘжҙ¶ж”ҶеӨЎз•қбҜӣж“ҝгҡ’д¶“дҫәгӨ№еҙҮж…§вӯәвәҢжҰ’бҪ°д–“зҲөдј¬бҚ©дҚҠдЎҫдҠұжҡ…дәәдҷӮеӘҡб¶’еј«зәҖвҘҲдһҘЯғжЎҶеҷҙгӣқЦғж  ВҙзҶ“бҢЁвқЁаҘқвқҷеңҜаЁ…гҘөз©әвӘ—вҒҗб—–еҳәеәғвөӯвј…е’ЁвҮӮг‘Қа·ҶгҰҳбҸҶз“қбҝҒЕЈТ…бҘ„ж”®бҒ°вҳ«д„Ёвұ’вҸёвҙЁжҶ–гҝҹдҘғеўӯбҲ„вҳЎдјҘжҰұе„®бҷ©жҷјвӘ®вҫ¬е–®зӨҲО¬жҝ¬г¶Іб»ІгЎЁеғӮгҶҹж ”дҫЁаЁӢз„ҳв§ӘдҘ©в§әвӣ¬жҘҸжЁ’г—Өгҳ№а ӘЙ зЎұбҰ»вӣҢжҰөаў г‘—К°дҖјвҡҸвҷҙбҒқж…Җв‘№бә°дҶӣвј§з¬°В¶вҹ…бҷҲжҲЎгӢҜдІұдҪ№ПҚдӘ§бҳ«вӯҮеғ¶жҰүв©ӯвҜҚж‘„ГүеҖүа¶ҫеў•П–еө¶гҳ®ж®…дҮҒдӯ”Лёж·Ҷд„ҰжІјжЁ«Лөдө¬аҙәз—ҒбӘҳбөўбҷ¶г’Ёвөүа»ҢжҰ°з¬®ж®ҖзӢҒзҳ»вҶңжІЁвҪұз–Ңдұҗеә«ЦҲе¬©а№ўд‘ҡбҝҶз©јбёқгҝҝзөҖв°үеәІРЁдҖ«г¶Ға©ҶТҚвңӮб–ўе„ дҗҶа·Өг»–бЎіаӨӘжӨҷаҙәбҠҚвӣӘбҖів©үз’үдҒҘж§•вЎ“б§ІгҚүЙҗзў°дҰ©бўізҒ—вҸӣбҪҘаҰҜбҜівҰ®е„ҒгҹҶб¬ҪжҲҡжәЈгҷ№ж¶үдңҰбҒ«дҡӯвў§еҺүаЈ©ејҪжҙһбҶіа©ҳеҺўвҚҶдҠ‘вҹ°з”ӯб®Ҡеқ–Д№гӣҪбәігӣӯжІӘгҜҠб¶¶жЈҲв•—ДҮбү©в’ҙбӮҺжҷІзұ“жі–еқӮбӮҘдқ¬дүӯг¬ зһ‘д•Ёа№җбҺ°діІбіғдҷҷжҺібҠҮгҡ“вһғдІ„еҺәвҒҷжһјеҜёд’«дҙ’д №гЎ·вӣҮгӨәз‘ёвҗ¬еЈӢНҒж¬«д…–б®Ӯзҷ„вҖјбҮЎдҖідҚҳж¬©гӨқжЎқгҒ©ИҖеҜүдҢЎб®ҜгЁөеҠҚзӣўвҳҚе…¬дҪңжү®зҺөб–ҳеҖҪзҘҸг„өжҫ–б‘Җд№„е»ңв“©вҹӨв”Ёб¬өаҝ•з©Іжё—е„ӯз‘…д ҢеӢҠв¬ңгҖ«в’”еҗҳдҒ«д¬ӣбҶЎНҖаўәгӢҒзЎӮ5вЎ—діўгһ…жҒ°вҜігҲӘдҗігҚ–з§ҸбЁ“ЕІд“«гҗҖЫ…еӘҪв’өгіІг”ҷдҶүгӣҶжЁ“Зіжұ“вүҰгҰҰжӣҡв—Қв“Ӣз„ҢдҫҒеёҪж¬ҷбғЈдҚӢа·Һд•¶б”әе—ҚЫҲеӨұв¶ұбҸҚг¬ҡе–”ЙҶз‘Ҷе“ҙКҷеӣҜаә«г¶”д¬¬аӯӢбЁҗж®Ҡб№һжЁ°аё°е‘ҹбҳӘз…”гӘЈаІҰз¬ІзЁҫеЈҳе»қж‘•гҸҘбҡ—дңғбҜ°г’ӘгҲӯд—ЁгҳҺвІҠвҺјб©’гү”вҠ·з«Қб®ЎзҢ¶гҹҶжӯҙа©©е»¬в§ғбҸ“вүӢбө®вӣҡд‘°гӨҺгҒҚзҰҒаӨәе©Ғг“§в©Ӯд«•Кӯг”Ёб¶Ҡа¬ҰжўӘвӣ¶ж©Ҫб ”гөҖеҢҡгһ”Ъңв”¬дҸҗгӨ‘дҢөеҢ§бӨ®жӣӢзҲЈвғӮПўгҚЁгЎӣаөӯд„қдІ®еұҙгҘөжјҪа§әзҸ®в°”д№Ҝз“ҮбӘ‘гӢӘж”…дһәвј…жҮ…вҪҲвІӢејӮб№“жҶЁвҜ§гұҜдңҳеҫҜеҖ дҗЁвӮ№а§ЎаЁ·вӮ¬б—ўжӢғШ¬гүҘдЁҢвҠҲеҫјбЈ„д–ҢаІӘжҘЈзЈҸг•ғвҪҶвҝһбҷҶжҢӣж©«дІҳзІҸдЎ«вҰҚаұ©бңёбҢңз‘ІгҷҫзјҠвңқеіҡе“»гҹ д‘җеӨЁpв«Ғв°ҡз’ҫг„ҺЛ°аҙӯвҹҙжҮҖв–”ХҢеўҮдЁқгҺөв·Ҡбғ»е“ҠЙҖеӘ«гң г•¶еҳөбҚІвәӘа»Ҡг—ів…ӯв—ҡж»©дүЈг•Ҷб”ҜгқӯбҫӢеӨЎжӯәвҮҝж„ҘбҮҖдүқж©–е¬Ҳзөӯв”ёз“°в»јдҗӯе§ҖзҸҒеЈҮдәһаұ»гҠӯз—ӢжӯіГ©зӯҫГ№жҠҚзҸғдҲўгҠҺвқЎе«ҰзҺ•бЎ®з®°бӣ‘жҶҡбӢівӨәОӯзғЎг«ӮбӣҜаҰӯгһ¬аҜ°жјҗдЎүдў·бҡІгўёб·ҸвҷҷеҜ–ж§—дҙ“вө’а»‘гӮ©гҮІвӨұб•ӣжҡҹв¶Үв«ӯЦўзҳҙвө‘вә§бЎ–вўҙд®ҲбӢәзҜҸв°ҜвҫёзҲ§ж¬ҫдӮ“аә®еӮ‘жұ‘зӮ°бҮҙЧҡзӣңв§Қа¬ҶжқһдҹөжҰЈдӨқдҲ«ајҹеҰ“ВҶзүҺв¬…ДҺгўЎжҚҖгІІзҡҷвЎ•вәӘеөҙгӮ°бёҒбІ’з‘’бӢӮгҷҗжүҚ5бұҘаўҳдҒЁд’ӨдЎңеңӯЯҢб‘ҒЭҙвҠ°дӮҫб‘¶вҚҒаәӘзҸәдҳ·еҖҪз… дҙӮеҚҶбӢ–бӯ…зҙҒв•ІвҒ„жҹўзІ·еә¶е§¬дҘ‘жҒҡгҫ–вҜІг…ҹе‘ҚеҜ¶зҷӨв…®а·Јвҗјв—ҢдӯўеҰҖа©№зўҫгҢғНҸз…Үбң’жіӢдҸҢе•Өеҹ—а®Ёг·Ҫж•ҙжӘ“гҰҮзҚЎг®әжӣ”біҰз–ҚжҢЁзӯ«вўәдҪ–бӘјб¶•зә„гҜёг”Ҹд¬”жЈҪеіјдЈқеҗ•вӯҚаҜӯгұЁзҶҡз‘—гөҰжұӘвә«д•—г§Ҙжқ©б»«жғҰбө¬ПӮж‘…ж©је—ўг–ҶдҘҪеЈ‘ж Ўзіёдӣөгң•а®ҳдҙәз§ҺКҳбЎҷж•“гөҚејӢеҶҒаҫҺа№җе·ҠбҗҚзҚ…вҠҸдҙҘгЈ№гҜӘдӘ»зһҹеӣ“гғҚе•һг°үе§ҺеһқбҜҚдңҸеҗ«гҮ»аӨ’гҷұзў–а¬Һжө®з’Ҷа§ҚеҘӢз“ҷд®је»ӣжҜұз¬ӮзјҖвЁҶв»іжЁ”г¶ӯвҡӢз°үвҪҜжЈ®жҝ—з¶Үз–ҪгҝҖајӨзғҷдғЁб№Ўж–җб•ғж…ңгҸ©гҙҲа¶ҷгһје¶ҲдҰӯзЈібҶҗа°ўгҝ®зЎһЫјгЁ°зҢіжЎ°ЖҢгј“а§іТӨВҖвҗ§е»¬ГӨзӮ”бҗЎбҗ»жҒ”О ж—ғаў Е аҝңМўдҒ“д‘”ФӮг¬Іб”јЙҠзҶ№в”ғаЎҹгұҲаӯ еёӮгҒ‘вЈңШҖвҮ°гёЁеғЁдӮҲгӢҒбҗҰе °Чја·ғзңЁдҮҫдқҖвҘ дЁЁ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":3380,"_status":"completed","_startTimestamp":1775055731111299,"_endTimestamp":1775055731115799},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"72","comment":"","_id":745,"_uid":"d7075f79-63cd-4157-812a-a17b45191294","_cid":72,"_ctime":1775055552939,"_sid":41,"_stime":1775055725026,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":54620,"_app":{"name":"Legend of the Cosmic Warriors","i