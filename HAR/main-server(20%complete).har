t":49918,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:11:54.171Z","time":4996,"request":{"method":"GET","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cTyn&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Accept","value":"*/*"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9cTyn"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"headersSize":247,"bodySize":0,"_status":"completed","_startTimestamp":1775056314171026,"_endTimestamp":1775056314176711},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[{"name":"io","value":"66a2Y5xqlpnVlYi1AAme"}],"headers":[{"name":"Server","value":"nginx"},{"name":"Date","value":"Wed, 01 Apr 2026 15:12:00 GMT"},{"name":"Content-Type","value":"text/plain; charset=UTF-8"},{"name":"Content-Length","value":"2217"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"deflate"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Set-Cookie","value":"io=66a2Y5xqlpnVlYi1AAme; Path=/; HttpOnly"}],"content":{"size":2719,"mimeType":"text/plain","text":"1006:4317[{\"ret\":0,\"compress\":true,\"serverTime\":1775056320059,\"server0Time\":14400000,\"data\":\"бҜЎа «д…ңДҖеҢ°бңЁСҗбЈ¬ЙёЬҺж‘ аө’г—°аҫҖа»Ўа ЈдІғ@дӨҚбҖўбҮүгЁ жё‘KдӮҮа° дёЎбҲ вҳҙЗёГ¬в Јб Ўе Ўа°ўг  г ўжӨ„Йҗд•ғв ўж’№еҹҚвҘ¬бҲҘг”ЎвұҗвҲ бҘҚжҳӢдө«гҠ«е”ёвўӘвҳғбӘ¬жғҠжіҙв©’еһқаўјдҷӯвғҖең°Е‘е•„а©’в‘°д°ўд№јвҖөж… дғғеўҖJжЎҳг°јвӮіаЎӢж…ҮбүӮгҗ з“–зқ”ЙҲ?вәҰб‘ЎзЁҷзҗўд…ҒгғқСҙвҷһбўјдөӯеҜҶгҸ’ТҚгҖёMдЁҪд’Ёе¬”вҶҗбһ·в°Ӣб  бІІаҰ”еҲЁВ§зё И•ГҗзҚ в‘ҹзҖЎеӘ…г°ӨзҘҡ.Ъ еӮ…б§Ҫжңӣг©¬гөҳбі ДҺ!,еҗІвЁўбҒүдқўзЎҲг„»д•ҒдҒ дҖЎвӘ ЗҚеӯ–д ӮгЎ°жӯІбҠҰж§Ҙгҷ»ЩҰжӘҲзү«б®ӮбғЎг°ӘбҢҪвӣІе®ҷеҙ§ЫҙвҖ бәЈжӢ зҖ°гӯҒзҗЈгҰҚ*еӢӣбҖ е®‘дҗұаІ©вҠұГқа№ҸвҘЎзӨҚеҙӨеҘҒеҗӘбҺ°ж„’зіӢдЎәбһ«бҢңвҷ°ШҲаҙ а«ӘУҒвҘҗе»ўИІдЈҙдҖЈжӮ§б‘ гӣҸЙҺбҖЎ2дӣ дҶ КҺШҜбҰ“а°ЁбЈӢГӣд’№бәӢд°„д”Ід—ҝбЈ гјҘГҸзҳ§дҮ—вҢўгЎ§в•ӯбәҢгҗЎв¬ңВӨеҪЎбҳҗВҲбәҶзӨҢг„ёдҠ бӮІбҲҪд ғжң•жҺһжұёТёв®ҒЧ“жӣңб ©1дҒ¬бҲў?жҷӮгң вқёжЁіе”һЬіжӣӨг¬Өв…ҺР б«ҡУҝд„§гһҡз§қбӣЎејҖдҖ§д«Ўв‘…зӘ”гІҺе®Ўаҙ‘Хҫв§…жҖӘбӮ•жҫҚгҲ‘зЈһв’Іб¶ еҷҗбңҗб№Јд’“аәҘХ·жңӮбұЈжӨӮЗӨУӨеў¶вҳ®дЁ©жҢҗбҚҘдҶ¶б№Өжў¶аҘ б„ӨвҸҗгҷ°&аҜўд‘»зӘ–в °еҮҠг©ҫг„Ҷб©ӨгЈҢР«ЧЎдӮ®бҠ‘е¬ұжғҰгқӨвӘ”б ёдү’бҖ»г„Ўв–§МҡtгҰ”зҡ§НҢдҷё еҪҘбіӘбҷ…дғ„дҒӯа«ұеө‘бҺ бҒөжңүвҖЎЛӘд©қаҪұаЈ—вҒӮЖүб·…гҶӮBе––аҘ„жҙҳаӯ…е“ҰвҖЈг–„еқ©еҶҢЖҶз•ЁгңӨе °вЎ«гҒҙзһәжҢңжҶ„а©ўз…Һа«ҪвқӘжҠ„вҜ…д’Ӯз°©гҶ°жҠ°Ж”вӘ…д© а»“д °еҙ§д«ӘвҮүВЎХ¬дЎ«віқа®•зҘҘв»’д•ўЕӢдӘңж“Җа¶ЁдүҳбЎЁФЁдғҹжҳҘдҝҖдҲӨ0д«ӘвӮҲд°ЎаЁўбёҙеҒӮдЁұдҠҗд„ІвӢҲд” жҢ“а·Үг”ІдҜҚбІҳдӮІбү„д·Җж•ӯбқӢд“–гқ«(бӢ§дұҰв“ЁвӮҶвӢ«г‘¶в©Әг—ҺвҒҸеҰ®гӢҚеҰ’гө®г”ұгҢӘд”ЎвөҚШ‘вҸҒзӨ з•ҺШҗб »жӮҹвҚҸзӨ°ж„ЈдЈ№гқҢгёҷв‘ӨзёҗУӢб”ӯгЁҠе”ҪЫҠгҠ•гіҲжҚҚв”јж¶Ҫг ҖеғқгҝҚМҖдўҚеҒІвҙұвң“гҳ°еҮ«гҙҙжҢ„з®ҚжҢҷвҫҺдҡ§вҝ©ГҷвҷЈбөҠдҪҜв—·гЈ©в„ҷејҠвӨ“аЁүгЁҚб’§г·ҚдҢ»гЁ’г Ҳв–ҖзёјЦ°з•ЈХҗжӯјд•ҡжөҸжӯҖз…ҢжҶ‘бһЁвҗүгӨҝд®Ҳж’Ҫб•ӨжңјвҜөвІҘе–Қб»ҢгҜҚв·ІзҺҙзҜҒвўқгҖөеҗҮеҲөеҒӮаҝ•бғІж‘ҘЙЎвҰғбҖ·дҒ вЎҢзҶҢвүҲеҙұа°Ӣвҝҫз—ӣгӮ·зҢ№гұўа¬ӨаҪҘа°ӮвҢҸдҒҠбүҪе¶ёгҷҝд®ӯвјҫв¬®г•ҝеқҝг·¬жҜҖзЈҫд–ҡзҒҮбҜәжҜҳвӮҶзғёзһёгҘҸз ҹгҚүжҳ–жғүгһёж§јзҜӨжҡқдӨӨж‘®жҸҫжІёз—јжҒҡЬЈвәјдӢғві дөівҡӢд·°е–әвёүз–ҠжҘ№жҺҹзӯҖбқҹж·„дҚҢеӢҷгҠөг¶ҚбҙҢеөөз©ҪгҮ•зӢ¬вҫҸв§ҷбіҹзў”б®”жҚҹеҳ’бҺҚжёҰжёЈжғ·в°§дҹҷЮҘе§ЈбӨ”ж өП–гіҚб»ҳжіҙзҸ«ж¶ в–іе·ҒбҜҜаҜ‘гөІгҺҠб°Қж«Ҡа·ңвҮўаўЎЖ»дӣ“бӘҝвӘ—гҚөе•ҡж°…е«—жҫқз§»д’«дҗЎж‘үг®«б—ҙбҘүг•ҲзұҺгҠ’ж ңеЎҚзҙ»дҗүзӮҲЦҷбҮ—зөЁаӨӘб” д…җб“ӮеғҘвҸҖв…ҰгҗөеҰҜвң·вғҙг“Ўбқ…дӣ®жӣҢж»ӯд§–бңҰв’үЬӣгӨӯб°№ЕұвЁёбӘ°дҲЁзҮЎбІід•ҷеҰҘз§ҚбҜҖжөӣаЁҶзұ§дё§вҶөвқ·б”«дёҳгҫҘгҰҹаўӘвЎ‘аҜҺдӨҙеҷҠжҗўаҘҒб”„вөҘдһЈдӣҲзҡӯдғҖг“ұејүг©ҷбӨ¬зҲӯНҮдҢ§еҶ¬зўёе„«бӨңгҒҒбҳҠг„өбҺөжҜҪдҸҡеҚ…бІҺз«°жҚҗгӮҘеҢ‘б—ғзҶҚа ғдөҮг–ҷдЎҶбҫ©б„җдӘ§з„’зҸ°жў°дҒҠа¬ІаҪЎвұҫе…ҶВ•вһқвһ·в“ г’Ұд¬§дҰЁбҹҪбӯ’з’–г°Ұдҹһжҹ бІҰв…җе•үдҢҫв§¶бҺўаҜҘбҠҠвӢҰеһЈв”ӣГЁеҺҺеӣ№д„ғвӣ®бү”жҚ°з·Ҷе®ўжӣҮдһҝвҪ¬зҺҹаұ дёја§–ЙјвҪ‘з—ҳГҖеЎғбҲҘг¬§гҖ№жҮ”г–ЎДҒжӨҪеҝ¬УҪСЎеҶ„зҸһвҸ„вұҸжҒңеіҚжҖҫа®…вҶ§дӨ“а©җдҘҳаӘ®б §в„ёбҺўСҢвЁҮбўҳжҙҘбЎӨаҰ¶еЈ–а¬ҒгёҙбҶ‘аҙ–вө©В»И гҙҝж„ўбЎӮдҲӘОӨв‘Ұд‘ёдҒЁв’ўдўүЖ°еӨўгҺЁеҮ’жўөеҲ°дЈӮвҒӘд•ӮвҒҠеЁ№дҚ№гҷҢЕҠдҚЁдҒҰе«ҷаҜЁвўҺЬ¬жЎҒеүәвҺ«вқ§а©Ҙдңҙд®®бӣҹвҲғзӮјвј©дҸЎб§„е®өбҲҫж—…еҗ“гҰ”а ®вҠІ  \"}]"},"redirectURL":"","headersSize":253,"bodySize":2217,"_status":"completed","_startTimestamp":1775056319162721,"_endTimestamp":1775056319167901},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"148","comment":"","_id":1509,"_uid":"acc72533-0b05-4a52-aecc-27fca6b0927e","_cid":148,"_ctime":1775056284934,"_sid":26,"_stime":1775056314170,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":49926,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:11:53.845Z","time":285,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9cTtf&sid=66a2Y5xqlpnVlYi1AAme","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"197"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9cTtf"},{"name":"sid","value":"66a2Y5xqlpnVlYi1AAme"}],"postData":{"mimeType":"text/plain","text":"193:4216[\"handler.process\",{\"type\":\"activity\",\"action\":\"buyHeroSuperGift\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"actId\":\"1c19108c-b90b-4918-95fb-b401a799b414\",\"itemId\":3,\"version\":\"1.0\"}]"},"headersSize":308,"bodySize"