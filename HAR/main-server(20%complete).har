вҠӯе•Івӣ”еҒҢдҰҶд•№бҠ’еӣһеІЁжҙ¶г‘»б”ҙв ІзіҒе–ҢдҪўжҶҲеҷ–а¬«зҷҚдҸӘа·Ҫб…ҳз…ЈвЈҗжў…дӣҢдҶ•дҚ–зҘ§аә«вӯҜв…Ҡд«ҲвЎӨдҳӨбӨұб¬ёаұ¬еӮҲдҗ·ЛЁзӯҚдҪҶдҗ«гӢЁгҷ®еёҠеӮүаӘҚдҪӯб„ұжҡҺдҚҘдӯ„гҖ»ШӯбҒёб©јдӘӢв ЎгЁӨаҙ§ДҖвҲәЪ©бҸ’гҗ¬д ёгҢЎдҒја° МөбӮҖв№ҠжҮЁбҖ зҙҰб’Ўд…ҖжҖ бҘ№дўҖвӢјз“–вҫҙJеӮўаЁӨШҖеҒ„еҙ¶г° б…ІЪҘЖҗв Ёа§Қд“ёдҘүгЈҫвҖ гүҗЮ§дһ в•ҖбҮҶбҒ·жЎҠз°ҰжҠҙж  г—үЧўзӮҲеөЁЮҲзҲҫО—еӨҘдҖ°аҙҙе©Ҙв¶ғбӯҠгёҲаҜҪб“ҪвҢҫз’ІзҜ”гҘҠвңҖдғәгҶәб ҺвҰҺг©Ҹжҳ«дҘӘЯЁгғғФ„е©ҰСўзӣҫе©ҝвҳ°в„—еҡўжғўдҫҡжҶғзЈҶМңгўҲбҖҖжҙ„еүӣаҝәг„ҝдіғаўІЛІвҝҝа«…ж—ӘгөЁж «жҘҺзӮҰдЁ—еҮӘгіҒе «еҙ№зјҘжҘҸгҮӯдҖІжһ”зҰҘдҷ„бҘҹжҝ§зҷҖбңҗдҸ—дё¶бЁ”аёҘеҷ г»’а°¬ШҘдұ гәӮШӯеёӨЖҶЗӢбҘўв„Ҙе… гәӘаӨ«гәҙеҖ•з№ҹеҘўз№»дӮ жӨҡдәҗжҷЈдҰ’е»җгІӯд»ҫеә“гҠҳвӣЈе ӨгўӘз»ӨвәҒд№ӣдҙ©вҳ®еў“еҮЁвҷ•бјңвҶҗе№ўвҳ‘дј—еұ¬бўёгІӘЕҙв••ЕІг°ҜбҶ°в№®дҶҠгё еЎӮгІҖгјғШЁеҲ–ЛҰжәңгҘ¬зӘўгҡ«а№©К’дә„вҗўв’ӮгӢ®гӨӘв§ӯд§ҺвЁ‘жЁҡвҘӘгҲӮе•©еЁҠв§¬ж§ҺгӯӘШҗа¬ҖДӨбә„бӨёвҹ®ж»ёгұ®бңҺг©ӨгҶҪе–ғв—үг‘ҸзЁҮеұҲбј”вҗҰе”ӮгӢҮгҘ…И‘б“Ұв¶©е‘•гЎ“ЪҲа§Ғе„ б·ҙж… дЁ kг ·дЎҷв”¶еҠЎе«”а§өг ·вңҲбӯўеәөбө“вҶүвҙ»вө»жө§вҢІеөңжЁҲжЈҮв Ҡб ҫеёҠдҺҗжӨ»вҚ¬жә·д¬ҙж•ёеҚӮж–№жӯұеҲӢаҫ’бҚёајҲЕёжӨҶбҺ—дј…еІҷб¬¶жҳЎе®һж·әз¬°аҘҰзӢӘжҸ…жІІб„„жң§жЈҳа«өж»ҡгһҚжўҮаіғжҠҳбҪ©б„·вӨұбЁҮзјҸб„¶еҪ–б§ҰаўІбЎ§вҠ°а „гҠӨа ҙаӘұбҺ·аЁҳаҫ·УҳбӮ§еіҙбҰҮжӢ¬г–Өзғ¶бҸұгўҜжһ¬зҮ§б…ҘдҶәбҷ¬жһ”еі§дҲҒбңҳв°®б§¬гЁҷдҸ§дў«вҖ—еҰ—бҮҖеҙҷг’¬Ш’бҡ®вЁҷбӮ¶б“җг©¬жҰӯбҳҜв§‘жҹҮгқҒг№Ҳд—‘жҠҶж‘“бҢөж—Әг’івІўеҗ®вһүжҢ·бҳӣг«Ҹз–Ҝбў„гҮ•г”…аЁҷжһҮеі„д…®ПғгӮЎвҢҚжғҜзјҷд°ҪбӢ·б®§г—ӮеҡҸдј«г°өж‘Өгёҫа¬ӮеҰҶд«„з№·д“ӘеҸ„вЈ»жӯөгңҡеЈ¶з«¶еҮөг«ӘзёүзӘЎе‘”дң…еҝҶдӯ©еәҠв¶Ӣв®үа¬Ҙеҙ‘бӣ‘еҳҲз¶Үд»”Мәб·”вҢҝеҝ–дӯЈеғӣаәҘжӘ–бһҡжҰ”жң»еөқж»ӯе§ҚбәјжҶ–бӯүвј–гјҖбё—вҚҹеҘҜз§ҡбҙҢдҲ’бҳ¬жғЁгҮҡбіӣг ҪжҲҲвӮ¬д¬ғбҺҷжјӘеӣ¬зҲҸиҖҡВ§жҹҸв’ЎК§в«ўжңұбһўз…Ҳдү©жҙҪб“©дҙқе№ӣз»ӮгӘғгёІдӯҺг’¶жўҺвүҮжіӨжҹ°КғХҳбңәгЁҰбЈҗдӯӮб”ҶбҰға°ҜжҶ№а»«жІөд°әг¶®ШёбЎ•з®Ҡа ®аі ЗЎвҮҒдҒ…бЈ“д“ёжҠҫФ№гҶ”зҲ»гҠ’аЁ°дҖ®жҢӨбҹөжІје·әОҪЬҘбү жӯ зҠҒб°·гҠҰвӣЈХӨбҙ¬дӯҡвҺ¬вӯ жӮ•дғҸгҷҢдҚҲдҶһжҡөаЈ дүӨдҚҳд«ҲТҫг ӯжқЁаәҶИ вә¶в‘ҪдЈәе“«еүігҡЈв«ҢгҚ¶еқЎе—ҺжјөвјқвҚҪдҚҝеұқЛҘе®¬в…ӯвһ•дҙіеҶӮжҪӨз“Ғб©ғвӯ·жЁқОӣдҹҺжЎҶгҷғгүҢжҚҫж“«бј’жҫҗб‘ұгІ—дҶҗеһ»бӮ¶ЮҒдј§еӣҢзҠјвҘҸвјғзҜ§з•ӣаӨҳбҚҶРӨдә°е Ҝж‘°в§ЁеҒңж¶қГҜв”ңб© гқ–бӮ”бЈ«аҙ…ЖҰж“„з№·в‘өаЈӯзөұеҗҳзІ»зҚ»бҡ„з‘ӣЕӮеҠЁгЈҡа қжүӯвӢ‘дӣЎд‘ҳжңјзҮЁбҚ®а«ҶгҡҸб…Үб¶“гҢ¶дұҖгәёбҪһд”Җз°¬еҺғаҙ¶гҷҚбӮ–вәЁжҲӘгҶҡг¶Ғдҗ бҷ¬дҳ«зҚ–гҡ°гҷҺФ°еӨӘгіҜМӮвӨҘеЈҠжһӮбә°д№ҚдұҳеӨ«жҠҖж•Јз‘ҡвү“бҷ§дҡўд’ҶбҠҜгӮ¶аҘІд–ҺгӨјбҢӨгұүж”ҳвӮҘеҘүвҗүаўӘеӨӘв¬үбәҝг»ёе©ғгЈҹвҳ‘г‘ҰаҰҡдңІзӨҶЮ“дӨ®бЎҚе…®вҜғжҠ©зҢ„вҳҶО»ж”ҖжҰ©б–“аҘңзҺ·бғүв®ғзҪҜб°јвёҒзҒ«дҗөаҰ‘е•Ҷж”‘г¬үбҗӯж°іеө аІӯгҹҘбҜӮвҳөЫ—гһүеҢҺг§ҚгҲ©бүіПӯг•Іві·еҠ„зЎҸв№ЁеҷҘж’ҡзӯҰг«»жҪіеқҫжЎҠгғұв©јз«Ұв¶„Ы‘е–ҡгёҠжұӯб—ёгҖ§еҰҜдҲ“гӮҲдҹ№в’©дҠ»з‘°г—§г№іб¬„гҚ…з¶“дҶ„гҝҒгҰҹбЁ©зҪ„дҒҶг№ҝеӨ°в”Ҙж№өвӯүе»Ҙз¶ёе‘§г®Ід«өдҶөдҮ¬дҮҳжҠЈв‘ҰгЈәв•‘еҺҳжЈўзҰӘбғһж·ҰгҲҫжҗёеЈҢжіӮв”өд®ҙбңҜб’©г……жӯІвұ–а©ҝеӢҙе•өвҷјж”¬еҢ·еҺҗб©ЁзҺҙбӨ®в»јд—ҝбҮЎжҹӘдҮ©бұ”гҘүг‘Ұз…§бұідқғаөӘг°өд©©жҰғг§әжҲЁЭҷе–“г–ӣбҺҜвҢәв®‘зөұвјҚбәҠд…ҸжҺҰеғ·а¶”аҪ—бЈөбқүвҳ„з№ЈГЁдҪҖжҲЁдҮЎПҒа°Ід…¬бәӨжҗӯЕҳаҙ®гғёдҰұгҳіа „а»ЎжҖӯв„   \"}]"},"redirectURL":"","headersSize":253,"bodySize":2497,"_status":"completed","_startTimestamp":1775055623473237,"_endTimestamp":1775055623477720},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"67","comment":"","_id":624,"_uid":"7855caa0-bcfb-4183-beb3-abd7cca7c4ee","_cid":67,"_ctime":1775055373090,"_sid":87,"_stime":1775055619100,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":35432,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:00:18.718Z","time":290,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9ZqAK&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content