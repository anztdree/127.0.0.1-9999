ҪдғһбәҜеҢ еҜҰе„ёеҗөД°еҲ О»в«—жҝіж¬Ғдіўб ¶ХҙбҘ·жӯөвЈ»бЈӘвұ–б§©зҶҷв•ғд”©аӘ¶в©ҷеҖЁа№¬е··в©ҰаәЈбЎҶЗ·Ыңв©”жў©е¶’аө¬еӢ’ж¬ бҫҶг–…е–ҙжӘҺЩөаўҶаіЈгң–д«”gб„Әж«ЁгӯёбӘҠеҸ·гұјгЁ ВҘв ұдҚӢаҪ·вө»з ІЧ жө¬РҒв‘Ҳд“ еҫҮвҙЎгӯ ајәгӮҗд•җбҠӨд–»зҚӯж‘»бӘӯдҳұгҳөжёёзҫқКҖаҫҖг“қд°«вӯҠ$дҙ§в„…!вҜҖзӘ©еғ”гҡ«е“ҙбӘ”дҸідҡңеҗқе°»бҗҖвҹ«д·өд–Ё  \"}]"},"redirectURL":"","headersSize":253,"bodySize":1284,"_status":"completed","_startTimestamp":1775056050110017,"_endTimestamp":1775056050116300},"cache":{},"timings":{"send":-1,"wait":-1,"receive":-1},"serverIPAddress":"47.252.2.215","connection":"92","comment":"","_id":1106,"_uid":"1824fc07-8b65-4623-a8b8-4d73884ca0cd","_cid":92,"_ctime":1775055887626,"_sid":63,"_stime":1775056049568,"_serverAddress":"47.252.2.215","_serverAddressFamily":0,"_serverPort":9300,"_clientAddress":"127.0.0.1","_clientAddressFamily":0,"_clientPort":41326,"_app":{"name":"Legend of the Cosmic Warriors","id":"com.cosmicwartwn.the"}},{"startedDateTime":"2026-04-01T15:07:29.141Z","time":287,"request":{"method":"POST","url":"https://s398-zd.pksilo.com:9300/socket.io/?EIO=3&transport=polling&t=Pr9bTFa&sid=ZIFlnwc_Kqme9OHHAAmW","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Host","value":"s398-zd.pksilo.com:9300"},{"name":"Accept-Encoding","value":"deflate, gzip"},{"name":"User-Agent","value":"Mozilla/5.0 (Linux; Android 12; itel S665L Build/SP1A.210812.016) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/61.0.2883.95 Mobile Safari/537.36 EgretNative"},{"name":"Content-type","value":"text/plain;charset=UTF-8"},{"name":"Accept","value":"*/*"},{"name":"Content-Length","value":"174"}],"queryString":[{"name":"EIO","value":"3"},{"name":"transport","value":"polling"},{"name":"t","value":"Pr9bTFa"},{"name":"sid","value":"ZIFlnwc_Kqme9OHHAAmW"}],"postData":{"mimeType":"text/plain","text":"170:42273[\"handler.process\",{\"type\":\"hero\",\"action\":\"evolve\",\"userId\":\"7fc36b98-61da-4f14-9eab-5ed05646ac0c\",\"heroId\":\"c589af82-b736-4559-9dd6-5ba8894c2191\",\"version\":\"1.0\"}]"},"headers